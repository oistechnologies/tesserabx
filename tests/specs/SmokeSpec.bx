/**
 * SmokeSpec: top-level smoke test for the Phase 0 skeleton.
 *
 * Verifies the application boots, all 16 modules are registered, the
 * health endpoint responds, and AI is off by default.
 */
class extends="coldbox.system.testing.BaseTestCase" appMapping="/" {

    function beforeAll(){
        super.beforeAll();
        super.setup();
    }

    function run(){
        describe( "TesseraBX Phase 0 skeleton", function(){

            it( "boots ColdBox cleanly", function(){
                expect( getController() ).notToBeNull();
                expect( getController().getAppHash() ).notToBeEmpty();
            } );

            it( "registers all 16 application modules", function(){
                var modules  = getController().getModuleService().getModuleRegistry();
                var expected = [
                    "core","contacts","audit","tickets","agent","admin","portal",
                    "widget","knowledgebase","channels","automation","sla","ai",
                    "notifications","reporting","api"
                ];
                for ( var name in expected ) {
                    expect( modules ).toHaveKey( name, "module '#name#' is not registered" );
                }
            } );

            it( "responds to /health", function(){
                var event = execute( route = "/health", renderResults = true );
                expect( event.getStatusCode() ).toBe( 200 );
                var body = event.getRenderedContent();
                expect( body ).toInclude( "ok" );
            } );

            it( "has AI disabled by default in Phase 0", function(){
                var enabled = getController().getSetting( "aiEnabled", false );
                var asBool  = isBoolean( enabled ) ? enabled : ( enabled == "true" );
                expect( asBool ).toBeFalse();
            } );

        } );
    }

}
