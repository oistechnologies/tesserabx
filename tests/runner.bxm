<bx:setting enableOutputOnly=true>
<!---
	TesseraBX — TestBox runner.

	Auto-discovers spec directories under:

	  - /tests/specs                                     (top-level)
	  - /modules_app/<module>/tests/specs                (host modules)
	  - /modules_app/<module>/modules/<nested>/tests/specs (nested host modules)
	  - /sample-addons/<addon>/tests/specs               (in-tree demo add-ons)
	  - /modules/<addon>/tests/specs                     (third-party add-ons,
	                                                      filtered to those whose
	                                                      ModuleConfig.bx declares
	                                                      settings.tesserabx so
	                                                      vendor dependencies like
	                                                      cbsecurity / qb / cbfs
	                                                      are not scanned)

	Override via URL query params.
--->
<bx:param name="url.reporter"           default="simple">
<bx:param name="url.recurse"            default="true" type="boolean">
<bx:param name="url.bundles"            default="">
<bx:param name="url.labels"             default="">
<bx:param name="url.excludes"           default="">
<bx:param name="url.reportpath"         default="#expandPath( "/tests/results" )#">
<bx:param name="url.bundlesPattern"     default="*Spec*.cfc|*Test*.cfc|*Spec*.bx|*Test*.bx">

<bx:script>
if ( !structKeyExists( url, "directory" ) || !len( url.directory ) ) {
    dirs = [ "tests.specs" ];
    modulesRoot = expandPath( "/modules_app" );
    if ( directoryExists( modulesRoot ) ) {
        for ( entry in directoryList( modulesRoot, false, "query" ) ) {
            if ( entry.type != "Dir" ) continue;
            specPath = modulesRoot & "/" & entry.name & "/tests/specs";
            if ( directoryExists( specPath ) ) {
                dirs.append( "modules_app." & entry.name & ".tests.specs" );
            }
            // Nested child modules (admin lives inside agent).
            nestedRoot = modulesRoot & "/" & entry.name & "/modules";
            if ( directoryExists( nestedRoot ) ) {
                for ( nested in directoryList( nestedRoot, false, "query" ) ) {
                    if ( nested.type != "Dir" ) continue;
                    nestedSpecs = nestedRoot & "/" & nested.name & "/tests/specs";
                    if ( directoryExists( nestedSpecs ) ) {
                        dirs.append( "modules_app." & entry.name & ".modules." & nested.name & ".tests.specs" );
                    }
                }
            }
        }
    }
    // sample-addons/ holds the Phase 12 reference add-on (and any
    // other in-tree demo add-ons). Same per-add-on spec discovery
    // shape as modules_app/, just rooted under a different folder.
    sampleAddonsRoot = expandPath( "/sample-addons" );
    if ( directoryExists( sampleAddonsRoot ) ) {
        for ( entry in directoryList( sampleAddonsRoot, false, "query" ) ) {
            if ( entry.type != "Dir" ) continue;
            specPath = sampleAddonsRoot & "/" & entry.name & "/tests/specs";
            if ( directoryExists( specPath ) ) {
                dirs.append( "sample-addons." & entry.name & ".tests.specs" );
            }
        }
    }
    // modules/ holds third-party TesseraBX add-ons (e.g. tesserabx-pm)
    // installed via ForgeBox or bind-mounted from a sibling repo
    // during development. Vendor dependencies (cbsecurity, qb, cbfs,
    // ...) also live here, so we only walk folders whose
    // ModuleConfig.bx declares a settings.tesserabx block. This
    // mirrors the isTesseraBXAddon heuristic in tasks/Migrate.cfc.
    addonsRoot = expandPath( "/modules" );
    if ( directoryExists( addonsRoot ) ) {
        for ( entry in directoryList( addonsRoot, false, "query" ) ) {
            if ( entry.type != "Dir" ) continue;
            configPath = addonsRoot & "/" & entry.name & "/ModuleConfig.bx";
            if ( !fileExists( configPath ) ) continue;
            cfg = fileRead( configPath );
            if (
                findNoCase( "settings.tesserabx", cfg ) == 0
             && findNoCase( "tesserabx :",        cfg ) == 0
            ) continue;
            specPath = addonsRoot & "/" & entry.name & "/tests/specs";
            if ( directoryExists( specPath ) ) {
                dirs.append( "modules." & entry.name & ".tests.specs" );
            }
        }
    }
    url.directory = dirs.toList();
}
</bx:script>

<bx:include template="/testbox/system/runners/HTMLRunner.cfm">
