# TesseraBX environment configuration.
#
# Copy this file to .env and fill in real values. The .env file is git-
# ignored. Every variable consumed by the application is documented here;
# if you add a new env var to the code, also add it here.

# ---------------------------------------------------------------------------
# Runtime mode. Affects ColdBox handlerCaching, viewCaching, and the
# cbwire request-stats panel. Set "development" locally and "production"
# everywhere else.
# ---------------------------------------------------------------------------
ENVIRONMENT=development

# ---------------------------------------------------------------------------
# Application server.
# ---------------------------------------------------------------------------
PORT=8080
APP_HOST_PORT=8080
# A ColdBox fwreinit URL parameter password. When set, hitting
# /?fwreinit=PASSWORD reinitializes the application. Leave blank to
# disable runtime reinit (production default).
COLDBOX_REINIT_PASSWORD=

# ---------------------------------------------------------------------------
# External Docker network for the reverse proxy.
#
# compose.yaml attaches the `app` service to this network so an external
# proxy can route to it. Set this to the network your proxy already owns.
# The dev override (compose.dev.yaml) overrides this so the dev stack
# runs standalone with no external network and no proxy.
# ---------------------------------------------------------------------------
PROXY_NETWORK=tesserabx_proxy

# ---------------------------------------------------------------------------
# PostgreSQL.
#
# The database is created in the `db` container with these credentials.
# In production point at your existing managed Postgres.
# ---------------------------------------------------------------------------
DB_HOST=db
DB_PORT=5432
DB_NAME=tesserabx
DB_USER=tesserabx
DB_PASSWORD=tesserabx
DB_SCHEMA=public
DB_SSL=false
DB_HOST_PORT=5432

# ---------------------------------------------------------------------------
# Redis.
# ---------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0
REDIS_HOST_PORT=6379

# ---------------------------------------------------------------------------
# CBFS storage. Three providers — pick one with CBFS_DEFAULT_PROVIDER:
#   local — disk on the running container (development default).
#   s3    — genuine AWS S3 via cbfs's stock S3Provider. Talks to
#           amazonaws.com; CBFS_PROVIDER_REGION is the AWS region.
#           CBFS_PROVIDER_ENDPOINT is ignored on this path.
#   b2    — Backblaze B2 (or any other S3-compatible endpoint whose
#           hostname embeds the region — Wasabi, DigitalOcean Spaces,
#           MinIO, etc.) via our B2Provider@core. The patched provider
#           swaps in PatchedAmazonS3 to fix s3sdk's path-style URL
#           builder, which otherwise double-prepends the region and
#           every B2 request returns 403.
#
# s3 and b2 share one set of credential vars below since only one is
# active per environment. Buckets must be private. Signed URLs are
# time-limited; the documented fallback is streaming files through
# the application behind cbSecurity. Verify production storage end-
# to-end via /agent/admin/storage before going live.
# ---------------------------------------------------------------------------
CBFS_DEFAULT_PROVIDER=local
CBFS_PROVIDER_ACCESS_KEY=
CBFS_PROVIDER_SECRET_KEY=
CBFS_PROVIDER_BUCKET=
CBFS_PROVIDER_REGION=us-west-002
CBFS_PROVIDER_ENDPOINT=s3.us-west-002.backblazeb2.com

# ---------------------------------------------------------------------------
# File upload constraints. Applied to every CBFS upload.
# UPLOAD_MAX_BYTES is the maximum size for any single upload (default 25MB).
# UPLOAD_ALLOWED_EXTENSIONS is a comma-separated list of allowed extensions
# (no leading dots).
# ---------------------------------------------------------------------------
UPLOAD_MAX_BYTES=26214400
UPLOAD_ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,pdf,txt,csv,xls,xlsx,doc,docx,zip

# ---------------------------------------------------------------------------
# Database backup retention.
#
# The nightly backup task writes a compressed pg_dump to the configured
# CBFS provider and prunes dumps older than this many days.
# WARNING: when CBFS_DEFAULT_PROVIDER=local in production, the backup
# lands on the same host as the database and is only partial protection.
# Setting CBFS_DEFAULT_PROVIDER=b2 (Backblaze) or =s3 (genuine AWS S3)
# in production places backups offsite and negates that concern.
# ---------------------------------------------------------------------------
BACKUP_RETENTION_DAYS=14

# ---------------------------------------------------------------------------
# Outbound mail. In dev, points at the mailpit SMTP trap; production
# overrides MAIL_HOST / MAIL_PORT / MAIL_USERNAME / MAIL_PASSWORD to a
# real relay.
#
# MAIL_FROM_DOMAIN is the host segment used in outbound Message-Id
# headers (RFC 5322); set it to the domain you actually send from
# so threading + reply detection works across mail clients.
# OUTBOUND_EMAIL_ENABLED is a global kill switch: set to "false" in
# environments where outbound email must not leave the box (a staging
# stack pointed at production data, for example).
# ---------------------------------------------------------------------------
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_TLS=false
MAIL_SSL=false
MAIL_FROM=no-reply@tesserabx.local
MAIL_FROM_DOMAIN=tesserabx.local
OUTBOUND_EMAIL_ENABLED=true

# ---------------------------------------------------------------------------
# Notifications outbound (Slack / Teams + unsubscribe links).
#
# SLACK_WEBHOOK_URL is the slack/teams incoming-webhook URL the
# notifications fan-out posts to. Microsoft Teams accepts the same
# Slack-compatible payload through its own webhook so a Teams URL
# slots in here unchanged. Leave blank to disable slack delivery;
# the dispatch path silently skips slack rows when no URL is set.
#
# APP_BASE_URL is the host agents and contacts reach the app at and
# is used to build the unsubscribe URL embedded in outbound emails.
# In dev this points at http://localhost:8080; production overrides
# to the public hostname.
#
# NOTIFICATIONS_UNSUBSCRIBE_SECRET signs the unsubscribe tokens with
# HMAC-SHA256. Tokens are pinned to a specific (recipient, event,
# channel) tuple so a leaked token cannot silence unrelated streams.
# Change to a long random string in production.
# ---------------------------------------------------------------------------
SLACK_WEBHOOK_URL=
APP_BASE_URL=http://localhost:8080
NOTIFICATIONS_UNSUBSCRIBE_SECRET=dev-unsubscribe-secret-please-change-me

# ---------------------------------------------------------------------------
# REST API (/api/v1). JWT signing settings.
#
# JWT_SECRET signs the API's access + refresh tokens. Change to a
# long random string in production. Leave blank and cbsecurity will
# auto-generate a secret that rotates with the application scope
# (fine for dev, never for production — every restart invalidates
# every issued token).
#
# JWT_EXPIRATION_MINUTES caps the access-token lifetime; agents
# request a fresh pair via POST /api/v1/auth/refresh before their
# current access token expires. JWT_REFRESH_MINUTES caps the
# refresh-token lifetime.
# ---------------------------------------------------------------------------
JWT_SECRET=dev-jwt-secret-please-change-me
JWT_EXPIRATION_MINUTES=60
JWT_REFRESH_MINUTES=10080

# ---------------------------------------------------------------------------
# Inbound email (IMAP polling). The scheduler container polls this mailbox
# every minute and turns each unread message into a ticket (or appends to
# an existing ticket on a reply). Stays inert when IMAP_ENABLED is anything
# but "true", so a fresh dev stack does not need any of these populated.
# ---------------------------------------------------------------------------
IMAP_ENABLED=false
IMAP_HOST=
IMAP_PORT=993
IMAP_USERNAME=
IMAP_PASSWORD=
IMAP_FOLDER=INBOX
IMAP_USE_SSL=true
IMAP_MAX_PER_POLL=50
IMAP_MARK_READ=true

# ---------------------------------------------------------------------------
# AI. Optional at runtime. When AI_ENABLED=false, the entire AI layer is
# inert: no AI UI elements render, no AI cbq jobs are enqueued, and the
# non-AI code path is taken everywhere. The documented default provider
# is OpenRouter.
# ---------------------------------------------------------------------------
AI_ENABLED=false
AI_PROVIDER=openrouter
AI_API_KEY=
AI_MODEL=
# Optional. Most providers infer this from AI_PROVIDER; only set when
# pointing bx-ai at a non-default endpoint (custom proxy, self-hosted
# OpenAI-compatible gateway, etc.).
AI_BASE_URL=
# Per-call timeout in seconds. The middleware enforces this against
# every provider call and an exceeded timeout records a "timeout"
# outcome in ai_interactions without breaking the caller's flow.
AI_TIMEOUT_SECONDS=60
# Best-effort PII redaction before any payload leaves the system.
# Currently masks email addresses; future passes will extend to
# phone numbers and credit-card-ish digit runs. Off only with an
# explicit reason.
AI_PII_REDACTION=true
# Embedding model for the pgvector semantic search. Most bx-ai
# providers can serve both chat and embeddings, but the model id is
# usually different. OpenRouter routes to OpenAI's text-embedding-3-
# small (1536 dimensions) by default. The column type on
# kb_articles.embedding is fixed at vector(1536); changing models to
# a different dimension requires altering the column.
AI_EMBEDDING_MODEL=openai/text-embedding-3-small
AI_EMBEDDING_DIM=1536

# ---------------------------------------------------------------------------
# Dev-only ports (used by compose.dev.yaml). Mailpit is the SMTP trap
# the dev stack points outbound mail at; Adminer is a lightweight DB
# inspector. Both are absent from the production compose file.
# ---------------------------------------------------------------------------
MAILPIT_UI_PORT=8025
MAILPIT_SMTP_PORT=1025
ADMINER_PORT=8081

# ---------------------------------------------------------------------------
# Container image tag. Used by docker compose to pin the build.
# ---------------------------------------------------------------------------
TESSERABX_IMAGE_TAG=latest
