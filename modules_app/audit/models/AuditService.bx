/**
 * AuditService: the public surface other modules call to record
 * significant operations and the admin UI calls to search the log.
 *
 * Per CLAUDE.md the audit module is cross-cutting: many modules
 * write to it, none read its entities directly except through this
 * service.
 *
 * record() is the only write path. Callers pass an event_type in
 * dotted-notation ("contact.role_granted") and any structured detail
 * as a metadata struct; the service serializes the struct to JSON
 * for storage. Missing optional fields stay null.
 *
 * search() is the admin read path. Filter args are all optional;
 * leaving them off returns the most recent events.
 */
class singleton=true {

    property name="wirebox"              inject="wirebox";
    property name="addonRegistryService" inject="AddonRegistryService@core";
    property name="auth"                 inject="AuthenticationService@cbauth";

    /**
     * Record one audit event.
     *
     * @eventType        Required. Dotted-notation event key.
     * @entityType       Optional. The affected entity's logical type.
     * @entityId         Optional. The affected entity's identifier.
     * @organizationId   Optional. The tenant context the event ran in.
     * @actorType        Optional. "agent" | "contact" | "system".
     * @actorId          Optional. Identifier of the actor.
     * @metadata         Optional struct. Serialized to JSON on insert.
     * @source           Optional. Add-on slug (addon_id) that
     *                   originated the event, or empty for core.
     *                   See docs/EXTENSIONS.md "Audit-event
     *                   contributions" for the contribution path.
     */
    public any function record(
        required string eventType,
        string entityType,
        string entityId,
        string organizationId,
        string actorType,
        string actorId,
        struct metadata,
        string source
    ){
        var event = wirebox.getInstance( "AuditEvent@audit" );
        event.setId( newId() );
        event.setEventType( arguments.eventType );
        if ( structKeyExists( arguments, "entityType" ) && len( arguments.entityType ?: "" ) ) {
            event.setEntityType( arguments.entityType );
        }
        if ( structKeyExists( arguments, "entityId" ) && len( arguments.entityId ?: "" ) ) {
            event.setEntityId( arguments.entityId );
        }
        if ( structKeyExists( arguments, "organizationId" ) && len( arguments.organizationId ?: "" ) ) {
            event.setOrganizationId( arguments.organizationId );
        }
        if ( structKeyExists( arguments, "actorType" ) && len( arguments.actorType ?: "" ) ) {
            event.setActorType( arguments.actorType );
        }
        if ( structKeyExists( arguments, "actorId" ) && len( arguments.actorId ?: "" ) ) {
            event.setActorId( arguments.actorId );
        }
        if ( structKeyExists( arguments, "metadata" ) && !isNull( arguments.metadata ) ) {
            event.setMetadataJson( jsonSerialize( arguments.metadata ) );
        }
        if ( structKeyExists( arguments, "source" ) && len( arguments.source ?: "" ) ) {
            event.setSource( arguments.source );
        }
        event.save();
        return event;
    }

    /**
     * Search the audit log. All filters optional; results are ordered
     * newest first. `limit` caps the page size; `offset` paginates.
     */
    public array function search(
        string eventType,
        string entityType,
        string entityId,
        string organizationId,
        string actorType,
        string actorId,
        any occurredAfter,
        any occurredBefore,
        string source,
        numeric limit = 100,
        numeric offset = 0
    ){
        var q = wirebox.getInstance( "AuditEvent@audit" );
        if ( structKeyExists( arguments, "eventType" ) && len( arguments.eventType ?: "" ) ) {
            q = q.where( "event_type", arguments.eventType );
        }
        if ( structKeyExists( arguments, "entityType" ) && len( arguments.entityType ?: "" ) ) {
            q = q.where( "entity_type", arguments.entityType );
        }
        if ( structKeyExists( arguments, "entityId" ) && len( arguments.entityId ?: "" ) ) {
            q = q.where( "entity_id", arguments.entityId );
        }
        if ( structKeyExists( arguments, "organizationId" ) && len( arguments.organizationId ?: "" ) ) {
            q = q.where( "organization_id", arguments.organizationId );
        }
        if ( structKeyExists( arguments, "actorType" ) && len( arguments.actorType ?: "" ) ) {
            q = q.where( "actor_type", arguments.actorType );
        }
        if ( structKeyExists( arguments, "actorId" ) && len( arguments.actorId ?: "" ) ) {
            q = q.where( "actor_id", arguments.actorId );
        }
        if ( structKeyExists( arguments, "source" ) && len( arguments.source ?: "" ) ) {
            // Sentinel "core" matches rows whose source is NULL
            // (events the core modules emit without a source slug).
            if ( arguments.source == "core" ) {
                q = q.whereNull( "source" );
            } else {
                q = q.where( "source", arguments.source );
            }
        }
        if ( structKeyExists( arguments, "occurredAfter" ) && !isNull( arguments.occurredAfter ) ) {
            q = q.where( "occurred_at", ">=", arguments.occurredAfter );
        }
        if ( structKeyExists( arguments, "occurredBefore" ) && !isNull( arguments.occurredBefore ) ) {
            q = q.where( "occurred_at", "<=", arguments.occurredBefore );
        }
        return q.orderBy( "occurred_at", "desc" )
            .limit( arguments.limit )
            .offset( arguments.offset )
            .get();
    }

    /**
     * Distinct source values currently in the log. Used by the admin
     * search UI to populate a "Source" filter dropdown. Returns each
     * add-on slug that has ever emitted an audit event, plus the
     * sentinel "core" representing rows where source IS NULL.
     */
    public array function listSources(){
        var rows = queryExecute(
            "SELECT DISTINCT source FROM audit_events ORDER BY source NULLS FIRST",
            {},
            { returntype : "array" }
        );
        var out = [];
        var seenNull = false;
        for ( var row in rows ) {
            if ( isNull( row.source ) || !len( row.source ?: "" ) ) {
                if ( !seenNull ) out.append( "core" );
                seenNull = true;
                continue;
            }
            out.append( row.source );
        }
        if ( !out.len() ) out.append( "core" );
        return out;
    }

    /**
     * The distinct event_type values currently in the log, merged with
     * the event types declared by every installed add-on in its
     * settings.tesserabx.auditEvents = [...] manifest block. The
     * declared-but-never-fired entries appear in the dropdown so
     * operators can filter for an add-on event the first time it
     * happens, not only after it has happened.
     *
     * Returns a deduplicated, sorted array.
     */
    public array function listEventTypes(){
        var seen = {};
        var rows = queryExecute(
            "SELECT DISTINCT event_type FROM audit_events ORDER BY event_type",
            {},
            { returntype: "array" }
        );
        for ( var row in rows ) {
            if ( len( row.event_type ?: "" ) ) seen[ row.event_type ] = true;
        }
        for ( var addon in addonRegistryService.listAll() ) {
            for ( var declared in extractAuditEventTypes( addon ) ) {
                if ( len( declared ) ) seen[ declared ] = true;
            }
        }
        var out = structKeyArray( seen );
        out.sort( "textnocase" );
        return out;
    }

    private array function extractAuditEventTypes( required struct addonRow ){
        // arguments.addonRow.metadata is the JSON-encoded manifest
        // captured by AddonRegistryService.upsert. The auditEvents
        // array (when present) is shaped like
        //   [ { type: "...", label: "...", severity: "..." }, ... ]
        var meta = arguments.addonRow.metadata ?: "";
        if ( !len( meta ) ) return [];
        try {
            var manifest = jsonDeserialize( meta );
        } catch ( any e ) {
            return [];
        }
        var declared = manifest.auditEvents ?: [];
        if ( !isArray( declared ) ) return [];
        var out = [];
        for ( var d in declared ) {
            if ( isStruct( d ) && structKeyExists( d, "type" ) && len( d.type ?: "" ) ) {
                out.append( d.type );
            }
        }
        return out;
    }

    // ---------------- agent home dashboard reads ----------------

    /**
     * Recent audit events the currently signed-in agent created. Used
     * as the dataProvider for the agent-home "My history" widget.
     * Returns the top N entries with already-formatted timestamps so
     * the partial / poll JSON can use the values directly.
     */
    public struct function recentForCurrentAgent( numeric limit = 10 ){
        var agentId = "";
        try {
            if ( auth.isLoggedIn() ) {
                var u = auth.getUser();
                if ( !isNull( u ) ) agentId = u.getId();
            }
        } catch ( any e ) {}
        if ( !len( agentId ) ) return { "rows" : [] };
        var events = search(
            actorType : "agent",
            actorId   : agentId,
            limit     : arguments.limit
        );
        var out = [];
        for ( var e in events ) {
            out.append( {
                "id"          : e.getId(),
                "eventType"   : e.getEventType()  ?: "",
                "entityType"  : e.getEntityType() ?: "",
                "entityId"    : e.getEntityId()   ?: "",
                "createdAt"   : dateTimeFormat( e.getOccurredAt(), "yyyy-mm-dd HH:nn" )
            } );
        }
        return { "rows" : out };
    }

    /**
     * Recent org-wide audit events for the admin "System pulse"
     * dashboard widget. No actor or organization filter — surfaces
     * the freshest events across the whole deployment. The widget
     * is admin-gated via the registry's requiredPermission so this
     * read-all behaviour does not leak to a regular agent.
     */
    public struct function recentSystemEvents( numeric limit = 8 ){
        var events = search( limit : arguments.limit );
        var out = [];
        for ( var e in events ) {
            out.append( {
                "id"         : e.getId(),
                "eventType"  : e.getEventType()  ?: "",
                "entityType" : e.getEntityType() ?: "",
                "entityId"   : e.getEntityId()   ?: "",
                "actorType"  : e.getActorType()  ?: "",
                "actorId"    : e.getActorId()    ?: "",
                "createdAt"  : dateTimeFormat( e.getOccurredAt(), "yyyy-mm-dd HH:nn" )
            } );
        }
        return { "rows" : out };
    }

    // ---------------- helpers ----------------

    private string function newId(){
        return createObject( "java", "java.util.UUID" ).randomUUID().toString();
    }

}
