/**
 * InboundEmailProcessorSpec: end-to-end inbound-message processing.
 *
 * Each `it` builds a synthetic email struct, hands it to the
 * processor, and asserts the resulting inbound_emails outcome and
 * any side effect (new ticket, appended message, dropped, etc.).
 *
 * Fixtures get a unique sender/messageId each run so specs stay
 * independent.
 */
class extends="coldbox.system.testing.BaseTestCase" appMapping="/" {

    function beforeAll(){
        super.beforeAll();
        super.setup();
        variables.processor = getController().getWireBox().getInstance( "InboundEmailProcessor@channels" );
        variables.channels  = getController().getWireBox().getInstance( "ChannelsService@channels" );
        variables.contacts  = getController().getWireBox().getInstance( "ContactsService@contacts" );
        variables.tickets   = getController().getWireBox().getInstance( "TicketsService@tickets" );
    }

    function run(){
        // The auto-ack TicketMessage row is now only persisted when
        // the underlying cbmailservices send actually shipped (see
        // OutboundEmailService.sendAutoAcknowledgement); a CI run
        // without Mailpit gets a send error from cbmailservices and
        // the ack row is correctly skipped. Specs whose assertion
        // depends on the ack message landing skip in that
        // environment. Probe at the top of run() per the project
        // memo "TestBox run() runs before beforeAll()".
        var mailpitPresent = probeMailpit( getSystemSetting( "MAILPIT_API_BASE", "http://mailpit:8025" ) );

        describe( "InboundEmailProcessor", function(){

            it( "creates an accountless ticket for an unknown sender", function(){
                var sender = "stranger-" & createUUID() & "@unknown.test";
                var msgId  = "msg-" & createUUID() & "@unknown.test";
                var result = variables.processor.process( {
                    messageId : msgId,
                    from      : sender,
                    subject   : "Hello there",
                    body      : "Need help with my account.",
                    headers   : {}
                } );
                expect( result.getOutcome() ).toBe( "ticket_created" );
                expect( result.getTicketId() ).notToBeEmpty();

                var t = variables.tickets.getTicket( result.getTicketId() );
                expect( t.isAccountless() ).toBeTrue();
                expect( t.getOriginatingEmail() ).toBe( sender );

                cleanupInbound( result.getId() );
                cleanupTicket( t.getId() );
            } );

            it( "creates a contact-backed ticket when the sender is a known Contact", function(){
                var org = variables.contacts.createOrganization( {
                    name : "Inbound Spec Org " & createUUID(),
                    slug : "inb-" & lCase( replace( createUUID(), "-", "", "all" ) )
                } );
                var email = "known-" & createUUID() & "@example.com";
                var contact = variables.contacts.provisionContact( {
                    organizationId : org.getId(),
                    email          : email,
                    password       : "spec-password"
                } );

                var result = variables.processor.process( {
                    messageId : "msg-" & createUUID() & "@example.com",
                    from      : email,
                    subject   : "Please help",
                    body      : "Got an issue.",
                    headers   : {}
                } );
                expect( result.getOutcome() ).toBe( "ticket_created" );

                var t = variables.tickets.getTicket( result.getTicketId() );
                expect( t.isAccountless() ).toBeFalse();
                expect( t.getRequesterContactId() ).toBe( contact.getId() );
                expect( t.getOrganizationId() ).toBe( org.getId() );

                cleanupInbound( result.getId() );
                cleanupTicket( t.getId() );
                queryExecute( "DELETE FROM contact_roles WHERE contact_id = :id", { id : contact.getId() } );
                queryExecute( "DELETE FROM contacts WHERE id = :id", { id : contact.getId() } );
                queryExecute( "DELETE FROM audit_events WHERE organization_id = :id", { id : org.getId() } );
                queryExecute( "DELETE FROM organizations WHERE id = :id", { id : org.getId() } );
            } );

            it( "auto-provisions a contact when the sender is on a verified approved domain of an auto-provision org", function(){
                var org = variables.contacts.createOrganization( {
                    name : "AutoProv Org " & createUUID(),
                    slug : "ap-" & lCase( replace( createUUID(), "-", "", "all" ) )
                } );
                variables.contacts.updateOrganization( org.getId(), { autoProvisionContacts : true } );
                var domain = "ap-" & lCase( replace( createUUID(), "-", "", "all" ) ) & ".test";
                variables.contacts.addDomainMapping( organizationId : org.getId(), domain : domain, isVerified : true );

                var sender = "newhire-" & createUUID() & "@" & domain;
                var result = variables.processor.process( {
                    messageId : "msg-" & createUUID() & "@" & domain,
                    from      : sender,
                    subject   : "First request",
                    body      : "Hello from a new person.",
                    headers   : {}
                } );
                expect( result.getOutcome() ).toBe( "ticket_created" );

                var t = variables.tickets.getTicket( result.getTicketId() );
                expect( t.isAccountless() ).toBeFalse();
                expect( t.getOrganizationId() ).toBe( org.getId() );

                var created = variables.contacts.getContactByEmail( sender );
                expect( created ).notToBeNull();
                expect( created.getSource() ).toBe( "domain-auto" );

                cleanupInbound( result.getId() );
                cleanupTicket( t.getId() );
                queryExecute( "DELETE FROM contacts WHERE id = :id", { id : created.getId() } );
                queryExecute( "DELETE FROM organization_domains WHERE organization_id = :id", { id : org.getId() } );
                queryExecute( "DELETE FROM audit_events WHERE organization_id = :id", { id : org.getId() } );
                queryExecute( "DELETE FROM organizations WHERE id = :id", { id : org.getId() } );
            } );

            it( "leaves the ticket accountless when the approved domain is not verified", function(){
                var org = variables.contacts.createOrganization( {
                    name : "Unverified Org " & createUUID(),
                    slug : "uv-" & lCase( replace( createUUID(), "-", "", "all" ) )
                } );
                variables.contacts.updateOrganization( org.getId(), { autoProvisionContacts : true } );
                var domain = "uv-" & lCase( replace( createUUID(), "-", "", "all" ) ) & ".test";
                variables.contacts.addDomainMapping( organizationId : org.getId(), domain : domain, isVerified : false );

                var sender = "stranger-" & createUUID() & "@" & domain;
                var result = variables.processor.process( {
                    messageId : "msg-" & createUUID() & "@" & domain,
                    from      : sender,
                    subject   : "Hello",
                    body      : "No account here.",
                    headers   : {}
                } );
                expect( result.getOutcome() ).toBe( "ticket_created" );

                var t = variables.tickets.getTicket( result.getTicketId() );
                expect( t.isAccountless() ).toBeTrue();
                expect( variables.contacts.getContactByEmail( sender ) ).toBeNull();

                cleanupInbound( result.getId() );
                cleanupTicket( t.getId() );
                queryExecute( "DELETE FROM organization_domains WHERE organization_id = :id", { id : org.getId() } );
                queryExecute( "DELETE FROM audit_events WHERE organization_id = :id", { id : org.getId() } );
                queryExecute( "DELETE FROM organizations WHERE id = :id", { id : org.getId() } );
            } );

            it( "drops a sender on the blacklist", function(){
                var sender = "spammer-" & createUUID() & "@blocked.test";
                var entry  = variables.channels.blockEmail( email = sender );

                var result = variables.processor.process( {
                    messageId : "msg-" & createUUID() & "@blocked.test",
                    from      : sender,
                    subject   : "Hi",
                    body      : ".",
                    headers   : {}
                } );
                expect( result.getOutcome() ).toBe( "blocked_blacklist" );
                expect( result.getTicketId() ?: "" ).toBe( "" );

                cleanupInbound( result.getId() );
                queryExecute( "DELETE FROM channel_blacklist WHERE id = :id", { id : entry.getId() } );
                queryExecute( "DELETE FROM audit_events WHERE entity_id = :id", { id : entry.getId() } );
            } );

            it( "detects RFC 3834 Auto-Submitted as a loop", function(){
                var result = variables.processor.process( {
                    messageId : "msg-" & createUUID() & "@auto.test",
                    from      : "vacation-" & createUUID() & "@auto.test",
                    subject   : "Re: your message",
                    body      : "I'm out of the office.",
                    headers   : { "Auto-Submitted" : "auto-replied" }
                } );
                expect( result.getOutcome() ).toBe( "blocked_loop_guard" );
                cleanupInbound( result.getId() );
            } );

            it( "detects auto-reply subject heuristics", function(){
                var result = variables.processor.process( {
                    messageId : "msg-" & createUUID() & "@auto.test",
                    from      : "vacation-" & createUUID() & "@auto.test",
                    subject   : "Out of office: please contact someone else",
                    body      : ".",
                    headers   : {}
                } );
                expect( result.getOutcome() ).toBe( "blocked_loop_guard" );
                cleanupInbound( result.getId() );
            } );

            it( "treats a duplicate Message-ID as already processed", function(){
                var sender = "dup-" & createUUID() & "@example.com";
                var msgId  = "msg-" & createUUID() & "@example.com";
                var first  = variables.processor.process( {
                    messageId : msgId, from : sender, subject : "first", body : "x", headers : {}
                } );
                var second = variables.processor.process( {
                    messageId : msgId, from : sender, subject : "first", body : "x", headers : {}
                } );
                expect( first.getOutcome() ).toBe( "ticket_created" );
                expect( second.getOutcome() ).toBe( "duplicate" );

                cleanupInbound( first.getId() );
                cleanupInbound( second.getId() );
                cleanupTicket( first.getTicketId() );
            } );

            it( title = "appends to an existing ticket when In-Reply-To matches a prior inbound", skip = !mailpitPresent, body = function(){
                var sender = "thread-" & createUUID() & "@example.com";
                var msgIdA = "msg-A-" & createUUID() & "@example.com";
                var first  = variables.processor.process( {
                    messageId : msgIdA, from : sender, subject : "First message", body : "Original.", headers : {}
                } );
                expect( first.getOutcome() ).toBe( "ticket_created" );

                var msgIdB = "msg-B-" & createUUID() & "@example.com";
                var second = variables.processor.process( {
                    messageId : msgIdB,
                    from      : sender,
                    subject   : "Re: First message",
                    body      : "Adding more.",
                    inReplyTo : msgIdA,
                    headers   : {}
                } );
                expect( second.getOutcome() ).toBe( "message_appended" );
                expect( second.getTicketId() ).toBe( first.getTicketId() );

                // One inbound + the auto-ack OutboundEmailService now
                // persists on ticket creation + the follow-up inbound.
                var messages = variables.tickets.listMessagesForTicket( first.getTicketId(), true );
                expect( arrayLen( messages ) ).toBe( 3 );

                cleanupInbound( first.getId() );
                cleanupInbound( second.getId() );
                cleanupTicket( first.getTicketId() );
            } );

            it( "falls back to subject [##NNN] matching when no message-id chain exists", function(){
                var sender = "subject-thread-" & createUUID() & "@example.com";
                var first  = variables.processor.process( {
                    messageId : "msg-A-" & createUUID() & "@example.com",
                    from      : sender,
                    subject   : "Cannot log in",
                    body      : "Original.",
                    headers   : {}
                } );
                expect( first.getOutcome() ).toBe( "ticket_created" );
                var ticket = variables.tickets.getTicket( first.getTicketId() );
                var tn = ticket.getTicketNumber();

                // Simulate a reply with no In-Reply-To header (an
                // email client that stripped threading on forward),
                // only the [##NNN] subject prefix.
                var second = variables.processor.process( {
                    messageId : "msg-B-" & createUUID() & "@example.com",
                    from      : sender,
                    subject   : "Re: [##" & tn & "] Cannot log in",
                    body      : "More info.",
                    headers   : {}
                } );
                expect( second.getOutcome() ).toBe( "message_appended" );
                expect( second.getTicketId() ).toBe( first.getTicketId() );

                cleanupInbound( first.getId() );
                cleanupInbound( second.getId() );
                cleanupTicket( first.getTicketId() );
            } );

            it( "extracts the bare address from an angle-bracket From header", function(){
                var bare = "alice-" & createUUID() & "@example.com";
                var result = variables.processor.process( {
                    messageId : "msg-" & createUUID() & "@example.com",
                    from      : "Alice Example <" & bare & ">",
                    subject   : "Spec",
                    body      : ".",
                    headers   : {}
                } );
                expect( result.getOutcome() ).toBe( "ticket_created" );
                expect( result.getSenderEmail() ).toBe( bare );
                cleanupInbound( result.getId() );
                cleanupTicket( result.getTicketId() );
            } );

            it( "persists email attachments on the resulting ticket message", function(){
                var sender  = "att-" & createUUID() & "@example.com";
                var tmpFile = makeTempPng();
                var result  = variables.processor.process( {
                    messageId   : "msg-" & createUUID() & "@example.com",
                    from        : sender,
                    subject     : "Screenshot of the issue",
                    body        : "See attached.",
                    headers     : {},
                    attachments : [ {
                        path             : tmpFile,
                        originalFilename : "shot.png",
                        contentType      : "image/png",
                        sizeBytes        : getFileInfo( tmpFile ).size
                    } ]
                } );
                expect( result.getOutcome() ).toBe( "ticket_created" );

                var atts = variables.tickets.listAttachmentsForTicket(
                    result.getTicketId(),
                    { type : "agent", id : "system-spec" }
                );
                expect( arrayLen( atts ) ).toBe( 1 );
                expect( atts[ 1 ].getOriginalFilename() ).toBe( "shot.png" );
                expect( len( atts[ 1 ].getMessageId() ?: "" ) ).toBeGT( 0 );

                cleanupAttachments( result.getTicketId() );
                cleanupInbound( result.getId() );
                cleanupTicket( result.getTicketId() );
                try { fileDelete( tmpFile ); } catch ( any e ) {}
            } );

            it( "drops the whole batch and posts an internal note when aggregate cap is exceeded", function(){
                // Squeeze the cap to 100 bytes for this spec so a small
                // file trips the limit; restore on the way out.
                // getSystemSetting walks java system properties before
                // env vars, so flipping the property is enough to
                // override for one spec without touching the OS env.
                var sys   = createObject( "java", "java.lang.System" );
                var prior = sys.getProperty( "EMAIL_ATTACHMENT_AGGREGATE_MAX_BYTES" ) ?: "";
                sys.setProperty( "EMAIL_ATTACHMENT_AGGREGATE_MAX_BYTES", "100" );

                var sender  = "agg-" & createUUID() & "@example.com";
                var tmpFile = makeTempPng();
                var fileSize = getFileInfo( tmpFile ).size;
                var result   = variables.processor.process( {
                    messageId   : "msg-" & createUUID() & "@example.com",
                    from        : sender,
                    subject     : "Big bundle",
                    body        : "Original.",
                    headers     : {},
                    attachments : [ {
                        path             : tmpFile,
                        originalFilename : "fat.png",
                        contentType      : "image/png",
                        sizeBytes        : fileSize
                    } ]
                } );
                expect( result.getOutcome() ).toBe( "ticket_created" );

                var atts = variables.tickets.listAttachmentsForTicket(
                    result.getTicketId(),
                    { type : "agent", id : "system-spec" }
                );
                expect( arrayLen( atts ) ).toBe( 0 );

                // The body posts + an internal note explains the drop.
                var messages = variables.tickets.listMessagesForTicket( result.getTicketId(), true );
                var hasNote = false;
                for ( var m in messages ) {
                    if ( m.getIsInternal() && findNoCase( "aggregate cap", m.getBody() ) ) {
                        hasNote = true;
                        break;
                    }
                }
                expect( hasNote ).toBeTrue();

                if ( len( prior ) ) {
                    sys.setProperty( "EMAIL_ATTACHMENT_AGGREGATE_MAX_BYTES", prior );
                } else {
                    sys.clearProperty( "EMAIL_ATTACHMENT_AGGREGATE_MAX_BYTES" );
                }
                cleanupAttachments( result.getTicketId() );
                cleanupInbound( result.getId() );
                cleanupTicket( result.getTicketId() );
                try { fileDelete( tmpFile ); } catch ( any e ) {}
            } );

            it( "rejects an inbound attachment whose magic bytes do not match its declared type", function(){
                var sender  = "magic-" & createUUID() & "@example.com";
                // Real ZIP local-file-header bytes (50 4B 03 04) with a
                // .pdf extension + application/pdf content type. The
                // sniffer should catch the mismatch and reject. Plain
                // fileWrite would utf-8-encode 0x50/0x4B safely but
                // chars >= 0x80 expand to two bytes, so go through
                // FileOutputStream + javaCast to write the exact bytes.
                var tmpFile = getTempDirectory() & "/bad-" & createUUID() & ".pdf";
                writeRawBytes( tmpFile, [ 80, 75, 3, 4, 0, 0, 0, 0, 120, 120, 120, 120, 120, 120, 120, 120 ] );

                var result = variables.processor.process( {
                    messageId   : "msg-" & createUUID() & "@example.com",
                    from        : sender,
                    subject     : "Doc",
                    body        : "See attached.",
                    headers     : {},
                    attachments : [ {
                        path             : tmpFile,
                        originalFilename : "doc.pdf",
                        contentType      : "application/pdf",
                        sizeBytes        : getFileInfo( tmpFile ).size
                    } ]
                } );
                expect( result.getOutcome() ).toBe( "ticket_created" );

                var atts = variables.tickets.listAttachmentsForTicket(
                    result.getTicketId(),
                    { type : "agent", id : "system-spec" }
                );
                expect( arrayLen( atts ) ).toBe( 0 );

                // Rejection should leave an internal-note breadcrumb.
                var messages = variables.tickets.listMessagesForTicket( result.getTicketId(), true );
                var hasRejection = false;
                for ( var m in messages ) {
                    if ( m.getIsInternal() && findNoCase( "rejected", m.getBody() ) ) {
                        hasRejection = true;
                        break;
                    }
                }
                expect( hasRejection ).toBeTrue();

                cleanupInbound( result.getId() );
                cleanupTicket( result.getTicketId() );
                try { fileDelete( tmpFile ); } catch ( any e ) {}
            } );

        } );
    }

    /**
     * Build a small but real PNG on disk so addAttachment's magic-byte
     * sniff sees the PNG signature instead of rejecting our fixture.
     * Goes through ImageIO so the bytes are also a decodable PNG —
     * the thumbnail pipeline runs sync in addAttachment and we don't
     * want it logging a parse-failure warning during specs.
     */
    private string function makeTempPng(){
        var img = createObject( "java", "java.awt.image.BufferedImage" )
            .init( 32, 32, createObject( "java", "java.awt.image.BufferedImage" ).TYPE_INT_RGB );
        var g = img.createGraphics();
        try {
            g.setColor( createObject( "java", "java.awt.Color" ).BLUE );
            g.fillRect( 0, 0, 32, 32 );
        } finally {
            g.dispose();
        }
        var path = getTempDirectory() & "/spec-png-" & createUUID() & ".png";
        var fos  = createObject( "java", "java.io.FileOutputStream" ).init( path );
        try {
            createObject( "java", "javax.imageio.ImageIO" ).write( img, "png", fos );
        } finally {
            fos.close();
        }
        return path;
    }

    /**
     * Write an exact byte sequence to disk. fileWrite() of an ad-hoc
     * String round-trips through UTF-8 and turns any char >= 0x80 into
     * two bytes, which clobbers magic-byte headers.
     */
    private void function writeRawBytes( required string path, required array bytes ){
        var fos = createObject( "java", "java.io.FileOutputStream" ).init( arguments.path );
        try {
            fos.write( javaCast( "byte[]", arguments.bytes ) );
        } finally {
            fos.close();
        }
    }

    private void function cleanupAttachments( required string ticketId ){
        queryExecute(
            "DELETE FROM audit_events
              WHERE entity_id IN (
                  SELECT id FROM attachments WHERE ticket_id = :id
              )",
            { id : arguments.ticketId }
        );
        queryExecute( "DELETE FROM attachments WHERE ticket_id = :id", { id : arguments.ticketId } );
    }

    private void function cleanupInbound( required string id ){
        queryExecute( "DELETE FROM inbound_emails WHERE id = :id", { id : arguments.id } );
    }

    /**
     * Probe Mailpit by opening a tiny HTTP connection. Mirrors the
     * helper in OutboundEmailServiceSpec / CbmailservicesMultipartSpec.
     * Using java.net.URLConnection rather than cfhttp because the
     * probe runs at the top of run() before BoxLang's request scope
     * is fully wired and cfhttp has been flaky in that window.
     */
    private boolean function probeMailpit( required string base ){
        try {
            var connectionHandle = createObject( "java", "java.net.URL" )
                .init( arguments.base & "/api/v1/info" )
                .openConnection();
            connectionHandle.setRequestMethod( "GET" );
            connectionHandle.setConnectTimeout( javaCast( "int", 1500 ) );
            connectionHandle.setReadTimeout( javaCast( "int", 1500 ) );
            var status = connectionHandle.getResponseCode();
            return status >= 200 && status < 500;
        } catch ( any e ) {
            return false;
        }
    }

    private void function cleanupTicket( required string id ){
        if ( !len( arguments.id ) ) return;
        queryExecute( "DELETE FROM notifications    WHERE ticket_id = :id", { id : arguments.id } );
        queryExecute( "DELETE FROM ticket_approvals WHERE ticket_id = :id", { id : arguments.id } );
        queryExecute( "DELETE FROM ticket_events WHERE ticket_id = :id", { id : arguments.id } );
        queryExecute( "DELETE FROM ticket_messages WHERE ticket_id = :id", { id : arguments.id } );
        queryExecute( "DELETE FROM audit_events WHERE entity_id = :id", { id : arguments.id } );
        queryExecute( "DELETE FROM tickets WHERE id = :id", { id : arguments.id } );
    }

}
