class extends="coldbox.system.testing.BaseTestCase" appMapping="/" {

    function beforeAll(){
        super.beforeAll();
        super.setup();
    }

    function run(){
        describe( "channels module", function(){
            it( "is registered with ColdBox", function(){
                var modules = getController().getModuleService().getModuleRegistry();
                expect( modules ).toHaveKey( "channels" );
            } );

            it( "exposes its entry point", function(){
                var cache = getController().getModuleService().getModuleConfigCache();
                expect( cache ).toHaveKey( "channels" );
                // channels is service-only; entryPoint is intentionally
                // empty so it doesn't grab a URL prefix (its inbound
                // pipeline runs in the scheduler, not via HTTP).
                expect( cache[ "channels" ] ).toHaveKey( "entryPoint" );
            } );
        } );
    }

}
