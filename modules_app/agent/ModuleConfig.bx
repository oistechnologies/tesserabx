/**
 * agent module: the technician dashboard surface.
 *
 * Owns Agent, Team, and agent-local entities (saved filters, etc).
 * Serves /agent and contains the nested admin child module which
 * resolves to /agent/admin.
 */
class {

    this.title              = "agent";
    this.author             = "TesseraBX";
    this.webURL             = "https://github.com/oistechnologies/tesserabx";
    this.description        = "Technician dashboard surface at /agent, containing the nested admin child module.";
    this.version            = "0.0.1";
    this.viewParentLookup   = true;
    this.layoutParentLookup = true;
    this.entryPoint         = "agent";
    this.modelNamespace     = "agent";
    this.cfmapping          = "tesserabx.modules.agent";
    this.autoMapModels      = false;
    this.dependencies       = [ "contacts", "audit", "tickets", "channels", "knowledgebase", "reporting", "notifications" ];

    function configure(){
        // `variables.` prefix is REQUIRED throughout configure(); see
        // gotcha log in docs/EXTENSIBILITY-PLAN.md ("Unscoped
        // assignments in ModuleConfig.bx configure() go to function-
        // local"). Unscoped settings/routes/etc. are invisible to
        // ColdBox.
        variables.settings = {};

        // Routes for /agent live in modules_app/agent/config/Router.bx,
        // which uses verb-aware route() declarations (POST /login goes
        // to Session.create, GET /login goes to Session.new, etc.).
        // Previously this array also declared `/login` and `/logout`
        // entries without verb constraints, but the Phase 1 scope-
        // walker bug was silently swallowing them. Phase 4's scoping
        // fix made them active and they began shadowing the verb-aware
        // routes (POST /login was routing to Session.new instead of
        // Session.create, breaking login). The duplicates are removed
        // here; the catch-all is kept for handler/action URL fallback.
        variables.routes = [
            { pattern : "/",                handler : "Home",    action : "index" },
            { pattern : "/:handler/:action?" }
        ];

        // cbSecurity firewall for /agent. Distinct from portal's firewall:
        // AgentAuthService backs cbauth, and the session storage key is
        // namespaced separately. The nested admin module overlays its own
        // /agent/admin rules so non-admin agents get 403 (not 404).
        variables.cbSecurity = {
            userService         : "AgentAuthService@agent",
            sessionStorageScope : "session",
            authStorage         : "tesserabx_agent_user",
            firewall : {
                rulesSource                 : "model",
                rulesModel                  : "AgentSecurityRules@agent",
                invalidAuthenticationEvent  : "agent:Session.new",
                defaultAuthenticationAction : "redirect",
                invalidAuthorizationEvent   : "agent:Session.unauthorized",
                defaultAuthorizationAction  : "block"
            }
        };

        variables.interceptorSettings = { customInterceptionPoints : [
            "onAgentCreated",
            "onAgentUpdated",
            "onAgentActivated",
            "onAgentDeactivated",
            "onAgentRoleGranted",
            "onAgentRoleRevoked"
        ] };
        variables.interceptors = [];
    }

    function onLoad(){
        binder.map( "Agent@agent" )
              .to( "#moduleMapping#.models.Agent" );
        binder.map( "AgentRole@agent" )
              .to( "#moduleMapping#.models.AgentRole" );
        binder.map( "Team@agent" )
              .to( "#moduleMapping#.models.Team" );
        binder.map( "TeamMember@agent" )
              .to( "#moduleMapping#.models.TeamMember" );
        binder.map( "AgentAuthService@agent" )
              .to( "#moduleMapping#.models.AgentAuthService" )
              .asSingleton();
        binder.map( "AgentSecurityRules@agent" )
              .to( "#moduleMapping#.models.AgentSecurityRules" )
              .asSingleton();
        binder.map( "RbacService@agent" )
              .to( "#moduleMapping#.models.RbacService" )
              .asSingleton();
        binder.map( "PermissionRegistry@agent" )
              .to( "#moduleMapping#.models.PermissionRegistry" )
              .asSingleton();
        binder.map( "RoleRegistry@agent" )
              .to( "#moduleMapping#.models.RoleRegistry" )
              .asSingleton();
        binder.map( "TeamsService@agent" )
              .to( "#moduleMapping#.models.TeamsService" )
              .asSingleton();
        binder.map( "AgentService@agent" )
              .to( "#moduleMapping#.models.AgentService" )
              .asSingleton();
        binder.map( "TotpService@agent" )
              .to( "#moduleMapping#.models.TotpService" )
              .asSingleton();
    }

    function onUnload(){}

}
