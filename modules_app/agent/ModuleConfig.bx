/**
 * agent module: the technician dashboard surface.
 *
 * Owns Agent, Team, and agent-local entities (saved filters, etc).
 * Serves /agent and contains the nested admin child module which
 * resolves to /agent/admin.
 */
class {

    this.title              = "agent";
    this.author             = "TesseraBX";
    this.webURL             = "https://github.com/oistechnologies/tesserabx";
    this.description        = "Technician dashboard surface at /agent, containing the nested admin child module.";
    this.version            = "0.0.1";
    this.viewParentLookup   = true;
    this.layoutParentLookup = true;
    this.entryPoint         = "agent";
    this.modelNamespace     = "agent";
    this.cfmapping          = "tesserabx.modules.agent";
    this.autoMapModels      = false;
    this.dependencies       = [ "contacts", "audit", "tickets", "channels", "knowledgebase", "reporting", "notifications" ];

    function configure(){
        // `variables.` prefix is REQUIRED throughout configure(); see
        // gotcha log in docs/EXTENSIBILITY-PLAN.md ("Unscoped
        // assignments in ModuleConfig.bx configure() go to function-
        // local"). Unscoped settings/routes/etc. are invisible to
        // ColdBox.
        variables.settings = {
            tesserabx : {
                helpSections : [
                    { id : "agent", title : "Agent dashboard", audience : "agent", sortWeight : 150, icon : "bi bi-person-badge" }
                ],
                helpPages : [
                    { id : "agent.signing-in-mfa", section : "agent", title : "Signing in and MFA", audience : "agent", sortWeight : 10, source : "resources/help/signing-in-mfa.md", searchable : true, keywords : [ "mfa", "totp", "sign in", "login", "recovery code", "two factor" ] }
                ],
                // Follow-up B1: the ten right-column cards on the
                // agent ticket-detail page are registered through the
                // same TicketPanelRegistry path as add-on panels. The
                // partials live under modules_app/agent/views/panels/
                // and consume prc.* the same way the inline cards did.
                // A `requiredPermission` of "tickets.view" is the
                // baseline for "anyone who can already see the
                // ticket"; tightening individual panels is a separate
                // pass.
                // Follow-up B2: the ten dashboard widgets on
                // /agent/reports are registered through
                // DashboardWidgetRegistry. The partials live under
                // modules_app/agent/views/widgets/ and read prc.*
                // directly (no dataProvider/dataMethod). Chart.js
                // initialization stays inline at the bottom of
                // reports/index.bxm since it references prc.* and
                // the canvas ids are stable.
                dashboardWidgets : [
                    { id : "open-tickets",        title : "Open tickets",                partial : "widgets/open_tickets",       module : "agent", defaultGridSize : "col-12 col-md-6 col-xl-3 d-flex", sortWeight : 100,  requiredPermission : "tickets.view" },
                    { id : "created-today",       title : "Created today",               partial : "widgets/created_today",      module : "agent", defaultGridSize : "col-12 col-md-6 col-xl-3 d-flex", sortWeight : 200,  requiredPermission : "tickets.view" },
                    { id : "avg-first-response",  title : "Avg first response",          partial : "widgets/avg_first_response", module : "agent", defaultGridSize : "col-12 col-md-6 col-xl-3 d-flex", sortWeight : 300,  requiredPermission : "tickets.view" },
                    { id : "sla-compliance",      title : "SLA first-response compliance", partial : "widgets/sla_compliance",   module : "agent", defaultGridSize : "col-12 col-md-6 col-xl-3 d-flex", sortWeight : 400,  requiredPermission : "tickets.view" },
                    { id : "volume-chart",        title : "Ticket volume",               partial : "widgets/volume_chart",       module : "agent", defaultGridSize : "col-12 col-xl-8 d-flex",          sortWeight : 500,  requiredPermission : "tickets.view" },
                    { id : "backlog-age",         title : "Backlog age",                 partial : "widgets/backlog_age",        module : "agent", defaultGridSize : "col-12 col-xl-4 d-flex",          sortWeight : 600,  requiredPermission : "tickets.view" },
                    { id : "by-status",           title : "By status",                   partial : "widgets/by_status",          module : "agent", defaultGridSize : "col-12 col-md-4 d-flex",          sortWeight : 700,  requiredPermission : "tickets.view" },
                    { id : "by-priority",         title : "By priority",                 partial : "widgets/by_priority",        module : "agent", defaultGridSize : "col-12 col-md-4 d-flex",          sortWeight : 800,  requiredPermission : "tickets.view" },
                    { id : "by-source",           title : "By source",                   partial : "widgets/by_source",          module : "agent", defaultGridSize : "col-12 col-md-4 d-flex",          sortWeight : 900,  requiredPermission : "tickets.view" },
                    { id : "agent-load",          title : "Agent open load",             partial : "widgets/agent_load",         module : "agent", defaultGridSize : "col-12 d-flex",                   sortWeight : 1000, requiredPermission : "tickets.view" }
                ],
                ticketPanels : [
                    { id : "summary",          position : "right", label : "AI summary",            partial : "panels/summary",          module : "agent", sortWeight : 100,  requiredPermission : "tickets.view", requiresAi : true                  },
                    { id : "escalation-risk",  position : "right", label : "Escalation risk",       partial : "panels/escalation_risk",  module : "agent", sortWeight : 150,  requiredPermission : "tickets.view", requiresAi : true                  },
                    { id : "kb-draft",         position : "right", label : "Draft KB article",      partial : "panels/kb_draft",         module : "agent", sortWeight : 200,  requiredPermission : "tickets.view", requiresAi : true                  },
                    { id : "related-articles", position : "right", label : "Related articles",      partial : "panels/related_articles", module : "agent", sortWeight : 300,  requiredPermission : "tickets.view", requiresAi : true                  },
                    { id : "custom-fields",    position : "right", label : "Custom fields",         partial : "panels/custom_fields",    module : "agent", sortWeight : 400,  requiredPermission : "tickets.view"                                     },
                    { id : "status",           position : "right", label : "Status",                partial : "panels/status",           module : "agent", sortWeight : 500,  requiredPermission : "tickets.view"                                     },
                    { id : "approval",         position : "right", label : "Approval",              partial : "panels/approval",         module : "agent", sortWeight : 550,  requiredPermission : "tickets.view"                                     },
                    { id : "sla",              position : "right", label : "SLA",                   partial : "panels/sla",              module : "agent", sortWeight : 600,  requiredPermission : "tickets.view"                                     },
                    { id : "assignment",       position : "right", label : "Assignment",            partial : "panels/assignment",       module : "agent", sortWeight : 700,  requiredPermission : "tickets.view"                                     },
                    { id : "block-sender",     position : "right", label : "Block sender",          partial : "panels/block_sender",     module : "agent", sortWeight : 800,  requiredPermission : "tickets.view"                                     },
                    { id : "promote-sender",   position : "right", label : "Promote sender",        partial : "panels/promote_sender",   module : "agent", sortWeight : 900,  requiredPermission : "tickets.view"                                     },
                    { id : "timeline",         position : "right", label : "Timeline",              partial : "panels/timeline",         module : "agent", sortWeight : 1000, requiredPermission : "tickets.view"                                     }
                ]
            }
        };

        // Routes for /agent live in modules_app/agent/config/Router.bx,
        // which uses verb-aware route() declarations (POST /login goes
        // to Session.create, GET /login goes to Session.new, etc.).
        // Previously this array also declared `/login` and `/logout`
        // entries without verb constraints, but the Phase 1 scope-
        // walker bug was silently swallowing them. Phase 4's scoping
        // fix made them active and they began shadowing the verb-aware
        // routes (POST /login was routing to Session.new instead of
        // Session.create, breaking login). The duplicates are removed
        // here; the catch-all is kept for handler/action URL fallback.
        variables.routes = [
            { pattern : "/",                handler : "Home",    action : "index" },
            { pattern : "/:handler/:action?" }
        ];

        // cbSecurity firewall for /agent. Distinct from portal's firewall:
        // AgentAuthService backs cbauth, and the session storage key is
        // namespaced separately. The nested admin module overlays its own
        // /agent/admin rules so non-admin agents get 403 (not 404).
        variables.cbSecurity = {
            userService         : "AgentAuthService@agent",
            sessionStorageScope : "session",
            authStorage         : "tesserabx_agent_user",
            firewall : {
                rulesSource                 : "model",
                rulesModel                  : "AgentSecurityRules@agent",
                invalidAuthenticationEvent  : "agent:Session.new",
                defaultAuthenticationAction : "redirect",
                invalidAuthorizationEvent   : "agent:Session.unauthorized",
                defaultAuthorizationAction  : "block"
            }
        };

        variables.interceptorSettings = { customInterceptionPoints : [
            "onAgentCreated",
            "onAgentUpdated",
            "onAgentActivated",
            "onAgentDeactivated",
            "onAgentRoleGranted",
            "onAgentRoleRevoked"
        ] };
        variables.interceptors = [];
    }

    function onLoad(){
        binder.map( "Agent@agent" )
              .to( "#moduleMapping#.models.Agent" );
        binder.map( "AgentRole@agent" )
              .to( "#moduleMapping#.models.AgentRole" );
        binder.map( "Team@agent" )
              .to( "#moduleMapping#.models.Team" );
        binder.map( "TeamMember@agent" )
              .to( "#moduleMapping#.models.TeamMember" );
        binder.map( "AgentAuthService@agent" )
              .to( "#moduleMapping#.models.AgentAuthService" )
              .asSingleton();
        binder.map( "AgentSecurityRules@agent" )
              .to( "#moduleMapping#.models.AgentSecurityRules" )
              .asSingleton();
        binder.map( "RbacService@agent" )
              .to( "#moduleMapping#.models.RbacService" )
              .asSingleton();
        binder.map( "PermissionRegistry@agent" )
              .to( "#moduleMapping#.models.PermissionRegistry" )
              .asSingleton();
        binder.map( "RoleRegistry@agent" )
              .to( "#moduleMapping#.models.RoleRegistry" )
              .asSingleton();
        binder.map( "TeamsService@agent" )
              .to( "#moduleMapping#.models.TeamsService" )
              .asSingleton();
        binder.map( "AgentService@agent" )
              .to( "#moduleMapping#.models.AgentService" )
              .asSingleton();
        binder.map( "TotpService@agent" )
              .to( "#moduleMapping#.models.TotpService" )
              .asSingleton();
    }

    function onUnload(){}

}
