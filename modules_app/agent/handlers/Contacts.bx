/**
 * agent:Contacts handler.
 *
 * Agent-facing CRUD over the Contact entity. Implements the
 * "agent-created provisioning" path from Phase 1: an agent creates a
 * Contact, assigns it to an Organization (and optionally an Office),
 * and optionally grants the organization-admin role.
 *
 * All data access goes through ContactsService@contacts. This handler
 * never imports a contacts entity directly.
 */
class {

    property name="contactsService" inject="ContactsService@contacts";
    property name="imageProcessing" inject="ImageProcessingService@core";
    property name="messagebox"      inject="messagebox@cbmessagebox";
    property name="validator"       inject="ValidationManager@cbvalidation";
    property name="auth"            inject="AuthenticationService@cbauth";

    // Contact avatars share the agent pipeline under this public-disk
    // prefix (the portal self-service upload uses the same one).
    variables.AVATAR_PREFIX = "contacts";

    function preHandler( event, rc, prc, action, eventArguments ){
        event.setLayout( name = "Agent", module = "core" );
    }

    function index( event, rc, prc ){
        prc.pageTitle    = "Contacts";
        prc.organizations = contactsService.listOrganizations();
        // Phase 1 ships one list-by-organization view. A queue-style
        // list across orgs lands in Phase 1d alongside ticket queues.
        prc.activeOrgId  = rc.organizationId ?: "";
        prc.contacts     = len( prc.activeOrgId )
            ? contactsService.listContactsForOrganization( prc.activeOrgId )
            : [];
        event.setView( "contacts/index" );
    }

    function show( event, rc, prc ){
        prc.contact = contactsService.getContactById( rc.id ?: "" );
        if ( isNull( prc.contact ) ) {
            messagebox.warn( "That contact does not exist." );
            relocate( uri = "/agent/contacts" );
            return;
        }
        prc.pageTitle     = "Contact: " & prc.contact.getEmail();
        prc.organization  = contactsService.getOrganizationById( prc.contact.getOrganizationId() );
        prc.roles         = contactsService.listRolesForContact( prc.contact.getId() );

        // Office is an optional FK; resolve the display name when set.
        prc.officeName = "";
        var officeId = prc.contact.getOfficeId() ?: "";
        if ( len( officeId ) ) {
            var office = contactsService.getOfficeById( officeId );
            if ( !isNull( office ) ) prc.officeName = office.getName() ?: "";
        }

        // Avatar render data. AvatarHelper draws the uploaded image when
        // present and a deterministic initials badge otherwise, so the
        // view always has a placeholder.
        prc.hasAvatar = len( prc.contact.getProfileImageOriginalPath() ?: "" ) > 0;
        prc.avatar = {
            id         : prc.contact.getId(),
            firstName  : prc.contact.getFirstName() ?: "",
            lastName   : prc.contact.getLastName()  ?: "",
            email      : prc.contact.getEmail()     ?: "",
            hasAvatar  : prc.hasAvatar,
            uploadedAt : prc.contact.getProfileImageUploadedAt()
        };
        event.setView( "contacts/show" );
    }

    function new( event, rc, prc ){
        prc.pageTitle    = "New contact";
        prc.organizations = contactsService.listOrganizations();
        prc.formData     = blankContactForm();
        // If the agent arrived from an organization page, preselect it
        // so the office dropdown can populate immediately.
        prc.formData.organizationId = rc.organizationId ?: "";
        prc.offices = len( prc.formData.organizationId )
            ? contactsService.listOfficesForOrganization( prc.formData.organizationId )
            : [];
        event.setView( "contacts/new" );
    }

    function create( event, rc, prc ){
        param rc.email             = "";
        param rc.firstName         = "";
        param rc.lastName          = "";
        param rc.organizationId    = "";
        param rc.officeId          = "";
        param rc.password          = "";
        param rc.organizationAdmin = false;

        var errors = validateNewContact( rc );
        if ( arrayLen( errors ) ) {
            messagebox.error( errors.toList( "<br>" ) );
            prc.pageTitle    = "New contact";
            prc.organizations = contactsService.listOrganizations();
            prc.formData     = rc;
            prc.offices      = len( rc.organizationId )
                ? contactsService.listOfficesForOrganization( rc.organizationId )
                : [];
            event.setView( "contacts/new" );
            return;
        }

        var data = contactDataFrom( rc );
        data.email          = rc.email;
        data.organizationId = rc.organizationId;
        data.password       = rc.password;
        data.source         = "agent";
        var contact = contactsService.provisionContact( data );

        if ( isBoolean( rc.organizationAdmin ) && rc.organizationAdmin ) {
            contactsService.assignRole(
                contactId        : contact.getId(),
                roleKey          : "organization-admin",
                grantedByAgentId : currentAgentId()
            );
        }

        messagebox.info( "Contact created." );
        relocate( uri = "/agent/contacts/" & contact.getId() );
    }

    function edit( event, rc, prc ){
        prc.contact = contactsService.getContactById( rc.id ?: "" );
        if ( isNull( prc.contact ) ) {
            messagebox.warn( "That contact does not exist." );
            relocate( uri = "/agent/contacts" );
            return;
        }
        prc.pageTitle = "Edit contact";
        prc.roles     = contactsService.listRolesForContact( prc.contact.getId() );
        // Office dropdown is scoped to the contact's organization.
        prc.offices   = contactsService.listOfficesForOrganization( prc.contact.getOrganizationId() );
        prc.isOrgAdmin = false;
        for ( var r in prc.roles ) {
            if ( r.getRoleKey() == "organization-admin" ) {
                prc.isOrgAdmin = true;
                break;
            }
        }
        event.setView( "contacts/edit" );
    }

    function update( event, rc, prc ){
        var contact = contactsService.getContactById( rc.id ?: "" );
        if ( isNull( contact ) ) {
            messagebox.warn( "That contact does not exist." );
            relocate( uri = "/agent/contacts" );
            return;
        }

        param rc.firstName         = "";
        param rc.lastName          = "";
        param rc.organizationAdmin = false;
        param rc.isActive          = true;

        // Go through the service rather than calling contact.save() —
        // Quick's save() rebinds every column on the entity, including
        // mfa_recovery_codes (jsonb / PGobject on load), which JDBC
        // cannot coerce back into a varchar bind. The service uses a
        // targeted UPDATE that only touches the columns this form
        // changes.
        var data = contactDataFrom( rc );
        data.isActive = isBoolean( rc.isActive ) ? rc.isActive : ( rc.isActive == "true" || rc.isActive == "1" );
        contact = contactsService.updateContactProfile( contact.getId(), data );

        var wantOrgAdmin = isBoolean( rc.organizationAdmin ) ? rc.organizationAdmin : ( rc.organizationAdmin == "true" || rc.organizationAdmin == "1" );
        if ( wantOrgAdmin ) {
            contactsService.assignRole(
                contactId        : contact.getId(),
                roleKey          : "organization-admin",
                grantedByAgentId : currentAgentId()
            );
        } else {
            contactsService.revokeRole(
                contactId : contact.getId(),
                roleKey   : "organization-admin"
            );
        }

        messagebox.info( "Contact updated." );
        relocate( uri = "/agent/contacts/" & contact.getId() );
    }

    /**
     * Multipart profile-image upload for a contact. Mirrors
     * admin:Users.uploadAvatar but targets a Contact under the
     * "contacts" public-disk prefix via ContactsService. Lives outside
     * any cbwire component because cbwire's FileUpload object can't
     * survive BoxLang's snapshot duplicate().
     */
    function uploadAvatar( event, rc, prc ){
        param rc.id = "";
        var contact = contactsService.getContactById( rc.id );
        if ( isNull( contact ) ) {
            messagebox.warn( "That contact does not exist." );
            relocate( uri = "/agent/contacts" );
            return;
        }
        if ( !structKeyExists( form, "profileImage" ) || !len( form.profileImage ?: "" ) ) {
            messagebox.error( "Pick a file before submitting." );
            relocate( uri = "/agent/contacts/" & rc.id );
            return;
        }
        try {
            var dest = getTempDirectory() & "/contact-avatar-" & createUUID() & "/";
            directoryCreate( dest );
            var result = fileUpload(
                destination  = dest,
                fileField    = "profileImage",
                accept       = "image/jpeg,image/png,image/gif,image/webp",
                nameConflict = "makeUnique"
            );
            var srcPath     = dest & result.serverFile;
            var contentType = result.contentType & "/" & result.contentSubType;

            var v = imageProcessing.validateUpload( srcPath, contentType );
            if ( !v.ok ) {
                messagebox.error( v.error );
                directoryDelete( dest, true );
                relocate( uri = "/agent/contacts/" & rc.id );
                return;
            }

            var paths = imageProcessing.processProfileImage( rc.id, srcPath, contentType, variables.AVATAR_PREFIX );
            contactsService.setProfileImage( rc.id, paths.original, contentType );
            directoryDelete( dest, true );
            messagebox.info( "Profile picture updated." );
        } catch ( any e ) {
            messagebox.error( "Profile picture upload failed: " & e.message );
        }
        relocate( uri = "/agent/contacts/" & rc.id );
    }

    function clearAvatar( event, rc, prc ){
        param rc.id = "";
        var contact = contactsService.getContactById( rc.id );
        if ( isNull( contact ) ) {
            messagebox.warn( "That contact does not exist." );
            relocate( uri = "/agent/contacts" );
            return;
        }
        try {
            imageProcessing.deleteProfileImages( rc.id, variables.AVATAR_PREFIX );
            contactsService.clearProfileImage( rc.id );
            messagebox.info( "Profile picture removed." );
        } catch ( any e ) {
            messagebox.error( "Could not remove the picture: " & e.message );
        }
        relocate( uri = "/agent/contacts/" & rc.id );
    }

    // ---------------- internals ----------------

    /**
     * The editable profile fields shared by create + update, read from
     * the request collection. officeId is carried through as-is; the
     * service maps a blank value to a real NULL (FK SET NULL).
     */
    private struct function contactDataFrom( required struct rc ){
        return {
            firstName   : trim( arguments.rc.firstName ?: "" ),
            lastName    : trim( arguments.rc.lastName ?: "" ),
            officeId    : trim( arguments.rc.officeId ?: "" ),
            phone       : trim( arguments.rc.phone ?: "" ),
            mobilePhone : trim( arguments.rc.mobilePhone ?: "" ),
            jobTitle    : trim( arguments.rc.jobTitle ?: "" ),
            timezone    : trim( arguments.rc.timezone ?: "" ),
            locale      : trim( arguments.rc.locale ?: "" ),
            isVip       : ( arguments.rc.isVip ?: "" ) == "true" || ( arguments.rc.isVip ?: "" ) == "1",
            notes       : arguments.rc.notes ?: ""
        };
    }

    private struct function blankContactForm(){
        return {
            email : "", firstName : "", lastName : "", organizationId : "", officeId : "",
            password : "", organizationAdmin : false, phone : "", mobilePhone : "",
            jobTitle : "", timezone : "", locale : "", isVip : false, notes : ""
        };
    }

    private array function validateNewContact( required struct rc ){
        var errors = [];
        if ( !len( trim( arguments.rc.email ?: "" ) ) ) errors.append( "Email is required." );
        if ( !len( trim( arguments.rc.organizationId ?: "" ) ) ) errors.append( "Organization is required." );
        if ( !len( arguments.rc.password ?: "" ) ) errors.append( "Initial password is required." );
        if ( len( arguments.rc.password ?: "" ) && len( arguments.rc.password ) < 8 ) {
            errors.append( "Password must be at least 8 characters." );
        }
        if ( len( trim( arguments.rc.email ?: "" ) ) && !isNull( contactsService.getContactByEmail( arguments.rc.email ) ) ) {
            errors.append( "A contact with that email already exists." );
        }
        return errors;
    }

    private string function currentAgentId(){
        if ( !auth.isLoggedIn() ) return "";
        var user = auth.getUser();
        if ( isNull( user ) ) return "";
        return user.getId();
    }

}
