/**
 * /agent/account — the My Account surface.
 *
 * index() renders the MyAccount wire (Profile / Password / MFA /
 * Email tabs). The wire owns all interactive state and writes.
 *
 * The avatar upload form lives outside the wire (rendered by the
 * parent view above the wire) because cbwire's FileUpload object
 * can't survive BoxLang's duplicate() during snapshot. uploadAvatar
 * + clearAvatar handle the multipart POSTs from that form.
 *
 * confirmEmail() consumes the verification token sent to the
 * agent's new email address. On success the agent's email is
 * swapped; on failure (unknown / expired / consumed token) the
 * user lands back on My Account with a clear flash.
 */
class {

    property name="auth"            inject="AuthenticationService@cbauth";
    property name="agentService"    inject="AgentService@agent";
    property name="imageProcessing" inject="ImageProcessingService@core";
    property name="messagebox"      inject="messagebox@cbmessagebox";

    function preHandler( event, rc, prc, action, eventArguments ){
        event.setLayout( name = "Agent", module = "core" );
    }

    function index( event, rc, prc ){
        if ( !auth.isLoggedIn() ) {
            relocate( uri = "/agent/login" );
            return;
        }
        var me = auth.getUser();
        prc.pageTitle      = "My Account";
        prc.agentId        = me.getId();
        prc.hasAvatar      = len( me.getProfileImageOriginalPath() ?: "" ) > 0;
        prc.uploadVersion  = prc.hasAvatar && !isNull( me.getProfileImageUploadedAt() )
            ? me.getProfileImageUploadedAt().getTime()
            : 0;
        event.setView( "account/index" );
    }

    /**
     * Multipart POST from the avatar card on /agent/account.
     * Mirrors the admin uploadAvatar in modules/admin/handlers/Users.bx
     * but always targets the signed-in agent rather than a path id.
     */
    function uploadAvatar( event, rc, prc ){
        if ( !auth.isLoggedIn() ) {
            relocate( uri = "/agent/login" );
            return;
        }
        var agentId = auth.getUser().getId();
        if ( !structKeyExists( form, "profileImage" ) || !len( form.profileImage ?: "" ) ) {
            messagebox.error( "Pick a file before submitting." );
            relocate( uri = "/agent/account" );
            return;
        }
        try {
            var dest   = getTempDirectory() & "/avatar-upload-" & createUUID() & "/";
            directoryCreate( dest );
            var result = fileUpload(
                destination = dest,
                fileField   = "profileImage",
                accept      = "image/jpeg,image/png,image/gif,image/webp",
                nameConflict= "makeUnique"
            );
            var srcPath  = dest & result.serverFile;
            var contentType = result.contentType & "/" & result.contentSubType;

            var v = imageProcessing.validateUpload( srcPath, contentType );
            if ( !v.ok ) {
                messagebox.error( v.error );
                fileDelete( srcPath );
                directoryDelete( dest );
                relocate( uri = "/agent/account" );
                return;
            }

            var paths = imageProcessing.processProfileImage( agentId, srcPath, contentType );
            agentService.setProfileImage(
                agentId      : agentId,
                originalPath : paths.original,
                contentType  : contentType
            );
            fileDelete( srcPath );
            directoryDelete( dest );
            messagebox.info( "Avatar uploaded." );
        } catch ( any e ) {
            messagebox.error( "Avatar upload failed: " & e.message );
        }
        relocate( uri = "/agent/account" );
    }

    function clearAvatar( event, rc, prc ){
        if ( !auth.isLoggedIn() ) {
            relocate( uri = "/agent/login" );
            return;
        }
        var agentId = auth.getUser().getId();
        try {
            imageProcessing.deleteProfileImages( agentId );
            agentService.clearProfileImage( agentId : agentId, actorAgentId : agentId );
            messagebox.info( "Avatar cleared." );
        } catch ( any e ) {
            messagebox.error( "Could not clear avatar: " & e.message );
        }
        relocate( uri = "/agent/account" );
    }

    function confirmEmail( event, rc, prc ){
        param rc.token = "";
        if ( !len( rc.token ) ) {
            messagebox.error( "Verification token is missing." );
            relocate( uri = "/agent/account" );
            return;
        }
        var ok = agentService.confirmEmailChange( rc.token );
        if ( ok ) {
            messagebox.info( "Email updated. The new address is now on file." );
        } else {
            messagebox.error( "This verification link is invalid, expired, or already used." );
        }
        relocate( uri = "/agent/account" );
    }

}
