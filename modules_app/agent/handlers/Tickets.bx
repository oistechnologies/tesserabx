/**
 * agent:Tickets handler.
 *
 * Agent-facing ticket workspace. Lists tickets across all
 * organizations, opens a single ticket with its full timeline,
 * lets the agent reply (public or internal), change status, assign
 * or reassign, and promote an accountless ticket's sender into a
 * Contact.
 *
 * All data access flows through TicketsService and ContactsService.
 * The handler never imports a ticket entity directly.
 */
class {

    property name="ticketsService"        inject="TicketsService@tickets";
    property name="approvalService"       inject="ApprovalService@tickets";
    property name="agentService"          inject="AgentService@agent";
    property name="customFieldsService"   inject="CustomFieldsService@tickets";
    property name="bulkActionsService"    inject="BulkActionsService@tickets";
    property name="agentFilterPrefs"      inject="AgentFilterPreferencesService@agent";
    property name="rbacService"           inject="RbacService@agent";
    property name="contactsService"       inject="ContactsService@contacts";
    property name="channelsService"       inject="ChannelsService@channels";
    property name="slaService"            inject="SlaService@sla";
    property name="aiCapability"          inject="AiCapability@ai";
    property name="suggestedReplyService" inject="SuggestedReplyService@ai";
    property name="summarizationService"  inject="SummarizationService@ai";
    property name="kbSuggestionService"   inject="KbSuggestionService@ai";
    property name="kbDraftService"        inject="KbDraftService@ai";
    property name="replyToneService"      inject="ReplyToneService@ai";
    property name="messagebox"            inject="messagebox@cbmessagebox";
    property name="auth"                  inject="AuthenticationService@cbauth";

    function preHandler( event, rc, prc, action, eventArguments ){
        event.setLayout( name = "Agent", module = "core" );
    }

    // ---------- list / show ----------

    function index( event, rc, prc ){
        // Detect "URL had a status param at all" BEFORE the param
        // statement defaults it to "". Combined with the hidden
        // statusFilterApplied sentinel on the filter form, this lets
        // the handler tell apart:
        //   - first visit / external link  -> apply resolved default
        //   - explicit clear via checkboxes -> respect empty (show all)
        //   - direct ?status=open deep-link -> respect explicit selection
        var statusInUrl  = event.valueExists( "status" );
        var sentinelSeen = event.valueExists( "statusFilterApplied" );

        param rc.status            = "";
        param rc.priority          = "";
        param rc.organizationId    = "";
        param rc.assignedToAgentId = "";
        param rc.accountlessOnly   = false;
        param rc.q                 = "";

        prc.pageTitle     = "Tickets";
        prc.statuses      = ticketsService.listStatuses();
        prc.priorities    = ticketsService.listPriorities();
        prc.organizations = contactsService.listOrganizations();
        prc.assignableAgents = rbacService.listAgentsWithRoles();
        prc.bulkActions   = bulkActionsService.listActions();

        // Apply the resolved default only on a clean entry to the
        // page (no status param, no sentinel). Once the user has
        // submitted the form even once, the sentinel is present and
        // an empty checkbox group means "show all".
        if ( !statusInUrl && !sentinelSeen && len( currentAgentId() ) ) {
            rc.status = arrayToList( agentFilterPrefs.resolveDefaultStatuses( currentAgentId() ), "," );
        }
        prc.statusArray = isArray( rc.status )
            ? rc.status
            : listToArray( rc.status ?: "", "," );

        prc.tickets       = ticketsService.listTickets(
            status            : prc.statusArray,
            priority          : rc.priority,
            organizationId    : rc.organizationId,
            assignedToAgentId : rc.assignedToAgentId,
            search            : rc.q,
            accountlessOnly   : ( rc.accountlessOnly == "true" || rc.accountlessOnly == "1" || rc.accountlessOnly == true ),
            limit             : 200
        );
        prc.orgNamesById = {};
        for ( var o in prc.organizations ) {
            prc.orgNamesById[ o.getId() ] = o.getName();
        }
        prc.slaByTicketId = {};
        for ( var tk in prc.tickets ) {
            prc.slaByTicketId[ tk.getId() ] = slaService.slaSummaryForTicket( tk );
        }
        // Avatar directory for the Assigned column.
        var assigneeIds = [];
        for ( var tk in prc.tickets ) {
            var aid = tk.getAssignedToAgentId() ?: "";
            if ( len( aid ) ) assigneeIds.append( aid );
        }
        prc.agentDirectory = agentService.directoryFor( assigneeIds );
        prc.filters = rc;
        event.setView( "tickets/index" );
    }

    function show( event, rc, prc ){
        var t = ticketsService.getTicket( rc.id ?: "" );
        if ( isNull( t ) ) {
            messagebox.warn( "That ticket does not exist." );
            relocate( uri = "/agent/tickets" );
            return;
        }
        loadShowContext( prc, t );
        event.setView( "tickets/show" );
    }

    /**
     * POST /agent/tickets/saveStatusDefault
     * Persist the currently submitted status filter as this agent's
     * personal default. An empty submission saves "show everything" as
     * the default (the row exists with an empty value); to fall back
     * to the global default instead, the agent uses resetStatusDefault.
     */
    function saveStatusDefault( event, rc, prc ){
        param rc.status = "";
        var agentId = currentAgentId();
        if ( !len( agentId ) ) {
            messagebox.error( "Sign in to save a filter default." );
            relocate( uri = "/agent/tickets" );
            return;
        }
        var sel = isArray( rc.status )
            ? rc.status
            : listToArray( rc.status ?: "", "," );
        agentFilterPrefs.saveStatusFilter( agentId, sel );
        messagebox.info( "Default status filter saved." );
        relocate( uri = "/agent/tickets" );
    }

    /**
     * POST /agent/tickets/resetStatusDefault
     * Drop the agent's saved status filter row so the resolver falls
     * back to the admin global, then to the open+paused category set.
     */
    function resetStatusDefault( event, rc, prc ){
        var agentId = currentAgentId();
        if ( !len( agentId ) ) {
            messagebox.error( "Sign in to reset a filter default." );
            relocate( uri = "/agent/tickets" );
            return;
        }
        agentFilterPrefs.clearStatusFilter( agentId );
        messagebox.info( "Reverted to the global default status filter." );
        relocate( uri = "/agent/tickets" );
    }

    function new( event, rc, prc ){
        prc.pageTitle     = "New ticket";
        prc.organizations = contactsService.listOrganizations();
        prc.statuses      = ticketsService.listStatuses();
        prc.priorities    = ticketsService.listPriorities();
        prc.types         = ticketsService.listTypes();
        prc.formData      = {
            subject              : rc.subject ?: "",
            organizationId       : rc.organizationId ?: "",
            requesterContactId   : rc.requesterContactId ?: "",
            originatingEmail     : rc.originatingEmail ?: "",
            priority             : rc.priority ?: "normal",
            ticketType           : rc.ticketType ?: "request"
        };
        prc.contactsForOrg = len( prc.formData.organizationId )
            ? contactsService.listContactsForOrganization( prc.formData.organizationId )
            : [];
        event.setView( "tickets/new" );
    }

    function create( event, rc, prc ){
        param rc.subject            = "";
        param rc.organizationId     = "";
        param rc.requesterContactId = "";
        param rc.originatingEmail   = "";
        param rc.priority           = "normal";
        param rc.ticketType         = "request";
        param rc.firstMessage       = "";

        if ( !len( trim( rc.subject ) ) ) {
            messagebox.error( "Subject is required." );
            return new( event, rc, prc );
        }

        var ticket = "";
        if ( len( rc.requesterContactId ) ) {
            ticket = ticketsService.createTicket( {
                requesterContactId : rc.requesterContactId,
                subject            : rc.subject,
                priority           : rc.priority,
                ticketType         : rc.ticketType,
                source             : "agent",
                actorType          : "agent",
                actorId            : currentAgentId()
            } );
        } else if ( len( rc.originatingEmail ) ) {
            ticket = ticketsService.createAccountlessTicket( {
                originatingEmail : rc.originatingEmail,
                subject          : rc.subject,
                priority         : rc.priority,
                ticketType       : rc.ticketType,
                source           : "agent",
                actorType        : "agent",
                actorId          : currentAgentId()
            } );
        } else {
            messagebox.error( "Pick a contact or supply an originating email." );
            return new( event, rc, prc );
        }

        if ( len( trim( rc.firstMessage ) ) ) {
            ticketsService.addMessage( {
                ticketId      : ticket.getId(),
                body          : rc.firstMessage,
                authorAgentId : currentAgentId(),
                isInternal    : false
            } );
        }

        messagebox.info( "Ticket created." );
        relocate( uri = "/agent/tickets/" & ticket.getId() );
    }

    // ---------- actions ----------

    function reply( event, rc, prc ){
        return postMessage( event, rc, prc, false, "Reply sent." );
    }

    /**
     * Draft a reply through the AI middleware and redirect back to
     * the ticket page with the suggestion in flash so the view can
     * prefill the public-reply textarea. A no-op (redirect with a
     * warning) when the AI capability is off, which keeps the
     * route safe even if someone hits it directly.
     */
    function suggestReply( event, rc, prc ){
        var t = ticketsService.getTicket( rc.id ?: "" );
        if ( isNull( t ) ) {
            messagebox.warn( "That ticket does not exist." );
            relocate( uri = "/agent/tickets" );
            return;
        }
        if ( !aiCapability.isFeatureEnabled( "suggested-reply" ) ) {
            messagebox.warn( "AI suggestions are not enabled." );
            relocate( uri = "/agent/tickets/" & t.getId() );
            return;
        }
        var result = suggestedReplyService.suggest(
            ticketId     : t.getId(),
            actorAgentId : currentAgentId()
        );
        if ( result.outcome == "ok" && len( result.reply ) ) {
            flash.put( "suggestedReply", result.reply );
            if ( len( result.notes ?: "" ) ) flash.put( "suggestedNotes", result.notes );
            messagebox.info( "Reply drafted." );
        } else if ( result.outcome == "error" ) {
            messagebox.error( "AI suggestion failed: " & result.error );
        } else {
            messagebox.warn( "AI suggestion not available (outcome: " & result.outcome & ")." );
        }
        relocate( uri = "/agent/tickets/" & t.getId() );
    }

    function internalNote( event, rc, prc ){
        return postMessage( event, rc, prc, true, "Internal note added." );
    }

    /**
     * Generate an AI thread summary and stash it in flash so the
     * ticket detail page can render it inside the Summary card. A
     * no-op when the AI capability is off so the route stays safe
     * even on direct hit.
     */
    function summarize( event, rc, prc ){
        var t = ticketsService.getTicket( rc.id ?: "" );
        if ( isNull( t ) ) {
            messagebox.warn( "That ticket does not exist." );
            relocate( uri = "/agent/tickets" );
            return;
        }
        if ( !aiCapability.isFeatureEnabled( "thread-summary" ) ) {
            messagebox.warn( "AI summaries are not enabled." );
            relocate( uri = "/agent/tickets/" & t.getId() );
            return;
        }
        var result = summarizationService.summarize( t.getId() );
        if ( result.outcome == "ok" && ( len( result.summary ) || result.keyPoints.len() ) ) {
            // SummarizationService already persisted onto the ticket;
            // the show action reads it from there.
            messagebox.info( "Summary generated." );
        } else if ( result.outcome == "error" ) {
            messagebox.error( "AI summary failed: " & result.error );
        } else {
            messagebox.warn( "AI summary not available (outcome: " & result.outcome & ")." );
        }
        relocate( uri = "/agent/tickets/" & t.getId() );
    }

    /**
     * Draft a knowledge-base article from this ticket. Creates the
     * article internal + unpublished per CLAUDE.md and the build
     * plan, then redirects to the KB admin edit page where the
     * agent can refine and publish. Warnings the model flagged
     * (customer names, ticket-specific identifiers) are stashed in
     * flash so the edit screen can surface them.
     */
    function draftKbArticle( event, rc, prc ){
        var t = ticketsService.getTicket( rc.id ?: "" );
        if ( isNull( t ) ) {
            messagebox.warn( "That ticket does not exist." );
            relocate( uri = "/agent/tickets" );
            return;
        }
        if ( !aiCapability.isFeatureEnabled( "kb-draft" ) ) {
            messagebox.warn( "AI KB drafting is not enabled." );
            relocate( uri = "/agent/tickets/" & t.getId() );
            return;
        }
        var result = kbDraftService.draftAndCreate(
            ticketId     : t.getId(),
            actorAgentId : currentAgentId()
        );
        if ( result.outcome == "ok" && len( result.articleId ) ) {
            if ( isArray( result.warnings ) && result.warnings.len() ) {
                flash.put( "kbDraftWarnings", result.warnings );
            }
            messagebox.info( "Draft article created. Review and publish when ready." );
            relocate( uri = "/agent/admin/kb/" & result.articleId );
            return;
        }
        if ( result.outcome == "error" ) messagebox.error( "AI draft failed: " & result.error );
        else                              messagebox.warn( "AI draft not available (outcome: " & result.outcome & ")." );
        relocate( uri = "/agent/tickets/" & t.getId() );
    }

    /**
     * Run the agent's in-progress reply through a tone / quality
     * check. The result lives in flash for the next page render so
     * the textarea is not blown away if the textarea is full.
     */
    function checkTone( event, rc, prc ){
        param rc.body = "";
        var t = ticketsService.getTicket( rc.id ?: "" );
        if ( isNull( t ) ) {
            messagebox.warn( "That ticket does not exist." );
            relocate( uri = "/agent/tickets" );
            return;
        }
        if ( !aiCapability.isFeatureEnabled( "reply-tone" ) ) {
            messagebox.warn( "AI tone check is not enabled." );
            relocate( uri = "/agent/tickets/" & t.getId() );
            return;
        }
        if ( !len( trim( rc.body ) ) ) {
            messagebox.warn( "Type the reply first, then check tone." );
            relocate( uri = "/agent/tickets/" & t.getId() );
            return;
        }
        var result = replyToneService.review(
            ticketId : t.getId(),
            draft    : rc.body
        );
        if ( result.outcome == "ok" ) {
            flash.put( "toneReview", {
                "score"       : result.score,
                "label"       : result.label,
                "suggestions" : result.suggestions,
                "draft"       : rc.body
            } );
            messagebox.info( "Tone reviewed." );
        } else if ( result.outcome == "error" ) {
            messagebox.error( "AI tone check failed: " & result.error );
        } else {
            messagebox.warn( "AI tone check not available (outcome: " & result.outcome & ")." );
        }
        relocate( uri = "/agent/tickets/" & t.getId() );
    }

    /**
     * POST /agent/tickets/:id/approval/decide
     * Decide the pending approval (Approve or Reject). The decider
     * must be the named approver; ApprovalService throws otherwise.
     */
    function decideApproval( event, rc, prc ){
        param rc.approvalId = "";
        param rc.decision   = "";
        param rc.comment    = "";
        var t = ticketsService.getTicket( rc.id ?: "" );
        if ( isNull( t ) ) {
            messagebox.warn( "That ticket does not exist." );
            relocate( uri = "/agent/tickets" );
            return;
        }
        if ( !len( rc.approvalId ) || ( rc.decision != "approve" && rc.decision != "reject" ) ) {
            messagebox.error( "Approval decision is missing or invalid." );
            relocate( uri = "/agent/tickets/" & t.getId() );
            return;
        }
        try {
            if ( rc.decision == "approve" ) {
                approvalService.approveTicket(
                    approvalId     : rc.approvalId,
                    deciderAgentId : currentAgentId(),
                    comment        : rc.comment
                );
                messagebox.info( "Approval granted." );
            } else {
                approvalService.rejectTicket(
                    approvalId     : rc.approvalId,
                    deciderAgentId : currentAgentId(),
                    comment        : rc.comment
                );
                messagebox.info( "Approval rejected." );
            }
        } catch ( any e ) {
            messagebox.error( e.message );
        }
        relocate( uri = "/agent/tickets/" & t.getId() );
    }

    function changeStatus( event, rc, prc ){
        param rc.status = "";
        var t = ticketsService.getTicket( rc.id ?: "" );
        if ( isNull( t ) ) {
            messagebox.warn( "That ticket does not exist." );
            relocate( uri = "/agent/tickets" );
            return;
        }
        try {
            ticketsService.changeStatus( {
                ticketId  : t.getId(),
                status    : rc.status,
                actorType : "agent",
                actorId   : currentAgentId()
            } );
            messagebox.info( "Ticket status updated to " & rc.status & "." );
        } catch ( any e ) {
            messagebox.error( e.message );
        }
        relocate( uri = "/agent/tickets/" & t.getId() );
    }

    function assign( event, rc, prc ){
        param rc.agentId = "";
        var t = ticketsService.getTicket( rc.id ?: "" );
        if ( isNull( t ) ) {
            messagebox.warn( "That ticket does not exist." );
            relocate( uri = "/agent/tickets" );
            return;
        }
        ticketsService.assignToAgent( {
            ticketId : t.getId(),
            agentId  : rc.agentId,
            actorId  : currentAgentId()
        } );
        messagebox.info( len( rc.agentId ) ? "Ticket assigned." : "Ticket unassigned." );
        relocate( uri = "/agent/tickets/" & t.getId() );
    }

    function bulk( event, rc, prc ){
        param rc.ticketIds = "";
        param rc.action    = "";
        var ids = listToArray( rc.ticketIds, "," );
        // Drop any empty entries that survive a stray comma.
        var cleanIds = [];
        for ( var id in ids ) {
            var t = trim( id );
            if ( len( t ) ) cleanIds.append( t );
        }
        if ( !cleanIds.len() ) {
            messagebox.error( "Select at least one ticket." );
            relocate( uri = "/agent/tickets" );
            return;
        }
        if ( !len( rc.action ) ) {
            messagebox.error( "Choose a bulk action." );
            relocate( uri = "/agent/tickets" );
            return;
        }

        // The bulk form's status dropdown is single-select; coerce
        // defensively in case multi-status checkbox values from the
        // filter form ever leak in here (they shouldn't — separate
        // <form> — but an array bind would break the params struct).
        var bulkStatus = isArray( rc.status ?: "" ) ? "" : ( rc.status ?: "" );
        var params = {
            assignedToAgentId : rc.assignedToAgentId ?: "",
            status            : bulkStatus,
            tag               : rc.tag ?: ""
        };
        try {
            bulkActionsService.enqueue(
                action       : rc.action,
                ticketIds    : cleanIds,
                params       : params,
                actorAgentId : currentAgentId()
            );
            messagebox.info( cleanIds.len() & " ticket(s) updated (" & rc.action & ")." );
        } catch ( any e ) {
            messagebox.error( "Bulk action failed: " & e.message );
        }
        relocate( uri = "/agent/tickets" );
    }

    function saveCustomFields( event, rc, prc ){
        var t = ticketsService.getTicket( rc.id ?: "" );
        if ( isNull( t ) ) {
            messagebox.warn( "That ticket does not exist." );
            relocate( uri = "/agent/tickets" );
            return;
        }
        // Build the {defId: value} struct from the form keys the
        // view emits as "cf_<definitionId>". Anything else in rc is
        // ignored, so other form posts cannot accidentally write
        // custom-field rows.
        var values = {};
        for ( var key in rc ) {
            if ( left( key, 3 ) == "cf_" ) {
                values[ mid( key, 4, len( key ) - 3 ) ] = rc[ key ];
            }
        }
        customFieldsService.setValuesFor(
            entityType   : "ticket",
            entityId     : t.getId(),
            values       : values,
            actorAgentId : currentAgentId()
        );
        messagebox.info( "Custom fields saved." );
        relocate( uri = "/agent/tickets/" & t.getId() );
    }

    function blockSender( event, rc, prc ){
        param rc.scope  = "email";
        param rc.reason = "";
        var t = ticketsService.getTicket( rc.id ?: "" );
        if ( isNull( t ) ) {
            messagebox.warn( "That ticket does not exist." );
            relocate( uri = "/agent/tickets" );
            return;
        }
        var sender = t.getOriginatingEmail() ?: "";
        if ( !len( sender ) ) {
            messagebox.error( "Ticket has no originating email to block." );
            relocate( uri = "/agent/tickets/" & t.getId() );
            return;
        }
        var agentId = currentAgentId();
        var blockedScope = "";
        try {
            if ( rc.scope == "domain" ) {
                var domain = listLast( sender, "@" );
                channelsService.blockDomain(
                    domain         : domain,
                    reason         : rc.reason,
                    addedByAgentId : agentId
                );
                blockedScope = "domain @" & domain;
                messagebox.info( "Blocked domain " & domain & "; ticket closed." );
            } else {
                channelsService.blockEmail(
                    email          : sender,
                    reason         : rc.reason,
                    addedByAgentId : agentId
                );
                blockedScope = "address " & sender;
                messagebox.info( "Blocked " & sender & "; ticket closed." );
            }
        } catch ( any e ) {
            messagebox.error( e.message );
            relocate( uri = "/agent/tickets/" & t.getId() );
            return;
        }

        // Drop a permanent internal note so the close action is
        // traceable on the ticket timeline itself, and slam the
        // ticket shut. Any current status can transition to "closed".
        var noteBody = "Sender " & blockedScope & " added to the inbound blacklist.";
        if ( len( trim( rc.reason ) ) ) {
            noteBody &= char( 10 ) & char( 10 ) & "Reason: " & trim( rc.reason );
        }
        noteBody &= char( 10 ) & "Ticket auto-closed.";
        ticketsService.addMessage( {
            ticketId      : t.getId(),
            body          : noteBody,
            authorAgentId : agentId,
            isInternal    : true
        } );

        if ( t.getStatus() != "closed" ) {
            ticketsService.changeStatus( {
                ticketId  : t.getId(),
                status    : "closed",
                actorType : "agent",
                actorId   : agentId
            } );
        }

        // The agent has dispatched this ticket; send them back to the
        // list instead of the now-closed show page so they can keep
        // working the queue.
        relocate( uri = "/agent/tickets" );
    }

    function promoteSender( event, rc, prc ){
        param rc.organizationId = "";
        param rc.firstName      = "";
        param rc.lastName       = "";
        param rc.password       = "";
        var t = ticketsService.getTicket( rc.id ?: "" );
        if ( isNull( t ) ) {
            messagebox.warn( "That ticket does not exist." );
            relocate( uri = "/agent/tickets" );
            return;
        }
        if ( !len( rc.organizationId ) ) {
            messagebox.error( "Pick an organization for the new contact." );
            relocate( uri = "/agent/tickets/" & t.getId() );
            return;
        }
        if ( !len( rc.password ) || len( rc.password ) < 8 ) {
            messagebox.error( "Password must be at least 8 characters." );
            relocate( uri = "/agent/tickets/" & t.getId() );
            return;
        }
        try {
            ticketsService.promoteSenderToContact( {
                ticketId       : t.getId(),
                organizationId : rc.organizationId,
                firstName      : rc.firstName,
                lastName       : rc.lastName,
                password       : rc.password,
                actorId        : currentAgentId()
            } );
            messagebox.info( "Sender promoted to a contact; ticket assigned to the organization." );
        } catch ( any e ) {
            messagebox.error( e.message );
        }
        relocate( uri = "/agent/tickets/" & t.getId() );
    }

    // ---------- internals ----------

    private any function postMessage( event, rc, prc, required boolean isInternal, required string flash ){
        param rc.body = "";
        var t = ticketsService.getTicket( rc.id ?: "" );
        if ( isNull( t ) ) {
            messagebox.warn( "That ticket does not exist." );
            relocate( uri = "/agent/tickets" );
            return;
        }
        if ( !len( trim( rc.body ) ) ) {
            messagebox.error( "Message body is required." );
            relocate( uri = "/agent/tickets/" & t.getId() );
            return;
        }
        var m = ticketsService.addMessage( {
            ticketId      : t.getId(),
            body          : rc.body,
            authorAgentId : currentAgentId(),
            isInternal    : arguments.isInternal
        } );

        // Attach any files posted alongside the message so the inline
        // attachment list under this message renders them.
        var attResult = processUploadedAttachments( t.getId(), m.getId() );
        if ( attResult.ok > 0 && !arrayLen( attResult.failed ) ) {
            messagebox.info( arguments.flash & " Attached " & attResult.ok & " file(s)." );
        } else if ( attResult.ok > 0 ) {
            messagebox.warn( arguments.flash & " Attached " & attResult.ok & " file(s); rejected: " & arrayToList( attResult.failed, "; " ) );
        } else if ( arrayLen( attResult.failed ) ) {
            messagebox.warn( arguments.flash & " Attachments rejected: " & arrayToList( attResult.failed, "; " ) );
        } else {
            messagebox.info( arguments.flash );
        }
        relocate( uri = "/agent/tickets/" & t.getId() );
    }

    /**
     * Shared file-upload loop used by both inline (reply / internal-
     * note) and standalone (Attachments tab) upload paths. Pulls every
     * file field named "attachments" off the request, persists each
     * via TicketsService.addAttachment, and returns a small summary.
     * messageId is optional: when present, each attachment is tied to
     * the just-created message so per-message inline rendering picks
     * them up. When the form contains no file fields, returns zeros
     * (not an error).
     */
    private struct function processUploadedAttachments( required string ticketId, string messageId = "" ){
        var result = { "ok" : 0, "failed" : [] };
        if ( !structKeyExists( form, "attachments" ) || !len( form.attachments ?: "" ) ) {
            return result;
        }
        var destDir = getTempDirectory() & "/ticket-att-" & createUUID() & "/";
        directoryCreate( destDir );
        try {
            var results = fileUploadAll( destination = destDir, nameConflict = "makeUnique" );
            for ( var r in results ) {
                var srcPath = destDir & r.serverFile;
                var ctype   = r.contentType & "/" & r.contentSubType;
                try {
                    var data = {
                        ticketId         : arguments.ticketId,
                        originalFilename : r.clientFile,
                        contentType      : ctype,
                        sizeBytes        : r.fileSize,
                        sourcePath       : srcPath,
                        uploaderAgentId  : currentAgentId()
                    };
                    if ( len( arguments.messageId ) ) data.messageId = arguments.messageId;
                    ticketsService.addAttachment( data );
                    result.ok++;
                } catch ( any e ) {
                    result.failed.append( r.clientFile & " (" & e.message & ")" );
                }
                try { fileDelete( srcPath ); } catch ( any e ) {}
            }
        } catch ( any e ) {
            result.failed.append( "(upload error) " & e.message );
        }
        try { directoryDelete( destDir, true ); } catch ( any e ) {}
        return result;
    }

    private void function loadShowContext( required struct prc, required any ticket ){
        arguments.prc.ticket       = arguments.ticket;
        arguments.prc.pageTitle    = "Ticket ##" & arguments.ticket.getTicketNumber();
        arguments.prc.messages     = ticketsService.listMessagesForTicket( arguments.ticket.getId(), true );
        arguments.prc.events       = ticketsService.listEventsForTicket( arguments.ticket.getId() );
        // B8: latest approval row for the ticket (null when none).
        arguments.prc.ticketApproval = approvalService.getForTicket( arguments.ticket.getId() );
        // Panels need the viewer's identity to gate the
        // approver-only Approve/Reject buttons. tbxViewer() is the
        // canonical helper.
        arguments.prc.viewer = tbxViewer();

        // Avatar/name directory for every agent referenced on this
        // page (assignee + each message author + each event actor)
        // so the view layer can render names + thumbnails without a
        // per-row DB hit.
        var agentIds = [];
        var assignedId = arguments.ticket.getAssignedToAgentId() ?: "";
        if ( len( assignedId ) ) agentIds.append( assignedId );
        for ( var m in arguments.prc.messages ) {
            var aid = m.getAuthorAgentId() ?: "";
            if ( len( aid ) ) agentIds.append( aid );
        }
        for ( var ev in arguments.prc.events ) {
            if ( ( ev.getActorType() ?: "" ) == "agent" ) {
                var actorId = ev.getActorId() ?: "";
                if ( len( actorId ) ) agentIds.append( actorId );
            }
        }
        // B8: include the approval row's approver so the panel can
        // render the name + email instead of falling back to the
        // raw UUID.
        if ( !isNull( arguments.prc.ticketApproval ) ) {
            var approverId = arguments.prc.ticketApproval.getApproverAgentId() ?: "";
            if ( len( approverId ) ) agentIds.append( approverId );
        }
        arguments.prc.agentDirectory = agentService.directoryFor( agentIds );

        // Assignment-card dropdown options.
        arguments.prc.assignableAgents = rbacService.listAgentsWithRoles();
        // Attachments + per-message bucket so the view can render
        // inline links under each message in O(1).
        var viewer = { type : "agent", id : currentAgentId() };
        arguments.prc.attachments  = ticketsService.listAttachmentsForTicket( arguments.ticket.getId(), viewer );
        arguments.prc.attachmentsByMessageId = {};
        for ( var att in arguments.prc.attachments ) {
            var mid = att.getMessageId() ?: "";
            if ( !structKeyExists( arguments.prc.attachmentsByMessageId, mid ) ) {
                arguments.prc.attachmentsByMessageId[ mid ] = [];
            }
            arguments.prc.attachmentsByMessageId[ mid ].append( att );
        }
        arguments.prc.statuses     = ticketsService.listStatuses();
        arguments.prc.organization = isNull( arguments.ticket.getOrganizationId() ) || !len( arguments.ticket.getOrganizationId() ?: "" )
            ? javaCast( "null", "" )
            : contactsService.getOrganizationById( arguments.ticket.getOrganizationId() );
        arguments.prc.requester    = isNull( arguments.ticket.getRequesterContactId() ) || !len( arguments.ticket.getRequesterContactId() ?: "" )
            ? javaCast( "null", "" )
            : contactsService.getContactById( arguments.ticket.getRequesterContactId() );
        arguments.prc.organizations = contactsService.listOrganizations();

        // "Block sender" card visibility. Only relevant when the
        // ticket is still accountless (a Contact-backed ticket means
        // we already trust the sender's organization) and we have a
        // raw address to act on. When the sender is already on the
        // blacklist the view shows a notice instead of the form.
        var sender = arguments.ticket.getOriginatingEmail() ?: "";
        arguments.prc.canShowBlockCard = arguments.ticket.isAccountless() && len( sender );
        arguments.prc.isSenderBlocked  = len( sender )
            ? channelsService.isBlocked( sender )
            : false;

        arguments.prc.sla = slaService.slaSummaryForTicket( arguments.ticket );
        arguments.prc.slaPolicy = len( arguments.ticket.getSlaPolicyId() ?: "" )
            ? slaService.getPolicyById( arguments.ticket.getSlaPolicyId() )
            : javaCast( "null", "" );

        // AI affordances. When the capability is off, render nothing
        // anywhere; the view checks `prc.aiEnabled` before drawing
        // any AI control. Per CLAUDE.md: AI must be invisible when
        // disabled.
        arguments.prc.aiEnabled         = aiCapability.isFeatureEnabled( "suggested-reply" );
        // The suggestReply action stores the draft + any agent-only
        // notes in flash so they survive the post-redirect-get cycle.
        // Notes render in a callout above the textarea; the draft
        // prefills the textarea itself.
        arguments.prc.suggestedReply    = flash.get( "suggestedReply", "" );
        arguments.prc.suggestedNotes    = flash.get( "suggestedNotes", "" );

        // AI thread summary is persisted on the ticket; reads here
        // so refreshing the page shows the last generation without
        // re-running the model. Comes back null when never generated.
        var persistedSummary = ticketsService.getAiSummary( arguments.ticket.getId() );
        arguments.prc.aiSummary = !isNull( persistedSummary ) ? persistedSummary : {};

        arguments.prc.tags = ticketsService.listTagsForTicket( arguments.ticket.getId() );

        // Related KB articles. Always populated; the service routes
        // through semantic search when AI is on and falls back to
        // keyword search otherwise, so the card is useful in both
        // modes (per the build plan's "fully functional with AI off"
        // requirement).
        arguments.prc.relatedArticles = kbSuggestionService.suggestForTicket(
            ticketId : arguments.ticket.getId(),
            viewer   : { "kind" : "agent" },
            limit    : 5
        );

        // The KB-draft button only makes sense once the ticket has a
        // resolution to draft FROM; we surface it on resolved or
        // closed tickets.
        var status = arguments.ticket.getStatus() ?: "";
        arguments.prc.canDraftKbArticle = arguments.prc.aiEnabled
            && ( status == "resolved" || status == "closed" );

        // Tone-check results survive the post-redirect-get via flash.
        // The draft field carries the textarea contents back so the
        // agent does not lose what they typed when running a check.
        arguments.prc.toneReview = flash.get( "toneReview", {} );

        // Custom fields (active definitions + saved values folded
        // in). Empty when no definitions are configured, so the
        // ticket view simply does not render the card.
        arguments.prc.customFields = customFieldsService.getValuesFor(
            entityType : "ticket",
            entityId   : arguments.ticket.getId()
        );
    }

    private string function currentAgentId(){
        if ( !auth.isLoggedIn() ) return "";
        var user = auth.getUser();
        if ( isNull( user ) ) return "";
        return user.getId();
    }

    // ---------- Attachments: agent-side upload + delete ----------

    /**
     * Multi-file upload from the Attachments tab. Iterates the
     * posted files, calls TicketsService.addAttachment per file
     * (try/catch each so one bad file doesn't take down the batch),
     * flashes a summary, and redirects back to the ticket.
     */
    function uploadAttachments( event, rc, prc ){
        param rc.ticketId = "";
        if ( !len( rc.ticketId ) ) {
            messagebox.error( "Missing ticket id." );
            relocate( uri = "/agent/tickets" );
            return;
        }
        var ticket = ticketsService.getTicket( rc.ticketId );
        if ( isNull( ticket ) ) {
            messagebox.error( "Ticket not found." );
            relocate( uri = "/agent/tickets" );
            return;
        }
        if ( !structKeyExists( form, "attachments" ) || !len( form.attachments ?: "" ) ) {
            messagebox.warn( "Pick at least one file." );
            relocate( uri = "/agent/tickets/" & rc.ticketId );
            return;
        }
        var result = processUploadedAttachments( rc.ticketId );
        if ( result.ok > 0 && !arrayLen( result.failed ) ) {
            messagebox.info( "Uploaded " & result.ok & " file(s)." );
        } else if ( result.ok > 0 ) {
            messagebox.warn( "Uploaded " & result.ok & " file(s); rejected: " & arrayToList( result.failed, "; " ) );
        } else if ( arrayLen( result.failed ) ) {
            messagebox.error( "All uploads rejected: " & arrayToList( result.failed, "; " ) );
        }
        relocate( uri = "/agent/tickets/" & rc.ticketId );
    }

    /**
     * Soft-delete a single attachment with a required reason.
     * Verifies the URL's ticketId matches the attachment so a
     * forged URL can't act across tickets.
     */
    function deleteAttachment( event, rc, prc ){
        param rc.ticketId     = "";
        param rc.attachmentId = "";
        param rc.reason       = "";

        if ( !len( rc.attachmentId ) || !len( rc.ticketId ) ) {
            messagebox.error( "Missing attachment or ticket id." );
            relocate( uri = "/agent/tickets" );
            return;
        }
        var viewer = { type : "agent", id : currentAgentId() };
        try {
            var att = ticketsService.getAttachmentForViewer( rc.attachmentId, viewer );
            if ( att.getTicketId() != rc.ticketId ) {
                messagebox.error( "Attachment does not belong to that ticket." );
                relocate( uri = "/agent/tickets/" & rc.ticketId );
                return;
            }
            ticketsService.softDeleteAttachment(
                attachmentId : rc.attachmentId,
                agentId      : currentAgentId(),
                reason       : rc.reason
            );
            messagebox.info( "Attachment deleted." );
        } catch ( TicketsService.MissingDeletionReason e ) {
            messagebox.error( "A deletion reason is required." );
        } catch ( TicketsService.AttachmentNotFound e ) {
            messagebox.error( "Attachment not found." );
        } catch ( TicketsService.AttachmentAccessDenied e ) {
            messagebox.error( "You do not have access to this attachment." );
        } catch ( any e ) {
            messagebox.error( "Could not delete attachment: " & e.message );
        }
        relocate( uri = "/agent/tickets/" & rc.ticketId );
    }

}
