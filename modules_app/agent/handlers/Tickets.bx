/**
 * agent:Tickets handler.
 *
 * Agent-facing ticket workspace. Lists tickets across all
 * organizations, opens a single ticket with its full timeline,
 * lets the agent reply (public or internal), change status, assign
 * or reassign, and promote an accountless ticket's sender into a
 * Contact.
 *
 * All data access flows through TicketsService and ContactsService.
 * The handler never imports a ticket entity directly.
 */
class {

    property name="ticketsService"        inject="TicketsService@tickets";
    property name="contactsService"       inject="ContactsService@contacts";
    property name="channelsService"       inject="ChannelsService@channels";
    property name="slaService"            inject="SlaService@sla";
    property name="aiCapability"          inject="AiCapability@ai";
    property name="suggestedReplyService" inject="SuggestedReplyService@ai";
    property name="summarizationService"  inject="SummarizationService@ai";
    property name="kbSuggestionService"   inject="KbSuggestionService@ai";
    property name="messagebox"            inject="messagebox@cbmessagebox";
    property name="auth"                  inject="AuthenticationService@cbauth";

    function preHandler( event, rc, prc, action, eventArguments ){
        event.setLayout( name = "Agent", module = "core" );
    }

    // ---------- list / show ----------

    function index( event, rc, prc ){
        param rc.status            = "";
        param rc.priority          = "";
        param rc.organizationId    = "";
        param rc.assignedToAgentId = "";
        param rc.accountlessOnly   = false;
        param rc.q                 = "";

        prc.pageTitle     = "Tickets";
        prc.statuses      = ticketsService.listStatuses();
        prc.priorities    = ticketsService.listPriorities();
        prc.organizations = contactsService.listOrganizations();
        prc.tickets       = ticketsService.listTickets(
            status            : rc.status,
            priority          : rc.priority,
            organizationId    : rc.organizationId,
            assignedToAgentId : rc.assignedToAgentId,
            search            : rc.q,
            accountlessOnly   : ( rc.accountlessOnly == "true" || rc.accountlessOnly == "1" || rc.accountlessOnly == true ),
            limit             : 200
        );
        prc.orgNamesById = {};
        for ( var o in prc.organizations ) {
            prc.orgNamesById[ o.getId() ] = o.getName();
        }
        prc.slaByTicketId = {};
        for ( var tk in prc.tickets ) {
            prc.slaByTicketId[ tk.getId() ] = slaService.slaSummaryForTicket( tk );
        }
        prc.filters = rc;
        event.setView( "tickets/index" );
    }

    function show( event, rc, prc ){
        var t = ticketsService.getTicket( rc.id ?: "" );
        if ( isNull( t ) ) {
            messagebox.warn( "That ticket does not exist." );
            relocate( uri = "/agent/tickets" );
            return;
        }
        loadShowContext( prc, t );
        event.setView( "tickets/show" );
    }

    function new( event, rc, prc ){
        prc.pageTitle     = "New ticket";
        prc.organizations = contactsService.listOrganizations();
        prc.statuses      = ticketsService.listStatuses();
        prc.priorities    = ticketsService.listPriorities();
        prc.types         = ticketsService.listTypes();
        prc.formData      = {
            subject              : rc.subject ?: "",
            organizationId       : rc.organizationId ?: "",
            requesterContactId   : rc.requesterContactId ?: "",
            originatingEmail     : rc.originatingEmail ?: "",
            priority             : rc.priority ?: "normal",
            ticketType           : rc.ticketType ?: "request"
        };
        prc.contactsForOrg = len( prc.formData.organizationId )
            ? contactsService.listContactsForOrganization( prc.formData.organizationId )
            : [];
        event.setView( "tickets/new" );
    }

    function create( event, rc, prc ){
        param rc.subject            = "";
        param rc.organizationId     = "";
        param rc.requesterContactId = "";
        param rc.originatingEmail   = "";
        param rc.priority           = "normal";
        param rc.ticketType         = "request";
        param rc.firstMessage       = "";

        if ( !len( trim( rc.subject ) ) ) {
            messagebox.error( "Subject is required." );
            return new( event, rc, prc );
        }

        var ticket = "";
        if ( len( rc.requesterContactId ) ) {
            ticket = ticketsService.createTicket( {
                requesterContactId : rc.requesterContactId,
                subject            : rc.subject,
                priority           : rc.priority,
                ticketType         : rc.ticketType,
                source             : "agent",
                actorType          : "agent",
                actorId            : currentAgentId()
            } );
        } else if ( len( rc.originatingEmail ) ) {
            ticket = ticketsService.createAccountlessTicket( {
                originatingEmail : rc.originatingEmail,
                subject          : rc.subject,
                priority         : rc.priority,
                ticketType       : rc.ticketType,
                source           : "agent",
                actorType        : "agent",
                actorId          : currentAgentId()
            } );
        } else {
            messagebox.error( "Pick a contact or supply an originating email." );
            return new( event, rc, prc );
        }

        if ( len( trim( rc.firstMessage ) ) ) {
            ticketsService.addMessage( {
                ticketId      : ticket.getId(),
                body          : rc.firstMessage,
                authorAgentId : currentAgentId(),
                isInternal    : false
            } );
        }

        messagebox.info( "Ticket created." );
        relocate( uri = "/agent/tickets/" & ticket.getId() );
    }

    // ---------- actions ----------

    function reply( event, rc, prc ){
        return postMessage( event, rc, prc, false, "Reply sent." );
    }

    /**
     * Draft a reply through the AI middleware and redirect back to
     * the ticket page with the suggestion in flash so the view can
     * prefill the public-reply textarea. A no-op (redirect with a
     * warning) when the AI capability is off, which keeps the
     * route safe even if someone hits it directly.
     */
    function suggestReply( event, rc, prc ){
        var t = ticketsService.getTicket( rc.id ?: "" );
        if ( isNull( t ) ) {
            messagebox.warn( "That ticket does not exist." );
            relocate( uri = "/agent/tickets" );
            return;
        }
        if ( !aiCapability.isFeatureEnabled( "suggested-reply" ) ) {
            messagebox.warn( "AI suggestions are not enabled." );
            relocate( uri = "/agent/tickets/" & t.getId() );
            return;
        }
        var result = suggestedReplyService.suggest(
            ticketId     : t.getId(),
            actorAgentId : currentAgentId()
        );
        if ( result.outcome == "ok" && len( result.reply ) ) {
            flash.put( "suggestedReply", result.reply );
            if ( len( result.notes ?: "" ) ) flash.put( "suggestedNotes", result.notes );
            messagebox.info( "Reply drafted." );
        } else if ( result.outcome == "error" ) {
            messagebox.error( "AI suggestion failed: " & result.error );
        } else {
            messagebox.warn( "AI suggestion not available (outcome: " & result.outcome & ")." );
        }
        relocate( uri = "/agent/tickets/" & t.getId() );
    }

    function internalNote( event, rc, prc ){
        return postMessage( event, rc, prc, true, "Internal note added." );
    }

    /**
     * Generate an AI thread summary and stash it in flash so the
     * ticket detail page can render it inside the Summary card. A
     * no-op when the AI capability is off so the route stays safe
     * even on direct hit.
     */
    function summarize( event, rc, prc ){
        var t = ticketsService.getTicket( rc.id ?: "" );
        if ( isNull( t ) ) {
            messagebox.warn( "That ticket does not exist." );
            relocate( uri = "/agent/tickets" );
            return;
        }
        if ( !aiCapability.isFeatureEnabled( "thread-summary" ) ) {
            messagebox.warn( "AI summaries are not enabled." );
            relocate( uri = "/agent/tickets/" & t.getId() );
            return;
        }
        var result = summarizationService.summarize( t.getId() );
        if ( result.outcome == "ok" && ( len( result.summary ) || result.keyPoints.len() ) ) {
            // SummarizationService already persisted onto the ticket;
            // the show action reads it from there.
            messagebox.info( "Summary generated." );
        } else if ( result.outcome == "error" ) {
            messagebox.error( "AI summary failed: " & result.error );
        } else {
            messagebox.warn( "AI summary not available (outcome: " & result.outcome & ")." );
        }
        relocate( uri = "/agent/tickets/" & t.getId() );
    }

    function changeStatus( event, rc, prc ){
        param rc.status = "";
        var t = ticketsService.getTicket( rc.id ?: "" );
        if ( isNull( t ) ) {
            messagebox.warn( "That ticket does not exist." );
            relocate( uri = "/agent/tickets" );
            return;
        }
        try {
            ticketsService.changeStatus( {
                ticketId  : t.getId(),
                status    : rc.status,
                actorType : "agent",
                actorId   : currentAgentId()
            } );
            messagebox.info( "Ticket status updated to " & rc.status & "." );
        } catch ( any e ) {
            messagebox.error( e.message );
        }
        relocate( uri = "/agent/tickets/" & t.getId() );
    }

    function assign( event, rc, prc ){
        param rc.agentId = "";
        var t = ticketsService.getTicket( rc.id ?: "" );
        if ( isNull( t ) ) {
            messagebox.warn( "That ticket does not exist." );
            relocate( uri = "/agent/tickets" );
            return;
        }
        ticketsService.assignToAgent( {
            ticketId : t.getId(),
            agentId  : rc.agentId,
            actorId  : currentAgentId()
        } );
        messagebox.info( len( rc.agentId ) ? "Ticket assigned." : "Ticket unassigned." );
        relocate( uri = "/agent/tickets/" & t.getId() );
    }

    function blockSender( event, rc, prc ){
        param rc.scope  = "email";
        param rc.reason = "";
        var t = ticketsService.getTicket( rc.id ?: "" );
        if ( isNull( t ) ) {
            messagebox.warn( "That ticket does not exist." );
            relocate( uri = "/agent/tickets" );
            return;
        }
        var sender = t.getOriginatingEmail() ?: "";
        if ( !len( sender ) ) {
            messagebox.error( "Ticket has no originating email to block." );
            relocate( uri = "/agent/tickets/" & t.getId() );
            return;
        }
        var agentId = currentAgentId();
        var blockedScope = "";
        try {
            if ( rc.scope == "domain" ) {
                var domain = listLast( sender, "@" );
                channelsService.blockDomain(
                    domain         : domain,
                    reason         : rc.reason,
                    addedByAgentId : agentId
                );
                blockedScope = "domain @" & domain;
                messagebox.info( "Blocked domain " & domain & "; ticket closed." );
            } else {
                channelsService.blockEmail(
                    email          : sender,
                    reason         : rc.reason,
                    addedByAgentId : agentId
                );
                blockedScope = "address " & sender;
                messagebox.info( "Blocked " & sender & "; ticket closed." );
            }
        } catch ( any e ) {
            messagebox.error( e.message );
            relocate( uri = "/agent/tickets/" & t.getId() );
            return;
        }

        // Drop a permanent internal note so the close action is
        // traceable on the ticket timeline itself, and slam the
        // ticket shut. Any current status can transition to "closed".
        var noteBody = "Sender " & blockedScope & " added to the inbound blacklist.";
        if ( len( trim( rc.reason ) ) ) {
            noteBody &= char( 10 ) & char( 10 ) & "Reason: " & trim( rc.reason );
        }
        noteBody &= char( 10 ) & "Ticket auto-closed.";
        ticketsService.addMessage( {
            ticketId      : t.getId(),
            body          : noteBody,
            authorAgentId : agentId,
            isInternal    : true
        } );

        if ( t.getStatus() != "closed" ) {
            ticketsService.changeStatus( {
                ticketId  : t.getId(),
                status    : "closed",
                actorType : "agent",
                actorId   : agentId
            } );
        }

        // The agent has dispatched this ticket; send them back to the
        // list instead of the now-closed show page so they can keep
        // working the queue.
        relocate( uri = "/agent/tickets" );
    }

    function promoteSender( event, rc, prc ){
        param rc.organizationId = "";
        param rc.firstName      = "";
        param rc.lastName       = "";
        param rc.password       = "";
        var t = ticketsService.getTicket( rc.id ?: "" );
        if ( isNull( t ) ) {
            messagebox.warn( "That ticket does not exist." );
            relocate( uri = "/agent/tickets" );
            return;
        }
        if ( !len( rc.organizationId ) ) {
            messagebox.error( "Pick an organization for the new contact." );
            relocate( uri = "/agent/tickets/" & t.getId() );
            return;
        }
        if ( !len( rc.password ) || len( rc.password ) < 8 ) {
            messagebox.error( "Password must be at least 8 characters." );
            relocate( uri = "/agent/tickets/" & t.getId() );
            return;
        }
        try {
            ticketsService.promoteSenderToContact( {
                ticketId       : t.getId(),
                organizationId : rc.organizationId,
                firstName      : rc.firstName,
                lastName       : rc.lastName,
                password       : rc.password,
                actorId        : currentAgentId()
            } );
            messagebox.info( "Sender promoted to a contact; ticket assigned to the organization." );
        } catch ( any e ) {
            messagebox.error( e.message );
        }
        relocate( uri = "/agent/tickets/" & t.getId() );
    }

    // ---------- internals ----------

    private any function postMessage( event, rc, prc, required boolean isInternal, required string flash ){
        param rc.body = "";
        var t = ticketsService.getTicket( rc.id ?: "" );
        if ( isNull( t ) ) {
            messagebox.warn( "That ticket does not exist." );
            relocate( uri = "/agent/tickets" );
            return;
        }
        if ( !len( trim( rc.body ) ) ) {
            messagebox.error( "Message body is required." );
            relocate( uri = "/agent/tickets/" & t.getId() );
            return;
        }
        ticketsService.addMessage( {
            ticketId      : t.getId(),
            body          : rc.body,
            authorAgentId : currentAgentId(),
            isInternal    : arguments.isInternal
        } );
        messagebox.info( arguments.flash );
        relocate( uri = "/agent/tickets/" & t.getId() );
    }

    private void function loadShowContext( required struct prc, required any ticket ){
        arguments.prc.ticket       = arguments.ticket;
        arguments.prc.pageTitle    = "Ticket ##" & arguments.ticket.getTicketNumber();
        arguments.prc.messages     = ticketsService.listMessagesForTicket( arguments.ticket.getId(), true );
        arguments.prc.events       = ticketsService.listEventsForTicket( arguments.ticket.getId() );
        arguments.prc.attachments  = ticketsService.listAttachmentsForTicket( arguments.ticket.getId() );
        arguments.prc.statuses     = ticketsService.listStatuses();
        arguments.prc.organization = isNull( arguments.ticket.getOrganizationId() ) || !len( arguments.ticket.getOrganizationId() ?: "" )
            ? javaCast( "null", "" )
            : contactsService.getOrganizationById( arguments.ticket.getOrganizationId() );
        arguments.prc.requester    = isNull( arguments.ticket.getRequesterContactId() ) || !len( arguments.ticket.getRequesterContactId() ?: "" )
            ? javaCast( "null", "" )
            : contactsService.getContactById( arguments.ticket.getRequesterContactId() );
        arguments.prc.organizations = contactsService.listOrganizations();

        // "Block sender" card visibility. Only relevant when the
        // ticket is still accountless (a Contact-backed ticket means
        // we already trust the sender's organization) and we have a
        // raw address to act on. When the sender is already on the
        // blacklist the view shows a notice instead of the form.
        var sender = arguments.ticket.getOriginatingEmail() ?: "";
        arguments.prc.canShowBlockCard = arguments.ticket.isAccountless() && len( sender );
        arguments.prc.isSenderBlocked  = len( sender )
            ? channelsService.isBlocked( sender )
            : false;

        arguments.prc.sla = slaService.slaSummaryForTicket( arguments.ticket );
        arguments.prc.slaPolicy = len( arguments.ticket.getSlaPolicyId() ?: "" )
            ? slaService.getPolicyById( arguments.ticket.getSlaPolicyId() )
            : javaCast( "null", "" );

        // AI affordances. When the capability is off, render nothing
        // anywhere; the view checks `prc.aiEnabled` before drawing
        // any AI control. Per CLAUDE.md: AI must be invisible when
        // disabled.
        arguments.prc.aiEnabled         = aiCapability.isFeatureEnabled( "suggested-reply" );
        // The suggestReply action stores the draft + any agent-only
        // notes in flash so they survive the post-redirect-get cycle.
        // Notes render in a callout above the textarea; the draft
        // prefills the textarea itself.
        arguments.prc.suggestedReply    = flash.get( "suggestedReply", "" );
        arguments.prc.suggestedNotes    = flash.get( "suggestedNotes", "" );

        // AI thread summary is persisted on the ticket; reads here
        // so refreshing the page shows the last generation without
        // re-running the model. Comes back null when never generated.
        var persistedSummary = ticketsService.getAiSummary( arguments.ticket.getId() );
        arguments.prc.aiSummary = !isNull( persistedSummary ) ? persistedSummary : {};

        arguments.prc.tags = ticketsService.listTagsForTicket( arguments.ticket.getId() );

        // Related KB articles. Always populated; the service routes
        // through semantic search when AI is on and falls back to
        // keyword search otherwise, so the card is useful in both
        // modes (per the build plan's "fully functional with AI off"
        // requirement).
        arguments.prc.relatedArticles = kbSuggestionService.suggestForTicket(
            ticketId : arguments.ticket.getId(),
            viewer   : { "kind" : "agent" },
            limit    : 5
        );
    }

    private string function currentAgentId(){
        if ( !auth.isLoggedIn() ) return "";
        var user = auth.getUser();
        if ( isNull( user ) ) return "";
        return user.getId();
    }

}
