/**
 * Agent session handler: login, logout, and the unauthorized landing.
 *
 * The unauthorized action returns HTTP 403 for direct hits to
 * /agent/admin/* by non-admin agents. The route exists; access is
 * denied.
 */
class {

    property name="auth"         inject="AuthenticationService@cbauth";
    property name="agentAuth"    inject="AgentAuthService@agent";
    property name="agentService" inject="AgentService@agent";
    property name="messagebox"   inject="messagebox@cbmessagebox";

    function new( event, rc, prc ){
        prc.pageTitle = "Agent Sign in";
        event.setLayout( name = "Auth", module = "core" );
        event.setView( "session/new" );
    }

    function create( event, rc, prc ){
        param rc.email    = "";
        param rc.password = "";

        if ( !agentAuth.isValidCredentials( rc.email, rc.password ) ) {
            messagebox.error( "Invalid email or password." );
            relocate( uri = "/agent/login" );
            return;
        }

        var agent = agentAuth.retrieveUserByUsername( rc.email );
        if ( !!agent.getMfaEnabled() ) {
            // Password ok, MFA challenge required. The pending id
            // lives in session until the second-step verify clears
            // it; we DO NOT call auth.login until the code matches.
            session.tesserabx_pending_mfa_agent_id = agent.getId();
            relocate( uri = "/agent/login/verify" );
            return;
        }

        // Password ok, no MFA yet. cbauth login goes through so the
        // agent can reach /agent/mfa/setup; enforcement on the rest
        // of /agent kicks in once enrolled.
        auth.login( agent );
        relocate( uri = "/agent/mfa/setup" );
    }

    function delete( event, rc, prc ){
        auth.logout();
        relocate( uri = "/agent/login" );
    }

    /**
     * Public "forgot password" request page (/agent/forgot-password).
     * Whitelisted so a signed-out agent can reach it. POST always shows
     * the same neutral confirmation regardless of whether the address
     * has an account (no user enumeration).
     */
    function forgotPasswordForm( event, rc, prc ){
        prc.pageTitle = "Reset your password";
        event.setLayout( name = "Auth", module = "core" );
        event.setView( "session/forgot-password" );
    }

    function forgotPasswordSubmit( event, rc, prc ){
        param rc.email = "";
        event.setLayout( name = "Auth", module = "core" );
        agentService.requestPasswordReset( rc.email );
        messagebox.info( "If an account exists for that email, we have sent a link to reset the password." );
        relocate( uri = "/agent/login" );
    }

    /**
     * Public reset-password page (/agent/reset-password?token=...).
     * Whitelisted; consumes the token and sets a new password. MFA is
     * untouched, so the next sign-in still challenges for the code.
     */
    function resetPasswordForm( event, rc, prc ){
        param rc.token = "";
        prc.pageTitle = "Reset your password";
        event.setLayout( name = "Auth", module = "core" );
        prc.token = trim( rc.token );
        event.setView( "session/reset-password" );
    }

    function resetPasswordSubmit( event, rc, prc ){
        param rc.token              = "";
        param rc.newPassword        = "";
        param rc.newPasswordConfirm = "";
        event.setLayout( name = "Auth", module = "core" );

        if ( rc.newPassword != rc.newPasswordConfirm ) {
            messagebox.error( "The passwords do not match." );
            relocate( uri = "/agent/reset-password?token=" & urlEncodedFormat( rc.token ) );
            return;
        }
        var result = agentService.confirmPasswordReset( trim( rc.token ), rc.newPassword );
        if ( result.ok ) {
            messagebox.info( "Your password has been reset. You can now sign in." );
            relocate( uri = "/agent/login" );
            return;
        }
        messagebox.error( result.error );
        relocate( uri = "/agent/reset-password?token=" & urlEncodedFormat( rc.token ) );
    }

    function unauthorized( event, rc, prc ){
        event.setLayout( name = "Agent", module = "core" );
        event.setHTTPHeader( statusCode = 403, statusText = "Forbidden" );
        prc.pageTitle = "Access denied";
        event.setView( "session/unauthorized" );
    }

}
