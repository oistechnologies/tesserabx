class extends="coldbox.system.testing.BaseTestCase" appMapping="/" {

    function beforeAll(){
        super.beforeAll();
        super.setup();
    }

    function run(){
        describe( "agent module", function(){
            it( "is registered with ColdBox", function(){
                var modules = getController().getModuleService().getModuleRegistry();
                expect( modules ).toHaveKey( "agent" );
            } );

            it( "exposes its entry point", function(){
                var cache = getController().getModuleService().getModuleConfigCache();
                expect( cache ).toHaveKey( "agent" );
                expect( cache[ "agent" ].entryPoint ).notToBeEmpty();
            } );

            it( "resolves AgentService@agent", function(){
                var svc = getController().getWireBox().getInstance( "AgentService@agent" );
                expect( svc ).notToBeNull();
            } );
        } );
    }

}
