/**
 * Agent: a provider-side technician account.
 *
 * NOT tenant-scoped. Agents see across organizations, subject to RBAC.
 *
 * Phase 0 ships the minimum to authenticate. Phase 1 adds teams,
 * agent-local entities (saved filters). Phase 6 adds MFA columns
 * and makes MFA mandatory for this account family.
 */
class
    extends="quick.models.BaseEntity"
    table="agents"
    accessors="true"
{

    property name="id";
    property name="email";
    property name="passwordHash"      column="password_hash";
    property name="firstName"         column="first_name";
    property name="lastName"          column="last_name";
    property name="isActive"          column="is_active";
    property name="isAdmin"           column="is_admin";
    property name="lastLoginAt"       column="last_login_at";
    property name="mfaSecret"         column="mfa_secret";
    property name="mfaEnabled"        column="mfa_enabled";
    property name="mfaEnrolledAt"     column="mfa_enrolled_at";
    property name="mfaRecoveryCodes"  column="mfa_recovery_codes";
    property name="createdAt"         column="created_at";
    property name="updatedAt"         column="updated_at";

    // No global scopes. Agents see across organizations.

    public string function getUsername(){ return getEmail(); }
    public string function getPassword(){ return getPasswordHash(); }
    public string function retrieveUserId(){ return getId(); }
    public string function retrieveUsername(){ return getEmail(); }
    public boolean function isLoaded(){
        var theId = getId();
        return !isNull( theId ) && len( theId );
    }
    public string function surface(){ return "agent"; }
    public boolean function isContact(){ return false; }
    public boolean function isAgent(){ return true; }

    // ---- cbsecurity role / permission interface ----

    /**
     * Roles for cbsecurity firewall rule matching. Every Agent has
     * "agent". Additional role keys live in agent_roles, managed
     * through RbacService. The is_admin column is the legacy fallback
     * (used by seeders and a handful of older specs); if no
     * agent_roles row exists for the agent and is_admin is true,
     * the agent still gets "agent-admin" so /agent/admin remains
     * reachable during the RBAC backfill.
     */
    public array function getRoles(){
        var roles = [ "agent" ];
        var theId = getId();
        if ( !isNull( theId ) && len( theId ) ) {
            try {
                var rows = queryExecute(
                    "SELECT role_key FROM agent_roles WHERE agent_id = :aid",
                    { aid : theId }
                );
                for ( var i = 1; i <= rows.recordCount; i++ ) {
                    var key = rows.role_key[ i ];
                    if ( !arrayFindNoCase( roles, key ) ) roles.append( key );
                }
            } catch ( any e ) {
                // Schema not yet migrated (very early app boot, test
                // bootstrap, etc.); fall through to the is_admin
                // fallback so the firewall does not lock us out.
            }
        }
        if ( getIsAdmin() && !arrayFindNoCase( roles, "agent-admin" ) ) {
            roles.append( "agent-admin" );
        }
        return roles;
    }

    public array function getPermissions(){
        return [];
    }

    /**
     * cbsecurity calls hasRole(name) and hasPermission(name) at
     * rule-match time.
     */
    public boolean function hasRole( required any role ){
        var requested = isArray( arguments.role ) ? arguments.role : listToArray( arguments.role );
        var owned = getRoles();
        for ( var r in requested ) {
            if ( arrayFindNoCase( owned, trim( r ) ) ) return true;
        }
        return false;
    }

    public boolean function hasPermission( required any permission ){
        return false;
    }

    // ---- cbsecurity JWT interface ----
    //
    // JwtService.fromUser calls these on the user it is minting a
    // token for. `getJwtScopes()` populates the `scope` claim;
    // `getJwtCustomClaims( payload )` returns any extra claims we
    // want carried on the token (e.g. account family).

    public array function getJwtScopes(){
        return getRoles();
    }

    public struct function getJwtCustomClaims( required struct payload ){
        return {
            "account_type" : "agent",
            "email"        : getEmail() ?: ""
        };
    }

}
