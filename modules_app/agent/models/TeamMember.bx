/**
 * TeamMember: one agent's membership of one team.
 */
class
    extends="quick.models.BaseEntity"
    table="team_members"
    accessors="true"
{

    property name="id";
    property name="teamId"      column="team_id";
    property name="agentId"     column="agent_id";
    property name="roleInTeam"  column="role_in_team";
    property name="joinedAt"    column="joined_at";

}
