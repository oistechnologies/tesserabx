/**
 * admin module router.
 *
 * Nested inside agent. With entryPoint = "admin" and the module
 * physically at modules_app/agent/modules/admin/, ColdBox mounts the
 * routes at /agent/admin.
 */
class {

    function configure(){
        // /agent/admin landing
        route( "/" ).to( "Home.index" );

        // Audit log search UI.
        route( "audit" ).to( "Audit.index" );

        // Channel blacklist management.
        route( "blacklist/:id/toggle" ).withVerbs( "POST" ).to( "Blacklist.toggle" );
        route( "blacklist/:id/remove" ).withVerbs( "POST" ).to( "Blacklist.remove" );
        route( "blacklist" ).withHandler( "Blacklist" ).toAction( {
            "GET"  : "index",
            "POST" : "create"
        } );

        // Knowledge base authoring (CRUD over Article).
        // Most-specific routes first so /kb/reindex-embeddings does
        // not get swallowed by /kb/:id when the handler dispatcher
        // matches.
        route( "kb/reindex-embeddings" ).withVerbs( "POST" ).to( "Kb.reindexEmbeddings" );
        route( "kb/new" ).withHandler( "Kb" ).toAction( {
            "GET"  : "new",
            "POST" : "create"
        } );
        route( "kb/:id/publish" ).withVerbs( "POST" ).to( "Kb.publish" );
        route( "kb/:id/unpublish" ).withVerbs( "POST" ).to( "Kb.unpublish" );
        route( "kb/:id/delete" ).withVerbs( "POST" ).to( "Kb.remove" );
        route( "kb/:id" ).withHandler( "Kb" ).toAction( {
            "GET"  : "edit",
            "POST" : "update"
        } );
        route( "kb" ).to( "Kb.index" );
    }

}
