/**
 * admin module router.
 *
 * Nested inside agent. With entryPoint = "admin" and the module
 * physically at modules_app/agent/modules/admin/, ColdBox mounts the
 * routes at /agent/admin.
 */
class {

    function configure(){
        // /agent/admin landing
        route( "/" ).to( "Home.index" );

        // Audit log search UI.
        route( "audit" ).to( "Audit.index" );

        // Channel blacklist management.
        route( "blacklist/:id/toggle" ).withVerbs( "POST" ).to( "Blacklist.toggle" );
        route( "blacklist/:id/remove" ).withVerbs( "POST" ).to( "Blacklist.remove" );
        route( "blacklist" ).withHandler( "Blacklist" ).toAction( {
            "GET"  : "index",
            "POST" : "create"
        } );

        // Knowledge base authoring (CRUD over Article).
        // Most-specific routes first so /kb/reindex-embeddings does
        // not get swallowed by /kb/:id when the handler dispatcher
        // matches.
        route( "kb/reindex-embeddings" ).withVerbs( "POST" ).to( "Kb.reindexEmbeddings" );
        route( "kb/new" ).withHandler( "Kb" ).toAction( {
            "GET"  : "new",
            "POST" : "create"
        } );
        route( "kb/:id/publish" ).withVerbs( "POST" ).to( "Kb.publish" );
        route( "kb/:id/unpublish" ).withVerbs( "POST" ).to( "Kb.unpublish" );
        route( "kb/:id/delete" ).withVerbs( "POST" ).to( "Kb.remove" );
        route( "kb/:id" ).withHandler( "Kb" ).toAction( {
            "GET"  : "edit",
            "POST" : "update"
        } );
        route( "kb" ).to( "Kb.index" );

        // GDPR data subject requests.
        route( "gdpr/export" ).withVerbs( "GET" ).to( "Gdpr.exportData" );
        route( "gdpr/erase" ).withVerbs( "POST" ).to( "Gdpr.erase" );
        route( "gdpr" ).to( "Gdpr.index" );

        // Outbound webhook subscriptions.
        route( "webhooks/new" ).withHandler( "Webhooks" ).toAction( {
            "GET"  : "newForm",
            "POST" : "create"
        } );
        route( "webhooks/:id/activate" ).withVerbs( "POST" ).to( "Webhooks.activate" );
        route( "webhooks/:id/deactivate" ).withVerbs( "POST" ).to( "Webhooks.deactivate" );
        route( "webhooks/:id/delete" ).withVerbs( "POST" ).to( "Webhooks.remove" );
        route( "webhooks/:id" ).withHandler( "Webhooks" ).toAction( {
            "GET"  : "edit",
            "POST" : "update"
        } );
        route( "webhooks" ).to( "Webhooks.index" );

        // Ticket workflow (status catalog + transitions).
        route( "workflow/new" ).withHandler( "Workflow" ).toAction( {
            "GET"  : "newForm",
            "POST" : "create"
        } );
        route( "workflow/:id/activate" ).withVerbs( "POST" ).to( "Workflow.activate" );
        route( "workflow/:id/deactivate" ).withVerbs( "POST" ).to( "Workflow.deactivate" );
        route( "workflow/:id" ).withHandler( "Workflow" ).toAction( {
            "GET"  : "edit",
            "POST" : "update"
        } );
        route( "workflow" ).to( "Workflow.index" );

        // Ticket custom field definitions. Most-specific patterns
        // first so /custom-fields/new and /:id/activate do not
        // collide with /:id.
        route( "custom-fields/new" ).withHandler( "CustomFields" ).toAction( {
            "GET"  : "newForm",
            "POST" : "create"
        } );
        route( "custom-fields/:id/activate" ).withVerbs( "POST" ).to( "CustomFields.activate" );
        route( "custom-fields/:id/deactivate" ).withVerbs( "POST" ).to( "CustomFields.deactivate" );
        route( "custom-fields/:id" ).withHandler( "CustomFields" ).toAction( {
            "GET"  : "edit",
            "POST" : "update"
        } );
        route( "custom-fields" ).to( "CustomFields.index" );

        // Branding + email server settings. Most-specific writes
        // first so /settings/branding et al. do not get swallowed.
        route( "settings/branding" ).withVerbs( "POST" ).to( "Settings.saveBranding" );
        route( "settings/mail" ).withVerbs( "POST" ).to( "Settings.saveMail" );
        route( "settings/test-email" ).withVerbs( "POST" ).to( "Settings.testEmail" );
        route( "settings" ).to( "Settings.index" );

        // Provider-user RBAC. Most-specific writes first; the index
        // is the only GET on /users.
        route( "users/grant" ).withVerbs( "POST" ).to( "Users.grant" );
        route( "users/revoke" ).withVerbs( "POST" ).to( "Users.revoke" );
        route( "users/activate" ).withVerbs( "POST" ).to( "Users.activate" );
        route( "users/deactivate" ).withVerbs( "POST" ).to( "Users.deactivate" );
        route( "users/reset-mfa" ).withVerbs( "POST" ).to( "Users.resetMfa" );
        route( "users" ).to( "Users.index" );

        // Teams + membership. Most-specific patterns first so
        // /teams/new and /teams/:id/members do not collide with
        // /teams/:id.
        route( "teams/new" ).withHandler( "Teams" ).toAction( {
            "GET"  : "newForm",
            "POST" : "create"
        } );
        route( "teams/:id/members/remove" ).withVerbs( "POST" ).to( "Teams.removeMember" );
        route( "teams/:id/members" ).withVerbs( "POST" ).to( "Teams.addMember" );
        route( "teams/:id/activate" ).withVerbs( "POST" ).to( "Teams.activate" );
        route( "teams/:id/deactivate" ).withVerbs( "POST" ).to( "Teams.deactivate" );
        route( "teams/:id" ).withHandler( "Teams" ).toAction( {
            "GET"  : "edit",
            "POST" : "update"
        } );
        route( "teams" ).to( "Teams.index" );

        // Scheduled report exports. Most-specific routes first so
        // /exports/new and /exports/:id/* do not collide with /:id.
        route( "exports/new" ).withHandler( "Exports" ).toAction( {
            "GET"  : "new",
            "POST" : "save"
        } );
        route( "exports/:id/run" ).withVerbs( "POST" ).to( "Exports.runNow" );
        route( "exports/:id/delete" ).withVerbs( "POST" ).to( "Exports.remove" );
        route( "exports/:id/download" ).to( "Exports.download" );
        route( "exports/:id" ).withHandler( "Exports" ).toAction( {
            "GET"  : "edit",
            "POST" : "save"
        } );
        route( "exports" ).to( "Exports.index" );
    }

}
