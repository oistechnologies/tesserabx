/**
 * admin module: nested inside agent.
 *
 * Loads as part of agent's lifecycle and resolves to /agent/admin.
 * Module-level cbSecurity rules cover /agent/admin/*, gated to
 * admin-flagged agents.
 *
 * Owns the RBAC entities, branding, and configuration entities.
 */
class {

    this.title              = "admin";
    this.author             = "TesseraBX";
    this.webURL             = "https://github.com/oistechnologies/tesserabx";
    this.description        = "Administration and configuration surface, nested at /agent/admin.";
    this.version            = "0.0.1";
    this.viewParentLookup   = true;
    this.layoutParentLookup = true;
    // Mount the admin surface at /agent/admin. The module physically
    // lives inside agent's modules/ folder per the CLAUDE.md spec, but
    // ColdBox 8's nested-module inheritance of parent entryPoint is
    // not automatic, so we declare the full prefix here.
    this.entryPoint         = "agent/admin";
    this.modelNamespace     = "admin";
    this.cfmapping          = "tesserabx.modules.agent.modules.admin";
    this.autoMapModels      = false;
    this.dependencies       = [ "contacts", "audit", "tickets", "agent", "knowledgebase" ];

    function configure(){
        // `variables.` prefix is REQUIRED. See gotcha log in
        // docs/EXTENSIBILITY-PLAN.md.
        variables.settings = {
            tesserabx : {
                // /agent home dashboard widget. Admin-gated pulse of
                // the most recent org-wide audit events; partner to
                // the audit module's per-agent "My history" widget.
                dashboardWidgets : [
                    { id : "agent-home.system-pulse", title : "System pulse", partial : "widgets/agent_home_system_pulse", module : "admin", zone : "agent-home", defaultGridSize : "col-12 col-md-6 d-flex", sortWeight : 1150, requiredPermission : "admin.audit.view", dataProvider : "AuditService@audit", dataMethod : "recentSystemEvents" }
                ]
            }
        };

        variables.routes = [
            { pattern : "/",                handler : "Home", action : "index" },
            { pattern : "/:handler/:action?" }
        ];

        variables.interceptorSettings = { customInterceptionPoints : [] };
        variables.interceptors = [];
    }

    function onLoad(){
        binder.map( "AppSetting@admin" )
              .to( "#moduleMapping#.models.AppSetting" );
        binder.map( "SettingsService@admin" )
              .to( "#moduleMapping#.models.SettingsService" )
              .asSingleton();
        binder.map( "BrandingService@admin" )
              .to( "#moduleMapping#.models.BrandingService" )
              .asSingleton();
        binder.map( "AdminPagesRegistry@admin" )
              .to( "#moduleMapping#.models.AdminPagesRegistry" )
              .asSingleton();
    }
    function onUnload(){}

}
