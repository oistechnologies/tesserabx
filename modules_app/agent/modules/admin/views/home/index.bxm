<bx:output>
<div class="row g-3">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <h2 class="card-title">Administration</h2>
                <p class="card-text text-body-secondary">
                    RBAC, branding, custom fields, email server settings, the inbound blacklist, the audit log, and installed add-ons live here. Cards visible to you depend on the permissions your roles imply.
                </p>
                <div class="row g-3">
                    <bx:if !arrayLen( prc.adminCards )>
                        <div class="col-12 text-body-secondary">No admin pages available with your current permissions.</div>
                    </bx:if>
                    <bx:loop array="#prc.adminCards#" item="card">
                        <div class="col-12 col-md-6 col-lg-4">
                            <a href="#encodeForHTMLAttribute( card.route )#" class="d-block text-decoration-none">
                                <div class="card h-100 border-1">
                                    <div class="card-body">
                                        <h5 class="card-title mb-2">
                                            <i class="#encodeForHTMLAttribute( card.icon )#"></i>
                                            #encodeForHTML( card.title )#
                                        </h5>
                                        <p class="card-text small text-body-secondary mb-0">#encodeForHTML( card.description )#</p>
                                    </div>
                                </div>
                            </a>
                        </div>
                    </bx:loop>
                </div>
            </div>
        </div>
    </div>
</div>
</bx:output>
