<bx:output>
<div class="row">
    <div class="col-12 col-lg-6">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h1 class="h4 mb-0">Edit category</h1>
            <a class="btn btn-outline-secondary btn-sm" href="/agent/admin/kb/categories">
                <i class="bi bi-arrow-left me-1"></i> Back to categories
            </a>
        </div>

        <form method="post" action="/agent/admin/kb/categories/#encodeForHTMLAttribute( prc.category.getId() )#" class="card">
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label" for="name">Name <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" id="name" name="name" required value="#encodeForHTMLAttribute( prc.category.getName() )#">
                </div>
                <div class="mb-3">
                    <label class="form-label" for="slug">Slug</label>
                    <input type="text" class="form-control" id="slug" name="slug" value="#encodeForHTMLAttribute( prc.category.getSlug() )#">
                    <div class="form-text">Used in URLs. Leave blank to regenerate from the name.</div>
                </div>
                <div class="mb-3">
                    <label class="form-label" for="parentId">Parent</label>
                    <select class="form-select" id="parentId" name="parentId">
                        <option value="">No parent (top level)</option>
                        <bx:loop array="#prc.parents#" item="p">
                            <bx:if p.getId() neq prc.category.getId()>
                                <option value="#encodeForHTMLAttribute( p.getId() )#"<bx:if ( prc.category.getParentId() ?: "" ) eq p.getId()> selected</bx:if>>#encodeForHTML( p.getName() )#</option>
                            </bx:if>
                        </bx:loop>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label" for="sortOrder">Sort order</label>
                    <input type="number" class="form-control" id="sortOrder" name="sortOrder" value="#encodeForHTMLAttribute( prc.category.getSortOrder() ?: 0 )#">
                    <div class="form-text">Lower numbers sort first.</div>
                </div>
            </div>
            <div class="card-footer d-flex justify-content-between">
                <a class="btn btn-outline-secondary" href="/agent/admin/kb/categories">Cancel</a>
                <button class="btn btn-primary" type="submit">Save changes</button>
            </div>
        </form>
    </div>
</div>
</bx:output>
