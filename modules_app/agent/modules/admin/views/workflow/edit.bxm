<bx:output>
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="h5 mb-0">
        <bx:if prc.isNew>New status
        <bx:else>Edit: <span class="badge text-bg-#encodeForHTML( prc.status.badgeClass )#">#encodeForHTML( prc.status.label )#</span></bx:if>
    </h2>
    <a class="btn btn-outline-secondary btn-sm" href="/agent/admin/workflow"><i class="bi bi-arrow-left"></i> Back</a>
</div>

<form method="post" action="<bx:if prc.isNew>/agent/admin/workflow/new<bx:else>/agent/admin/workflow/#encodeForHTMLAttribute( prc.status.id )#</bx:if>" id="wfForm">
    <input type="hidden" id="toKeysInput" name="to_keys" value="">

    <div class="row g-3">
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header"><strong>Details</strong></div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label" for="label">Label</label>
                            <input type="text" id="label" name="label" class="form-control" required value="#encodeForHTMLAttribute( prc.status.label )#">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" for="key">Key</label>
                            <input type="text" id="key" name="key" class="form-control" required value="#encodeForHTMLAttribute( prc.status.key )#" <bx:if !prc.isNew>readonly</bx:if>>
                            <div class="form-text small">Lowercase letters, digits, hyphens, underscores. Cannot change after creation.</div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" for="category">Category</label>
                            <select id="category" name="category" class="form-select">
                                <bx:loop array="#prc.categories#" item="c">
                                    <option value="#encodeForHTMLAttribute( c.key )#"<bx:if prc.status.category eq c.key> selected</bx:if>>#encodeForHTML( c.label )#</option>
                                </bx:loop>
                            </select>
                            <div class="form-text small">
                                Drives SLA pause / breach behavior.
                            </div>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label" for="badgeClass">Badge color</label>
                            <select id="badgeClass" name="badgeClass" class="form-select">
                                <bx:loop array="#prc.badgeClasses#" item="bc">
                                    <option value="#encodeForHTMLAttribute( bc )#"<bx:if prc.status.badgeClass eq bc> selected</bx:if>>#encodeForHTML( bc )#</option>
                                </bx:loop>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label" for="sortOrder">Sort order</label>
                            <input type="number" id="sortOrder" name="sortOrder" class="form-control" value="#encodeForHTMLAttribute( prc.status.sortOrder )#">
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <bx:if !prc.isNew>
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-header"><strong>Allowed transitions from #encodeForHTML( prc.status.label )#</strong></div>
                    <div class="card-body">
                        <p class="text-body-secondary small mb-2">Tick every status this one can move to. Self is always permitted as a no-op.</p>
                        <div class="d-flex flex-wrap gap-2">
                            <bx:loop array="#prc.targets#" item="t">
                                <bx:if !t.isSelf>
                                    <label class="border rounded px-2 py-1">
                                        <input type="checkbox" class="form-check-input me-1 wf-target" value="#encodeForHTMLAttribute( t.key )#"<bx:if t.allowed> checked</bx:if>>
                                        #encodeForHTML( t.label )#
                                    </label>
                                </bx:if>
                            </bx:loop>
                        </div>
                    </div>
                </div>
            </div>
        </bx:if>
    </div>

    <div class="mt-3">
        <button class="btn btn-primary" type="submit">
            <bx:if prc.isNew>Create status<bx:else>Save changes</bx:if>
        </button>
    </div>
</form>

<bx:if !prc.isNew>
    <script>
        (function(){
            var form = document.getElementById('wfForm');
            if ( !form ) return;
            form.addEventListener('submit', function(){
                var keys = [];
                document.querySelectorAll('.wf-target').forEach(function(cb){
                    if ( cb.checked ) keys.push(cb.value);
                });
                document.getElementById('toKeysInput').value = keys.join(',');
            });
        })();
    </script>
</bx:if>
</bx:output>
