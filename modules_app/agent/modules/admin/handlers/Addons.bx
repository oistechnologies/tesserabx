/**
 * /agent/admin/addons handler.
 *
 * Single page listing every discovered add-on with controls to:
 *   - toggle the global enabled flag
 *   - switch enablement_mode between 'all' and 'specific'
 *   - manage per-organization enablement rows
 *
 * Gated to agents holding the admin.addons.manage permission (the
 * agent-admin role implies it by default).
 */
class {

    property name="addonRegistryService" inject="AddonRegistryService@core";
    property name="contactsService"      inject="ContactsService@contacts";

    function preHandler( event, rc, prc, action, eventArguments ){
        event.setLayout( name = "Agent", module = "core" );
    }

    function index( event, rc, prc ){
        prc.pageTitle     = "Add-ons";
        prc.addons        = addonRegistryService.listAll();
        prc.organizations = contactsService.listOrganizations();
        event.setView( "addons/index" );
    }

    /**
     * POST /agent/admin/addons/setGlobalEnabled
     *   rc.addonId : string
     *   rc.enabled : "true" | "false"
     */
    function setGlobalEnabled( event, rc, prc ){
        param rc.addonId = "";
        param rc.enabled = "false";
        if ( len( rc.addonId ) ) {
            addonRegistryService.setGlobalEnabled( rc.addonId, rc.enabled == "true" );
        }
        relocate( event = "admin:Addons.index" );
    }

    /**
     * POST /agent/admin/addons/setEnablementMode
     *   rc.addonId : string
     *   rc.mode    : "all" | "specific"
     */
    function setEnablementMode( event, rc, prc ){
        param rc.addonId = "";
        param rc.mode    = "all";
        if ( len( rc.addonId ) ) {
            addonRegistryService.setEnablementMode( rc.addonId, rc.mode );
        }
        relocate( event = "admin:Addons.index" );
    }

    /**
     * POST /agent/admin/addons/setOrgEnablement
     *   rc.addonId        : string
     *   rc.organizationId : string
     *   rc.enabled        : "true" | "false"
     */
    function setOrgEnablement( event, rc, prc ){
        param rc.addonId        = "";
        param rc.organizationId = "";
        param rc.enabled        = "false";
        if ( len( rc.addonId ) && len( rc.organizationId ) ) {
            var actor = "";
            try { actor = prc.oCurrentUser.getId(); } catch ( any e ) {}
            addonRegistryService.setOrgEnablement(
                addonId        : rc.addonId,
                organizationId : rc.organizationId,
                enabled        : rc.enabled == "true",
                actorAgentId   : actor
            );
        }
        relocate( event = "admin:Addons.index" );
    }

}
