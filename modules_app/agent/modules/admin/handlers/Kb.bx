/**
 * /agent/admin/kb handler.
 *
 * Authoring surface over knowledge-base articles. Delegates every
 * write to KnowledgebaseService; never reads Article / Category
 * entities directly.
 *
 * Admin-only via the cbSecurity rule on /agent/admin/*.
 */
class {

    property name="kb"              inject="KnowledgebaseService@knowledgebase";
    property name="contactsService" inject="ContactsService@contacts";
    property name="aiCapability"    inject="AiCapability@ai";
    property name="kbIndexer"       inject="KbIndexingService@ai";
    property name="messagebox"      inject="messagebox@cbmessagebox";
    property name="auth"            inject="AuthenticationService@cbauth";

    function preHandler( event, rc, prc, action, eventArguments ){
        event.setLayout( name = "Agent", module = "core" );
    }

    function index( event, rc, prc ){
        prc.pageTitle    = "Knowledge base";
        prc.articles     = kb.listVisibleArticles(
            viewer = { kind : "agent" }
        );
        prc.organizations = contactsService.listOrganizations();
        prc.aiEnabled     = aiCapability.isEnabled();
        prc.missingEmbeddingCount = prc.aiEnabled
            ? kb.listArticlesNeedingEmbedding( 1000 ).len()
            : 0;
        event.setView( "kb/index" );
    }

    /**
     * Backfill embeddings for every published article missing one.
     * Synchronous (each article is a single short embedding call),
     * and admin-gated like every other action under /agent/admin.
     * No-op when AI is off; the button on the index view hides
     * itself in that case.
     */
    function reindexEmbeddings( event, rc, prc ){
        if ( !aiCapability.isEnabled() ) {
            messagebox.warn( "AI is not enabled; nothing to reindex." );
            relocate( uri = "/agent/admin/kb" );
            return;
        }
        var result = kbIndexer.backfillMissing( 500 );
        var msg = "Reindex: " & result.indexed & " indexed";
        if ( result.failed > 0 )  msg &= ", " & result.failed & " failed";
        if ( len( result.skipped ) ) msg &= " (" & result.skipped & ")";
        messagebox.info( msg & "." );
        relocate( uri = "/agent/admin/kb" );
    }

    function new( event, rc, prc ){
        prc.pageTitle = "New article";
        prc.formData = {
            title           : rc.title      ?: "",
            slug            : rc.slug       ?: "",
            body            : rc.body       ?: "",
            visibility      : rc.visibility ?: "internal",
            categoryId      : rc.categoryId ?: "",
            organizationIds : []
        };
        prc.organizations = contactsService.listOrganizations();
        prc.categories    = kb.listCategories();
        event.setView( "kb/edit" );
    }

    function create( event, rc, prc ){
        var fields = readArticleFields( rc );
        if ( !len( trim( fields.title ) ) ) {
            messagebox.error( "Title is required." );
            return new( event, rc, prc );
        }
        var article = kb.createArticle( fields, currentAgentId() );
        if ( fields.visibility == "organization" ) {
            kb.setArticleOrganizations( article.getId(), fields.organizationIds );
        }
        messagebox.info( "Article saved as a draft." );
        relocate( uri = "/agent/admin/kb/" & article.getId() );
    }

    function edit( event, rc, prc ){
        var article = kb.getArticleById( rc.id ?: "" );
        if ( isNull( article ) ) {
            messagebox.warn( "That article does not exist." );
            relocate( uri = "/agent/admin/kb" );
            return;
        }
        prc.pageTitle = "Edit article";
        prc.article   = article;
        prc.formData = {
            title           : article.getTitle(),
            slug            : article.getSlug(),
            body            : article.getBody() ?: "",
            visibility      : article.getVisibility(),
            categoryId      : article.getCategoryId() ?: "",
            organizationIds : kb.listOrganizationIdsForArticle( article.getId() )
        };
        prc.organizations = contactsService.listOrganizations();
        prc.categories    = kb.listCategories();
        event.setView( "kb/edit" );
    }

    function update( event, rc, prc ){
        var article = kb.getArticleById( rc.id ?: "" );
        if ( isNull( article ) ) {
            messagebox.warn( "That article does not exist." );
            relocate( uri = "/agent/admin/kb" );
            return;
        }
        var fields = readArticleFields( rc );
        kb.updateArticle( article.getId(), fields );
        if ( fields.visibility == "organization" ) {
            kb.setArticleOrganizations( article.getId(), fields.organizationIds );
        } else {
            kb.setArticleOrganizations( article.getId(), [] );
        }
        messagebox.info( "Article updated." );
        relocate( uri = "/agent/admin/kb/" & article.getId() );
    }

    function publish( event, rc, prc ){
        param rc.changeNote = "";
        kb.publishArticle( arguments.rc.id ?: "", currentAgentId(), rc.changeNote );
        messagebox.info( "Article published." );
        relocate( uri = "/agent/admin/kb/" & rc.id );
    }

    function unpublish( event, rc, prc ){
        kb.unpublishArticle( rc.id ?: "", currentAgentId() );
        messagebox.info( "Article unpublished. It is back to a draft." );
        relocate( uri = "/agent/admin/kb/" & rc.id );
    }

    function remove( event, rc, prc ){
        kb.deleteArticle( rc.id ?: "", currentAgentId() );
        messagebox.info( "Article deleted." );
        relocate( uri = "/agent/admin/kb" );
    }

    // ---------- internals ----------

    private struct function readArticleFields( required struct rc ){
        param arguments.rc.title           = "";
        param arguments.rc.slug            = "";
        param arguments.rc.body            = "";
        param arguments.rc.visibility      = "internal";
        param arguments.rc.categoryId      = "";
        param arguments.rc.organizationIds = "";
        var orgIds = isArray( arguments.rc.organizationIds )
            ? arguments.rc.organizationIds
            : listToArray( arguments.rc.organizationIds, "," );
        return {
            title           : trim( arguments.rc.title ),
            slug            : trim( arguments.rc.slug ),
            body            : arguments.rc.body,
            visibility      : arguments.rc.visibility,
            categoryId      : trim( arguments.rc.categoryId ),
            organizationIds : orgIds
        };
    }

    private string function currentAgentId(){
        if ( !auth.isLoggedIn() ) return "";
        var u = auth.getUser();
        if ( isNull( u ) ) return "";
        return u.getId();
    }

}
