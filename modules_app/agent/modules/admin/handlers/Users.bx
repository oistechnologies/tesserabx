/**
 * /agent/admin/users handler.
 *
 * Thin shell around the CBWire components AgentsList and AgentForm.
 * All search, filter, sort, pagination, create, update, activate,
 * deactivate, and role grant/revoke now live in the wires.
 *
 * The legacy form-POST endpoints (grant, revoke, activate,
 * deactivate, resetMfa) are kept as direct-URL fallbacks for any
 * consumer that hits the routes directly (smoke scripts, bookmarks).
 * Wire actions are the primary path for new traffic.
 */
class {

    property name="rbacService"     inject="RbacService@agent";
    property name="agentService"    inject="AgentService@agent";
    property name="imageProcessing" inject="ImageProcessingService@core";
    property name="messagebox"      inject="messagebox@cbmessagebox";
    property name="auth"            inject="AuthenticationService@cbauth";

    function preHandler( event, rc, prc, action, eventArguments ){
        event.setLayout( name = "Agent", module = "core" );
    }

    function index( event, rc, prc ){
        prc.pageTitle = "Users";
        event.setView( "users/index" );
    }

    function newForm( event, rc, prc ){
        prc.pageTitle = "New agent";
        event.setView( "users/new" );
    }

    function edit( event, rc, prc ){
        param rc.id = "";
        prc.pageTitle = "Edit agent";
        prc.agentId   = rc.id;
        var agent     = agentService.getAgentById( rc.id );
        prc.hasAvatar      = !isNull( agent ) && len( agent.getProfileImageOriginalPath() ?: "" ) > 0;
        prc.uploadVersion  = prc.hasAvatar && !isNull( agent.getProfileImageUploadedAt() )
            ? agent.getProfileImageUploadedAt().getTime()
            : 0;
        event.setView( "users/edit" );
    }

    // ---------- Legacy POST endpoints (direct-URL fallbacks) ----------

    function grant( event, rc, prc ){
        param rc.agentId = "";
        param rc.roleKey = "";
        try {
            rbacService.grantRole(
                agentId      : rc.agentId,
                roleKey      : rc.roleKey,
                actorAgentId : currentAgentId()
            );
            messagebox.info( "Role granted." );
        } catch ( any e ) {
            messagebox.error( "Could not grant role: " & e.message );
        }
        relocate( uri = "/agent/admin/users" );
    }

    function revoke( event, rc, prc ){
        param rc.agentId = "";
        param rc.roleKey = "";
        if ( rc.roleKey == "agent-admin" && rc.agentId == currentAgentId() ) {
            messagebox.error( "You cannot revoke your own administrator role." );
            relocate( uri = "/agent/admin/users" );
            return;
        }
        try {
            rbacService.revokeRole(
                agentId      : rc.agentId,
                roleKey      : rc.roleKey,
                actorAgentId : currentAgentId()
            );
            messagebox.info( "Role revoked." );
        } catch ( any e ) {
            messagebox.error( "Could not revoke role: " & e.message );
        }
        relocate( uri = "/agent/admin/users" );
    }

    function activate( event, rc, prc ){
        param rc.agentId = "";
        rbacService.setAgentActive(
            agentId      : rc.agentId,
            active       : true,
            actorAgentId : currentAgentId()
        );
        messagebox.info( "User activated." );
        relocate( uri = "/agent/admin/users" );
    }

    function deactivate( event, rc, prc ){
        param rc.agentId = "";
        if ( rc.agentId == currentAgentId() ) {
            messagebox.error( "You cannot deactivate your own account." );
            relocate( uri = "/agent/admin/users" );
            return;
        }
        rbacService.setAgentActive(
            agentId      : rc.agentId,
            active       : false,
            actorAgentId : currentAgentId()
        );
        messagebox.info( "User deactivated." );
        relocate( uri = "/agent/admin/users" );
    }

    /**
     * Conventional multipart form POST for the profile-image upload.
     * Sits outside the AgentForm wire because cbwire's FileUpload
     * object isn't duplicate-able on BoxLang (its wire reference
     * transitively holds a non-clonable ScheduledThreadPoolExecutor).
     * After processing, redirects back to the edit page.
     */
    function uploadAvatar( event, rc, prc ){
        param rc.id = "";
        if ( !len( rc.id ) ) {
            messagebox.error( "Agent id is required." );
            relocate( uri = "/agent/admin/users" );
            return;
        }
        if ( !structKeyExists( form, "profileImage" ) || !len( form.profileImage ?: "" ) ) {
            messagebox.error( "Pick a file before submitting." );
            relocate( uri = "/agent/admin/users/" & rc.id & "/edit" );
            return;
        }
        try {
            var dest   = getTempDirectory() & "/avatar-upload-" & createUUID() & "/";
            directoryCreate( dest );
            var result = fileUpload(
                destination = dest,
                fileField   = "profileImage",
                accept      = "image/jpeg,image/png,image/gif,image/webp",
                nameConflict= "makeUnique"
            );
            var srcPath  = dest & result.serverFile;
            var contentType = result.contentType & "/" & result.contentSubType;

            var v = imageProcessing.validateUpload( srcPath, contentType );
            if ( !v.ok ) {
                messagebox.error( v.error );
                fileDelete( srcPath );
                directoryDelete( dest );
                relocate( uri = "/agent/admin/users/" & rc.id & "/edit" );
                return;
            }

            var paths = imageProcessing.processProfileImage( rc.id, srcPath, contentType );
            agentService.setProfileImage(
                agentId      : rc.id,
                originalPath : paths.original,
                contentType  : contentType
            );
            fileDelete( srcPath );
            directoryDelete( dest );
            messagebox.info( "Avatar uploaded." );
        } catch ( any e ) {
            messagebox.error( "Avatar upload failed: " & e.message );
        }
        relocate( uri = "/agent/admin/users/" & rc.id & "/edit" );
    }

    function clearAvatar( event, rc, prc ){
        param rc.id = "";
        if ( !len( rc.id ) ) {
            messagebox.error( "Agent id is required." );
            relocate( uri = "/agent/admin/users" );
            return;
        }
        try {
            imageProcessing.deleteProfileImages( rc.id );
            agentService.clearProfileImage(
                agentId      : rc.id,
                actorAgentId : currentAgentId()
            );
            messagebox.info( "Avatar cleared." );
        } catch ( any e ) {
            messagebox.error( "Could not clear avatar: " & e.message );
        }
        relocate( uri = "/agent/admin/users/" & rc.id & "/edit" );
    }

    function resetMfa( event, rc, prc ){
        param rc.agentId = "";
        if ( !len( rc.agentId ) ) {
            messagebox.error( "Agent id is required." );
            relocate( uri = "/agent/admin/users" );
            return;
        }
        queryExecute(
            "UPDATE agents
             SET    mfa_enabled         = FALSE,
                    mfa_secret          = NULL,
                    mfa_enrolled_at     = NULL,
                    mfa_recovery_codes  = NULL,
                    updated_at          = NOW()
             WHERE  id = :id",
            { id : rc.agentId }
        );
        messagebox.info( "MFA reset. The user will be prompted to enroll on next sign-in." );
        relocate( uri = "/agent/admin/users" );
    }

    // ---------- internals ----------

    private string function currentAgentId(){
        if ( !auth.isLoggedIn() ) return "";
        var u = auth.getUser();
        if ( isNull( u ) ) return "";
        return u.getId();
    }

}
