/**
 * /agent/admin/audit handler.
 *
 * Search and listing UI over the central audit log. Admin-only by
 * the cbSecurity rule on /agent/admin/*. Calls AuditService@audit;
 * never reads the AuditEvent entity directly.
 */
class {

    property name="auditService"    inject="AuditService@audit";
    property name="contactsService" inject="ContactsService@contacts";
    property name="agentService"    inject="AgentService@agent";

    function preHandler( event, rc, prc, action, eventArguments ){
        event.setLayout( name = "Agent", module = "core" );
    }

    function index( event, rc, prc ){
        param rc.eventType      = "";
        param rc.organizationId = "";
        param rc.entityId       = "";
        param rc.source         = "";
        param rc.limit          = 100;

        prc.pageTitle      = "Audit log";
        prc.events         = auditService.search(
            eventType      : rc.eventType,
            organizationId : rc.organizationId,
            entityId       : rc.entityId,
            source         : rc.source,
            limit          : int( rc.limit )
        );
        prc.eventTypes     = auditService.listEventTypes();
        prc.sources        = auditService.listSources();
        prc.organizations  = contactsService.listOrganizations();

        // Preload an agent directory keyed by id for every agent
        // actor in the result set, so the view can render avatars +
        // names without a per-row DB hit.
        var actorIds = [];
        for ( var ev in prc.events ) {
            if ( ( ev.getActorType() ?: "" ) == "agent" ) {
                var actorId = ev.getActorId() ?: "";
                if ( len( actorId ) ) actorIds.append( actorId );
            }
        }
        prc.agentDirectory = agentService.directoryFor( actorIds );
        prc.filters        = {
            eventType      : rc.eventType,
            organizationId : rc.organizationId,
            entityId       : rc.entityId,
            source         : rc.source,
            limit          : rc.limit
        };
        event.setView( "audit/index" );
    }

}
