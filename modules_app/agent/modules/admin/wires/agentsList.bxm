<bx:output>
<bx:script>
    // Inline UDF: header sort indicator (arrow + active state).
    public string function sortIndicator( current, dir, col ){
        if ( arguments.current != arguments.col ) {
            return "<i class='bi bi-arrow-down-up text-body-tertiary small'></i>";
        }
        return ( arguments.dir == "asc" )
            ? "<i class='bi bi-arrow-up text-primary small'></i>"
            : "<i class='bi bi-arrow-down text-primary small'></i>";
    }

    // Pulled once per render. Service does the heavy lifting; the
    // template just lays it out.
    local.result      = listResult();
    local.me          = currentAgentId();
    local.roles       = roleCatalog();
    local.teamsList   = teams();
    local.deptList    = departments();
    local.totalPages  = local.result.totalPages;
    local.startWindow = max( 1, local.result.page - 2 );
    local.endWindow   = min( local.totalPages, local.result.page + 2 );
    local.startRow    = local.result.total == 0 ? 0 : ( ( local.result.page - 1 ) * local.result.pageSize ) + 1;
    local.endRow      = min( local.result.total, local.result.page * local.result.pageSize );
</bx:script>

<div>
    <!-- Header + new-agent CTA -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">Provider users</h2>
        <a href="/agent/admin/users/new" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> New agent
        </a>
    </div>

    <bx:if len( notice )>
        <div class="alert alert-#encodeForHTMLAttribute( noticeKind )# d-flex justify-content-between align-items-center" role="alert">
            <span>#encodeForHTML( notice )#</span>
            <button type="button" class="btn-close" aria-label="Dismiss" wire:click="$set('notice','')"></button>
        </div>
    </bx:if>

    <!-- Filter toolbar -->
    <div class="card mb-3">
        <div class="card-body">
            <div class="row g-2">
                <div class="col-md-4">
                    <label class="form-label small text-body-secondary mb-1">Search</label>
                    <input
                        type="search"
                        class="form-control"
                        placeholder="email, name, or title"
                        wire:model.live.debounce.300ms="q">
                </div>
                <div class="col-md-2">
                    <label class="form-label small text-body-secondary mb-1">Status</label>
                    <select class="form-select" wire:model.live="status">
                        <option value="active">Active</option>
                        <option value="inactive">Deactivated</option>
                        <option value="any">All</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small text-body-secondary mb-1">Role</label>
                    <select class="form-select" wire:model.live="roleKey">
                        <option value="">Any role</option>
                        <bx:loop array="#local.roles#" item="local.r">
                            <option value="#encodeForHTMLAttribute( local.r.key )#">#encodeForHTML( local.r.label )#</option>
                        </bx:loop>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small text-body-secondary mb-1">Team</label>
                    <select class="form-select" wire:model.live="teamId">
                        <option value="">Any team</option>
                        <bx:loop array="#local.teamsList#" item="local.t">
                            <option value="#encodeForHTMLAttribute( local.t.id )#">#encodeForHTML( local.t.name )#</option>
                        </bx:loop>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small text-body-secondary mb-1">Department</label>
                    <select class="form-select" wire:model.live="department">
                        <option value="">Any department</option>
                        <bx:loop array="#local.deptList#" item="local.d">
                            <option value="#encodeForHTMLAttribute( local.d )#">#encodeForHTML( local.d )#</option>
                        </bx:loop>
                    </select>
                </div>
            </div>
        </div>
    </div>

    <!-- Bulk action bar (only when something is selected) -->
    <bx:if arrayLen( selectedIds )>
        <div class="alert alert-secondary d-flex justify-content-between align-items-center" role="status">
            <span><strong>#encodeForHTML( arrayLen( selectedIds ) )#</strong> agent(s) selected</span>
            <div class="btn-group btn-group-sm">
                <button type="button" class="btn btn-outline-success" wire:click="bulkActivate" wire:confirm="Activate the selected agents?">
                    <i class="bi bi-check-circle"></i> Activate
                </button>
                <button type="button" class="btn btn-outline-danger" wire:click="bulkDeactivate" wire:confirm="Deactivate the selected agents?">
                    <i class="bi bi-slash-circle"></i> Deactivate
                </button>
                <button type="button" class="btn btn-outline-secondary" wire:click="clearSelection">
                    Clear
                </button>
            </div>
        </div>
    </bx:if>

    <!-- Table -->
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width:2.5rem" class="text-center">
                            <input type="checkbox" class="form-check-input" wire:model.live="selectAllOnPage" title="Select all on this page">
                        </th>
                        <th role="button" wire:click="applySort('email')">
                            Email #sortIndicator( sort, dir, "email" )#
                        </th>
                        <th role="button" wire:click="applySort('last_name')">
                            Name #sortIndicator( sort, dir, "last_name" )#
                        </th>
                        <th role="button" wire:click="applySort('title')">
                            Title #sortIndicator( sort, dir, "title" )#
                        </th>
                        <th role="button" wire:click="applySort('department')">
                            Department #sortIndicator( sort, dir, "department" )#
                        </th>
                        <th>MFA</th>
                        <th role="button" wire:click="applySort('is_active')">
                            Status #sortIndicator( sort, dir, "is_active" )#
                        </th>
                        <th class="text-end" style="width:14rem">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <bx:if !arrayLen( local.result.rows )>
                        <tr>
                            <td colspan="8" class="text-center py-4 text-body-secondary">
                                No agents match the current filters.
                            </td>
                        </tr>
                    </bx:if>
                    <bx:loop array="#local.result.rows#" item="local.row">
                        <bx:set local.isMe = ( local.row.id == local.me ) >
                        <bx:set local.agentMini = {
                            id        : local.row.id,
                            firstName : local.row.firstName,
                            lastName  : local.row.lastName,
                            email     : local.row.email,
                            hasAvatar : len( local.row.profileImageOriginalPath ?: "" ) > 0,
                            uploadedAt: local.row.profileImageUploadedAt
                        } >
                        <tr class="#local.row.isActive ? '' : 'table-secondary'#">
                            <td class="text-center">
                                <bx:if !local.isMe>
                                    <input type="checkbox"
                                           class="form-check-input"
                                           value="#encodeForHTMLAttribute( local.row.id )#"
                                           wire:model.live="selectedIds">
                                </bx:if>
                            </td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    #view( view = "_partials/avatar", module = "core", args = { agent : local.agentMini, size : 32 } )#
                                    <div>
                                        <a href="/agent/admin/users/#encodeForHTMLAttribute( local.row.id )#/edit" class="text-decoration-none">
                                            #encodeForHTML( local.row.email )#
                                        </a>
                                        <bx:if local.isMe>
                                            <span class="badge text-bg-info ms-1">You</span>
                                        </bx:if>
                                    </div>
                                </div>
                            </td>
                            <td>
                                #encodeForHTML( trim( local.row.firstName & " " & local.row.lastName ) )#
                            </td>
                            <td>#encodeForHTML( local.row.title )#</td>
                            <td>#encodeForHTML( local.row.department )#</td>
                            <td>
                                <bx:if local.row.mfaEnabled>
                                    <span class="badge text-bg-success">Enrolled</span>
                                <bx:else>
                                    <span class="badge text-bg-light text-black">Not enrolled</span>
                                </bx:if>
                            </td>
                            <td>
                                <bx:if local.row.isActive>
                                    <span class="badge text-bg-success">Active</span>
                                <bx:else>
                                    <span class="badge text-bg-secondary">Deactivated</span>
                                </bx:if>
                            </td>
                            <td class="text-end">
                                <div class="btn-group btn-group-sm">
                                    <a href="/agent/admin/users/#encodeForHTMLAttribute( local.row.id )#/edit" class="btn btn-outline-secondary">
                                        <i class="bi bi-pencil"></i> Edit
                                    </a>
                                    <bx:if local.row.isActive>
                                        <bx:if !local.isMe>
                                            <button type="button"
                                                    class="btn btn-outline-danger"
                                                    wire:click="deactivate('#encodeForHTMLAttribute( local.row.id )#')"
                                                    wire:confirm="Deactivate this agent?">
                                                Deactivate
                                            </button>
                                        </bx:if>
                                    <bx:else>
                                        <button type="button"
                                                class="btn btn-outline-success"
                                                wire:click="activate('#encodeForHTMLAttribute( local.row.id )#')">
                                            Reactivate
                                        </button>
                                    </bx:if>
                                </div>
                            </td>
                        </tr>
                    </bx:loop>
                </tbody>
            </table>
        </div>

        <!-- Pagination footer -->
        <div class="card-footer d-flex flex-wrap align-items-center justify-content-between gap-2">
            <div class="d-flex align-items-center gap-2">
                <small class="text-body-secondary">
                    <bx:if local.result.total>
                        Showing #local.startRow#–#local.endRow# of #local.result.total#
                    <bx:else>
                        0 results
                    </bx:if>
                </small>
                <div class="d-flex align-items-center gap-1">
                    <label class="small text-body-secondary mb-0">Page size</label>
                    <select class="form-select form-select-sm" style="width:auto"
                            wire:change="setPageSize($event.target.value)">
                        <bx:loop array="#[ 10, 25, 50, 100 ]#" item="local.s">
                            <option value="#local.s#" #( local.s == pageSize ? 'selected' : '' )#>#local.s#</option>
                        </bx:loop>
                    </select>
                </div>
            </div>

            <bx:if local.totalPages gt 1>
                <nav>
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item #( local.result.page == 1 ? 'disabled' : '' )#">
                            <button type="button" class="page-link" wire:click="goToPage(#local.result.page - 1#)">
                                Prev
                            </button>
                        </li>
                        <bx:loop from="#local.startWindow#" to="#local.endWindow#" index="local.p">
                            <li class="page-item #( local.p == local.result.page ? 'active' : '' )#">
                                <button type="button" class="page-link" wire:click="goToPage(#local.p#)">#local.p#</button>
                            </li>
                        </bx:loop>
                        <li class="page-item #( local.result.page == local.totalPages ? 'disabled' : '' )#">
                            <button type="button" class="page-link" wire:click="goToPage(#local.result.page + 1#)">
                                Next
                            </button>
                        </li>
                    </ul>
                </nav>
            </bx:if>
        </div>
    </div>
</div>

</bx:output>
