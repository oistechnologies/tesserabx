/**
 * agent module router.
 *
 * All routes are auto-prefixed with /agent because of
 * `entryPoint = "agent"` in ModuleConfig.bx.
 *
 * Same-pattern routes must be declared once with `toAction({...})`
 * mapping each verb to its action. Calling `route(pattern).to(event)`
 * twice with the same pattern collapses into a single route whose
 * event ends up empty, which silently falls through to ColdBox's
 * default `:handler/:action` resolution.
 */
class {

    function configure(){
        // /agent landing + dashboard preference endpoints. The four
        // /home/* endpoints back the auto-refresh poll, drag-and-drop
        // reorder, hide/restore button, and reset-to-default action.
        // All four are POST-only (or GET for poll) and return JSON;
        // the client JS handles UI updates without a page navigation.
        route( "home/poll"                ).withVerbs( "GET"  ).to( "Home.poll" );
        route( "home/preferences/order"   ).withVerbs( "POST" ).to( "Home.saveOrder" );
        route( "home/preferences/hidden"  ).withVerbs( "POST" ).to( "Home.saveHidden" );
        route( "home/preferences/reset"   ).withVerbs( "POST" ).to( "Home.resetPreferences" );
        route( "/" ).to( "Home.index" );

        // Auth
        route( "login/verify" ).withHandler( "Mfa" ).toAction( {
            "GET"  : "verifyForm",
            "POST" : "verifySubmit"
        } );
        route( "login" ).withHandler( "Session" ).toAction( {
            "GET"  : "new",
            "POST" : "create"
        } );
        route( "logout" ).to( "Session.delete" );

        // MFA enrollment + recovery-codes display.
        route( "mfa/setup" ).withHandler( "Mfa" ).toAction( {
            "GET"  : "setupForm",
            "POST" : "setupSubmit"
        } );
        route( "mfa/recovery-codes" ).to( "Mfa.recoveryCodes" );

        // Unauthorized landing (the 403 page hit by non-admin agents
        // trying to reach /agent/admin/*).
        route( "unauthorized" ).to( "Session.unauthorized" );

        // (The former /agent/avatars/:id/:size handler was removed in
        // Phase 8.0. Avatars now serve directly from the public CBFS
        // disk at <CBFS_PUBLIC_BASE_URL>/agents/<id>/profile/<size>.jpg,
        // no app round-trip required.)

        // Ticket attachment downloads + thumbnails. Both pass through
        // TicketsService access checks (Phase 8.2 chokepoint). Routes
        // declared above the catchall so the two-segment patterns
        // win against /:handler/:action.
        route( "attachments/:id/thumbnail" ).withVerbs( "GET" ).to( "Attachments.thumbnail" );
        route( "attachments/:id" ).withVerbs( "GET" ).to( "Attachments.show" );

        // Multi-file upload + per-attachment soft-delete actions on
        // tickets. Both POST-only. The upload pattern is intentionally
        // nested under /tickets/:ticketId/attachments so the URL
        // mirrors the access path (handler also verifies the
        // attachment.ticketId matches before deleting).
        route( "tickets/:ticketId/attachments/:attachmentId/delete" ).withVerbs( "POST" ).to( "Tickets.deleteAttachment" );
        route( "tickets/:ticketId/attachments" ).withVerbs( "POST" ).to( "Tickets.uploadAttachments" );

        // My Account surface: self-service for any logged-in agent.
        // confirm-email consumes the verification token; most-specific
        // pattern first. Avatar upload + clear use plain multipart
        // POSTs (not cbwire) because the cbwire FileUpload object
        // can't survive BoxLang's snapshot duplicate().
        route( "account/confirm-email" ).to( "Account.confirmEmail" );
        route( "account/avatar/clear" ).withVerbs( "POST" ).to( "Account.clearAvatar" );
        route( "account/avatar" ).withVerbs( "POST" ).to( "Account.uploadAvatar" );
        route( "account" ).to( "Account.index" );

        // Contacts: agent-created provisioning. Most-specific patterns
        // first so /contacts/new and /contacts/:id/edit win over
        // /contacts/:id.
        route( "contacts/new" ).to( "Contacts.new" );
        route( "contacts/:id/edit" ).to( "Contacts.edit" );
        route( "contacts/:id" ).withHandler( "Contacts" ).toAction( {
            "GET"  : "show",
            "POST" : "update"
        } );
        route( "contacts" ).withHandler( "Contacts" ).toAction( {
            "GET"  : "index",
            "POST" : "create"
        } );

        // Tickets workspace. The action routes (reply, internal-note,
        // status, assign, promote) are all POST-only; the UI uses
        // small forms per action to keep handlers focused.
        route( "tickets/new" ).to( "Tickets.new" );
        route( "tickets/:id/reply" ).withVerbs( "POST" ).to( "Tickets.reply" );
        route( "tickets/:id/internal-note" ).withVerbs( "POST" ).to( "Tickets.internalNote" );
        route( "tickets/:id/status" ).withVerbs( "POST" ).to( "Tickets.changeStatus" );
        route( "tickets/:id/assign" ).withVerbs( "POST" ).to( "Tickets.assign" );
        route( "tickets/:id/promote-sender" ).withVerbs( "POST" ).to( "Tickets.promoteSender" );
        route( "tickets/:id/block-sender" ).withVerbs( "POST" ).to( "Tickets.blockSender" );
        route( "tickets/:id/approval/decide" ).withVerbs( "POST" ).to( "Tickets.decideApproval" );
        route( "tickets/:id/suggest-reply" ).withVerbs( "POST" ).to( "Tickets.suggestReply" );
        route( "tickets/:id/summarize" ).withVerbs( "POST" ).to( "Tickets.summarize" );
        route( "tickets/:id/draft-kb-article" ).withVerbs( "POST" ).to( "Tickets.draftKbArticle" );
        route( "tickets/:id/check-tone" ).withVerbs( "POST" ).to( "Tickets.checkTone" );
        route( "tickets/:id/custom-fields" ).withVerbs( "POST" ).to( "Tickets.saveCustomFields" );
        // Bulk actions: enqueues a cbq job so a multi-hundred ticket
        // run does not block the redirect-back-to-list response.
        route( "tickets/bulk" ).withVerbs( "POST" ).to( "Tickets.bulk" );
        // Per-agent filter defaults. Declared above /tickets/:id so the
        // literal segments win against the show pattern.
        route( "tickets/saveStatusDefault"  ).withVerbs( "POST" ).to( "Tickets.saveStatusDefault" );
        route( "tickets/resetStatusDefault" ).withVerbs( "POST" ).to( "Tickets.resetStatusDefault" );
        route( "tickets/:id" ).to( "Tickets.show" );
        route( "tickets" ).withHandler( "Tickets" ).toAction( {
            "GET"  : "index",
            "POST" : "create"
        } );

        // Reporting dashboard. The reporting module exposes the
        // service; the handler / view live here in agent so the
        // route is local and ColdBox doesn't try to cross modules.
        route( "reports/export/tickets.csv" ).to( "Reports.exportTickets" );
        route( "reports" ).to( "Reports.index" );

        // Notifications. Mark-read posts redirect to the
        // notification's stored link when present (the row carries
        // /agent/tickets/:id or similar) so the dropdown's click
        // flow is a single submit.
        route( "notifications/poll"          ).to( "Notifications.poll" );
        route( "notifications/mark-all-read" ).withVerbs( "POST" ).to( "Notifications.markAllRead" );
        route( "notifications/delete-all"    ).withVerbs( "POST" ).to( "Notifications.deleteAll" );
        route( "notifications/:id/read"      ).withVerbs( "POST" ).to( "Notifications.markRead" );
        route( "notifications"               ).to( "Notifications.index" );

        // Help (Phase 11) is served from a single /help URL space
        // for both surfaces. The help handlers pick the Agent layout
        // when tbxViewer().userType is 'agent' and the Portal layout
        // otherwise, so signed-in agents land on /help with their
        // dashboard chrome while anonymous portal visitors land on
        // the same URLs with the portal chrome. Routing the agent
        // surface separately (/agent/help) would require the
        // cross-module event syntax, which ColdBox parses
        // inconsistently when invoked from a module router.
    }

}
