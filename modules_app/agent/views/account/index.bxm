<bx:output>
<!-- Avatar card lives in the parent view (not the wire template)
     because cbwire's FileUpload object can't survive BoxLang's
     duplicate() during snapshot. Same pattern as the admin user
     edit page (modules_app/agent/modules/admin/views/users/edit.bxm). -->
<div class="card mb-3">
    <div class="card-header"><strong>Profile picture</strong></div>
    <div class="card-body d-flex flex-wrap align-items-center gap-4">
        <div>
            <bx:if prc.hasAvatar>
                <bx:set local.publicBaseUrl = getInstance( "coldbox:setting:cbfsPublicBaseUrl" ) >
                <img src="#encodeForHTMLAttribute( local.publicBaseUrl )#/agents/#encodeForHTMLAttribute( prc.agentId )#/profile/128.jpg?v=#encodeForHTMLAttribute( prc.uploadVersion )#"
                     width="128" height="128"
                     class="rounded-circle"
                     style="object-fit:cover"
                     alt="Current avatar">
            <bx:else>
                <div class="text-body-secondary fst-italic" style="width:128px; text-align:center;">
                    No picture uploaded yet.
                </div>
            </bx:if>
        </div>
        <div class="flex-grow-1" style="min-width:240px;">
            <form method="post"
                  action="/agent/account/avatar"
                  enctype="multipart/form-data"
                  class="mb-2">
                <label class="form-label small text-body-secondary">Upload a new picture</label>
                <div class="input-group input-group-sm">
                    <input type="file"
                           name="profileImage"
                           class="form-control"
                           accept="image/jpeg,image/png,image/gif,image/webp"
                           required>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-cloud-upload"></i> Upload
                    </button>
                </div>
                <div class="form-text small">JPG, PNG, GIF, or WebP. Cropped square; resized to 32/64/128/256 px.</div>
            </form>
            <bx:if prc.hasAvatar>
                <form method="post"
                      action="/agent/account/avatar/clear"
                      onsubmit="return confirm('Remove your profile picture?');">
                    <button type="submit" class="btn btn-sm btn-outline-danger">
                        <i class="bi bi-trash"></i> Clear picture
                    </button>
                </form>
            </bx:if>
        </div>
    </div>
</div>

#wire( name = "MyAccount@agent" )#
</bx:output>
