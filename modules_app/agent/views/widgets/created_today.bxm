<bx:output>
<bx:set local.tiles = prc.tiles >
<div class="card text-bg-info flex-fill">
    <div class="card-body d-flex justify-content-between align-items-center">
        <div>
            <div class="small opacity-75">Created today</div>
            <div class="display-6 fw-semibold">#encodeForHTML( local.tiles.createdToday )#</div>
        </div>
        <i class="bi bi-plus-circle fs-1 opacity-50"></i>
    </div>
</div>
</bx:output>
