<bx:output>
<bx:set local.tiles = prc.tiles >
<bx:set local.slaPct = local.tiles.slaCompliancePct ?: 0 >
<bx:set local.slaColor = local.tiles.slaTotal gt 0
                       ? ( local.slaPct gte 90 ? "success"
                       : ( local.slaPct gte 70 ? "warning"
                       :                          "danger" ) )
                       : "secondary" >
<div class="card text-bg-#local.slaColor# flex-fill">
    <div class="card-body d-flex justify-content-between align-items-center">
        <div>
            <div class="small opacity-75">SLA first-response compliance</div>
            <div class="display-6 fw-semibold">
                <bx:if local.tiles.slaTotal gt 0>
                    #encodeForHTML( local.tiles.slaCompliancePct )#<small class="fs-6 opacity-75">%</small>
                <bx:else>
                    -
                </bx:if>
            </div>
            <div class="small opacity-75">
                <bx:if local.tiles.slaTotal gt 0>
                    #encodeForHTML( local.tiles.slaMet )# of #encodeForHTML( local.tiles.slaTotal )# met (30d)
                <bx:else>
                    no SLA tickets in window
                </bx:if>
            </div>
        </div>
        <i class="bi bi-shield-check fs-1 opacity-50"></i>
    </div>
</div>
</bx:output>
