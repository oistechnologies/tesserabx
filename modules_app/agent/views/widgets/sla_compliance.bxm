<bx:output>
<bx:set local.tiles = prc.tiles >
<bx:set local.slaPct = local.tiles.slaCompliancePct ?: 0 >
<bx:set local.slaColor = local.tiles.slaTotal gt 0
                       ? ( local.slaPct gte 90 ? "success"
                       : ( local.slaPct gte 70 ? "warning"
                       :                          "danger" ) )
                       : "secondary" >
<bx:set local.metric = local.tiles.slaTotal gt 0
                     ? encodeForHTML( local.tiles.slaCompliancePct ) & '<small class="fs-5 opacity-75">%</small>'
                     : '<span class="opacity-50">-</span>' >
<bx:set local.caption = local.tiles.slaTotal gt 0
                      ? encodeForHTML( local.tiles.slaMet ) & " of " & encodeForHTML( local.tiles.slaTotal ) & " met (30d)"
                      : "no SLA tickets in window" >
#view( view = "_partials/small_box", module = "core", args = {
    color   : local.slaColor,
    metric  : local.metric,
    label   : "SLA first-response compliance",
    icon    : "bi bi-shield-check",
    caption : local.caption
} )#
</bx:output>
