<bx:output>
<bx:set local.tiles = prc.tiles >
<bx:set local.metric = local.tiles.avgFirstResponseMinutes gt 0
                     ? encodeForHTML( local.tiles.avgFirstResponseMinutes ) & '<small class="fs-5 opacity-75 ms-1">min</small>'
                     : '<span class="opacity-50">-</span>' >
#view( view = "_partials/small_box", module = "core", args = {
    color   : "warning",
    metric  : local.metric,
    label   : "Avg first response",
    icon    : "bi bi-stopwatch",
    caption : "last 30 days"
} )#
</bx:output>
