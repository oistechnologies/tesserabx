<bx:output>
<div class="d-flex justify-content-end mb-3">
    <a class="btn btn-outline-secondary btn-sm" href="/agent/reports/export/tickets.csv">
        <i class="bi bi-download"></i> Export tickets (CSV)
    </a>
</div>

<!--
    Follow-up B2: every dashboard widget is contributed through
    DashboardWidgetRegistry. The agent module's manifest registers
    the ten core widgets (tiles, charts, backlog table, agent load);
    add-ons contribute additional widgets via
    settings.tesserabx.dashboardWidgets. The registry sorts by
    sortWeight, applies the viewer's audience filter + requiresAi
    check, and wraps each widget in its declared defaultGridSize
    column. A widget that declares a dataProvider has its data
    pre-fetched into prc.widgetData; widgets that read prc.* directly
    leave dataProvider blank.
-->
<bx:set local.allWidgets = tbxDashboardWidgets() >
<bx:if arrayLen( local.allWidgets )>
    <div class="row g-3 align-items-stretch">
        <bx:loop array="#local.allWidgets#" item="local.w">
            <bx:if len( local.w.partial )>
                <bx:if len( local.w.dataProvider ?: "" ) && len( local.w.dataMethod ?: "" )>
                    <bx:set prc.widgetData = application.wirebox
                        .getInstance( "DashboardWidgetRegistry@reporting" )
                        .fetchWidgetData( local.w ) >
                </bx:if>
                <div class="#encodeForHTMLAttribute( local.w.defaultGridSize )#">
                    #view( view = local.w.partial, module = local.w.module )#
                </div>
            </bx:if>
        </bx:loop>
    </div>
</bx:if>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
(function(){
    var volumeData   = #jsonSerialize( prc.volume )#;
    var byStatus     = #jsonSerialize( prc.byStatus )#;
    var byPriority   = #jsonSerialize( prc.byPriority )#;
    var bySource     = #jsonSerialize( prc.bySource )#;

    function ctx( id ){
        var el = document.getElementById( id );
        return el ? el.getContext( '2d' ) : null;
    }

    var volC = ctx( 'chart-volume' );
    if ( volC ) {
        new Chart( volC, {
            type : 'line',
            data : {
                labels   : volumeData.map( function( d ){ return d.day; } ),
                datasets : [ {
                    label : 'Tickets',
                    data  : volumeData.map( function( d ){ return d.count; } ),
                    fill  : true,
                    tension : 0.25,
                    borderColor     : '##0d6efd',
                    backgroundColor : 'rgba(13,110,253,0.12)'
                } ]
            },
            options : { responsive : true, plugins : { legend : { display : false } }, scales : { y : { beginAtZero : true, ticks : { precision : 0 } } } }
        } );
    }

    function donut( id, rows ){
        var c = ctx( id );
        if ( !c ) return;
        new Chart( c, {
            type : 'doughnut',
            data : {
                labels   : rows.map( function( r ){ return r.label; } ),
                datasets : [ { data : rows.map( function( r ){ return r.count; } ) } ]
            },
            options : { responsive : true, plugins : { legend : { position : 'bottom' } } }
        } );
    }
    donut( 'chart-status',   byStatus );
    donut( 'chart-priority', byPriority );
    donut( 'chart-source',   bySource );
})();
</script>
</bx:output>
