<bx:output>
<bx:set local.brand = getInstance( "SettingsService@admin" ).getBranding() >
<div class="login-box">
    <div class="card card-outline card-primary">
        <div class="card-header text-center">
            <a href="/agent" class="link-body-emphasis text-decoration-none">
                <bx:if len( local.brand.logoUrl )>
                    <img src="#encodeForHTMLAttribute( local.brand.logoUrl )#"
                         alt="#encodeForHTMLAttribute( local.brand.productName )#"
                         class="mb-2"
                         style="max-height:48px">
                </bx:if>
                <h1 class="h4 mb-0 fw-semibold">#encodeForHTML( local.brand.productName )#</h1>
            </a>
            <div class="small text-body-secondary mt-1">Agent sign in</div>
        </div>
        <div class="card-body login-card-body">
            #view( view = "_partials/toast_flash", module = "core" )#
            <bx:if len( prc.token ?: "" )>
                <p class="login-box-msg">Choose a new password</p>
                <form method="post" action="/agent/reset-password">
                    <input type="hidden" name="token" value="#encodeForHTMLAttribute( prc.token )#">
                    <div class="input-group mb-3">
                        <div class="form-floating">
                            <input type="password" class="form-control" id="newPassword" name="newPassword" required autofocus autocomplete="new-password" placeholder="">
                            <label for="newPassword">New password</label>
                        </div>
                        <div class="input-group-text"><i class="bi bi-lock-fill"></i></div>
                    </div>
                    <div class="input-group mb-3">
                        <div class="form-floating">
                            <input type="password" class="form-control" id="newPasswordConfirm" name="newPasswordConfirm" required autocomplete="new-password" placeholder="">
                            <label for="newPasswordConfirm">Confirm password</label>
                        </div>
                        <div class="input-group-text"><i class="bi bi-lock-fill"></i></div>
                    </div>
                    <div class="form-text small mb-3">At least 8 characters.</div>
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-check-lg me-1"></i> Reset password
                    </button>
                </form>
            <bx:else>
                <div class="callout callout-warning">
                    <i class="bi bi-exclamation-triangle me-1"></i> This link is missing or invalid. Request a new one below.
                </div>
                <a href="/agent/forgot-password" class="btn btn-outline-secondary w-100">Request a new reset link</a>
            </bx:if>
        </div>
    </div>
</div>
</bx:output>
