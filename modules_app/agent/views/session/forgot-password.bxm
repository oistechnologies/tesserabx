<bx:output>
<bx:set local.brand = getInstance( "SettingsService@admin" ).getBranding() >
<div class="login-box">
    <div class="card card-outline card-primary">
        <div class="card-header text-center">
            <a href="/agent" class="link-body-emphasis text-decoration-none">
                <bx:if len( local.brand.logoUrl )>
                    <img src="#encodeForHTMLAttribute( local.brand.logoUrl )#"
                         alt="#encodeForHTMLAttribute( local.brand.productName )#"
                         class="mb-2"
                         style="max-height:48px">
                </bx:if>
                <h1 class="h4 mb-0 fw-semibold">#encodeForHTML( local.brand.productName )#</h1>
            </a>
            <div class="small text-body-secondary mt-1">Agent sign in</div>
        </div>
        <div class="card-body login-card-body">
            #view( view = "_partials/toast_flash", module = "core" )#
            <p class="login-box-msg">Enter your agent email and we will send you a link to reset your password.</p>
            <form method="post" action="/agent/forgot-password">
                <div class="input-group mb-3">
                    <div class="form-floating">
                        <input type="email" class="form-control" id="email" name="email" required autofocus autocomplete="username" placeholder="agent@example.com">
                        <label for="email">Email</label>
                    </div>
                    <div class="input-group-text"><i class="bi bi-envelope"></i></div>
                </div>
                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-send me-1"></i> Send reset link
                </button>
            </form>
            <div class="text-center mt-3">
                <a href="/agent/login" class="small text-decoration-none">Back to sign in</a>
            </div>
            <div class="form-text small text-center mt-2">
                Multi-factor authentication is not affected; you will still need your authenticator code to sign in.
            </div>
        </div>
    </div>
</div>
</bx:output>
