<bx:output>
<bx:set local.t = prc.ticket >
<bx:set local.summaryData = prc.aiSummary ?: {} >
<bx:set local.hasSummary = isStruct( local.summaryData ) && ( len( local.summaryData.summary ?: "" ) || arrayLen( local.summaryData.keyPoints ?: [] ) ) >
<bx:set local.cardBadges = local.hasSummary ? [ { label : "Ready", color : "info" } ] : [] >
<bx:savecontent variable="local.body">
    <bx:if local.hasSummary>
        <bx:if len( local.summaryData.summary ?: "" )>
            <p class="mb-2">#encodeForHTML( local.summaryData.summary )#</p>
        </bx:if>
        <bx:if arrayLen( local.summaryData.keyPoints ?: [] )>
            <div class="text-body-secondary mb-1">Key points</div>
            <ul class="mb-2 ps-3">
                <bx:loop array="#local.summaryData.keyPoints#" item="local.kp">
                    <li>#encodeForHTML( local.kp )#</li>
                </bx:loop>
            </ul>
        </bx:if>
        <bx:if len( local.summaryData.nextStep ?: "" )>
            <div class="alert alert-info py-2 px-3 small mb-2" role="note">
                <strong>Next step:</strong> #encodeForHTML( local.summaryData.nextStep )#
            </div>
        </bx:if>
        <bx:if !isNull( local.summaryData.generatedAt ?: javaCast( "null", "" ) ) && isDate( local.summaryData.generatedAt )>
            <div class="text-body-secondary mb-2">
                <i class="bi bi-clock"></i>
                Generated #encodeForHTML( dateTimeFormat( local.summaryData.generatedAt, "yyyy-mm-dd HH:nn" ) )#
            </div>
        </bx:if>
    </bx:if>
    <form method="post" action="/agent/tickets/#encodeForHTMLAttribute( local.t.getId() )#/summarize">
        <button class="btn btn-outline-info btn-sm w-100" type="submit">
            <i class="bi bi-stars"></i>
            <bx:if local.hasSummary>Refresh summary<bx:else>Generate summary</bx:if>
        </button>
    </form>
</bx:savecontent>
#view( view = "_partials/collapsible_card", module = "core", args = {
    id        : "summary-card",
    title     : "AI Summary",
    badges    : local.cardBadges,
    bodyClass : "small",
    collapsed : !local.hasSummary,
    body      : local.body
} )#
</bx:output>
