<bx:output>
<bx:if prc.sla.hasSla>
    <bx:set local.t = prc.ticket >
    <bx:set local.sla = prc.sla >
    <bx:switch expression="#local.sla.status#">
        <bx:case value="breached"><bx:set local.slaBadge = { label : "Breached",   color : "danger"    } ></bx:case>
        <bx:case value="approaching"><bx:set local.slaBadge = { label : "Approaching", color : "warning" } ></bx:case>
        <bx:case value="paused"><bx:set local.slaBadge = { label : "Paused",      color : "info"      } ></bx:case>
        <bx:case value="met"><bx:set local.slaBadge = { label : "Met",         color : "success"   } ></bx:case>
        <bx:case value="ok"><bx:set local.slaBadge = { label : "On track",    color : "secondary" } ></bx:case>
        <bx:defaultcase><bx:set local.slaBadge = { label : "No SLA",      color : "light"     } ></bx:defaultcase>
    </bx:switch>
    <bx:savecontent variable="local.body">
        <bx:if !isNull( prc.slaPolicy )>
            <div class="text-body-secondary mb-2">Policy: #encodeForHTML( prc.slaPolicy.getName() )#</div>
        </bx:if>
        <dl class="row mb-0">
            <dt class="col-5">First response</dt>
            <dd class="col-7">
                <bx:if local.sla.firstResponse eq "met">
                    <span class="text-success">Met</span> #encodeForHTML( dateTimeFormat( local.sla.firstResponseAt, "yyyy-mm-dd HH:nn" ) )#
                <bx:elseif local.sla.firstResponse eq "breached">
                    <span class="text-danger">Breached</span> at #encodeForHTML( dateTimeFormat( local.sla.firstResponseDue, "yyyy-mm-dd HH:nn" ) )#
                <bx:elseif local.sla.firstResponse eq "approaching">
                    <span class="text-warning">Due</span> #encodeForHTML( dateTimeFormat( local.sla.firstResponseDue, "yyyy-mm-dd HH:nn" ) )#
                <bx:elseif local.sla.firstResponse eq "ok">
                    Due #encodeForHTML( dateTimeFormat( local.sla.firstResponseDue, "yyyy-mm-dd HH:nn" ) )#
                <bx:else>
                    -
                </bx:if>
            </dd>
            <dt class="col-5">Resolution</dt>
            <dd class="col-7">
                <bx:if local.sla.resolution eq "met">
                    <span class="text-success">Met</span>
                <bx:elseif local.sla.resolution eq "breached">
                    <span class="text-danger">Breached</span> at #encodeForHTML( dateTimeFormat( local.sla.resolutionDue, "yyyy-mm-dd HH:nn" ) )#
                <bx:elseif local.sla.resolution eq "approaching">
                    <span class="text-warning">Due</span> #encodeForHTML( dateTimeFormat( local.sla.resolutionDue, "yyyy-mm-dd HH:nn" ) )#
                <bx:elseif local.sla.resolution eq "ok">
                    Due #encodeForHTML( dateTimeFormat( local.sla.resolutionDue, "yyyy-mm-dd HH:nn" ) )#
                <bx:else>
                    -
                </bx:if>
            </dd>
            <bx:if local.sla.paused>
                <dt class="col-5">Paused since</dt>
                <dd class="col-7">#encodeForHTML( dateTimeFormat( local.t.getSlaPausedAt(), "yyyy-mm-dd HH:nn" ) )#</dd>
            </bx:if>
        </dl>
    </bx:savecontent>
    #view( view = "_partials/collapsible_card", module = "core", args = {
        id        : "sla-card",
        title     : "SLA",
        badges    : [ local.slaBadge ],
        bodyClass : "small",
        body      : local.body
    } )#
</bx:if>
</bx:output>
