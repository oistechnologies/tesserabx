<bx:output>
<div class="row">
    <div class="col-12 col-lg-8">
        <div class="card">
            <div class="card-body">
                <form method="post" action="/agent/contacts/#encodeForHTMLAttribute( prc.contact.getId() )#">
                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            <label class="form-label">Email</label>
                            <input type="email" class="form-control" disabled value="#encodeForHTMLAttribute( prc.contact.getEmail() )#">
                            <div class="form-text">Email is the immutable identity; use contact merge to change.</div>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label" for="isActive">Status</label>
                            <select class="form-select" name="isActive" id="isActive">
                                <option value="true"<bx:if prc.contact.getIsActive()> selected</bx:if>>Active</option>
                                <option value="false"<bx:if !prc.contact.getIsActive()> selected</bx:if>>Inactive</option>
                            </select>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label" for="firstName">First name</label>
                            <input type="text" class="form-control" id="firstName" name="firstName" value="#encodeForHTMLAttribute( prc.contact.getFirstName() ?: "" )#">
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label" for="lastName">Last name</label>
                            <input type="text" class="form-control" id="lastName" name="lastName" value="#encodeForHTMLAttribute( prc.contact.getLastName() ?: "" )#">
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label" for="officeId">Office</label>
                            <select class="form-select" id="officeId" name="officeId">
                                <option value="">No office</option>
                                <bx:loop array="#prc.offices#" item="office">
                                    <option value="#encodeForHTMLAttribute( office.getId() )#"<bx:if ( prc.contact.getOfficeId() ?: "" ) eq office.getId()> selected</bx:if>>#encodeForHTML( office.getName() )#</option>
                                </bx:loop>
                            </select>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label" for="jobTitle">Job title</label>
                            <input type="text" class="form-control" id="jobTitle" name="jobTitle" value="#encodeForHTMLAttribute( prc.contact.getJobTitle() ?: "" )#">
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label" for="phone">Phone</label>
                            <input type="text" class="form-control" id="phone" name="phone" value="#encodeForHTMLAttribute( prc.contact.getPhone() ?: "" )#">
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label" for="mobilePhone">Mobile</label>
                            <input type="text" class="form-control" id="mobilePhone" name="mobilePhone" value="#encodeForHTMLAttribute( prc.contact.getMobilePhone() ?: "" )#">
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label" for="timezone">Time zone</label>
                            <input type="text" class="form-control" id="timezone" name="timezone" placeholder="e.g. America/New_York" value="#encodeForHTMLAttribute( prc.contact.getTimezone() ?: "" )#">
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label" for="locale">Locale</label>
                            <input type="text" class="form-control" id="locale" name="locale" placeholder="e.g. en_US" value="#encodeForHTMLAttribute( prc.contact.getLocale() ?: "" )#">
                        </div>
                        <div class="col-12">
                            <label class="form-label" for="notes">Internal notes</label>
                            <textarea class="form-control" id="notes" name="notes" rows="3">#encodeForHTML( prc.contact.getNotes() ?: "" )#</textarea>
                            <div class="form-text">Agent-only. Never shown to the client.</div>
                        </div>
                        <div class="col-12 col-md-6">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="isVip" name="isVip" value="true"<bx:if isBoolean( prc.contact.getIsVip() ) and prc.contact.getIsVip()> checked</bx:if>>
                                <label class="form-check-label" for="isVip">VIP (priority handling)</label>
                            </div>
                        </div>
                        <div class="col-12 col-md-6">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="organizationAdmin" name="organizationAdmin" value="true"<bx:if prc.isOrgAdmin> checked</bx:if>>
                                <label class="form-check-label" for="organizationAdmin">Organization Admin</label>
                            </div>
                        </div>
                    </div>
                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <a class="btn btn-outline-secondary" href="/agent/contacts/#encodeForHTMLAttribute( prc.contact.getId() )#">Cancel</a>
                        <button class="btn btn-primary" type="submit">Save changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
</bx:output>
