<bx:output>
<div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">
        <div class="card">
            <div class="card-body">
                <h2 class="h4 mb-3">Set up two-factor authentication</h2>
                <p class="text-body-secondary small">
                    Scan the QR code with an authenticator app (Google Authenticator, 1Password, Authy, etc.), then enter the
                    6-digit code below to confirm enrollment.
                </p>

                <div class="text-center my-3">
                    <img alt="MFA QR code"
                         class="border rounded p-2 bg-light"
                         width="240" height="240"
                         src="https://api.qrserver.com/v1/create-qr-code/?size=240x240&data=#encodeForHTMLAttribute( prc.otpauth )#">
                </div>

                <details class="mb-3">
                    <summary class="small">Can't scan? Enter this secret manually.</summary>
                    <div class="bg-light text-black border rounded p-2 mt-2 small font-monospace">
                        <code class="text-black">#encodeForHTML( prc.secret )#</code>
                    </div>
                </details>

                <form method="post" action="/agent/mfa/setup">
                    <div class="mb-3">
                        <label class="form-label" for="code">Verification code</label>
                        <input type="text"
                               id="code"
                               name="code"
                               class="form-control form-control-lg text-center font-monospace"
                               required
                               autocomplete="one-time-code"
                               inputmode="numeric"
                               pattern="\d{6}"
                               maxlength="6"
                               placeholder="123456">
                    </div>
                    <button class="btn btn-primary w-100" type="submit">Confirm and enable MFA</button>
                </form>
            </div>
        </div>
    </div>
</div>
</bx:output>
