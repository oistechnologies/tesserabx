<bx:output>
<bx:set local.t = prc.ticket >

<div class="row g-3">

    <div class="col-12 col-lg-8">

        <div class="card mb-3">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <div>
                        <div class="small text-body-secondary">Ticket ###local.t.getTicketNumber()# &middot; #encodeForHTML( local.t.getTicketType() )# &middot; <span class="badge text-bg-secondary">#encodeForHTML( local.t.getPriority() )#</span></div>
                        <h2 class="h4 mb-0 mt-1">#encodeForHTML( local.t.getSubject() )#</h2>
                    </div>
                    <span class="badge text-bg-primary fs-6">#encodeForHTML( local.t.getStatus() )#</span>
                </div>
                <dl class="row small mb-0">
                    <dt class="col-sm-3">Organization</dt>
                    <dd class="col-sm-9">
                        <bx:if local.t.isAccountless()>
                            <span class="badge text-bg-warning">Accountless</span>
                            (sender: #encodeForHTML( local.t.getOriginatingEmail() ?: "" )#)
                        <bx:else>
                            <bx:if !isNull( prc.organization )>#encodeForHTML( prc.organization.getName() )#</bx:if>
                        </bx:if>
                    </dd>
                    <dt class="col-sm-3">Requester</dt>
                    <dd class="col-sm-9">
                        <bx:if !isNull( prc.requester )>
                            #encodeForHTML( prc.requester.getEmail() )#
                        <bx:else>
                            <bx:if len( local.t.getOriginatingEmail() ?: "" )>#encodeForHTML( local.t.getOriginatingEmail() )# (unregistered)<bx:else>(none)</bx:if>
                        </bx:if>
                    </dd>
                    <dt class="col-sm-3">Assigned to</dt>
                    <dd class="col-sm-9">
                        <bx:if len( local.t.getAssignedToAgentId() ?: "" )>
                            #encodeForHTML( local.t.getAssignedToAgentId() )#
                        <bx:else>
                            <em class="text-body-secondary">unassigned</em>
                        </bx:if>
                    </dd>
                    <dt class="col-sm-3">Source</dt>
                    <dd class="col-sm-9">#encodeForHTML( local.t.getSource() )#</dd>
                    <bx:if arrayLen( prc.tags ?: [] )>
                        <dt class="col-sm-3">Tags</dt>
                        <dd class="col-sm-9">
                            <bx:loop array="#prc.tags#" item="local.tag">
                                <span class="badge text-bg-#encodeForHTMLAttribute( local.tag.color ?: 'secondary' )# me-1">#encodeForHTML( local.tag.name )#</span>
                            </bx:loop>
                        </dd>
                    </bx:if>
                </dl>
            </div>
        </div>

        <bx:set local.publicCount = 0 >
        <bx:set local.internalCount = 0 >
        <bx:loop array="#prc.messages#" item="local.m">
            <bx:if local.m.getIsInternal()>
                <bx:set local.internalCount = local.internalCount + 1 >
            <bx:else>
                <bx:set local.publicCount = local.publicCount + 1 >
            </bx:if>
        </bx:loop>

        <h3 class="h6 mt-4 mb-2">Conversation
            <small class="text-body-secondary">(#local.publicCount# public, #local.internalCount# internal)</small>
        </h3>

        <bx:if !arrayLen( prc.messages )>
            <p class="text-body-secondary">No messages yet.</p>
        </bx:if>
        <bx:loop array="#prc.messages#" item="local.m">
            <div class="card mb-2 #local.m.getIsInternal() ? 'border-warning' : ''#">
                <div class="card-body">
                    <div class="d-flex justify-content-between small text-body-secondary mb-2">
                        <span>
                            <bx:if local.m.isFromAgent()>
                                <strong>Agent</strong> #encodeForHTML( local.m.getAuthorAgentId() ?: "" )#
                            <bx:elseif len( local.m.getAuthorContactId() ?: "" )>
                                <strong>Contact</strong> #encodeForHTML( local.m.getAuthorContactId() )#
                            <bx:else>
                                <strong>Email</strong> #encodeForHTML( local.m.getAuthorEmail() ?: "" )#
                            </bx:if>
                            <bx:if local.m.getIsInternal()>
                                &middot; <span class="badge text-bg-warning">Internal</span>
                            </bx:if>
                        </span>
                        <span>#encodeForHTML( dateTimeFormat( local.m.getCreatedAt(), "yyyy-mm-dd HH:nn" ) )#</span>
                    </div>
                    <div style="white-space:pre-wrap">#encodeForHTML( local.m.getBody() )#</div>
                </div>
            </div>
        </bx:loop>

        <div class="card mt-3">
            <div class="card-header">Reply</div>
            <div class="card-body">
                <ul class="nav nav-tabs" role="tablist">
                    <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="##public-pane" type="button">Public reply</button></li>
                    <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="##internal-pane" type="button">Internal note</button></li>
                </ul>
                <div class="tab-content pt-3">
                    <div class="tab-pane fade show active" id="public-pane" role="tabpanel">
                        <bx:if prc.aiEnabled ?: false>
                            <form method="post" action="/agent/tickets/#encodeForHTMLAttribute( local.t.getId() )#/suggest-reply" class="mb-2">
                                <button class="btn btn-outline-info btn-sm" type="submit">
                                    <i class="bi bi-stars"></i> Suggest reply
                                </button>
                                <small class="text-body-secondary ms-2">Drafts a reply from the conversation so far.</small>
                            </form>
                        </bx:if>
                        <bx:if len( prc.suggestedNotes ?: "" )>
                            <div class="alert alert-info py-2 px-3 small" role="note">
                                <strong><i class="bi bi-info-circle"></i> AI note for agent:</strong>
                                <div style="white-space:pre-wrap">#encodeForHTML( prc.suggestedNotes )#</div>
                            </div>
                        </bx:if>

                        <bx:set local.tone = prc.toneReview ?: {} >
                        <bx:if isStruct( local.tone ) && structKeyExists( local.tone, "label" ) && len( local.tone.label ?: "" )>
                            <bx:set local.toneClass = local.tone.label eq "excellent" ? "success"
                                                  : ( local.tone.label eq "good"      ? "success"
                                                  : ( local.tone.label eq "ok"        ? "warning"
                                                  :                                     "danger" ) ) >
                            <div class="alert alert-#local.toneClass# py-2 px-3 small mb-2" role="note">
                                <div class="d-flex justify-content-between align-items-center">
                                    <strong><i class="bi bi-pencil-square"></i> Tone review</strong>
                                    <span class="badge text-bg-#local.toneClass#">#encodeForHTML( local.tone.label )# &middot; #encodeForHTML( local.tone.score )#/100</span>
                                </div>
                                <bx:if arrayLen( local.tone.suggestions ?: [] )>
                                    <ul class="mb-0 ps-3 mt-1">
                                        <bx:loop array="#local.tone.suggestions#" item="local.sug">
                                            <li>#encodeForHTML( local.sug )#</li>
                                        </bx:loop>
                                    </ul>
                                </bx:if>
                            </div>
                        </bx:if>

                        <bx:set local.replyBody = prc.suggestedReply ?: "" >
                        <bx:if !len( local.replyBody ) && isStruct( prc.toneReview ?: {} ) && structKeyExists( prc.toneReview ?: {}, "draft" )>
                            <bx:set local.replyBody = prc.toneReview.draft >
                        </bx:if>

                        <form method="post" action="/agent/tickets/#encodeForHTMLAttribute( local.t.getId() )#/reply">
                            <textarea class="form-control mb-2" name="body" id="reply-body-#encodeForHTMLAttribute( local.t.getId() )#" rows="4" placeholder="Reply visible to the requester...">#encodeForHTML( local.replyBody )#</textarea>
                            <div class="d-flex justify-content-between align-items-center">
                                <bx:if prc.aiEnabled ?: false>
                                    <button class="btn btn-outline-secondary btn-sm" type="submit" formaction="/agent/tickets/#encodeForHTMLAttribute( local.t.getId() )#/check-tone">
                                        <i class="bi bi-pencil-square"></i> Check tone
                                    </button>
                                <bx:else>
                                    <span></span>
                                </bx:if>
                                <button class="btn btn-primary" type="submit">Send reply</button>
                            </div>
                        </form>
                    </div>
                    <div class="tab-pane fade" id="internal-pane" role="tabpanel">
                        <form method="post" action="/agent/tickets/#encodeForHTMLAttribute( local.t.getId() )#/internal-note">
                            <textarea class="form-control mb-2" name="body" rows="4" placeholder="Note visible only to agents..."></textarea>
                            <div class="d-flex justify-content-end">
                                <button class="btn btn-warning" type="submit">Add internal note</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <div class="col-12 col-lg-4">

        <bx:if prc.aiEnabled ?: false>
            <bx:set local.summaryData = prc.aiSummary ?: {} >
            <bx:set local.hasSummary = isStruct( local.summaryData ) && ( len( local.summaryData.summary ?: "" ) || arrayLen( local.summaryData.keyPoints ?: [] ) ) >
            <div class="card mb-3">
                <div class="card-header p-0">
                    <a class="d-flex justify-content-between align-items-center w-100 px-3 py-2 text-decoration-none text-body<bx:if !local.hasSummary> collapsed</bx:if>"
                       data-bs-toggle="collapse"
                       href="##summary-card"
                       role="button"
                       aria-expanded="<bx:if local.hasSummary>true<bx:else>false</bx:if>"
                       aria-controls="summary-card">
                        <span>
                            AI Summary
                            <bx:if local.hasSummary>
                                <span class="badge text-bg-info ms-2">Ready</span>
                            </bx:if>
                        </span>
                        <i class="bi bi-chevron-down"></i>
                    </a>
                </div>
                <div id="summary-card" class="collapse<bx:if local.hasSummary> show</bx:if>">
                    <div class="card-body small">
                        <bx:if local.hasSummary>
                            <bx:if len( local.summaryData.summary ?: "" )>
                                <p class="mb-2">#encodeForHTML( local.summaryData.summary )#</p>
                            </bx:if>
                            <bx:if arrayLen( local.summaryData.keyPoints ?: [] )>
                                <div class="text-body-secondary mb-1">Key points</div>
                                <ul class="mb-2 ps-3">
                                    <bx:loop array="#local.summaryData.keyPoints#" item="local.kp">
                                        <li>#encodeForHTML( local.kp )#</li>
                                    </bx:loop>
                                </ul>
                            </bx:if>
                            <bx:if len( local.summaryData.nextStep ?: "" )>
                                <div class="alert alert-info py-2 px-3 small mb-2" role="note">
                                    <strong>Next step:</strong> #encodeForHTML( local.summaryData.nextStep )#
                                </div>
                            </bx:if>
                            <bx:if !isNull( local.summaryData.generatedAt ?: javaCast( "null", "" ) ) && isDate( local.summaryData.generatedAt )>
                                <div class="text-body-secondary mb-2">
                                    <i class="bi bi-clock"></i>
                                    Generated #encodeForHTML( dateTimeFormat( local.summaryData.generatedAt, "yyyy-mm-dd HH:nn" ) )#
                                </div>
                            </bx:if>
                        </bx:if>
                        <form method="post" action="/agent/tickets/#encodeForHTMLAttribute( local.t.getId() )#/summarize">
                            <button class="btn btn-outline-info btn-sm w-100" type="submit">
                                <i class="bi bi-stars"></i>
                                <bx:if local.hasSummary>Refresh summary<bx:else>Generate summary</bx:if>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </bx:if>

        <bx:if prc.canDraftKbArticle ?: false>
            <div class="card mb-3">
                <div class="card-header p-0">
                    <a class="d-flex justify-content-between align-items-center w-100 px-3 py-2 text-decoration-none text-body collapsed"
                       data-bs-toggle="collapse"
                       href="##kb-draft-card"
                       role="button"
                       aria-expanded="false"
                       aria-controls="kb-draft-card">
                        <span>Draft KB article <span class="badge text-bg-info ms-2">AI</span></span>
                        <i class="bi bi-chevron-down"></i>
                    </a>
                </div>
                <div id="kb-draft-card" class="collapse">
                    <div class="card-body small">
                        <p class="mb-2 text-body-secondary">Generate an internal-only draft KB article from this resolved ticket. You will review and publish before customers see it.</p>
                        <form method="post" action="/agent/tickets/#encodeForHTMLAttribute( local.t.getId() )#/draft-kb-article">
                            <button class="btn btn-outline-info btn-sm w-100" type="submit">
                                <i class="bi bi-journal-plus"></i> Draft KB article
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </bx:if>

        <bx:if arrayLen( prc.relatedArticles ?: [] )>
            <bx:set local.firstArticle = prc.relatedArticles[ 1 ] >
            <bx:set local.relatedSource = local.firstArticle.source ?: "" >
            <div class="card mb-3">
                <div class="card-header p-0">
                    <a class="d-flex justify-content-between align-items-center w-100 px-3 py-2 text-decoration-none text-body collapsed"
                       data-bs-toggle="collapse"
                       href="##related-articles-card"
                       role="button"
                       aria-expanded="false"
                       aria-controls="related-articles-card">
                        <span>
                            Related articles
                            <span class="badge text-bg-secondary ms-2">#arrayLen( prc.relatedArticles )#</span>
                            <bx:if local.relatedSource eq "semantic">
                                <span class="badge text-bg-info ms-1" title="Ranked by AI semantic similarity">AI</span>
                            </bx:if>
                        </span>
                        <i class="bi bi-chevron-down"></i>
                    </a>
                </div>
                <div id="related-articles-card" class="collapse">
                    <div class="card-body small">
                        <bx:loop array="#prc.relatedArticles#" item="local.article">
                            <div class="mb-2 pb-2 border-bottom">
                                <a href="/kb/#encodeForHTMLAttribute( local.article.slug )#" target="_blank">
                                    #encodeForHTML( local.article.title )#
                                </a>
                                <bx:if len( local.article.snippet ?: "" )>
                                    <div class="text-body-secondary">#encodeForHTML( local.article.snippet )#</div>
                                </bx:if>
                            </div>
                        </bx:loop>
                    </div>
                </div>
            </div>
        </bx:if>

        <bx:if arrayLen( prc.customFields ?: [] )>
            <bx:set local.cfFilled = 0 >
            <bx:loop array="#prc.customFields#" item="local.cf">
                <bx:if len( local.cf.display )><bx:set local.cfFilled = local.cfFilled + 1 ></bx:if>
            </bx:loop>
            <div class="card mb-3">
                <div class="card-header p-0">
                    <a class="d-flex justify-content-between align-items-center w-100 px-3 py-2 text-decoration-none text-body collapsed"
                       data-bs-toggle="collapse"
                       href="##custom-fields-card"
                       role="button"
                       aria-expanded="false"
                       aria-controls="custom-fields-card">
                        <span>
                            Custom fields
                            <span class="badge text-bg-light text-black ms-2">#local.cfFilled# / #arrayLen( prc.customFields )#</span>
                        </span>
                        <i class="bi bi-chevron-down"></i>
                    </a>
                </div>
                <div id="custom-fields-card" class="collapse">
                    <div class="card-body">
                        <form method="post" action="/agent/tickets/#encodeForHTMLAttribute( local.t.getId() )#/custom-fields">
                            <bx:loop array="#prc.customFields#" item="local.cf">
                                <bx:set local.def = local.cf.definition >
                                <bx:set local.v   = local.cf.value >
                                <bx:set local.fid = "cf_" & local.def.id >
                                <div class="mb-3">
                                    <label class="form-label small mb-1" for="#encodeForHTMLAttribute( local.fid )#">
                                        #encodeForHTML( local.def.label )#
                                        <bx:if local.def.isRequired><span class="text-danger">*</span></bx:if>
                                    </label>

                                    <bx:if local.def.fieldType eq "text">
                                        <input type="text" class="form-control form-control-sm" id="#encodeForHTMLAttribute( local.fid )#" name="#encodeForHTMLAttribute( local.fid )#" value="#encodeForHTMLAttribute( local.v.valueText )#" <bx:if local.def.isRequired>required</bx:if>>
                                    <bx:elseif local.def.fieldType eq "textarea">
                                        <textarea class="form-control form-control-sm" id="#encodeForHTMLAttribute( local.fid )#" name="#encodeForHTMLAttribute( local.fid )#" rows="3" <bx:if local.def.isRequired>required</bx:if>>#encodeForHTML( local.v.valueText )#</textarea>
                                    <bx:elseif local.def.fieldType eq "number">
                                        <input type="number" step="any" class="form-control form-control-sm" id="#encodeForHTMLAttribute( local.fid )#" name="#encodeForHTMLAttribute( local.fid )#" value="#encodeForHTMLAttribute( local.v.valueNumber )#" <bx:if local.def.isRequired>required</bx:if>>
                                    <bx:elseif local.def.fieldType eq "date">
                                        <bx:set local.dateStr = "" >
                                        <bx:if len( toString( local.v.valueDate ) )>
                                            <bx:try>
                                                <bx:set local.dateStr = dateFormat( local.v.valueDate, "yyyy-mm-dd" ) >
                                                <bx:catch any></bx:catch>
                                            </bx:try>
                                        </bx:if>
                                        <input type="date" class="form-control form-control-sm" id="#encodeForHTMLAttribute( local.fid )#" name="#encodeForHTMLAttribute( local.fid )#" value="#encodeForHTMLAttribute( local.dateStr )#" <bx:if local.def.isRequired>required</bx:if>>
                                    <bx:elseif local.def.fieldType eq "select">
                                        <select class="form-select form-select-sm" id="#encodeForHTMLAttribute( local.fid )#" name="#encodeForHTMLAttribute( local.fid )#" <bx:if local.def.isRequired>required</bx:if>>
                                            <option value=""<bx:if !len( local.v.valueText )> selected</bx:if>>--</option>
                                            <bx:loop array="#getInstance( 'CustomFieldsService@tickets' ).parseOptions( local.def.options )#" item="local.opt">
                                                <option value="#encodeForHTMLAttribute( local.opt )#"<bx:if local.v.valueText eq local.opt> selected</bx:if>>#encodeForHTML( local.opt )#</option>
                                            </bx:loop>
                                        </select>
                                    <bx:elseif local.def.fieldType eq "boolean">
                                        <div class="form-check">
                                            <input type="hidden" name="#encodeForHTMLAttribute( local.fid )#" value="false">
                                            <input class="form-check-input" type="checkbox" id="#encodeForHTMLAttribute( local.fid )#" name="#encodeForHTMLAttribute( local.fid )#" value="true"<bx:if local.v.valueBoolean> checked</bx:if>>
                                            <label class="form-check-label small" for="#encodeForHTMLAttribute( local.fid )#">Yes</label>
                                        </div>
                                    </bx:if>

                                    <bx:if len( local.def.helpText )>
                                        <div class="form-text small text-body-secondary">#encodeForHTML( local.def.helpText )#</div>
                                    </bx:if>
                                </div>
                            </bx:loop>
                            <button class="btn btn-sm btn-primary" type="submit">Save fields</button>
                        </form>
                    </div>
                </div>
            </div>
        </bx:if>

        <div class="card mb-3">
            <div class="card-header p-0">
                <a class="d-flex justify-content-between align-items-center w-100 px-3 py-2 text-decoration-none text-body collapsed"
                   data-bs-toggle="collapse"
                   href="##status-card"
                   role="button"
                   aria-expanded="false"
                   aria-controls="status-card">
                    <span>Status <span class="badge text-bg-primary ms-2">#encodeForHTML( local.t.getStatus() )#</span></span>
                    <i class="bi bi-chevron-down"></i>
                </a>
            </div>
            <div id="status-card" class="collapse">
                <div class="card-body">
                    <form method="post" action="/agent/tickets/#encodeForHTMLAttribute( local.t.getId() )#/status" class="d-flex gap-2">
                        <select class="form-select" name="status">
                            <bx:loop array="#prc.statuses#" item="local.s">
                                <option value="#encodeForHTMLAttribute( local.s )#"<bx:if local.t.getStatus() eq local.s> selected</bx:if>>#encodeForHTML( local.s )#</option>
                            </bx:loop>
                        </select>
                        <button class="btn btn-outline-primary" type="submit">Set</button>
                    </form>
                </div>
            </div>
        </div>

        <bx:if prc.sla.hasSla>
            <bx:set local.sla = prc.sla >
            <div class="card mb-3">
                <div class="card-header p-0">
                    <a class="d-flex justify-content-between align-items-center w-100 px-3 py-2 text-decoration-none text-body collapsed"
                       data-bs-toggle="collapse"
                       href="##sla-card"
                       role="button"
                       aria-expanded="false"
                       aria-controls="sla-card">
                        <span>
                            SLA
                            <bx:switch expression="#local.sla.status#">
                                <bx:case value="breached"><span class="badge text-bg-danger ms-2">Breached</span></bx:case>
                                <bx:case value="approaching"><span class="badge text-bg-warning ms-2">Approaching</span></bx:case>
                                <bx:case value="paused"><span class="badge text-bg-info ms-2">Paused</span></bx:case>
                                <bx:case value="met"><span class="badge text-bg-success ms-2">Met</span></bx:case>
                                <bx:case value="ok"><span class="badge text-bg-secondary ms-2">On track</span></bx:case>
                                <bx:defaultcase><span class="badge text-bg-light text-black ms-2">No SLA</span></bx:defaultcase>
                            </bx:switch>
                        </span>
                        <i class="bi bi-chevron-down"></i>
                    </a>
                </div>
                <div id="sla-card" class="collapse">
                    <div class="card-body small">
                        <bx:if !isNull( prc.slaPolicy )>
                            <div class="text-body-secondary mb-2">Policy: #encodeForHTML( prc.slaPolicy.getName() )#</div>
                        </bx:if>
                        <dl class="row mb-0">
                            <dt class="col-5">First response</dt>
                            <dd class="col-7">
                                <bx:if local.sla.firstResponse eq "met">
                                    <span class="text-success">Met</span> #encodeForHTML( dateTimeFormat( local.sla.firstResponseAt, "yyyy-mm-dd HH:nn" ) )#
                                <bx:elseif local.sla.firstResponse eq "breached">
                                    <span class="text-danger">Breached</span> at #encodeForHTML( dateTimeFormat( local.sla.firstResponseDue, "yyyy-mm-dd HH:nn" ) )#
                                <bx:elseif local.sla.firstResponse eq "approaching">
                                    <span class="text-warning">Due</span> #encodeForHTML( dateTimeFormat( local.sla.firstResponseDue, "yyyy-mm-dd HH:nn" ) )#
                                <bx:elseif local.sla.firstResponse eq "ok">
                                    Due #encodeForHTML( dateTimeFormat( local.sla.firstResponseDue, "yyyy-mm-dd HH:nn" ) )#
                                <bx:else>
                                    -
                                </bx:if>
                            </dd>
                            <dt class="col-5">Resolution</dt>
                            <dd class="col-7">
                                <bx:if local.sla.resolution eq "met">
                                    <span class="text-success">Met</span>
                                <bx:elseif local.sla.resolution eq "breached">
                                    <span class="text-danger">Breached</span> at #encodeForHTML( dateTimeFormat( local.sla.resolutionDue, "yyyy-mm-dd HH:nn" ) )#
                                <bx:elseif local.sla.resolution eq "approaching">
                                    <span class="text-warning">Due</span> #encodeForHTML( dateTimeFormat( local.sla.resolutionDue, "yyyy-mm-dd HH:nn" ) )#
                                <bx:elseif local.sla.resolution eq "ok">
                                    Due #encodeForHTML( dateTimeFormat( local.sla.resolutionDue, "yyyy-mm-dd HH:nn" ) )#
                                <bx:else>
                                    -
                                </bx:if>
                            </dd>
                            <bx:if local.sla.paused>
                                <dt class="col-5">Paused since</dt>
                                <dd class="col-7">#encodeForHTML( dateTimeFormat( local.t.getSlaPausedAt(), "yyyy-mm-dd HH:nn" ) )#</dd>
                            </bx:if>
                        </dl>
                    </div>
                </div>
            </div>
        </bx:if>

        <div class="card mb-3">
            <div class="card-header p-0">
                <a class="d-flex justify-content-between align-items-center w-100 px-3 py-2 text-decoration-none text-body collapsed"
                   data-bs-toggle="collapse"
                   href="##assignment-card"
                   role="button"
                   aria-expanded="false"
                   aria-controls="assignment-card">
                    <span>
                        Assignment
                        <bx:if len( local.t.getAssignedToAgentId() ?: "" )>
                            <span class="badge text-bg-secondary ms-2">Assigned</span>
                        <bx:else>
                            <span class="badge text-bg-light text-black ms-2">Unassigned</span>
                        </bx:if>
                    </span>
                    <i class="bi bi-chevron-down"></i>
                </a>
            </div>
            <div id="assignment-card" class="collapse">
                <div class="card-body">
                    <form method="post" action="/agent/tickets/#encodeForHTMLAttribute( local.t.getId() )#/assign">
                        <input type="text" class="form-control mb-2" name="agentId" placeholder="Agent UUID (leave blank to unassign)" value="#encodeForHTMLAttribute( local.t.getAssignedToAgentId() ?: "" )#">
                        <div class="d-flex justify-content-end">
                            <button class="btn btn-outline-primary" type="submit">Save</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <bx:if prc.canShowBlockCard ?: false>
            <div class="card mb-3 border-danger">
                <div class="card-header bg-danger-subtle p-0">
                    <a class="d-flex justify-content-between align-items-center w-100 px-3 py-2 text-decoration-none text-body collapsed"
                       data-bs-toggle="collapse"
                       href="##block-sender-card"
                       role="button"
                       aria-expanded="false"
                       aria-controls="block-sender-card">
                        <span>Block this sender</span>
                        <i class="bi bi-chevron-down"></i>
                    </a>
                </div>
                <div id="block-sender-card" class="collapse">
                    <div class="card-body">
                        <bx:if prc.isSenderBlocked ?: false>
                            <p class="small mb-2">
                                <i class="bi bi-shield-x"></i>
                                Sender <code>#encodeForHTML( local.t.getOriginatingEmail() )#</code> is already on the inbound blacklist.
                                Future emails from this sender will not become tickets.
                            </p>
                            <a class="btn btn-outline-secondary btn-sm w-100" href="/agent/admin/blacklist">
                                Manage blacklist
                            </a>
                        <bx:else>
                            <p class="small mb-2">Adds <code>#encodeForHTML( local.t.getOriginatingEmail() )#</code> (or its domain) to the inbound blacklist. Future emails from a blocked sender are dropped instead of becoming tickets, and this ticket will be auto-closed with an internal note.</p>
                            <form method="post" action="/agent/tickets/#encodeForHTMLAttribute( local.t.getId() )#/block-sender">
                                <div class="mb-2">
                                    <select class="form-select form-select-sm" name="scope">
                                        <option value="email">This address only (#encodeForHTML( local.t.getOriginatingEmail() )#)</option>
                                        <option value="domain">Entire domain (@#encodeForHTML( listLast( local.t.getOriginatingEmail(), "@" ) )#)</option>
                                    </select>
                                </div>
                                <div class="mb-2">
                                    <input type="text" class="form-control form-control-sm" name="reason" placeholder="Reason (optional)">
                                </div>
                                <button class="btn btn-danger btn-sm w-100" type="submit">Block</button>
                            </form>
                        </bx:if>
                    </div>
                </div>
            </div>
        </bx:if>

        <bx:if local.t.isAccountless()>
            <div class="card mb-3 border-warning">
                <div class="card-header bg-warning-subtle p-0">
                    <a class="d-flex justify-content-between align-items-center w-100 px-3 py-2 text-decoration-none text-body collapsed"
                       data-bs-toggle="collapse"
                       href="##promote-sender-card"
                       role="button"
                       aria-expanded="false"
                       aria-controls="promote-sender-card">
                        <span>Promote sender to contact</span>
                        <i class="bi bi-chevron-down"></i>
                    </a>
                </div>
                <div id="promote-sender-card" class="collapse">
                    <div class="card-body">
                        <p class="small mb-2">Creates a Contact for <code>#encodeForHTML( local.t.getOriginatingEmail() ?: "" )#</code> in the chosen organization and assigns this ticket to them.</p>
                        <form method="post" action="/agent/tickets/#encodeForHTMLAttribute( local.t.getId() )#/promote-sender">
                            <div class="mb-2">
                                <select class="form-select" name="organizationId" required>
                                    <option value="">Select organization...</option>
                                    <bx:loop array="#prc.organizations#" item="local.o">
                                        <option value="#encodeForHTMLAttribute( local.o.getId() )#">#encodeForHTML( local.o.getName() )#</option>
                                    </bx:loop>
                                </select>
                            </div>
                            <div class="row g-2 mb-2">
                                <div class="col-6"><input type="text" class="form-control" name="firstName" placeholder="First name"></div>
                                <div class="col-6"><input type="text" class="form-control" name="lastName" placeholder="Last name"></div>
                            </div>
                            <div class="mb-2">
                                <input type="text" class="form-control" name="password" placeholder="Initial password (min 8 chars)" minlength="8" required>
                            </div>
                            <button class="btn btn-warning w-100" type="submit">Promote</button>
                        </form>
                    </div>
                </div>
            </div>
        </bx:if>

        <div class="card">
            <div class="card-header p-0">
                <a class="d-flex justify-content-between align-items-center w-100 px-3 py-2 text-decoration-none text-body collapsed"
                   data-bs-toggle="collapse"
                   href="##timeline-card"
                   role="button"
                   aria-expanded="false"
                   aria-controls="timeline-card">
                    <span>Timeline</span>
                    <i class="bi bi-chevron-down"></i>
                </a>
            </div>
            <div id="timeline-card" class="collapse">
                <div class="card-body p-0">
                    <ul class="list-group list-group-flush small">
                        <bx:loop array="#prc.events#" item="local.e">
                            <li class="list-group-item">
                                <div class="text-body-secondary">#encodeForHTML( dateTimeFormat( local.e.getOccurredAt(), "yyyy-mm-dd HH:nn:ss" ) )#</div>
                                <code>#encodeForHTML( local.e.getEventType() )#</code>
                            </li>
                        </bx:loop>
                    </ul>
                </div>
            </div>
        </div>

    </div>
</div>
</bx:output>
