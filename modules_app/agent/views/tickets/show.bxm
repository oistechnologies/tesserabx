<bx:output>
<bx:set local.t = prc.ticket >

<div class="row g-3">

    <div class="col-12 col-lg-8">

        <div class="card mb-3">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <div>
                        <div class="small text-body-secondary">Ticket ###local.t.getTicketNumber()# &middot; #encodeForHTML( local.t.getTicketType() )# &middot; <span class="badge text-bg-secondary">#encodeForHTML( local.t.getPriority() )#</span></div>
                        <h2 class="h4 mb-0 mt-1">#encodeForHTML( local.t.getSubject() )#</h2>
                    </div>
                    <span class="badge text-bg-primary fs-6">#encodeForHTML( local.t.getStatus() )#</span>
                </div>
                <dl class="row small mb-0">
                    <dt class="col-sm-3">Organization</dt>
                    <dd class="col-sm-9">
                        <bx:if local.t.isAccountless()>
                            <span class="badge text-bg-warning">Accountless</span>
                            (sender: #encodeForHTML( local.t.getOriginatingEmail() ?: "" )#)
                        <bx:else>
                            <bx:if !isNull( prc.organization )>#encodeForHTML( prc.organization.getName() )#</bx:if>
                        </bx:if>
                    </dd>
                    <dt class="col-sm-3">Requester</dt>
                    <dd class="col-sm-9">
                        <bx:if !isNull( prc.requester )>
                            #encodeForHTML( prc.requester.getEmail() )#
                        <bx:else>
                            <bx:if len( local.t.getOriginatingEmail() ?: "" )>#encodeForHTML( local.t.getOriginatingEmail() )# (unregistered)<bx:else>(none)</bx:if>
                        </bx:if>
                    </dd>
                    <dt class="col-sm-3">Assigned to</dt>
                    <dd class="col-sm-9">
                        <bx:if len( local.t.getAssignedToAgentId() ?: "" )>
                            <bx:set local.assignedAgent = prc.agentDirectory[ local.t.getAssignedToAgentId() ] ?: {} >
                            <bx:if structKeyExists( local.assignedAgent, "id" )>
                                <span class="d-inline-flex align-items-center gap-2">
                                    <bx:set local.assignedAgent.hasAvatar = len( local.assignedAgent.profileImageOriginalPath ?: "" ) gt 0 >
                                    <bx:set local.assignedAgent.uploadedAt = local.assignedAgent.profileImageUploadedAt >
                                    #view( view = "_partials/avatar", module = "core", args = { agent : local.assignedAgent, size : 24 } )#
                                    <span>#encodeForHTML( trim( local.assignedAgent.firstName & " " & local.assignedAgent.lastName ) )#</span>
                                    <small class="text-body-secondary">(#encodeForHTML( local.assignedAgent.email )#)</small>
                                </span>
                            <bx:else>
                                <code class="small">#encodeForHTML( local.t.getAssignedToAgentId() )#</code>
                            </bx:if>
                        <bx:else>
                            <em class="text-body-secondary">unassigned</em>
                        </bx:if>
                    </dd>
                    <dt class="col-sm-3">Source</dt>
                    <dd class="col-sm-9">#encodeForHTML( local.t.getSource() )#</dd>
                    <bx:if arrayLen( prc.tags ?: [] )>
                        <dt class="col-sm-3">Tags</dt>
                        <dd class="col-sm-9">
                            <bx:loop array="#prc.tags#" item="local.tag">
                                <span class="badge text-bg-#encodeForHTMLAttribute( local.tag.color ?: 'secondary' )# me-1">#encodeForHTML( local.tag.name )#</span>
                            </bx:loop>
                        </dd>
                    </bx:if>
                </dl>
            </div>
        </div>

        <bx:set local.publicCount = 0 >
        <bx:set local.internalCount = 0 >
        <bx:loop array="#prc.messages#" item="local.m">
            <bx:if local.m.getIsInternal()>
                <bx:set local.internalCount = local.internalCount + 1 >
            <bx:else>
                <bx:set local.publicCount = local.publicCount + 1 >
            </bx:if>
        </bx:loop>

        <h3 class="h6 mt-4 mb-2">Conversation
            <small class="text-body-secondary">(#local.publicCount# public, #local.internalCount# internal)</small>
        </h3>

        <bx:if !arrayLen( prc.messages )>
            <p class="text-body-secondary">No messages yet.</p>
        </bx:if>
        <bx:loop array="#prc.messages#" item="local.m">
            <div class="card mb-2 #local.m.getIsInternal() ? 'border-warning' : ''#">
                <div class="card-body">
                    <div class="d-flex justify-content-between small text-body-secondary mb-2">
                        <span>
                            <bx:if local.m.isFromAgent()>
                                <bx:set local.msgAgent = prc.agentDirectory[ local.m.getAuthorAgentId() ?: "" ] ?: {} >
                                <bx:if structKeyExists( local.msgAgent, "id" )>
                                    <bx:set local.msgAgent.hasAvatar = len( local.msgAgent.profileImageOriginalPath ?: "" ) gt 0 >
                                    <bx:set local.msgAgent.uploadedAt = local.msgAgent.profileImageUploadedAt >
                                    <span class="d-inline-flex align-items-center gap-2">
                                        #view( view = "_partials/avatar", module = "core", args = { agent : local.msgAgent, size : 20 } )#
                                        <strong>#encodeForHTML( trim( local.msgAgent.firstName & " " & local.msgAgent.lastName ) )#</strong>
                                    </span>
                                <bx:else>
                                    <strong>Agent</strong> #encodeForHTML( local.m.getAuthorAgentId() ?: "" )#
                                </bx:if>
                            <bx:elseif len( local.m.getAuthorContactId() ?: "" )>
                                <bx:set local.msgContact = prc.contactDirectory[ local.m.getAuthorContactId() ?: "" ] ?: {} >
                                <bx:if structKeyExists( local.msgContact, "id" )>
                                    <bx:set local.contactDisplayName = trim( ( local.msgContact.firstName ?: "" ) & " " & ( local.msgContact.lastName ?: "" ) ) >
                                    <bx:if !len( local.contactDisplayName )>
                                        <bx:set local.contactDisplayName = local.msgContact.email >
                                    </bx:if>
                                    <strong>#encodeForHTML( local.contactDisplayName )#</strong><bx:if len( local.msgContact.email ?: "" ) and local.contactDisplayName neq local.msgContact.email>
                                        <span class="text-body-secondary">&lt;#encodeForHTML( local.msgContact.email )#&gt;</span>
                                    </bx:if>
                                <bx:else>
                                    <strong>Contact</strong> #encodeForHTML( local.m.getAuthorContactId() )#
                                </bx:if>
                            <bx:else>
                                <strong>Email</strong> #encodeForHTML( local.m.getAuthorEmail() ?: "" )#
                            </bx:if>
                            <bx:if local.m.getIsInternal()>
                                &middot; <span class="badge text-bg-warning">Internal</span>
                            </bx:if>
                        </span>
                        <span>#encodeForHTML( dateTimeFormat( local.m.getCreatedAt(), "yyyy-mm-dd HH:nn" ) )#</span>
                    </div>
                    <div style="white-space:pre-wrap">#encodeForHTML( local.m.getBody() )#</div>
                    <bx:set local.msgAttachments = prc.attachmentsByMessageId[ local.m.getId() ] ?: [] >
                    <bx:if arrayLen( local.msgAttachments )>
                        <div class="mt-2 d-flex flex-wrap gap-2">
                            <bx:loop array="#local.msgAttachments#" item="local.att">
                                <bx:if local.att.isDeleted()>
                                    <span class="text-body-secondary small fst-italic">
                                        <i class="bi bi-trash"></i> #encodeForHTML( local.att.getOriginalFilename() )# (deleted)
                                    </span>
                                <bx:elseif local.att.isImage() && local.att.getThumbnailStatus() == "ready">
                                    <a href="/agent/attachments/#encodeForHTMLAttribute( local.att.getId() )#"
                                       target="_blank"
                                       title="#encodeForHTMLAttribute( local.att.getOriginalFilename() )# (#local.att.displaySize()#)">
                                        <img src="/agent/attachments/#encodeForHTMLAttribute( local.att.getId() )#/thumbnail"
                                             alt="#encodeForHTMLAttribute( local.att.getOriginalFilename() )#"
                                             style="max-height:80px; border-radius:4px; border:1px solid var(--bs-border-color);">
                                    </a>
                                <bx:else>
                                    <a href="/agent/attachments/#encodeForHTMLAttribute( local.att.getId() )#"
                                       target="_blank"
                                       class="btn btn-sm btn-outline-secondary">
                                        <i class="bi bi-paperclip"></i>
                                        #encodeForHTML( local.att.getOriginalFilename() )#
                                        <small class="text-body-secondary">#local.att.displaySize()#</small>
                                    </a>
                                </bx:if>
                            </bx:loop>
                        </div>
                    </bx:if>
                </div>
            </div>
        </bx:loop>

        <div class="card mt-3">
            <div class="card-header">Reply</div>
            <div class="card-body">
                <bx:set local.attachmentCount = 0 >
                <bx:loop array="#prc.attachments ?: []#" item="local.acount">
                    <bx:if !local.acount.isDeleted()><bx:set local.attachmentCount = local.attachmentCount + 1 ></bx:if>
                </bx:loop>
                <ul class="nav nav-tabs" role="tablist">
                    <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="##public-pane" type="button">Public reply</button></li>
                    <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="##internal-pane" type="button">Internal note</button></li>
                    <li class="nav-item">
                        <button class="nav-link" data-bs-toggle="tab" data-bs-target="##attachments-pane" type="button">
                            Attachments <span class="badge text-bg-secondary">#local.attachmentCount#</span>
                        </button>
                    </li>
                </ul>
                <div class="tab-content pt-3">
                    <div class="tab-pane fade show active" id="public-pane" role="tabpanel">
                        <bx:if prc.aiEnabled ?: false>
                            <form method="post" action="/agent/tickets/#encodeForHTMLAttribute( local.t.getId() )#/suggest-reply" class="mb-2">
                                <button class="btn btn-outline-info btn-sm" type="submit">
                                    <i class="bi bi-stars"></i> Suggest reply
                                </button>
                                <small class="text-body-secondary ms-2">Drafts a reply from the conversation so far.</small>
                            </form>
                        </bx:if>
                        <bx:if len( prc.suggestedNotes ?: "" )>
                            <div class="alert alert-info py-2 px-3 small" role="note">
                                <strong><i class="bi bi-info-circle"></i> AI note for agent:</strong>
                                <div style="white-space:pre-wrap">#encodeForHTML( prc.suggestedNotes )#</div>
                            </div>
                        </bx:if>

                        <bx:set local.tone = prc.toneReview ?: {} >
                        <bx:if isStruct( local.tone ) && structKeyExists( local.tone, "label" ) && len( local.tone.label ?: "" )>
                            <bx:set local.toneClass = local.tone.label eq "excellent" ? "success"
                                                  : ( local.tone.label eq "good"      ? "success"
                                                  : ( local.tone.label eq "ok"        ? "warning"
                                                  :                                     "danger" ) ) >
                            <div class="alert alert-#local.toneClass# py-2 px-3 small mb-2" role="note">
                                <div class="d-flex justify-content-between align-items-center">
                                    <strong><i class="bi bi-pencil-square"></i> Tone review</strong>
                                    <span class="badge text-bg-#local.toneClass#">#encodeForHTML( local.tone.label )# &middot; #encodeForHTML( local.tone.score )#/100</span>
                                </div>
                                <bx:if arrayLen( local.tone.suggestions ?: [] )>
                                    <ul class="mb-0 ps-3 mt-1">
                                        <bx:loop array="#local.tone.suggestions#" item="local.sug">
                                            <li>#encodeForHTML( local.sug )#</li>
                                        </bx:loop>
                                    </ul>
                                </bx:if>
                            </div>
                        </bx:if>

                        <bx:set local.replyBody = prc.suggestedReply ?: "" >
                        <bx:if !len( local.replyBody ) && isStruct( prc.toneReview ?: {} ) && structKeyExists( prc.toneReview ?: {}, "draft" )>
                            <bx:set local.replyBody = prc.toneReview.draft >
                        </bx:if>

                        <form method="post" action="/agent/tickets/#encodeForHTMLAttribute( local.t.getId() )#/reply" enctype="multipart/form-data">
                            <textarea class="form-control mb-2" name="body" id="reply-body-#encodeForHTMLAttribute( local.t.getId() )#" rows="4" placeholder="Reply visible to the requester...">#encodeForHTML( local.replyBody )#</textarea>
                            <div class="mb-2">
                                <label class="form-label small text-body-secondary mb-1">
                                    <i class="bi bi-paperclip"></i> Attachments (optional)
                                </label>
                                <input type="file" name="attachments" class="form-control form-control-sm" multiple>
                            </div>
                            <div class="d-flex justify-content-between align-items-center">
                                <bx:if prc.aiEnabled ?: false>
                                    <button class="btn btn-outline-secondary btn-sm" type="submit" formaction="/agent/tickets/#encodeForHTMLAttribute( local.t.getId() )#/check-tone">
                                        <i class="bi bi-pencil-square"></i> Check tone
                                    </button>
                                <bx:else>
                                    <span></span>
                                </bx:if>
                                <button class="btn btn-primary" type="submit">Send reply</button>
                            </div>
                        </form>
                    </div>
                    <div class="tab-pane fade" id="internal-pane" role="tabpanel">
                        <form method="post" action="/agent/tickets/#encodeForHTMLAttribute( local.t.getId() )#/internal-note" enctype="multipart/form-data">
                            <textarea class="form-control mb-2" name="body" rows="4" placeholder="Note visible only to agents..."></textarea>
                            <div class="mb-2">
                                <label class="form-label small text-body-secondary mb-1">
                                    <i class="bi bi-paperclip"></i> Attachments (optional)
                                </label>
                                <input type="file" name="attachments" class="form-control form-control-sm" multiple>
                            </div>
                            <div class="d-flex justify-content-end">
                                <button class="btn btn-warning" type="submit">Add internal note</button>
                            </div>
                        </form>
                    </div>
                    <div class="tab-pane fade" id="attachments-pane" role="tabpanel">

                        <!-- Upload form: multi-file, plain POST. Phase 8.7 will
                             enhance this into a drag-and-drop zone via JS. -->
                        <form method="post"
                              action="/agent/tickets/#encodeForHTMLAttribute( local.t.getId() )#/attachments"
                              enctype="multipart/form-data"
                              class="mb-3">
                            <label class="form-label small text-body-secondary">Upload files</label>
                            <div class="input-group input-group-sm">
                                <input type="file" name="attachments" class="form-control" multiple required>
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-cloud-upload"></i> Upload
                                </button>
                            </div>
                            <div class="form-text small">Multiple files allowed. Max per file follows UPLOAD_MAX_BYTES.</div>
                        </form>

                        <bx:if !arrayLen( prc.attachments ?: [] )>
                            <div class="text-body-secondary fst-italic">No attachments yet.</div>
                        <bx:else>
                            <div class="row g-2">
                                <bx:loop array="#prc.attachments#" item="local.att">
                                    <div class="col-12 col-md-6 col-xl-4">
                                        <div class="card h-100 #local.att.isDeleted() ? 'opacity-50' : ''#">
                                            <div class="card-body p-2 d-flex gap-2 align-items-start">
                                                <div style="flex:0 0 96px;">
                                                    <bx:if local.att.isImage() && local.att.getThumbnailStatus() == "ready" && !local.att.isDeleted()>
                                                        <a href="/agent/attachments/#encodeForHTMLAttribute( local.att.getId() )#" target="_blank">
                                                            <img src="/agent/attachments/#encodeForHTMLAttribute( local.att.getId() )#/thumbnail"
                                                                 alt="#encodeForHTMLAttribute( local.att.getOriginalFilename() )#"
                                                                 style="width:96px; height:96px; object-fit:cover; border-radius:4px; border:1px solid var(--bs-border-color);">
                                                        </a>
                                                    <bx:else>
                                                        <div class="d-flex align-items-center justify-content-center"
                                                             style="width:96px; height:96px; background:var(--bs-secondary-bg); border-radius:4px;">
                                                            <i class="bi bi-file-earmark" style="font-size:2.5rem; color:var(--bs-secondary);"></i>
                                                        </div>
                                                    </bx:if>
                                                </div>
                                                <div class="flex-grow-1" style="min-width:0;">
                                                    <div class="text-truncate fw-semibold" title="#encodeForHTMLAttribute( local.att.getOriginalFilename() )#">
                                                        #encodeForHTML( local.att.getOriginalFilename() )#
                                                    </div>
                                                    <div class="small text-body-secondary">
                                                        #local.att.displaySize()# &middot;
                                                        #encodeForHTML( dateTimeFormat( local.att.getCreatedAt(), "yyyy-mm-dd HH:nn" ) )#
                                                    </div>
                                                    <div class="small text-body-secondary text-truncate">
                                                        <bx:if len( local.att.getUploaderAgentId() ?: "" )>
                                                            agent
                                                        <bx:elseif len( local.att.getUploaderContactId() ?: "" )>
                                                            contact
                                                        <bx:else>
                                                            email
                                                        </bx:if>
                                                    </div>
                                                    <bx:if local.att.isDeleted()>
                                                        <div class="alert alert-secondary p-1 px-2 mt-1 mb-0 small">
                                                            <i class="bi bi-trash"></i> Deleted #encodeForHTML( dateTimeFormat( local.att.getDeletedAt(), "yyyy-mm-dd HH:nn" ) )#
                                                            <div class="text-body-secondary fst-italic" style="white-space:pre-wrap">#encodeForHTML( local.att.getDeletionReason() ?: "" )#</div>
                                                        </div>
                                                    <bx:else>
                                                        <div class="mt-2 d-flex gap-1">
                                                            <a class="btn btn-sm btn-outline-primary"
                                                               href="/agent/attachments/#encodeForHTMLAttribute( local.att.getId() )#"
                                                               target="_blank">
                                                                <i class="bi bi-download"></i>
                                                            </a>
                                                            <button type="button"
                                                                    class="btn btn-sm btn-outline-danger"
                                                                    data-bs-toggle="modal"
                                                                    data-bs-target="##deleteAttachmentModal"
                                                                    data-attachment-id="#encodeForHTMLAttribute( local.att.getId() )#"
                                                                    data-attachment-name="#encodeForHTMLAttribute( local.att.getOriginalFilename() )#">
                                                                <i class="bi bi-trash"></i>
                                                            </button>
                                                        </div>
                                                    </bx:if>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </bx:loop>
                            </div>
                        </bx:if>

                        <!-- Shared delete-with-reason modal. Vanilla JS fills
                             the hidden attachmentId field from the clicked
                             button's data attributes. -->
                        <div class="modal fade" id="deleteAttachmentModal" tabindex="-1" aria-hidden="true">
                            <div class="modal-dialog">
                                <form method="post" id="deleteAttachmentForm">
                                    <div class="modal-content">
                                        <div class="modal-header">
                                            <h5 class="modal-title">Delete attachment</h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                        </div>
                                        <div class="modal-body">
                                            <p class="small text-body-secondary">
                                                Removing <strong id="deleteAttachmentName"></strong> from this ticket.
                                                The file stays in storage for audit; clients and agents will no longer see it.
                                            </p>
                                            <label class="form-label">Reason (required)</label>
                                            <textarea name="reason" class="form-control" rows="3" required></textarea>
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                                            <button type="submit" class="btn btn-danger">Delete attachment</button>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                        <script>
                        (function(){
                            var ticketId = "#encodeForJavaScript( local.t.getId() )#";
                            var modal    = document.getElementById( 'deleteAttachmentModal' );
                            var form     = document.getElementById( 'deleteAttachmentForm' );
                            var nameEl   = document.getElementById( 'deleteAttachmentName' );
                            if ( !modal || !form ) return;
                            modal.addEventListener( 'show.bs.modal', function( ev ){
                                var btn  = ev.relatedTarget;
                                var aid  = btn.getAttribute( 'data-attachment-id' );
                                var name = btn.getAttribute( 'data-attachment-name' ) || '';
                                form.action = '/agent/tickets/' + encodeURIComponent( ticketId )
                                            + '/attachments/' + encodeURIComponent( aid ) + '/delete';
                                nameEl.textContent = name;
                            } );
                        })();
                        </script>
                    </div>
                </div>
            </div>
        </div>

    </div>


    <div class="col-12 col-lg-4">

        <!--
            Right-column panels. Follow-up B1: every right-column card
            is contributed through TicketPanelRegistry. The agent
            module's manifest registers the ten core panels (summary,
            kb-draft, related-articles, custom-fields, status, sla,
            assignment, block-sender, promote-sender, timeline);
            add-ons contribute additional panels via
            settings.tesserabx.ticketPanels. The registry sorts by
            sortWeight and applies the viewer's audience filter +
            requiresAi check before this loop runs.
        -->
        <bx:loop array="#tbxTicketPanels( "right" )#" item="local.p">
            <bx:if len( local.p.partial )>
                #view( view = local.p.partial, module = local.p.module )#
            </bx:if>
        </bx:loop>
    </div>
</div>
</bx:output>
