<bx:output>
<bx:set local.exportQs = "" >
<bx:loop array="#prc.statusArray#" item="s">
    <bx:set local.exportQs &= "status=" & encodeForURL( s ) & "&" >
</bx:loop>
<bx:set local.exportQs &= "priority=" & encodeForURL( prc.filters.priority ?: "" )
                       & "&organizationId=" & encodeForURL( prc.filters.organizationId ?: "" ) >

<form method="get" action="/agent/tickets" class="card mb-3" id="ticketFilterForm">
    <input type="hidden" name="statusFilterApplied" value="1">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-12">
                <label class="form-label" for="q">Search</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="search" class="form-control" id="q" name="q" placeholder="Subject or originating email..." value="#encodeForHTMLAttribute( prc.filters.q ?: "" )#">
                </div>
            </div>
            <div class="col-12 col-md-4">
                <label class="form-label d-block">Status</label>
                <div class="row row-cols-2 g-1" id="statusCheckboxes">
                    <bx:loop array="#prc.statuses#" item="s">
                        <div class="col">
                            <div class="form-check">
                                <input class="form-check-input status-filter-cb" type="checkbox"
                                        name="status"
                                        id="status_#encodeForHTMLAttribute( s )#"
                                        value="#encodeForHTMLAttribute( s )#"
                                        onchange="document.getElementById('ticketFilterForm').submit()"
                                        <bx:if arrayContains( prc.statusArray, s )>checked</bx:if>>
                                <label class="form-check-label" for="status_#encodeForHTMLAttribute( s )#">#encodeForHTML( s )#</label>
                            </div>
                        </div>
                    </bx:loop>
                </div>
            </div>
            <div class="col-12 col-md-3">
                <label class="form-label" for="priority">Priority</label>
                <select class="form-select" id="priority" name="priority" onchange="document.getElementById('ticketFilterForm').submit()">
                    <option value="">All</option>
                    <bx:loop array="#prc.priorities#" item="p">
                        <option value="#encodeForHTMLAttribute( p )#"<bx:if ( prc.filters.priority ?: "" ) eq p> selected</bx:if>>#encodeForHTML( p )#</option>
                    </bx:loop>
                </select>
            </div>
            <div class="col-12 col-md-3">
                <label class="form-label" for="organizationId">Organization</label>
                <select class="form-select" id="organizationId" name="organizationId" onchange="document.getElementById('ticketFilterForm').submit()">
                    <option value="">All organizations</option>
                    <bx:loop array="#prc.organizations#" item="org">
                        <option value="#encodeForHTMLAttribute( org.getId() )#"<bx:if ( prc.filters.organizationId ?: "" ) eq org.getId()> selected</bx:if>>#encodeForHTML( org.getName() )#</option>
                    </bx:loop>
                </select>
            </div>
            <div class="col-12 col-md-2 d-flex align-items-end">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="accountlessOnly" id="accountlessOnly" value="true"
                            onchange="document.getElementById('ticketFilterForm').submit()"
                            <bx:if ( prc.filters.accountlessOnly ?: "" ) eq "true" or ( prc.filters.accountlessOnly ?: false ) eq true> checked</bx:if>>
                    <label class="form-check-label" for="accountlessOnly">Accountless only</label>
                </div>
            </div>
        </div>
        <div class="d-flex justify-content-between align-items-center mt-3 flex-wrap gap-2">
            <div class="d-flex gap-2 small">
                <form method="post" action="/agent/tickets/saveStatusDefault" class="d-inline" id="saveStatusDefaultForm">
                    <input type="hidden" name="status" id="saveStatusDefaultValue" value="">
                    <button type="submit" class="btn btn-sm btn-link p-0 align-baseline">Save current as my default</button>
                </form>
                <span class="text-body-secondary">|</span>
                <form method="post" action="/agent/tickets/resetStatusDefault" class="d-inline">
                    <button type="submit" class="btn btn-sm btn-link p-0 align-baseline text-secondary">Reset to global default</button>
                </form>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <a class="btn btn-outline-secondary" href="/agent/reports/export/tickets.csv?#local.exportQs#">
                    <i class="bi bi-download"></i> Export CSV
                </a>
                <a class="btn btn-outline-secondary" href="/agent/tickets">Reset</a>
                <a class="btn btn-success" href="/agent/tickets/new"><i class="bi bi-plus-lg"></i> New ticket</a>
            </div>
        </div>
    </div>
</form>

<script>
    (function(){
        // The save-default form lives outside the main filter form (nested
        // forms are illegal HTML). On submit, copy the currently-checked
        // status checkboxes into a comma-delimited hidden field so the
        // handler receives the same shape it would from the filter form.
        var saveForm = document.getElementById('saveStatusDefaultForm');
        if ( saveForm ) {
            saveForm.addEventListener('submit', function(){
                var picked = Array.prototype.slice.call(
                    document.querySelectorAll('.status-filter-cb:checked')
                ).map(function(cb){ return cb.value; });
                document.getElementById('saveStatusDefaultValue').value = picked.join(',');
            });
        }
    })();
</script>

<div id="bulkBar" class="card mb-2 d-none">
    <div class="card-body py-2">
        <form id="bulkForm" method="post" action="/agent/tickets/bulk" class="row g-2 align-items-end">
            <input type="hidden" name="ticketIds" id="bulkTicketIds" value="">

            <div class="col-auto pe-0">
                <span class="badge text-bg-primary" id="bulkSelectionCount">0 selected</span>
            </div>

            <div class="col-md-3">
                <label class="form-label small mb-1" for="bulkAction">Action</label>
                <select class="form-select form-select-sm" id="bulkAction" name="action">
                    <option value="">-- choose --</option>
                    <bx:loop array="#prc.bulkActions#" item="ba">
                        <option value="#encodeForHTMLAttribute( ba.key )#">#encodeForHTML( ba.label )#</option>
                    </bx:loop>
                </select>
            </div>

            <div class="col-md-4 bulk-param-assign d-none">
                <label class="form-label small mb-1" for="assignedToAgentId">Assign to</label>
                <select class="form-select form-select-sm" id="assignedToAgentId" name="assignedToAgentId">
                    <option value="">-- unassign --</option>
                    <bx:loop array="#prc.assignableAgents#" item="a">
                        <bx:if a.isActive>
                            <option value="#encodeForHTMLAttribute( a.id )#">#encodeForHTML( a.email )#</option>
                        </bx:if>
                    </bx:loop>
                </select>
            </div>

            <div class="col-md-3 bulk-param-status d-none">
                <label class="form-label small mb-1" for="bulkStatus">Status</label>
                <select class="form-select form-select-sm" id="bulkStatus" name="status">
                    <bx:loop array="#prc.statuses#" item="s">
                        <option value="#encodeForHTMLAttribute( s )#">#encodeForHTML( s )#</option>
                    </bx:loop>
                </select>
            </div>

            <div class="col-md-3 bulk-param-tag d-none">
                <label class="form-label small mb-1" for="bulkTag">Tag name</label>
                <input type="text" class="form-control form-control-sm" id="bulkTag" name="tag" placeholder="e.g. escalated">
            </div>

            <div class="col text-end">
                <button class="btn btn-sm btn-primary" type="submit"><i class="bi bi-lightning"></i> Apply</button>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
        <table class="table table-striped table-hover mb-0 align-middle">
            <thead>
                <tr>
                    <th style="width: 2.5rem;"><input type="checkbox" id="bulkSelectAll" class="form-check-input"></th>
                    <th>##</th>
                    <th>Subject</th>
                    <th>Organization</th>
                    <th>Status</th>
                    <th>Priority</th>
                    <th>SLA</th>
                    <th>Assigned to</th>
                    <th>Updated</th>
                </tr>
            </thead>
            <tbody>
                <bx:if !arrayLen( prc.tickets )>
                    <tr><td colspan="9" class="text-center text-body-secondary py-4">No tickets match.</td></tr>
                </bx:if>
                <bx:loop array="#prc.tickets#" item="t">
                    <bx:set sla = prc.slaByTicketId[ t.getId() ] ?: { status : "none" } >
                    <tr>
                        <td><input type="checkbox" class="form-check-input bulk-row" value="#encodeForHTMLAttribute( t.getId() )#"></td>
                        <td class="text-body-secondary">##<a href="/agent/tickets/#encodeForURL( t.getId() )#" class="link-secondary">#t.getTicketNumber()#</a></td>
                        <td><a href="/agent/tickets/#encodeForURL( t.getId() )#">#encodeForHTML( t.getSubject() )#</a></td>
                        <td>
                            <bx:if t.isAccountless()>
                                <span class="badge text-bg-warning">Accountless</span>
                            <bx:else>
                                #encodeForHTML( prc.orgNamesById[ t.getOrganizationId() ] ?: "(unknown)" )#
                            </bx:if>
                        </td>
                        <td><span class="badge text-bg-secondary">#encodeForHTML( t.getStatus() )#</span></td>
                        <td>#encodeForHTML( t.getPriority() )#</td>
                        <td>
                            <bx:switch expression="#sla.status#">
                                <bx:case value="breached"><span class="badge text-bg-danger">Breached</span></bx:case>
                                <bx:case value="approaching"><span class="badge text-bg-warning">Approaching</span></bx:case>
                                <bx:case value="paused"><span class="badge text-bg-info">Paused</span></bx:case>
                                <bx:case value="met"><span class="badge text-bg-success">Met</span></bx:case>
                                <bx:case value="ok"><span class="badge text-bg-secondary">On track</span></bx:case>
                                <bx:defaultcase><span class="text-body-secondary">-</span></bx:defaultcase>
                            </bx:switch>
                        </td>
                        <td>
                            <bx:if len( t.getAssignedToAgentId() ?: "" ) and structKeyExists( prc.agentDirectory, t.getAssignedToAgentId() )>
                                <bx:set local.assignee = prc.agentDirectory[ t.getAssignedToAgentId() ] >
                                <bx:set local.assignee.hasAvatar = len( local.assignee.profileImageOriginalPath ?: "" ) gt 0 >
                                <bx:set local.assignee.uploadedAt = local.assignee.profileImageUploadedAt >
                                <div class="d-flex align-items-center gap-2">
                                    #view( view = "_partials/avatar", module = "core", args = { agent : local.assignee, size : 24 } )#
                                    <small>#encodeForHTML( trim( local.assignee.firstName & " " & local.assignee.lastName ) )#</small>
                                </div>
                            <bx:else>
                                <span class="text-body-secondary">—</span>
                            </bx:if>
                        </td>
                        <td><small>#encodeForHTML( dateTimeFormat( t.getUpdatedAt(), "yyyy-mm-dd HH:nn" ) )#</small></td>
                    </tr>
                </bx:loop>
            </tbody>
        </table>
        </div>
    </div>
</div>

<script>
    (function(){
        var rows      = document.querySelectorAll('.bulk-row');
        var selectAll = document.getElementById('bulkSelectAll');
        var bar       = document.getElementById('bulkBar');
        var count     = document.getElementById('bulkSelectionCount');
        var idsInput  = document.getElementById('bulkTicketIds');
        var actionSel = document.getElementById('bulkAction');
        var paramAssign = document.querySelector('.bulk-param-assign');
        var paramStatus = document.querySelector('.bulk-param-status');
        var paramTag    = document.querySelector('.bulk-param-tag');

        function syncSelection(){
            var ids = [];
            rows.forEach(function(r){ if ( r.checked ) ids.push(r.value); });
            idsInput.value = ids.join(',');
            count.textContent = ids.length + ' selected';
            if ( ids.length ) bar.classList.remove('d-none');
            else bar.classList.add('d-none');
        }

        function syncActionInputs(){
            paramAssign.classList.add('d-none');
            paramStatus.classList.add('d-none');
            paramTag.classList.add('d-none');
            switch ( actionSel.value ) {
                case 'assign':        paramAssign.classList.remove('d-none'); break;
                case 'change_status': paramStatus.classList.remove('d-none'); break;
                case 'add_tag':       paramTag.classList.remove('d-none');    break;
            }
        }

        rows.forEach(function(r){ r.addEventListener('change', syncSelection); });
        if ( selectAll ) {
            selectAll.addEventListener('change', function(){
                rows.forEach(function(r){ r.checked = selectAll.checked; });
                syncSelection();
            });
        }
        if ( actionSel ) actionSel.addEventListener('change', syncActionInputs);
    })();
</script>
</bx:output>
