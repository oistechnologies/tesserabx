<bx:output>
<form method="get" action="/agent/tickets" class="card mb-3">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-12">
                <label class="form-label" for="q">Search</label>
                <input type="search" class="form-control" id="q" name="q" placeholder="Subject or originating email..." value="#encodeForHTMLAttribute( prc.filters.q ?: "" )#">
            </div>
            <div class="col-12 col-md-3">
                <label class="form-label" for="status">Status</label>
                <select class="form-select" id="status" name="status">
                    <option value="">All</option>
                    <bx:loop array="#prc.statuses#" item="s">
                        <option value="#encodeForHTMLAttribute( s )#"<bx:if ( prc.filters.status ?: "" ) eq s> selected</bx:if>>#encodeForHTML( s )#</option>
                    </bx:loop>
                </select>
            </div>
            <div class="col-12 col-md-3">
                <label class="form-label" for="priority">Priority</label>
                <select class="form-select" id="priority" name="priority">
                    <option value="">All</option>
                    <bx:loop array="#prc.priorities#" item="p">
                        <option value="#encodeForHTMLAttribute( p )#"<bx:if ( prc.filters.priority ?: "" ) eq p> selected</bx:if>>#encodeForHTML( p )#</option>
                    </bx:loop>
                </select>
            </div>
            <div class="col-12 col-md-4">
                <label class="form-label" for="organizationId">Organization</label>
                <select class="form-select" id="organizationId" name="organizationId">
                    <option value="">All organizations</option>
                    <bx:loop array="#prc.organizations#" item="org">
                        <option value="#encodeForHTMLAttribute( org.getId() )#"<bx:if ( prc.filters.organizationId ?: "" ) eq org.getId()> selected</bx:if>>#encodeForHTML( org.getName() )#</option>
                    </bx:loop>
                </select>
            </div>
            <div class="col-12 col-md-2 d-flex align-items-end">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="accountlessOnly" id="accountlessOnly" value="true"<bx:if ( prc.filters.accountlessOnly ?: "" ) eq "true" or ( prc.filters.accountlessOnly ?: false ) eq true> checked</bx:if>>
                    <label class="form-check-label" for="accountlessOnly">Accountless only</label>
                </div>
            </div>
        </div>
        <div class="d-flex justify-content-end gap-2 mt-3 flex-wrap">
            <bx:set local.exportQs = "status=" & encodeForURL( prc.filters.status ?: "" )
                                   & "&priority=" & encodeForURL( prc.filters.priority ?: "" )
                                   & "&organizationId=" & encodeForURL( prc.filters.organizationId ?: "" ) >
            <a class="btn btn-outline-secondary" href="/agent/reports/export/tickets.csv?#local.exportQs#">
                <i class="bi bi-download"></i> Export CSV
            </a>
            <a class="btn btn-outline-secondary" href="/agent/tickets">Reset</a>
            <button class="btn btn-primary" type="submit">Filter</button>
            <a class="btn btn-success" href="/agent/tickets/new"><i class="bi bi-plus-lg"></i> New ticket</a>
        </div>
    </div>
</form>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0 align-middle">
            <thead>
                <tr>
                    <th>##</th>
                    <th>Subject</th>
                    <th>Organization</th>
                    <th>Status</th>
                    <th>Priority</th>
                    <th>SLA</th>
                    <th>Updated</th>
                </tr>
            </thead>
            <tbody>
                <bx:if !arrayLen( prc.tickets )>
                    <tr><td colspan="7" class="text-center text-body-secondary py-4">No tickets match.</td></tr>
                </bx:if>
                <bx:loop array="#prc.tickets#" item="t">
                    <bx:set sla = prc.slaByTicketId[ t.getId() ] ?: { status : "none" } >
                    <tr>
                        <td class="text-body-secondary">##<a href="/agent/tickets/#encodeForURL( t.getId() )#" class="link-secondary">#t.getTicketNumber()#</a></td>
                        <td><a href="/agent/tickets/#encodeForURL( t.getId() )#">#encodeForHTML( t.getSubject() )#</a></td>
                        <td>
                            <bx:if t.isAccountless()>
                                <span class="badge text-bg-warning">Accountless</span>
                            <bx:else>
                                #encodeForHTML( prc.orgNamesById[ t.getOrganizationId() ] ?: "(unknown)" )#
                            </bx:if>
                        </td>
                        <td><span class="badge text-bg-secondary">#encodeForHTML( t.getStatus() )#</span></td>
                        <td>#encodeForHTML( t.getPriority() )#</td>
                        <td>
                            <bx:switch expression="#sla.status#">
                                <bx:case value="breached"><span class="badge text-bg-danger">Breached</span></bx:case>
                                <bx:case value="approaching"><span class="badge text-bg-warning">Approaching</span></bx:case>
                                <bx:case value="paused"><span class="badge text-bg-info">Paused</span></bx:case>
                                <bx:case value="met"><span class="badge text-bg-success">Met</span></bx:case>
                                <bx:case value="ok"><span class="badge text-bg-secondary">On track</span></bx:case>
                                <bx:defaultcase><span class="text-body-secondary">-</span></bx:defaultcase>
                            </bx:switch>
                        </td>
                        <td><small>#encodeForHTML( dateTimeFormat( t.getUpdatedAt(), "yyyy-mm-dd HH:nn" ) )#</small></td>
                    </tr>
                </bx:loop>
            </tbody>
        </table>
    </div>
</div>
</bx:output>
