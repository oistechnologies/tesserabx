/**
 * ContactsServiceSpec: behavioral specs for the contacts service.
 *
 * Exercises the agent-created provisioning path, role assignment,
 * domain-mapping resolution, and the basic merge flow. Each `it`
 * creates and tears down its own ephemeral organization so specs
 * stay independent of each other and of the dev seed data.
 */
class extends="coldbox.system.testing.BaseTestCase" appMapping="/" {

    function beforeAll(){
        super.beforeAll();
        super.setup();
        variables.service = getController().getWireBox().getInstance( "ContactsService@contacts" );
    }

    function run(){
        describe( "ContactsService", function(){

            it( "createOrganization persists name, slug, and tier", function(){
                var slug = "spec-" & lCase( replace( createUUID(), "-", "", "all" ) );
                var org = variables.service.createOrganization( {
                    name : "Spec Org",
                    slug : slug,
                    tier : "Silver"
                } );
                expect( org.getId() ).notToBeEmpty();
                expect( org.getSlug() ).toBe( slug );
                expect( org.getTier() ).toBe( "Silver" );
                cleanupOrganization( org.getId() );
            } );

            it( "provisionContact hashes the password and writes a contact", function(){
                var org = makeOrg();
                var contact = variables.service.provisionContact( {
                    organizationId : org.getId(),
                    email          : "alice-" & createUUID() & "@example.com",
                    password       : "plaintext-secret",
                    firstName      : "Alice",
                    lastName       : "Tester"
                } );
                expect( contact.getId() ).notToBeEmpty();
                expect( contact.getPasswordHash() ).notToBe( "plaintext-secret" );
                expect( contact.getFirstName() ).toBe( "Alice" );
                cleanupContact( contact.getId() );
                cleanupOrganization( org.getId() );
            } );

            it( "assignRole creates a role row and is idempotent", function(){
                var org = makeOrg();
                var contact = makeContact( org.getId() );
                var first = variables.service.assignRole(
                    contactId : contact.getId(),
                    roleKey   : "organization-admin"
                );
                var second = variables.service.assignRole(
                    contactId : contact.getId(),
                    roleKey   : "organization-admin"
                );
                expect( first.getId() ).toBe( second.getId() );

                var roles = variables.service.listRolesForContact( contact.getId() );
                expect( arrayLen( roles ) ).toBe( 1 );

                cleanupContactRoles( contact.getId() );
                cleanupContact( contact.getId() );
                cleanupOrganization( org.getId() );
            } );

            it( "revokeRole removes the role row", function(){
                var org = makeOrg();
                var contact = makeContact( org.getId() );
                variables.service.assignRole(
                    contactId : contact.getId(),
                    roleKey   : "organization-admin"
                );
                variables.service.revokeRole(
                    contactId : contact.getId(),
                    roleKey   : "organization-admin"
                );
                expect( arrayLen( variables.service.listRolesForContact( contact.getId() ) ) ).toBe( 0 );

                cleanupContact( contact.getId() );
                cleanupOrganization( org.getId() );
            } );

            it( "Contact.isOrganizationAdmin reflects the role row", function(){
                var org = makeOrg();
                var contact = makeContact( org.getId() );
                expect( contact.isOrganizationAdmin() ).toBeFalse();

                variables.service.assignRole(
                    contactId : contact.getId(),
                    roleKey   : "organization-admin"
                );
                var refreshed = variables.service.getContactById( contact.getId() );
                expect( refreshed.isOrganizationAdmin() ).toBeTrue();

                cleanupContactRoles( contact.getId() );
                cleanupContact( contact.getId() );
                cleanupOrganization( org.getId() );
            } );

            it( "resolveOrganizationForEmail returns the mapped organization", function(){
                var org = makeOrg();
                var domain = "spec-" & lCase( replace( createUUID(), "-", "", "all" ) ) & ".test";
                variables.service.addDomainMapping(
                    organizationId : org.getId(),
                    domain         : domain
                );
                var resolved = variables.service.resolveOrganizationForEmail( "anyone@" & domain );
                expect( resolved ).notToBeNull();
                expect( resolved.getId() ).toBe( org.getId() );

                queryExecute(
                    "DELETE FROM organization_domains WHERE organization_id = :orgId",
                    { orgId : org.getId() }
                );
                cleanupOrganization( org.getId() );
            } );

            it( "writes audit events for role grant and revoke", function(){
                var audit = getController().getWireBox().getInstance( "AuditService@audit" );
                var org = makeOrg();
                var contact = makeContact( org.getId() );

                variables.service.assignRole(
                    contactId : contact.getId(),
                    roleKey   : "organization-admin"
                );
                variables.service.revokeRole(
                    contactId : contact.getId(),
                    roleKey   : "organization-admin"
                );

                var grants = audit.search(
                    eventType : "contact.role_granted",
                    entityId  : contact.getId(),
                    limit     : 10
                );
                var revokes = audit.search(
                    eventType : "contact.role_revoked",
                    entityId  : contact.getId(),
                    limit     : 10
                );
                expect( arrayLen( grants ) ).toBe( 1 );
                expect( arrayLen( revokes ) ).toBe( 1 );
                expect( grants[ 1 ].getMetadataAsStruct().roleKey ).toBe( "organization-admin" );

                queryExecute( "DELETE FROM audit_events WHERE entity_id = :id", { id : contact.getId() } );
                cleanupContact( contact.getId() );
                queryExecute( "DELETE FROM audit_events WHERE entity_id = :id", { id : org.getId() } );
                cleanupOrganization( org.getId() );
            } );

            it( "mergeContacts moves roles onto the target and deactivates the source", function(){
                var org = makeOrg();
                var source = makeContact( org.getId(), "src-" & createUUID() & "@example.com" );
                var target = makeContact( org.getId(), "tgt-" & createUUID() & "@example.com" );
                variables.service.assignRole(
                    contactId : source.getId(),
                    roleKey   : "organization-admin"
                );

                var result = variables.service.mergeContacts(
                    sourceContactId : source.getId(),
                    targetContactId : target.getId()
                );

                expect( result.rolesMoved ).toBe( 1 );
                expect( arrayLen( variables.service.listRolesForContact( source.getId() ) ) ).toBe( 0 );
                expect( arrayLen( variables.service.listRolesForContact( target.getId() ) ) ).toBe( 1 );

                var sourceReloaded = variables.service.getContactById( source.getId() );
                expect( sourceReloaded.getIsActive() ).toBeFalse();

                cleanupContactRoles( target.getId() );
                cleanupContact( source.getId() );
                cleanupContact( target.getId() );
                cleanupOrganization( org.getId() );
            } );

            it( "updateOrganization changes attributes including the auto-provision flag", function(){
                var org = makeOrg();
                variables.service.updateOrganization( org.getId(), {
                    phone                 : "+1-555-1000",
                    website               : "https://updated.example.com",
                    status                : "suspended",
                    autoProvisionContacts : true
                } );
                var reloaded = variables.service.getOrganizationById( org.getId() );
                expect( reloaded.getPhone() ).toBe( "+1-555-1000" );
                expect( reloaded.getWebsite() ).toBe( "https://updated.example.com" );
                expect( reloaded.getStatus() ).toBe( "suspended" );
                expect( reloaded.getAutoProvisionContacts() ).toBeTrue();
                cleanupOrganization( org.getId() );
            } );

            it( "deactivateOrganization clears the active flag and archives status", function(){
                var org = makeOrg();
                variables.service.deactivateOrganization( org.getId() );
                var reloaded = variables.service.getOrganizationById( org.getId() );
                expect( reloaded.getIsActive() ).toBeFalse();
                expect( reloaded.getStatus() ).toBe( "archived" );

                variables.service.setOrganizationActive( id : org.getId(), active : true );
                var reactivated = variables.service.getOrganizationById( org.getId() );
                expect( reactivated.getIsActive() ).toBeTrue();
                expect( reactivated.getStatus() ).toBe( "active" );
                cleanupOrganization( org.getId() );
            } );

            it( "office CRUD round-trips and delete unassigns contacts", function(){
                var org = makeOrg();
                var office = variables.service.createOffice( org.getId(), {
                    name      : "HQ",
                    city      : "Austin",
                    region    : "TX",
                    isPrimary : true
                } );
                expect( office.getId() ).notToBeEmpty();
                expect( office.getIsPrimary() ).toBeTrue();

                var fetched = variables.service.getOfficeById( office.getId() );
                expect( fetched.getCity() ).toBe( "Austin" );

                variables.service.updateOffice( office.getId(), { name : "HQ West", phone : "+1-512-555-0100" } );
                var updated = variables.service.getOfficeById( office.getId() );
                expect( updated.getName() ).toBe( "HQ West" );
                expect( updated.getPhone() ).toBe( "+1-512-555-0100" );

                // A contact assigned to the office is unassigned (not
                // deleted) when the office is deleted.
                var contact = variables.service.provisionContact( {
                    organizationId : org.getId(),
                    email          : "office-" & createUUID() & "@example.com",
                    password       : "spec-password",
                    officeId       : office.getId()
                } );
                variables.service.deleteOffice( office.getId() );
                expect( variables.service.getOfficeById( office.getId() ) ).toBeNull();
                var reloadedContact = variables.service.getContactById( contact.getId() );
                expect( reloadedContact ).notToBeNull();
                expect( len( reloadedContact.getOfficeId() ?: "" ) ).toBe( 0 );

                cleanupContact( contact.getId() );
                cleanupOrganization( org.getId() );
            } );

            it( "setDomainVerified and removeDomainMapping manage the approved-domain list", function(){
                var org = makeOrg();
                var domain = "spec-" & lCase( replace( createUUID(), "-", "", "all" ) ) & ".test";
                var mapping = variables.service.addDomainMapping(
                    organizationId : org.getId(),
                    domain         : domain,
                    isVerified     : false
                );
                expect( mapping.getIsVerified() ).toBeFalse();

                variables.service.setDomainVerified( id : mapping.getId(), verified : true );
                expect( variables.service.getDomainMapping( domain ).getIsVerified() ).toBeTrue();

                variables.service.removeDomainMapping( mapping.getId() );
                expect( variables.service.getDomainMapping( domain ) ).toBeNull();

                cleanupOrganization( org.getId() );
            } );

            it( "vipContactIds returns only VIP contacts", function(){
                var org = makeOrg();
                var vip = variables.service.provisionContact( {
                    organizationId : org.getId(),
                    email          : "vipid-" & createUUID() & "@example.com",
                    password       : "spec-password",
                    isVip          : true
                } );
                var plain = makeContact( org.getId() );
                var ids = variables.service.vipContactIds();
                expect( ids ).toInclude( vip.getId() );
                expect( ids ).notToInclude( plain.getId() );

                cleanupContact( vip.getId() );
                cleanupContact( plain.getId() );
                cleanupOrganization( org.getId() );
            } );

            it( "directoryFor includes the isVip flag and office name", function(){
                var org    = makeOrg();
                var office = variables.service.createOffice( org.getId(), { name : "HQ Dir" } );
                var vip = variables.service.provisionContact( {
                    organizationId : org.getId(),
                    email          : "vip-" & createUUID() & "@example.com",
                    password       : "spec-password",
                    isVip          : true,
                    officeId       : office.getId()
                } );
                var plain = makeContact( org.getId() );
                var dir = variables.service.directoryFor( [ vip.getId(), plain.getId() ] );
                expect( dir[ vip.getId() ].isVip ).toBeTrue();
                expect( dir[ vip.getId() ].officeName ).toBe( "HQ Dir" );
                expect( dir[ plain.getId() ].isVip ).toBeFalse();
                expect( dir[ plain.getId() ].officeName ).toBe( "" );

                cleanupContact( vip.getId() );
                cleanupContact( plain.getId() );
                cleanupOrganization( org.getId() );
            } );

            describe( "resolveOrAutoProvisionContact", function(){

                it( "returns the existing contact when the email is already known", function(){
                    var org = makeOrg();
                    var contact = makeContact( org.getId(), "known-" & createUUID() & "@example.com" );
                    var resolved = variables.service.resolveOrAutoProvisionContact( contact.getEmail() );
                    expect( resolved ).notToBeNull();
                    expect( resolved.getId() ).toBe( contact.getId() );
                    cleanupContact( contact.getId() );
                    cleanupOrganization( org.getId() );
                } );

                it( "returns null when the domain is mapped but not verified", function(){
                    var org = autoProvisionOrg();
                    var domain = specDomain();
                    variables.service.addDomainMapping( organizationId : org.getId(), domain : domain, isVerified : false );
                    // Inline the call into expect(): a `var x = <null>`
                    // assignment is dropped by BoxLang's scope walker and
                    // a later reference throws KeyNotFoundException.
                    expect( variables.service.resolveOrAutoProvisionContact( "newperson@" & domain ) ).toBeNull();
                    cleanupDomains( org.getId() );
                    cleanupOrganization( org.getId() );
                } );

                it( "returns null when verified but the org has auto-provision off", function(){
                    var org = makeOrg(); // auto_provision defaults to false
                    var domain = specDomain();
                    variables.service.addDomainMapping( organizationId : org.getId(), domain : domain, isVerified : true );
                    expect( variables.service.resolveOrAutoProvisionContact( "newperson@" & domain ) ).toBeNull();
                    cleanupDomains( org.getId() );
                    cleanupOrganization( org.getId() );
                } );

                it( "auto-provisions a domain-auto contact when verified and enabled", function(){
                    var org = autoProvisionOrg();
                    var domain = specDomain();
                    variables.service.addDomainMapping( organizationId : org.getId(), domain : domain, isVerified : true );
                    var email = "newperson-" & createUUID() & "@" & domain;
                    var resolved = variables.service.resolveOrAutoProvisionContact( email );
                    expect( resolved ).notToBeNull();
                    expect( resolved.getOrganizationId() ).toBe( org.getId() );
                    expect( resolved.getSource() ).toBe( "domain-auto" );
                    expect( resolved.getEmail() ).toBe( lCase( email ) );

                    cleanupContact( resolved.getId() );
                    cleanupDomains( org.getId() );
                    cleanupOrganization( org.getId() );
                } );

            } );

        } );
    }

    // ---------------- helpers ----------------

    private any function makeOrg(){
        return variables.service.createOrganization( {
            name : "Spec Org " & createUUID(),
            slug : "spec-" & lCase( replace( createUUID(), "-", "", "all" ) )
        } );
    }

    private any function makeContact( required string organizationId, string email ){
        var addr = structKeyExists( arguments, "email" ) ? arguments.email : "c-" & createUUID() & "@example.com";
        return variables.service.provisionContact( {
            organizationId : arguments.organizationId,
            email          : addr,
            password       : "spec-password"
        } );
    }

    private any function autoProvisionOrg(){
        var org = makeOrg();
        variables.service.updateOrganization( org.getId(), { autoProvisionContacts : true } );
        return variables.service.getOrganizationById( org.getId() );
    }

    private string function specDomain(){
        return "spec-" & lCase( replace( createUUID(), "-", "", "all" ) ) & ".test";
    }

    private void function cleanupDomains( required string organizationId ){
        queryExecute(
            "DELETE FROM organization_domains WHERE organization_id = :orgId",
            { orgId : arguments.organizationId }
        );
    }

    private void function cleanupContact( required string id ){
        queryExecute( "DELETE FROM contacts WHERE id = :id", { id : arguments.id } );
    }

    private void function cleanupContactRoles( required string contactId ){
        queryExecute( "DELETE FROM contact_roles WHERE contact_id = :cid", { cid : arguments.contactId } );
    }

    private void function cleanupOrganization( required string id ){
        queryExecute( "DELETE FROM organizations WHERE id = :id", { id : arguments.id } );
    }

}
