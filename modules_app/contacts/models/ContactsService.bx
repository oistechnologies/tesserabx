/**
 * ContactsService: the public surface other modules use to reach
 * contact and organization data.
 *
 * Per CLAUDE.md, no other module imports the Contact / Organization /
 * Office / ContactRole / OrganizationDomain entities directly. They
 * call this service. The service owns input validation (cbvalidation
 * usage lives in handlers; this service trusts its callers but checks
 * preconditions that affect data integrity).
 *
 * Phase 1 surface:
 *   - Organization read / list / create
 *   - Office read / list / create within an organization
 *   - Contact read / list / create (the agent-created provisioning
 *     path), update, deactivate
 *   - Role assignment: assignRole / revokeRole / listRoles
 *   - Domain mapping: resolveOrganizationForEmail / addDomainMapping /
 *     listDomainMappings
 *   - Contact merge (basic): mergeContacts
 *
 * Phase 1c will extend this service when tickets need to look up the
 * contact for an inbound message.
 */
class singleton=true {

    property name="wirebox"             inject="wirebox";
    property name="bcrypt"              inject="@BCrypt";
    property name="auditService"        inject="AuditService@audit";
    property name="interceptorService"  inject="coldbox:interceptorService";
    property name="eventPayloadBuilder" inject="EventPayloadBuilder@core";

    // ---------------- Organizations ----------------

    public any function getOrganizationById( required string id ){
        var org = wirebox.getInstance( "Organization@contacts" )
            .where( "id", arguments.id )
            .first();
        return isNull( org ) ? javaCast( "null", "" ) : org;
    }

    public any function getOrganizationBySlug( required string slug ){
        var org = wirebox.getInstance( "Organization@contacts" )
            .where( "slug", arguments.slug )
            .first();
        return isNull( org ) ? javaCast( "null", "" ) : org;
    }

    public array function listOrganizations(){
        return wirebox.getInstance( "Organization@contacts" )
            .orderBy( "name" )
            .get();
    }

    /**
     * `{ value, label }` rows for every organization, sorted by name.
     * Used by any dropdown that needs an organization picker (e.g. the
     * automation rule editor's organizationId condition field).
     */
    public array function listOrganizationOptions(){
        var rows = queryExecute(
            "SELECT id, name FROM organizations ORDER BY name"
        );
        var out = [];
        for ( var i = 1; i <= rows.recordCount; i++ ) {
            out.append( { value : rows.id[ i ], label : rows.name[ i ] } );
        }
        return out;
    }

    /**
     * Contact + office counts per organization, keyed by org id, in a
     * single aggregate query (avoids N+1 from the org list view).
     * Orgs with no contacts/offices are still present with zeroes.
     */
    public struct function organizationCounts(){
        var rows = queryExecute(
            "SELECT o.id AS org_id,
                    count( DISTINCT c.id ) AS contact_count,
                    count( DISTINCT f.id ) AS office_count
             FROM   organizations o
             LEFT JOIN contacts c ON c.organization_id = o.id
             LEFT JOIN offices  f ON f.organization_id = o.id
             GROUP BY o.id"
        );
        var out = {};
        for ( var i = 1; i <= rows.recordCount; i++ ) {
            out[ rows.org_id[ i ] ] = {
                "contacts" : rows.contact_count[ i ],
                "offices"  : rows.office_count[ i ]
            };
        }
        return out;
    }

    public any function createOrganization( required struct data ){
        var org = wirebox.getInstance( "Organization@contacts" );
        org.setId( newId() );
        org.setName( arguments.data.name );
        org.setSlug( len( arguments.data.slug ?: "" ) ? arguments.data.slug : slugify( arguments.data.name ) );
        applyOrganizationData( org, arguments.data );
        // Organizations carry no jsonb/PGobject column, so Quick's
        // save() is safe here (unlike Contact, which must use a
        // targeted UPDATE because of mfa_recovery_codes).
        org.save();
        recordAudit(
            eventType      : "organization.created",
            entityType     : "Organization",
            entityId       : org.getId(),
            organizationId : org.getId(),
            metadata       : { "name" : org.getName(), "slug" : org.getSlug(), "tier" : org.getTier() ?: "" }
        );

        interceptorService.announce(
            "onOrganizationCreated",
            eventPayloadBuilder.build(
                event          : "onOrganizationCreated",
                organizationId : org.getId(),
                actorType      : arguments.data.actorType ?: "system",
                actorId        : arguments.data.actorId ?: "system",
                entity         : { type : "Organization", id : org.getId() },
                metadata       : { name : org.getName(), slug : org.getSlug(), tier : org.getTier() ?: "" }
            ),
            true
        );
        return org;
    }

    /**
     * Update an organization's attributes. Only the keys present in
     * `data` are touched; absent keys are left as they are. Quick's
     * save() is safe because organizations have no jsonb column.
     */
    public any function updateOrganization( required string id, required struct data ){
        var org = getOrganizationById( arguments.id );
        if ( isNull( org ) ) return javaCast( "null", "" );
        if ( structKeyExists( arguments.data, "name" ) && len( arguments.data.name ) ) {
            org.setName( arguments.data.name );
        }
        if ( structKeyExists( arguments.data, "slug" ) && len( arguments.data.slug ) ) {
            org.setSlug( slugify( arguments.data.slug ) );
        }
        applyOrganizationData( org, arguments.data );
        org.save();
        recordAudit(
            eventType      : "organization.updated",
            entityType     : "Organization",
            entityId       : org.getId(),
            organizationId : org.getId(),
            actorType      : arguments.data.actorType ?: "agent",
            actorId        : arguments.data.actorId ?: "",
            metadata       : { "name" : org.getName(), "slug" : org.getSlug() }
        );

        interceptorService.announce(
            "onOrganizationUpdated",
            eventPayloadBuilder.build(
                event          : "onOrganizationUpdated",
                organizationId : org.getId(),
                actorType      : arguments.data.actorType ?: "agent",
                actorId        : arguments.data.actorId ?: "system",
                entity         : { type : "Organization", id : org.getId() },
                metadata       : { name : org.getName() }
            ),
            true
        );
        return org;
    }

    /**
     * Flip an organization's active flag. Deactivation also moves the
     * lifecycle status to "archived" so the list view reflects it;
     * reactivation restores "active".
     */
    public any function setOrganizationActive(
        required string  id,
        required boolean active,
        string actorId = ""
    ){
        var org = getOrganizationById( arguments.id );
        if ( isNull( org ) ) return javaCast( "null", "" );
        org.setIsActive( arguments.active );
        org.setStatus( arguments.active ? "active" : "archived" );
        org.save();
        var eventType = arguments.active ? "organization.activated" : "organization.deactivated";
        recordAudit(
            eventType      : eventType,
            entityType     : "Organization",
            entityId       : org.getId(),
            organizationId : org.getId(),
            actorType      : "agent",
            actorId        : arguments.actorId
        );

        interceptorService.announce(
            arguments.active ? "onOrganizationUpdated" : "onOrganizationDeactivated",
            eventPayloadBuilder.build(
                event          : arguments.active ? "onOrganizationUpdated" : "onOrganizationDeactivated",
                organizationId : org.getId(),
                actorType      : "agent",
                actorId        : len( arguments.actorId ) ? arguments.actorId : "system",
                entity         : { type : "Organization", id : org.getId() }
            ),
            true
        );
        return org;
    }

    public any function deactivateOrganization( required string id, string actorId = "" ){
        return setOrganizationActive( id : arguments.id, active : false, actorId : arguments.actorId );
    }

    /**
     * Apply the editable attribute columns from a data struct onto an
     * Organization entity. Shared by create + update. Each key is
     * optional; only present keys are set. `name`, `slug`, `id`, and
     * audit/actor keys are handled by the callers, not here.
     */
    private void function applyOrganizationData( required any org, required struct data ){
        var fields = [
            "tier", "accountNumber", "status", "phone", "website", "industry",
            "addressLine1", "addressLine2", "city", "region", "postalCode",
            "country", "timezone", "notes"
        ];
        for ( var f in fields ) {
            if ( structKeyExists( arguments.data, f ) ) {
                invoke( arguments.org, "set" & f, [ arguments.data[ f ] ] );
            }
        }
        if ( structKeyExists( arguments.data, "autoProvisionContacts" ) ) {
            arguments.org.setAutoProvisionContacts( normalizeBoolean( arguments.data.autoProvisionContacts ) );
        }
        // primary_contact_id is an FK with ON DELETE SET NULL. An empty
        // string is not a valid contact id and would violate the FK, so
        // map blank to a real null.
        if ( structKeyExists( arguments.data, "primaryContactId" ) ) {
            arguments.org.setPrimaryContactId(
                len( trim( arguments.data.primaryContactId ?: "" ) )
                    ? arguments.data.primaryContactId
                    : javaCast( "null", "" )
            );
        }
    }

    private boolean function normalizeBoolean( required any value ){
        if ( isBoolean( arguments.value ) ) return arguments.value;
        var s = lCase( trim( toString( arguments.value ) ) );
        return ( s == "true" || s == "1" || s == "yes" || s == "on" );
    }

    // ---------------- Offices ----------------

    public array function listOfficesForOrganization( required string organizationId ){
        return wirebox.getInstance( "Office@contacts" )
            .withoutGlobalScope()
            .where( "organization_id", arguments.organizationId )
            .orderBy( "is_primary", "desc" )
            .orderBy( "name" )
            .get();
    }

    public any function getOfficeById( required string id ){
        var office = wirebox.getInstance( "Office@contacts" )
            .withoutGlobalScope()
            .where( "id", arguments.id )
            .first();
        return isNull( office ) ? javaCast( "null", "" ) : office;
    }

    /**
     * Create a full office / location record. `data` carries at least
     * `name`; the address / phone / timezone / isPrimary fields are
     * optional. Offices have no jsonb column, so Quick's save() is safe.
     */
    public any function createOffice( required string organizationId, required struct data ){
        var office = wirebox.getInstance( "Office@contacts" );
        office.setId( newId() );
        office.setOrganizationId( arguments.organizationId );
        office.setName( arguments.data.name ?: "" );
        applyOfficeData( office, arguments.data );
        office.save();
        recordAudit(
            eventType      : "office.created",
            entityType     : "Office",
            entityId       : office.getId(),
            organizationId : arguments.organizationId,
            metadata       : { "name" : office.getName() }
        );

        interceptorService.announce(
            "onOfficeCreated",
            eventPayloadBuilder.build(
                event          : "onOfficeCreated",
                organizationId : arguments.organizationId,
                actorType      : arguments.data.actorType ?: "agent",
                actorId        : arguments.data.actorId ?: "system",
                entity         : { type : "Office", id : office.getId() },
                metadata       : { name : office.getName() }
            ),
            true
        );
        return office;
    }

    public any function updateOffice( required string id, required struct data ){
        var office = getOfficeById( arguments.id );
        if ( isNull( office ) ) return javaCast( "null", "" );
        if ( structKeyExists( arguments.data, "name" ) && len( arguments.data.name ) ) {
            office.setName( arguments.data.name );
        }
        applyOfficeData( office, arguments.data );
        office.save();
        recordAudit(
            eventType      : "office.updated",
            entityType     : "Office",
            entityId       : office.getId(),
            organizationId : office.getOrganizationId(),
            metadata       : { "name" : office.getName() }
        );

        interceptorService.announce(
            "onOfficeUpdated",
            eventPayloadBuilder.build(
                event          : "onOfficeUpdated",
                organizationId : office.getOrganizationId(),
                entity         : { type : "Office", id : office.getId() },
                metadata       : { name : office.getName() }
            ),
            true
        );
        return office;
    }

    /**
     * Hard-delete an office. Contacts assigned to it have office_id set
     * to NULL by the FK (ON DELETE SET NULL), so no contact is orphaned.
     */
    public void function deleteOffice( required string id ){
        var office = getOfficeById( arguments.id );
        if ( isNull( office ) ) return;
        var orgId = office.getOrganizationId();
        var name  = office.getName();
        office.delete();
        recordAudit(
            eventType      : "office.deleted",
            entityType     : "Office",
            entityId       : arguments.id,
            organizationId : orgId,
            metadata       : { "name" : name }
        );

        interceptorService.announce(
            "onOfficeDeleted",
            eventPayloadBuilder.build(
                event          : "onOfficeDeleted",
                organizationId : orgId,
                entity         : { type : "Office", id : arguments.id },
                metadata       : { name : name }
            ),
            true
        );
    }

    private void function applyOfficeData( required any office, required struct data ){
        var fields = [
            "addressLine1", "addressLine2", "city", "region",
            "postalCode", "country", "phone", "timezone"
        ];
        for ( var f in fields ) {
            if ( structKeyExists( arguments.data, f ) ) {
                invoke( arguments.office, "set" & f, [ arguments.data[ f ] ] );
            }
        }
        if ( structKeyExists( arguments.data, "isPrimary" ) ) {
            arguments.office.setIsPrimary( normalizeBoolean( arguments.data.isPrimary ) );
        }
    }

    // ---------------- Contacts ----------------

    public any function getContactById( required string id ){
        var contact = wirebox.getInstance( "Contact@contacts" )
            .withoutGlobalScope()
            .where( "id", arguments.id )
            .first();
        return isNull( contact ) ? javaCast( "null", "" ) : contact;
    }

    /**
     * Bulk lookup of contact display data keyed by id. Mirrors
     * AgentService.directoryFor so a view rendering many messages
     * authored by different contacts can resolve names + emails in
     * O(1) per row without a per-row DB hit. Unknown ids are
     * silently absent from the returned struct; callers treat that
     * as "render a placeholder".
     */
    public struct function directoryFor( required array contactIds ){
        var out = {};
        if ( !arrayLen( arguments.contactIds ) ) return out;
        var clean = {};
        for ( var id in arguments.contactIds ) {
            if ( len( id ?: "" ) ) clean[ id ] = true;
        }
        if ( structIsEmpty( clean ) ) return out;
        var ids = structKeyArray( clean );
        var placeholders = [];
        var binds        = {};
        for ( var i = 1; i <= arrayLen( ids ); i++ ) {
            placeholders.append( ":c" & i );
            binds[ "c" & i ] = ids[ i ];
        }
        var rows = queryExecute(
            "SELECT c.id, c.email, c.first_name, c.last_name, c.is_vip, o.name AS office_name
             FROM   contacts c
             LEFT JOIN offices o ON o.id = c.office_id
             WHERE  c.id IN ( " & placeholders.toList() & " )",
            binds
        );
        for ( var i = 1; i <= rows.recordCount; i++ ) {
            out[ rows.id[ i ] ] = {
                id         : rows.id[ i ],
                email      : rows.email[ i ]       ?: "",
                firstName  : rows.first_name[ i ]  ?: "",
                lastName   : rows.last_name[ i ]   ?: "",
                isVip      : !!rows.is_vip[ i ],
                officeName : rows.office_name[ i ] ?: ""
            };
        }
        return out;
    }

    public any function getContactByEmail( required string email ){
        // Email lookup is case-insensitive (RFC 5321 treats the domain
        // as case-insensitive and the local part as case-sensitive in
        // theory, but every mailer in practice lowercases on send).
        // The Contact column itself is stored lowercased on provision.
        var contact = wirebox.getInstance( "Contact@contacts" )
            .withoutGlobalScope()
            .where( "email", lCase( arguments.email ) )
            .first();
        return isNull( contact ) ? javaCast( "null", "" ) : contact;
    }

    /**
     * Inbound-channel resolver: given a sender email, return the
     * Contact to attach to a ticket, auto-creating one when the
     * sender's domain is an approved+verified domain on an
     * organization that has opted in to auto-provisioning.
     *
     * This is the single place the tenant-assignment decision lives;
     * the channels module calls it rather than reaching into entities
     * directly (CLAUDE.md cross-module rule). Returns null when no
     * Contact applies, so the caller falls back to an accountless
     * ticket exactly as before.
     *
     * Order:
     *   1. Known email wins (global lookup; an email already owned by
     *      another org keeps its org, preserving existing behavior).
     *   2. Domain must be mapped AND is_verified.
     *   3. Organization must exist, be active, and have
     *      auto_provision_contacts enabled.
     *   4. Provision with source = "domain-auto".
     */
    public any function resolveOrAutoProvisionContact( required string email ){
        var existing = getContactByEmail( arguments.email );
        if ( !isNull( existing ) ) return existing;

        var domain = extractDomain( arguments.email );
        if ( !len( domain ) ) return javaCast( "null", "" );

        var mapping = getDomainMapping( domain );
        if ( isNull( mapping ) || !mapping.getIsVerified() ) return javaCast( "null", "" );

        var org = getOrganizationById( mapping.getOrganizationId() );
        if ( isNull( org ) || !org.getIsActive() || !org.getAutoProvisionContacts() ) {
            return javaCast( "null", "" );
        }

        return provisionContact( {
            organizationId : org.getId(),
            email          : arguments.email,
            source         : "domain-auto",
            actorType      : "system"
        } );
    }

    /**
     * Ids of every VIP contact. Used by the agent ticket list to
     * filter to VIP-requester tickets without the tickets module
     * having to read the contacts table directly (the handler passes
     * these ids into TicketsService.listTickets).
     */
    public array function vipContactIds(){
        var rows = queryExecute( "SELECT id FROM contacts WHERE is_vip = TRUE" );
        var out = [];
        for ( var i = 1; i <= rows.recordCount; i++ ) out.append( rows.id[ i ] );
        return out;
    }

    public array function listContactsForOrganization( required string organizationId ){
        return wirebox.getInstance( "Contact@contacts" )
            .withoutGlobalScope()
            .where( "organization_id", arguments.organizationId )
            .orderBy( "email" )
            .get();
    }

    /**
     * Agent-created provisioning: create a Contact for a given
     * Organization. Caller supplies email and either a password
     * (which we hash) or no password (then we generate a random one
     * for an invite flow that Phase 2 will add).
     *
     * Caller must validate input first; this service trusts its inputs.
     */
    public any function provisionContact( required struct data ){
        var raw = structKeyExists( arguments.data, "password" ) && len( arguments.data.password )
            ? arguments.data.password
            : createUUID();
        var contact = wirebox.getInstance( "Contact@contacts" );
        contact.setId( newId() );
        contact.setOrganizationId( arguments.data.organizationId );
        // Lowercase email on write so getContactByEmail's case-
        // insensitive lookup stays a single equality test.
        contact.setEmail( lCase( arguments.data.email ) );
        contact.setPasswordHash( bcrypt.hashPassword( raw ) );
        if ( structKeyExists( arguments.data, "firstName" ) ) contact.setFirstName( arguments.data.firstName );
        if ( structKeyExists( arguments.data, "lastName" ) )  contact.setLastName( arguments.data.lastName );
        if ( structKeyExists( arguments.data, "officeId" ) && len( arguments.data.officeId ) ) {
            contact.setOfficeId( arguments.data.officeId );
        }
        // Optional support-CRM profile fields.
        for ( var f in [ "phone", "mobilePhone", "jobTitle", "timezone", "locale", "notes" ] ) {
            if ( structKeyExists( arguments.data, f ) ) invoke( contact, "set" & f, [ arguments.data[ f ] ] );
        }
        if ( structKeyExists( arguments.data, "isVip" ) ) {
            contact.setIsVip( normalizeBoolean( arguments.data.isVip ) );
        }
        // How this account came to exist: agent (default), portal,
        // domain-auto, import, email. Recorded so the agent UI can
        // distinguish auto-provisioned contacts.
        contact.setSource( arguments.data.source ?: "agent" );
        // INSERT of a fresh entity is safe with Quick's save(); the
        // mfa_recovery_codes (jsonb) PGobject trap only bites on
        // save() AFTER a load, which is why the update paths below use
        // targeted UPDATEs instead.
        contact.save();
        recordAudit(
            eventType      : "contact.provisioned",
            entityType     : "Contact",
            entityId       : contact.getId(),
            organizationId : contact.getOrganizationId(),
            metadata       : { "email" : contact.getEmail() }
        );

        interceptorService.announce(
            "onContactProvisioned",
            eventPayloadBuilder.build(
                event          : "onContactProvisioned",
                organizationId : contact.getOrganizationId(),
                actorType      : arguments.data.actorType ?: "system",
                actorId        : arguments.data.actorId ?: "system",
                entity         : { type : "Contact", id : contact.getId() },
                metadata       : { email : contact.getEmail() }
            ),
            true
        );
        return contact;
    }

    /**
     * Update the editable profile fields on a contact. Targeted
     * UPDATE (NOT contact.save()) because Quick's save() re-binds
     * every column on the entity, including `mfa_recovery_codes`
     * (jsonb) which JDBC hands back as a PGobject. The JDBC driver
     * can't coerce that PGobject back into a varchar bind, so save()
     * on any MFA-enrolled contact throws BoxCastException at the
     * controller boundary. See memory note
     * [boxlang-pgobject-quick-save] for the broader pattern.
     *
     * Mirrors the agent-side workaround in Mfa.bx and the existing
     * comments there.
     */
    public any function updateContactProfile( required string id, required struct data ){
        var sets  = [ "updated_at = NOW()" ];
        var binds = { "id" : arguments.id };

        // Plain text columns: dataKey -> db column.
        var textMap = {
            "firstName"   : "first_name",
            "lastName"    : "last_name",
            "phone"       : "phone",
            "mobilePhone" : "mobile_phone",
            "jobTitle"    : "job_title",
            "timezone"    : "timezone",
            "locale"      : "locale",
            "notes"       : "notes"
        };
        for ( var key in textMap ) {
            if ( structKeyExists( arguments.data, key ) ) {
                sets.append( textMap[ key ] & " = :" & key );
                binds[ key ] = arguments.data[ key ];
            }
        }

        // Boolean columns. Every queryExecute bind goes in as varchar,
        // so the non-text columns are wrapped in cast(... as boolean).
        var boolMap = { "isActive" : "is_active", "isVip" : "is_vip" };
        for ( var key in boolMap ) {
            if ( structKeyExists( arguments.data, key ) ) {
                sets.append( boolMap[ key ] & " = cast( :" & key & " as boolean )" );
                binds[ key ] = normalizeBoolean( arguments.data[ key ] );
            }
        }

        // office_id is a nullable FK (ON DELETE SET NULL). A blank value
        // means "unassign", which must be a real NULL, not an empty
        // string (no office has an empty id, so the FK would reject it).
        if ( structKeyExists( arguments.data, "officeId" ) ) {
            if ( len( trim( arguments.data.officeId ?: "" ) ) ) {
                sets.append( "office_id = :officeId" );
                binds[ "officeId" ] = arguments.data.officeId;
            } else {
                sets.append( "office_id = NULL" );
            }
        }

        // Targeted UPDATE (NOT contact.save()): Quick's save() re-binds
        // every column on the entity, including mfa_recovery_codes
        // (jsonb / PGobject on load), which JDBC cannot coerce back into
        // a varchar bind. See memory note [quick-save-pgobject].
        queryExecute(
            "UPDATE contacts SET " & sets.toList( ", " ) & " WHERE id = :id",
            binds
        );
        return getContactById( arguments.id );
    }

    public any function deactivateContact( required string id ){
        var contact = getContactById( arguments.id );
        if ( isNull( contact ) ) return javaCast( "null", "" );
        // Targeted UPDATE for the same reason updateContactProfile uses
        // one — Quick's save() would rebind mfa_recovery_codes (PGobject)
        // and fail at the JDBC layer.
        queryExecute(
            "UPDATE contacts SET is_active = FALSE, updated_at = NOW() WHERE id = :id",
            { id : arguments.id }
        );
        contact.setIsActive( false );
        recordAudit(
            eventType      : "contact.deactivated",
            entityType     : "Contact",
            entityId       : contact.getId(),
            organizationId : contact.getOrganizationId()
        );

        interceptorService.announce(
            "onContactDeactivated",
            eventPayloadBuilder.build(
                event          : "onContactDeactivated",
                organizationId : contact.getOrganizationId(),
                entity         : { type : "Contact", id : contact.getId() }
            ),
            true
        );
        return contact;
    }

    /**
     * Re-enable a previously deactivated contact. Targeted UPDATE for
     * the same mfa_recovery_codes (PGobject) reason as deactivateContact.
     */
    public any function reactivateContact( required string id ){
        var contact = getContactById( arguments.id );
        if ( isNull( contact ) ) return javaCast( "null", "" );
        queryExecute(
            "UPDATE contacts SET is_active = TRUE, updated_at = NOW() WHERE id = :id",
            { id : arguments.id }
        );
        contact.setIsActive( true );
        recordAudit(
            eventType      : "contact.reactivated",
            entityType     : "Contact",
            entityId       : contact.getId(),
            organizationId : contact.getOrganizationId()
        );
        return contact;
    }

    // ---------------- Profile image ----------------

    /**
     * Persist uploaded profile-image metadata. The bytes live on the
     * public CBFS disk under contacts/<id>/profile/ (written by
     * ImageProcessingService); only the original path + MIME + an
     * upload timestamp (the avatar URL cache-buster) are stored here.
     * Targeted UPDATE to avoid Quick rebinding mfa_recovery_codes.
     */
    public void function setProfileImage(
        required string contactId,
        required string originalPath,
        required string contentType
    ){
        queryExecute(
            "UPDATE contacts
             SET    profile_image_original_path = :path,
                    profile_image_content_type  = :ctype,
                    profile_image_uploaded_at   = NOW(),
                    updated_at                  = NOW()
             WHERE  id = :id",
            { id : arguments.contactId, path : arguments.originalPath, ctype : arguments.contentType }
        );
    }

    /**
     * Clear profile-image metadata (the caller deletes the bytes via
     * ImageProcessingService.deleteProfileImages first).
     */
    public void function clearProfileImage( required string contactId ){
        queryExecute(
            "UPDATE contacts
             SET    profile_image_original_path = NULL,
                    profile_image_content_type  = NULL,
                    profile_image_uploaded_at   = NULL,
                    updated_at                  = NOW()
             WHERE  id = :id",
            { id : arguments.contactId }
        );
    }

    // ---------------- Passwords ----------------

    /**
     * Self-service password change. Verifies the current password
     * against the stored bcrypt hash, then writes the new hash.
     * Returns { ok : boolean, error : string }; does not throw so the
     * portal handler can surface a friendly message.
     */
    public struct function changePassword(
        required string contactId,
        required string currentPassword,
        required string newPassword
    ){
        var contact = getContactById( arguments.contactId );
        if ( isNull( contact ) ) return { ok : false, error : "Account not found." };
        if ( !bcrypt.checkPassword( arguments.currentPassword, contact.getPasswordHash() ) ) {
            return { ok : false, error : "Your current password is incorrect." };
        }
        if ( len( arguments.newPassword ) < 8 ) {
            return { ok : false, error : "New password must be at least 8 characters." };
        }
        setPassword( arguments.contactId, arguments.newPassword );
        return { ok : true, error : "" };
    }

    /**
     * Set (overwrite) a contact's password with no current-password
     * check. Backs the invite / set-password token flow. Targeted
     * UPDATE; bcrypt-hashes the raw input.
     */
    public void function setPassword( required string contactId, required string newPassword ){
        queryExecute(
            "UPDATE contacts SET password_hash = :hash, updated_at = NOW() WHERE id = :id",
            { id : arguments.contactId, hash : bcrypt.hashPassword( arguments.newPassword ) }
        );
        recordAudit(
            eventType  : "contact.password_changed",
            entityType : "Contact",
            entityId   : arguments.contactId
        );
    }

    // ---------------- Roles ----------------

    public array function listRolesForContact( required string contactId ){
        return wirebox.getInstance( "ContactRole@contacts" )
            .where( "contact_id", arguments.contactId )
            .get();
    }

    public any function assignRole(
        required string contactId,
        required string roleKey,
        string grantedByAgentId
    ){
        var existing = wirebox.getInstance( "ContactRole@contacts" )
            .where( "contact_id", arguments.contactId )
            .where( "role_key", arguments.roleKey )
            .first();
        if ( !isNull( existing ) ) {
            return existing;
        }
        var assignment = wirebox.getInstance( "ContactRole@contacts" );
        assignment.setId( newId() );
        assignment.setContactId( arguments.contactId );
        assignment.setRoleKey( arguments.roleKey );
        if ( structKeyExists( arguments, "grantedByAgentId" ) && len( arguments.grantedByAgentId ?: "" ) ) {
            assignment.setGrantedByAgentId( arguments.grantedByAgentId );
        }
        assignment.save();
        var contact = getContactById( arguments.contactId );
        recordAudit(
            eventType      : "contact.role_granted",
            entityType     : "Contact",
            entityId       : arguments.contactId,
            organizationId : isNull( contact ) ? "" : contact.getOrganizationId(),
            actorType      : "agent",
            actorId        : arguments.grantedByAgentId ?: "",
            metadata       : { "roleKey" : arguments.roleKey }
        );

        interceptorService.announce(
            "onContactRoleGranted",
            eventPayloadBuilder.build(
                event          : "onContactRoleGranted",
                organizationId : isNull( contact ) ? "" : contact.getOrganizationId(),
                actorType      : "agent",
                actorId        : arguments.grantedByAgentId ?: "system",
                entity         : { type : "Contact", id : arguments.contactId },
                metadata       : { roleKey : arguments.roleKey }
            ),
            true
        );
        return assignment;
    }

    public void function revokeRole(
        required string contactId,
        required string roleKey
    ){
        wirebox.getInstance( "ContactRole@contacts" )
            .where( "contact_id", arguments.contactId )
            .where( "role_key", arguments.roleKey )
            .delete();
        var contact = getContactById( arguments.contactId );
        recordAudit(
            eventType      : "contact.role_revoked",
            entityType     : "Contact",
            entityId       : arguments.contactId,
            organizationId : isNull( contact ) ? "" : contact.getOrganizationId(),
            metadata       : { "roleKey" : arguments.roleKey }
        );

        interceptorService.announce(
            "onContactRoleRevoked",
            eventPayloadBuilder.build(
                event          : "onContactRoleRevoked",
                organizationId : isNull( contact ) ? "" : contact.getOrganizationId(),
                entity         : { type : "Contact", id : arguments.contactId },
                metadata       : { roleKey : arguments.roleKey }
            ),
            true
        );
    }

    /**
     * Count active contacts in an organization holding the
     * organization-admin role. The portal member-management guard uses
     * this to refuse the operation (role revoke or deactivate) that
     * would leave the organization with zero admins.
     */
    public numeric function countActiveOrgAdmins( required string organizationId ){
        var rows = queryExecute(
            "SELECT COUNT(*) AS n
             FROM   contacts c
             JOIN   contact_roles r ON r.contact_id = c.id
             WHERE  c.organization_id = :orgId
             AND    c.is_active = TRUE
             AND    r.role_key = 'organization-admin'",
            { orgId : arguments.organizationId }
        );
        return val( rows.n[ 1 ] );
    }

    // ---------------- Domain mapping ----------------

    public any function resolveOrganizationForEmail( required string email ){
        var domain = extractDomain( arguments.email );
        if ( !len( domain ) ) return javaCast( "null", "" );
        var mapping = getDomainMapping( domain );
        if ( isNull( mapping ) ) return javaCast( "null", "" );
        return getOrganizationById( mapping.getOrganizationId() );
    }

    /**
     * Return the OrganizationDomain row for a bare domain (e.g.
     * "acme.com"), or null. Callers that need is_verified ask here
     * rather than through resolveOrganizationForEmail, which only
     * yields the Organization.
     */
    public any function getDomainMapping( required string domain ){
        var mapping = wirebox.getInstance( "OrganizationDomain@contacts" )
            .where( "domain", lCase( trim( arguments.domain ) ) )
            .first();
        return isNull( mapping ) ? javaCast( "null", "" ) : mapping;
    }

    public any function setDomainVerified( required string id, required boolean verified ){
        var mapping = wirebox.getInstance( "OrganizationDomain@contacts" )
            .where( "id", arguments.id )
            .first();
        if ( isNull( mapping ) ) return javaCast( "null", "" );
        mapping.setIsVerified( arguments.verified );
        mapping.save();
        recordAudit(
            eventType      : "organization.domain_verified",
            entityType     : "Organization",
            entityId       : mapping.getOrganizationId(),
            organizationId : mapping.getOrganizationId(),
            metadata       : { "domain" : mapping.getDomain(), "isVerified" : arguments.verified }
        );
        return mapping;
    }

    public void function removeDomainMapping( required string id ){
        var mapping = wirebox.getInstance( "OrganizationDomain@contacts" )
            .where( "id", arguments.id )
            .first();
        if ( isNull( mapping ) ) return;
        var orgId  = mapping.getOrganizationId();
        var domain = mapping.getDomain();
        mapping.delete();
        recordAudit(
            eventType      : "organization.domain_unmapped",
            entityType     : "Organization",
            entityId       : orgId,
            organizationId : orgId,
            metadata       : { "domain" : domain }
        );

        interceptorService.announce(
            "onOrganizationDomainUnmapped",
            eventPayloadBuilder.build(
                event          : "onOrganizationDomainUnmapped",
                organizationId : orgId,
                entity         : { type : "Organization", id : orgId },
                metadata       : { domain : domain }
            ),
            true
        );
    }

    public any function addDomainMapping(
        required string organizationId,
        required string domain,
        boolean isVerified = false
    ){
        var existing = wirebox.getInstance( "OrganizationDomain@contacts" )
            .where( "domain", lCase( arguments.domain ) )
            .first();
        if ( !isNull( existing ) ) {
            return existing;
        }
        var mapping = wirebox.getInstance( "OrganizationDomain@contacts" );
        mapping.setId( newId() );
        mapping.setOrganizationId( arguments.organizationId );
        mapping.setDomain( lCase( arguments.domain ) );
        mapping.setIsVerified( arguments.isVerified );
        mapping.save();
        recordAudit(
            eventType      : "organization.domain_mapped",
            entityType     : "Organization",
            entityId       : arguments.organizationId,
            organizationId : arguments.organizationId,
            metadata       : { "domain" : mapping.getDomain(), "isVerified" : arguments.isVerified }
        );

        interceptorService.announce(
            "onOrganizationDomainMapped",
            eventPayloadBuilder.build(
                event          : "onOrganizationDomainMapped",
                organizationId : arguments.organizationId,
                entity         : { type : "Organization", id : arguments.organizationId },
                metadata       : { domain : mapping.getDomain(), isVerified : arguments.isVerified }
            ),
            true
        );
        return mapping;
    }

    public array function listDomainMappingsForOrganization( required string organizationId ){
        return wirebox.getInstance( "OrganizationDomain@contacts" )
            .where( "organization_id", arguments.organizationId )
            .orderBy( "domain" )
            .get();
    }

    // ---------------- Contact merge ----------------

    /**
     * Basic merge: move the source contact's roles onto the target,
     * then deactivate the source. Phase 1c will extend this to move
     * tickets/messages onto the target. Both contacts must already
     * exist in the same organization; cross-org merge is rejected.
     */
    public struct function mergeContacts(
        required string sourceContactId,
        required string targetContactId
    ){
        var source = getContactById( arguments.sourceContactId );
        var target = getContactById( arguments.targetContactId );
        if ( isNull( source ) || isNull( target ) ) {
            throw( type="ContactsService.MergeFailed", message="Source or target contact not found." );
        }
        if ( source.getOrganizationId() != target.getOrganizationId() ) {
            throw( type="ContactsService.CrossOrgMerge", message="Cannot merge contacts across organizations." );
        }

        var moved = 0;
        for ( var assignment in listRolesForContact( source.getId() ) ) {
            assignRole(
                contactId : target.getId(),
                roleKey   : assignment.getRoleKey()
            );
            moved++;
        }
        wirebox.getInstance( "ContactRole@contacts" )
            .where( "contact_id", source.getId() )
            .delete();

        // Targeted UPDATE; Quick's save() rebinds every column on
        // the entity (including the new mfa_recovery_codes JSON
        // column) as varchar, which Postgres rejects with "is of
        // type json but expression is of type character varying".
        queryExecute(
            "UPDATE contacts SET is_active = FALSE, updated_at = NOW() WHERE id = :id",
            { id : source.getId() }
        );
        source.setIsActive( false );

        recordAudit(
            eventType      : "contact.merged",
            entityType     : "Contact",
            entityId       : target.getId(),
            organizationId : target.getOrganizationId(),
            metadata       : {
                "sourceContactId" : source.getId(),
                "targetContactId" : target.getId(),
                "rolesMoved"      : moved
            }
        );

        interceptorService.announce(
            "onContactMerged",
            eventPayloadBuilder.build(
                event          : "onContactMerged",
                organizationId : target.getOrganizationId(),
                entity         : { type : "Contact", id : target.getId() },
                metadata       : {
                    sourceContactId : source.getId(),
                    targetContactId : target.getId(),
                    rolesMoved      : moved
                }
            ),
            true
        );

        return {
            "sourceContactId" : source.getId(),
            "targetContactId" : target.getId(),
            "rolesMoved"      : moved
        };
    }

    // ---------------- helpers ----------------

    private string function newId(){
        return createObject( "java", "java.util.UUID" ).randomUUID().toString();
    }

    private string function slugify( required string text ){
        return lCase( reReplace( reReplace( arguments.text, "[^A-Za-z0-9]+", "-", "all" ), "(^-|-$)", "", "all" ) );
    }

    /**
     * The bare, lowercased domain of an email address ("a@b.com" ->
     * "b.com"), or an empty string if the address has no domain part.
     */
    private string function extractDomain( required string email ){
        var parts = listToArray( arguments.email, "@" );
        if ( arrayLen( parts ) < 2 ) return "";
        return lCase( trim( parts[ arrayLen( parts ) ] ) );
    }

    /**
     * Thin wrapper around AuditService.record that drops empty
     * optional fields. Keeps call sites in this service compact.
     */
    private void function recordAudit(
        required string eventType,
        string entityType,
        string entityId,
        string organizationId,
        string actorType,
        string actorId,
        struct metadata
    ){
        var args = { "eventType" : arguments.eventType };
        if ( structKeyExists( arguments, "entityType" ) && len( arguments.entityType ?: "" ) ) args.entityType = arguments.entityType;
        if ( structKeyExists( arguments, "entityId" ) && len( arguments.entityId ?: "" ) ) args.entityId = arguments.entityId;
        if ( structKeyExists( arguments, "organizationId" ) && len( arguments.organizationId ?: "" ) ) args.organizationId = arguments.organizationId;
        if ( structKeyExists( arguments, "actorType" ) && len( arguments.actorType ?: "" ) ) args.actorType = arguments.actorType;
        if ( structKeyExists( arguments, "actorId" ) && len( arguments.actorId ?: "" ) ) args.actorId = arguments.actorId;
        if ( structKeyExists( arguments, "metadata" ) && !isNull( arguments.metadata ) ) args.metadata = arguments.metadata;
        auditService.record( argumentCollection = args );
    }

}
