/**
 * NotificationsServiceSpec: dispatch + read-state covers.
 *
 * Live UI verification happens in the dev stack; this suite asserts
 * the contract callers (interceptors, handlers, the bell partial)
 * rely on.
 */
class extends="coldbox.system.testing.BaseTestCase" appMapping="/" {

    function beforeAll(){
        super.beforeAll();
        super.setup();
        variables.svc = getController().getWireBox().getInstance( "NotificationsService@notifications" );
    }

    function run(){
        describe( "NotificationsService", function(){

            it( "dispatches a ticket.created inapp notification per recipient", function(){
                var agentId   = createUUID();
                var contactId = createUUID();
                var created = variables.svc.dispatchForEvent(
                    eventKey   : "ticket.created",
                    recipients : [
                        { "type" : "agent",   "id" : agentId },
                        { "type" : "contact", "id" : contactId }
                    ],
                    context    : {
                        "ticketId"     : "spec-ticket",
                        "ticketNumber" : 1234,
                        "subject"      : "test subject",
                        "status"       : "new"
                    }
                );
                expect( created.len() ).toBeGTE( 2 );
                // Each notification carries the rendered title with
                // placeholders substituted.
                var agentRow = created[ 1 ];
                expect( agentRow.getStatus() ).toBe( "sent" );
                expect( agentRow.getTitle() ).toInclude( "1234" );

                cleanup( agentId, contactId );
            } );

            it( "renders placeholders from the context struct", function(){
                var agentId = createUUID();
                variables.svc.dispatchForEvent(
                    eventKey   : "ticket.status_changed",
                    recipients : [ { "type" : "agent", "id" : agentId } ],
                    context    : {
                        "ticketId"     : "x",
                        "ticketNumber" : 99,
                        "subject"      : "s",
                        "from"         : "open",
                        "to"           : "resolved"
                    }
                );
                var notes = variables.svc.listForRecipient( "agent", agentId );
                expect( notes.len() ).toBe( 1 );
                expect( notes[ 1 ].getTitle() ).toInclude( "resolved" );
                expect( notes[ 1 ].getBody() ).toInclude( "open" );
                cleanup( agentId, "" );
            } );

            it( "silently skips a template row for an unrecognized channel", function(){
                // inapp + email + slack are the wired channels. Any
                // other channel value in the templates table must not
                // crash dispatch and must not create a notifications
                // row, so an unknown row stays inert.
                queryExecute(
                    "INSERT INTO notification_templates
                        ( id, event_key, channel, recipient_type, title_template, body_template, is_active )
                     VALUES
                        ( :id, 'spec.sms_only', 'sms', 'agent', 'hello {{subject}}', 'body', TRUE )",
                    { id : createUUID() }
                );
                var agentId = createUUID();
                variables.svc.dispatchForEvent(
                    eventKey   : "spec.sms_only",
                    recipients : [ { "type" : "agent", "id" : agentId } ],
                    context    : { "subject" : "hi" }
                );
                var rows = queryExecute(
                    "SELECT COUNT(*) AS n FROM notifications WHERE recipient_id = :id",
                    { id : agentId }
                );
                expect( rows.n[ 1 ] ).toBe( 0 );
                queryExecute( "DELETE FROM notification_templates WHERE event_key = 'spec.sms_only'" );
            } );

            it( "isChannelEnabled defaults to true when no preference row exists", function(){
                expect( variables.svc.isChannelEnabled( "agent", createUUID(), "ticket.created", "email" ) ).toBeTrue();
            } );

            it( "setPreference + isChannelEnabled flip and read", function(){
                var agentId = createUUID();
                variables.svc.setPreference(
                    recipientType : "agent",
                    recipientId   : agentId,
                    eventKey      : "ticket.status_changed",
                    channel       : "email",
                    enabled       : false
                );
                expect( variables.svc.isChannelEnabled( "agent", agentId, "ticket.status_changed", "email" ) ).toBeFalse();
                // Other channels stay on.
                expect( variables.svc.isChannelEnabled( "agent", agentId, "ticket.status_changed", "inapp" ) ).toBeTrue();
                queryExecute( "DELETE FROM notification_preferences WHERE recipient_id = :id", { id : agentId } );
            } );

            it( "dispatch honors a disabled preference and skips that channel", function(){
                var agentId = createUUID();
                variables.svc.setPreference(
                    recipientType : "agent",
                    recipientId   : agentId,
                    eventKey      : "ticket.status_changed",
                    channel       : "email",
                    enabled       : false
                );
                variables.svc.dispatchForEvent(
                    eventKey   : "ticket.status_changed",
                    recipients : [ { "type" : "agent", "id" : agentId } ],
                    context    : { "ticketId" : "t", "ticketNumber" : 1, "subject" : "s", "from" : "open", "to" : "resolved" }
                );
                var rows = queryExecute(
                    "SELECT channel FROM notifications WHERE recipient_id = :id",
                    { id : agentId }
                );
                var channels = [];
                for ( var i = 1; i <= rows.recordCount; i++ ) channels.append( rows.channel[ i ] );
                expect( channels ).toInclude( "inapp" );
                expect( channels ).notToInclude( "email" );

                queryExecute( "DELETE FROM notifications WHERE recipient_id = :id", { id : agentId } );
                queryExecute( "DELETE FROM notification_preferences WHERE recipient_id = :id", { id : agentId } );
            } );

            it( "unreadCount and markRead flip status correctly", function(){
                var agentId = createUUID();
                variables.svc.dispatchForEvent(
                    eventKey   : "ticket.created",
                    recipients : [ { "type" : "agent", "id" : agentId } ],
                    context    : { "ticketId" : "t", "ticketNumber" : 1, "subject" : "s", "status" : "new" }
                );
                expect( variables.svc.unreadCount( "agent", agentId ) ).toBe( 1 );

                var notes = variables.svc.listForRecipient( "agent", agentId );
                variables.svc.markRead( notes[ 1 ].getId(), "agent", agentId );
                expect( variables.svc.unreadCount( "agent", agentId ) ).toBe( 0 );

                cleanup( agentId, "" );
            } );

            it( "buildUnsubscribeUrl + verifyUnsubscribeToken round-trip the recipient/event/channel tuple", function(){
                var unsubUrl = variables.svc.buildUnsubscribeUrl( "contact", "rid-123", "ticket.status_changed", "email" );
                expect( unsubUrl ).toInclude( "/unsubscribe?token=" );
                var token = listLast( unsubUrl, "=" );
                var decoded = variables.svc.verifyUnsubscribeToken( token );
                expect( decoded ).notToBeNull();
                expect( decoded.recipientType ).toBe( "contact" );
                expect( decoded.recipientId   ).toBe( "rid-123" );
                expect( decoded.eventKey      ).toBe( "ticket.status_changed" );
                expect( decoded.channel       ).toBe( "email" );
            } );

            it( "verifyUnsubscribeToken rejects a tampered signature", function(){
                var unsubUrl = variables.svc.buildUnsubscribeUrl( "agent", "rid-xyz", "ticket.created", "email" );
                var token = listLast( unsubUrl, "=" );
                // Flip a character early in the signature half. Last-
                // char flips can fall in base64 padding bits and
                // decode to identical bytes, so target a position we
                // know contributes to the byte sequence.
                var dotIdx = find( ".", token );
                var flipAt = dotIdx + 2; // first char of signature
                var orig   = mid( token, flipAt, 1 );
                var swap   = ( orig == "A" ? "B" : "A" );
                var tampered = mid( token, 1, flipAt - 1 ) & swap & mid( token, flipAt + 1, len( token ) - flipAt );
                expect( variables.svc.verifyUnsubscribeToken( tampered ) ).toBeNull();
                expect( variables.svc.verifyUnsubscribeToken( "" ) ).toBeNull();
                expect( variables.svc.verifyUnsubscribeToken( "junk" ) ).toBeNull();
            } );

            it( "recordBounce inserts a notification_bounces row", function(){
                var email = "bounce-" & createUUID() & "@example.com";
                variables.svc.recordBounce(
                    recipientEmail : email,
                    kind           : "hard",
                    reason         : "mailbox does not exist"
                );
                var rows = queryExecute(
                    "SELECT kind, reason FROM notification_bounces WHERE recipient_email = :e",
                    { e : email }
                );
                expect( rows.recordCount ).toBe( 1 );
                expect( rows.kind[ 1 ] ).toBe( "hard" );
                queryExecute( "DELETE FROM notification_bounces WHERE recipient_email = :e", { e : email } );
            } );

            it( "markAllRead clears every unread row for the recipient", function(){
                var agentId = createUUID();
                for ( var i = 1; i <= 3; i++ ) {
                    variables.svc.dispatchForEvent(
                        eventKey   : "ticket.created",
                        recipients : [ { "type" : "agent", "id" : agentId } ],
                        context    : { "ticketId" : "t", "ticketNumber" : i, "subject" : "s", "status" : "new" }
                    );
                }
                expect( variables.svc.unreadCount( "agent", agentId ) ).toBe( 3 );
                variables.svc.markAllRead( "agent", agentId );
                expect( variables.svc.unreadCount( "agent", agentId ) ).toBe( 0 );
                cleanup( agentId, "" );
            } );

        } );
    }

    private void function cleanup( required string agentId, required string contactId ){
        if ( len( arguments.agentId ) )   queryExecute( "DELETE FROM notifications WHERE recipient_id = :id", { id : arguments.agentId } );
        if ( len( arguments.contactId ) ) queryExecute( "DELETE FROM notifications WHERE recipient_id = :id", { id : arguments.contactId } );
    }

}
