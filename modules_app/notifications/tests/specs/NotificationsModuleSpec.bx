class extends="coldbox.system.testing.BaseTestCase" appMapping="/" {

    function beforeAll(){
        super.beforeAll();
        super.setup();
    }

    function run(){
        describe( "notifications module", function(){
            it( "is registered with ColdBox", function(){
                var modules = getController().getModuleService().getModuleRegistry();
                expect( modules ).toHaveKey( "notifications" );
            } );

            it( "is service-only (no HTTP entry point of its own)", function(){
                // The agent surface mounts /agent/notifications; the
                // notifications module itself is service-only.
                var cache = getController().getModuleService().getModuleConfigCache();
                expect( cache ).toHaveKey( "notifications" );
                expect( cache[ "notifications" ].entryPoint ).toBe( "" );
            } );
        } );
    }

}
