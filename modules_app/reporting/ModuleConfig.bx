/**
 * reporting module.
 *
 * Owns no entities. Reads across other modules' service layers to
 * render dashboards, scheduled exports, raw data exports.
 *
 * Service-only module: no HTTP entry point of its own. Reports for
 * provider staff live under /agent/reports so they inherit the
 * agent firewall (CLAUDE.md: two surfaces, / and /agent). The
 * route is registered in /config/Router.bx pointing at handlers
 * here via the reporting: prefix.
 */
class {

    this.title              = "reporting";
    this.author             = "TesseraBX";
    this.webURL             = "https://github.com/oistechnologies/tesserabx";
    this.description        = "Dashboards, exports, scheduled reports.";
    this.version            = "0.0.1";
    this.viewParentLookup   = true;
    this.layoutParentLookup = true;
    this.entryPoint         = "";
    this.modelNamespace     = "reporting";
    this.cfmapping          = "tesserabx.modules.reporting";
    this.autoMapModels      = false;
    this.dependencies       = [ "contacts", "tickets", "sla" ];

    function configure(){
        variables.settings              = {};
        variables.routes                = [];
        variables.interceptorSettings   = { customInterceptionPoints : [] };
        variables.interceptors          = [];
    }

    function onLoad(){
        binder.map( "ReportingService@reporting" )
              .to( "#moduleMapping#.models.ReportingService" )
              .asSingleton();
        binder.map( "ScheduledExport@reporting" )
              .to( "#moduleMapping#.models.ScheduledExport" );
        binder.map( "ScheduledExportService@reporting" )
              .to( "#moduleMapping#.models.ScheduledExportService" )
              .asSingleton();
    }

    function onUnload(){}

}
