class extends="coldbox.system.testing.BaseTestCase" appMapping="/" {

    function beforeAll(){
        super.beforeAll();
        super.setup();
    }

    function run(){
        describe( "reporting module", function(){
            it( "is registered with ColdBox", function(){
                var modules = getController().getModuleService().getModuleRegistry();
                expect( modules ).toHaveKey( "reporting" );
            } );

            it( "is service-only (no HTTP entry point of its own)", function(){
                // Routes live under /agent/reports so they inherit
                // the agent firewall; the module itself is service-
                // only (handlers exposed via the reporting: prefix).
                var cache = getController().getModuleService().getModuleConfigCache();
                expect( cache ).toHaveKey( "reporting" );
                expect( cache[ "reporting" ].entryPoint ).toBe( "" );
            } );
        } );
    }

}
