class extends="coldbox.system.testing.BaseTestCase" appMapping="/" {

    function beforeAll(){
        super.beforeAll();
        super.setup();
    }

    function run(){
        describe( "tickets module", function(){
            it( "is registered with ColdBox", function(){
                var modules = getController().getModuleService().getModuleRegistry();
                expect( modules ).toHaveKey( "tickets" );
            } );

            it( "exposes its entry point", function(){
                var registry = getController().getModuleService().getModuleRegistry();
                expect( registry[ "tickets" ] ).toHaveKey( "entryPoint" );
            } );
        } );
    }

}
