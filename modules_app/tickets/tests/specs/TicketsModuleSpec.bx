class extends="coldbox.system.testing.BaseTestCase" appMapping="/" {

    function beforeAll(){
        super.beforeAll();
        super.setup();
    }

    function run(){
        describe( "tickets module", function(){
            it( "is registered with ColdBox", function(){
                var modules = getController().getModuleService().getModuleRegistry();
                expect( modules ).toHaveKey( "tickets" );
            } );

            it( "exposes its entry point", function(){
                var cache = getController().getModuleService().getModuleConfigCache();
                expect( cache ).toHaveKey( "tickets" );
                // tickets is service-only; entryPoint is intentionally
                // empty so the /tickets URL space stays free for portal
                // and /agent/tickets stays free for agent.
                expect( cache[ "tickets" ] ).toHaveKey( "entryPoint" );
            } );
        } );
    }

}
