/**
 * AttachmentSpec: TicketsService attachment-lifecycle coverage that
 * complements AttachmentSecuritySpec.
 *
 * AttachmentSecuritySpec hammers the access-check / soft-delete /
 * magic-byte cases at the service boundary. This spec adds:
 *   - cbfs_path shape (per-org prefix vs accountless prefix)
 *   - thumbnail status transitions and markThumbnail* helpers
 *   - listAttachmentsForTicket visibility for soft-deleted rows
 *     (hidden from contacts, included for agents)
 *   - readAttachmentBytes emits the download audit event
 *
 * The cbfs_path specs need the default disk to be local because
 * addAttachment writes through CBFS; CI runs with
 * CBFS_DEFAULT_PROVIDER=local. Specs that can be exercised purely
 * through direct INSERT (thumbnail markers, soft-delete listing)
 * stay independent of the default provider.
 */
class extends="coldbox.system.testing.BaseTestCase" appMapping="/" {

    function beforeAll(){
        super.beforeAll();
        super.setup();
        variables.tickets  = getController().getWireBox().getInstance( "TicketsService@tickets" );
        variables.contacts = getController().getWireBox().getInstance( "ContactsService@contacts" );
    }

    function run(){
        describe( "Attachment lifecycle", function(){

            it( "addAttachment writes the file under org/<orgId>/tickets/<ticketId>/ on a tenant ticket", function(){
                var f      = makeFixture();
                var ticket = makeTicket( f );
                var src    = writeTempJpeg();
                var att    = variables.tickets.addAttachment( {
                    ticketId         : ticket.getId(),
                    originalFilename : "shot.jpg",
                    contentType      : "image/jpeg",
                    sizeBytes        : getFileInfo( src ).size,
                    sourcePath       : src,
                    uploaderAgentId  : f.agentId
                } );
                expect( att.getCbfsPath() ).toInclude( "org/" & f.org.getId() & "/tickets/" & ticket.getId() & "/" );
                expect( att.getOrganizationId() ).toBe( f.org.getId() );

                cleanupFixture( f, [ ticket.getId() ] );
                try { fileDelete( src ); } catch ( any e ) {}
            } );

            it( "addAttachment writes under tickets/_no_org/<ticketId>/ when the ticket has no org", function(){
                var f         = makeFixture();
                var accountless = variables.tickets.createAccountlessTicket( {
                    originatingEmail : "drive-by-" & createUUID() & "@example.com",
                    subject          : "no-org",
                    source           : "email",
                    actorType        : "system"
                } );
                var src = writeTempJpeg();
                var att = variables.tickets.addAttachment( {
                    ticketId         : accountless.getId(),
                    originalFilename : "shot.jpg",
                    contentType      : "image/jpeg",
                    sizeBytes        : getFileInfo( src ).size,
                    sourcePath       : src,
                    uploaderAgentId  : f.agentId
                } );
                expect( att.getCbfsPath() ).toInclude( "tickets/_no_org/tickets/" & accountless.getId() & "/" );
                expect( att.getOrganizationId() ?: "" ).toBe( "" );

                cleanupFixture( f, [ accountless.getId() ] );
                try { fileDelete( src ); } catch ( any e ) {}
            } );

            it( "addAttachment seeds thumbnail_status=pending for image extensions", function(){
                var f      = makeFixture();
                var ticket = makeTicket( f );
                var src    = writeTempJpeg();
                var att    = variables.tickets.addAttachment( {
                    ticketId         : ticket.getId(),
                    originalFilename : "shot.jpg",
                    contentType      : "image/jpeg",
                    sizeBytes        : getFileInfo( src ).size,
                    sourcePath       : src,
                    uploaderAgentId  : f.agentId
                } );
                // Sync generation runs inside addAttachment; the real JPEG
                // fixture decodes cleanly so status flips to ready before
                // the call returns. Either pending or ready is correct
                // depending on whether the sync path has finished writing
                // the .thumb.jpg blob (it has, because addAttachment
                // calls markThumbnailReady before returning the entity).
                expect( [ "pending", "ready" ] ).toInclude( att.getThumbnailStatus() );

                cleanupFixture( f, [ ticket.getId() ] );
                try { fileDelete( src ); } catch ( any e ) {}
            } );

            it( "addAttachment marks non-image extensions as thumbnail unsupported", function(){
                var f      = makeFixture();
                var ticket = makeTicket( f );
                var src    = getTempDirectory() & "/spec-att-" & createUUID() & ".txt";
                fileWrite( src, "plain text contents" );
                var att = variables.tickets.addAttachment( {
                    ticketId         : ticket.getId(),
                    originalFilename : "notes.txt",
                    contentType      : "text/plain",
                    sizeBytes        : getFileInfo( src ).size,
                    sourcePath       : src,
                    uploaderAgentId  : f.agentId
                } );
                expect( att.getThumbnailStatus() ).toBe( "unsupported" );

                cleanupFixture( f, [ ticket.getId() ] );
                try { fileDelete( src ); } catch ( any e ) {}
            } );

            it( "markThumbnailReady transitions pending -> ready and stamps generated_at", function(){
                var f      = makeFixture();
                var ticket = makeTicket( f );
                var msgId  = makeMessage( ticket.getId(), f.contact.getId() );
                var attId  = insertAttachment( ticket.getId(), msgId, f.org.getId(), "pending" );

                variables.tickets.markThumbnailReady( attId );

                var row = queryExecute(
                    "SELECT thumbnail_status, thumbnail_generated_at FROM attachments WHERE id = :id",
                    { id : attId },
                    { returntype : "array" }
                )[ 1 ];
                expect( row.thumbnail_status ).toBe( "ready" );
                expect( len( toString( row.thumbnail_generated_at ?: "" ) ) ).toBeGT( 0 );

                cleanupFixture( f, [ ticket.getId() ] );
            } );

            it( "markThumbnailFailed transitions pending -> failed without stamping generated_at", function(){
                var f      = makeFixture();
                var ticket = makeTicket( f );
                var msgId  = makeMessage( ticket.getId(), f.contact.getId() );
                var attId  = insertAttachment( ticket.getId(), msgId, f.org.getId(), "pending" );

                variables.tickets.markThumbnailFailed( attId );

                var row = queryExecute(
                    "SELECT thumbnail_status, thumbnail_generated_at FROM attachments WHERE id = :id",
                    { id : attId },
                    { returntype : "array" }
                )[ 1 ];
                expect( row.thumbnail_status ).toBe( "failed" );
                // The column stays null on the failure path; BoxLang
                // sometimes surfaces SQL NULL as an empty string from
                // queryExecute, so check for "no length" rather than
                // strict isNull.
                expect( len( toString( row.thumbnail_generated_at ?: "" ) ) ).toBe( 0 );

                cleanupFixture( f, [ ticket.getId() ] );
            } );

            it( "soft-deleted attachments are hidden from contact listing but visible to agent listing", function(){
                var f      = makeFixture();
                var ticket = makeTicket( f );
                var msgId  = makeMessage( ticket.getId(), f.contact.getId() );
                var attId  = insertAttachment( ticket.getId(), msgId, f.org.getId(), "ready" );
                variables.tickets.softDeleteAttachment(
                    attachmentId : attId,
                    agentId      : f.agentId,
                    reason       : "spec cleanup"
                );

                var contactList = variables.tickets.listAttachmentsForTicket(
                    ticket.getId(),
                    { type : "contact", id : f.contact.getId() }
                );
                var agentList = variables.tickets.listAttachmentsForTicket(
                    ticket.getId(),
                    { type : "agent", id : f.agentId }
                );
                expect( arrayLen( contactList ) ).toBe( 0 );
                expect( arrayLen( agentList ) ).toBe( 1 );
                expect( agentList[ 1 ].isDeleted() ).toBeTrue();

                cleanupFixture( f, [ ticket.getId() ] );
            } );

            it( "readAttachmentBytes emits a ticket.attachment_downloaded audit event", function(){
                var f      = makeFixture();
                var ticket = makeTicket( f );
                var src    = writeTempJpeg();
                var att    = variables.tickets.addAttachment( {
                    ticketId         : ticket.getId(),
                    originalFilename : "shot.jpg",
                    contentType      : "image/jpeg",
                    sizeBytes        : getFileInfo( src ).size,
                    sourcePath       : src,
                    uploaderAgentId  : f.agentId
                } );
                variables.tickets.readAttachmentBytes(
                    att.getId(),
                    { type : "agent", id : f.agentId }
                );
                // entity_id is the ticket id (the attachment id rides
                // in the metadata blob). Scope by ticket so the count
                // is unambiguous even if the schema someday changes.
                var rows = queryExecute(
                    "SELECT id FROM audit_events
                      WHERE event_type = 'ticket.attachment_downloaded'
                        AND entity_id  = :tid",
                    { tid : ticket.getId() },
                    { returntype : "array" }
                );
                expect( arrayLen( rows ) ).toBeGTE( 1 );

                cleanupFixture( f, [ ticket.getId() ] );
                try { fileDelete( src ); } catch ( any e ) {}
            } );

        } );
    }

    // ---------------- helpers ----------------

    private struct function makeFixture(){
        var org = variables.contacts.createOrganization( {
            name : "Att Lifecycle Org " & createUUID(),
            slug : "att-life-" & lCase( replace( createUUID(), "-", "", "all" ) )
        } );
        var contact = variables.contacts.provisionContact( {
            organizationId : org.getId(),
            email          : "att-life-" & createUUID() & "@example.com",
            password       : "spec-password"
        } );
        var agentId = createObject( "java", "java.util.UUID" ).randomUUID().toString();
        queryExecute(
            "INSERT INTO agents ( id, email, password_hash, is_admin, is_active )
             VALUES ( :id, :email, :hash, false, true )",
            {
                id    : agentId,
                email : "att-life-agent-" & createUUID() & "@example.com",
                hash  : "$2a$12$G7WvY1Y4gl0sGJCWBiuWSemOi.dlpUXywSgk6JpT0QJ2AnP70mP8C"
            }
        );
        return { org : org, contact : contact, agentId : agentId };
    }

    private any function makeTicket( required struct fixture ){
        return variables.tickets.createTicket( {
            requesterContactId : arguments.fixture.contact.getId(),
            organizationId     : arguments.fixture.org.getId(),
            subject            : "Att lifecycle ticket",
            initialMessage     : "Body",
            source             : "agent"
        } );
    }

    private string function makeMessage( required string ticketId, required string contactId ){
        var m = variables.tickets.addMessage( {
            ticketId        : arguments.ticketId,
            body            : "public reply",
            authorContactId : arguments.contactId,
            isInternal      : false
        } );
        return m.getId();
    }

    /**
     * Insert a fake attachment row directly. Bypasses CBFS so the spec
     * stays decoupled from the default-disk provider for paths that
     * only need a row to exist.
     */
    private string function insertAttachment(
        required string ticketId,
        required string messageId,
        required string organizationId,
        required string thumbStatus
    ){
        var id = createObject( "java", "java.util.UUID" ).randomUUID().toString();
        queryExecute(
            "INSERT INTO attachments
                ( id, ticket_id, message_id, organization_id,
                  original_filename, content_type, size_bytes, cbfs_path,
                  thumbnail_status )
             VALUES
                ( :id, :tid, :mid, :oid,
                  :fn, :ct, cast( :sz as bigint ), :path,
                  :ts )",
            {
                id   : id,
                tid  : arguments.ticketId,
                mid  : arguments.messageId,
                oid  : arguments.organizationId,
                fn   : "spec.jpg",
                ct   : "image/jpeg",
                sz   : 1024,
                path : "org/" & arguments.organizationId & "/tickets/" & arguments.ticketId & "/" & id & ".jpg",
                ts   : arguments.thumbStatus
            }
        );
        return id;
    }

    private string function writeTempJpeg(){
        var BufferedImage = createObject( "java", "java.awt.image.BufferedImage" );
        var img = BufferedImage.init( 60, 60, BufferedImage.TYPE_INT_RGB );
        var g   = img.createGraphics();
        try {
            g.setColor( createObject( "java", "java.awt.Color" ).BLUE );
            g.fillRect( 0, 0, 60, 60 );
        } finally {
            g.dispose();
        }
        var path = getTempDirectory() & "/spec-att-life-" & createUUID() & ".jpg";
        var fos  = createObject( "java", "java.io.FileOutputStream" ).init( path );
        try {
            createObject( "java", "javax.imageio.ImageIO" ).write( img, "jpg", fos );
        } finally {
            fos.close();
        }
        return path;
    }

    private void function cleanupFixture( required struct fixture, array ticketIds = [] ){
        for ( var tid in arguments.ticketIds ) {
            queryExecute(
                "DELETE FROM audit_events
                  WHERE entity_id IN ( SELECT id FROM attachments WHERE ticket_id = :id )",
                { id : tid }
            );
            queryExecute( "DELETE FROM attachments WHERE ticket_id = :id", { id : tid } );
            queryExecute( "DELETE FROM ticket_events WHERE ticket_id = :id", { id : tid } );
            queryExecute( "DELETE FROM ticket_messages WHERE ticket_id = :id", { id : tid } );
            queryExecute( "DELETE FROM audit_events WHERE entity_id = :id", { id : tid } );
            queryExecute( "DELETE FROM tickets WHERE id = :id", { id : tid } );
        }
        if ( !structIsEmpty( arguments.fixture ) ) {
            queryExecute( "DELETE FROM audit_events WHERE actor_id = :id", { id : arguments.fixture.agentId } );
            queryExecute( "DELETE FROM contact_roles WHERE contact_id = :id", { id : arguments.fixture.contact.getId() } );
            queryExecute( "DELETE FROM contacts WHERE id = :id", { id : arguments.fixture.contact.getId() } );
            queryExecute( "DELETE FROM audit_events WHERE organization_id = :id", { id : arguments.fixture.org.getId() } );
            queryExecute( "DELETE FROM organizations WHERE id = :id", { id : arguments.fixture.org.getId() } );
            queryExecute( "DELETE FROM agents WHERE id = :id", { id : arguments.fixture.agentId } );
        }
    }

}
