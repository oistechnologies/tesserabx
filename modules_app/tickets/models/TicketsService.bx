/**
 * TicketsService: the public surface other modules use to create,
 * read, and act on tickets.
 *
 * Per CLAUDE.md, no other module imports Ticket / TicketMessage /
 * TicketEvent / Attachment directly. portal / widget / channels
 * create tickets through createTicket() and createAccountlessTicket().
 *
 * Every write operation records a TicketEvent (per-ticket timeline)
 * and emits a corresponding audit event through AuditService for
 * the central compliance log.
 */
class singleton=true {

    property name="wirebox"            inject="wirebox";
    property name="contactsService"    inject="ContactsService@contacts";
    property name="auditService"       inject="AuditService@audit";
    property name="slaService"         inject="SlaService@sla";
    property name="workflowService"    inject="WorkflowService@tickets";
    property name="cbfs"               inject="DiskService@cbfs";
    property name="imageProcessing"    inject="ImageProcessingService@core";
    property name="interceptorService"   inject="coldbox:interceptorService";
    property name="eventPayloadBuilder"  inject="EventPayloadBuilder@core";
    property name="ticketDto"            inject="TicketDto@tickets";
    property name="auth"                 inject="AuthenticationService@cbauth";

    // ---------- Status workflow ----------
    //
    // Statuses and transitions live in the ticket_statuses /
    // ticket_status_transitions tables and are admin-editable
    // through /agent/admin/workflow. The cached lookups in
    // WorkflowService keep these hot paths fast.

    variables.PRIORITIES = [ "low", "normal", "high", "urgent" ];
    variables.TYPES = [ "incident", "request", "problem", "question" ];
    variables.SOURCES = [ "email", "portal", "widget", "agent" ];

    public array function listStatuses() { return workflowService.listStatusKeys(); }
    public array function listPriorities() { return variables.PRIORITIES; }
    public array function listTypes() { return variables.TYPES; }

    public boolean function isValidTransition( required string from, required string to ){
        return workflowService.isValidTransition( arguments.from, arguments.to );
    }

    // ---------- Reads ----------

    /**
     * Single ticket lookup. Bypasses tenant scope; service callers
     * (the agent UI) handle authorization. Returns null when not
     * found.
     */
    public any function getTicket( required string id ){
        var t = wirebox.getInstance( "Ticket@tickets" )
            .withoutGlobalScope()
            .where( "id", arguments.id )
            .first();
        return isNull( t ) ? javaCast( "null", "" ) : t;
    }

    /**
     * List tickets for the agent surface. Bypasses tenant scope so
     * agents see across organizations. Filters are all optional.
     *
     * `status` accepts either a single key, a comma-delimited list of
     * keys, or an array of keys. Multi-status filtering switches the
     * generated SQL from `WHERE status = ?` to `WHERE status IN (...)`.
     * An empty array (or empty string) applies no status filter.
     */
    public array function listTickets(
        any status,
        string priority,
        string organizationId,
        string assignedToAgentId,
        string search,
        boolean accountlessOnly = false,
        array requesterContactIds,
        numeric limit = 100,
        numeric offset = 0
    ){
        var q = wirebox.getInstance( "Ticket@tickets" ).withoutGlobalScope();
        // Restrict to a caller-supplied set of requester contacts (the
        // agent VIP filter passes VIP contact ids here, resolved by
        // ContactsService so this module never reads the contacts
        // table). An explicitly empty set means "no matches".
        if ( structKeyExists( arguments, "requesterContactIds" ) ) {
            if ( !arrayLen( arguments.requesterContactIds ) ) return [];
            q = q.whereIn( "requester_contact_id", arguments.requesterContactIds );
        }
        if ( structKeyExists( arguments, "status" ) ) {
            var statusArr = isArray( arguments.status )
                ? arguments.status
                : listToArray( toString( arguments.status ?: "" ), "," );
            statusArr = statusArr.filter( s => len( trim( toString( s ) ) ) );
            if ( statusArr.len() ) q = q.whereIn( "status", statusArr );
        }
        if ( structKeyExists( arguments, "priority" ) && len( arguments.priority ?: "" ) ) q = q.where( "priority", arguments.priority );
        if ( structKeyExists( arguments, "organizationId" ) && len( arguments.organizationId ?: "" ) ) q = q.where( "organization_id", arguments.organizationId );
        if ( structKeyExists( arguments, "assignedToAgentId" ) && len( arguments.assignedToAgentId ?: "" ) ) q = q.where( "assigned_to_agent_id", arguments.assignedToAgentId );
        if ( arguments.accountlessOnly ) q = q.whereNull( "organization_id" );

        // Postgres full-text search on subject + originating_email.
        // plainto_tsquery accepts raw user input safely; ts_rank_cd
        // sorts results by relevance.
        if ( structKeyExists( arguments, "search" ) && len( trim( arguments.search ?: "" ) ) ) {
            q = q.whereRaw(
                "search_vector @@ plainto_tsquery( 'english', ? )",
                [ trim( arguments.search ) ]
            ).orderByRaw(
                "ts_rank_cd( search_vector, plainto_tsquery( 'english', ? ) ) DESC",
                [ trim( arguments.search ) ]
            );
        } else {
            q = q.orderBy( "created_at", "desc" );
        }
        return q.limit( arguments.limit ).offset( arguments.offset ).get();
    }

    /**
     * List tickets for a Contact (portal view). Uses tenant scope so
     * a leak (Contact for the wrong org) returns nothing. Excludes
     * accountless tickets explicitly.
     */
    public array function listTicketsForContact( required string contactId ){
        return wirebox.getInstance( "Ticket@tickets" )
            .where( "requester_contact_id", arguments.contactId )
            .whereNotNull( "organization_id" )
            .orderBy( "created_at", "desc" )
            .get();
    }

    /**
     * Tickets across one organization. Intended for the Organization
     * Admin role on the portal: they see the full org-wide queue, not
     * just tickets they personally raised. The tenant scope on Ticket
     * already restricts this to the caller's organization in client
     * context; passing organizationId explicitly is defensive and
     * lets the agent UI reuse the same method for an org-filter view.
     */
    public array function listTicketsForOrganization( required string organizationId ){
        return wirebox.getInstance( "Ticket@tickets" )
            .where( "organization_id", arguments.organizationId )
            .orderBy( "created_at", "desc" )
            .get();
    }

    /**
     * Messages for a ticket. includeInternal defaults to false so the
     * portal can call this directly without leaking internal notes.
     * The agent UI passes true.
     */
    public array function listMessagesForTicket(
        required string ticketId,
        boolean includeInternal = false
    ){
        var q = wirebox.getInstance( "TicketMessage@tickets" )
            .where( "ticket_id", arguments.ticketId );
        if ( !arguments.includeInternal ) {
            q = q.where( "is_internal", false );
        }
        return q.orderBy( "created_at", "asc" ).get();
    }

    public array function listEventsForTicket( required string ticketId ){
        return wirebox.getInstance( "TicketEvent@tickets" )
            .where( "ticket_id", arguments.ticketId )
            .orderBy( "occurred_at", "asc" )
            .get();
    }

    /**
     * Attachments visible to the supplied viewer.
     *
     * viewer is a struct with at least .type ("agent" or "contact")
     * and .id. Agents see all non-deleted attachments AND deleted
     * rows (so the UI can render a "deleted" badge with the audit
     * trail). Contacts see only non-deleted, non-internal, same-org
     * attachments. The caller must already have proven they're
     * allowed to see the parent ticket; this method scopes within
     * that ticket.
     */
    public array function listAttachmentsForTicket(
        required string ticketId,
        struct viewer = { type : "agent", id : "" }
    ){
        var q = wirebox.getInstance( "Attachment@tickets" )
            .where( "ticket_id", arguments.ticketId );

        if ( ( arguments.viewer.type ?: "" ) == "contact" ) {
            // Hide soft-deleted from contacts entirely.
            q = q.whereNull( "deleted_at" );
            // Strip attachments belonging to internal notes.
            q = q.whereNotExists( function( q2 ){
                q2.from( "ticket_messages tm" )
                    .whereColumn( "tm.id", "attachments.message_id" )
                    .where( "tm.is_internal", true );
            } );
        }

        return q.orderBy( "created_at", "asc" ).get();
    }

    /**
     * Look up a single attachment and enforce viewer access.
     * Throws TicketsService.AttachmentNotFound on missing,
     * TicketsService.AttachmentAccessDenied on access fail.
     *
     * The single chokepoint every download handler uses.
     */
    public any function getAttachmentForViewer(
        required string attachmentId,
        required struct viewer
    ){
        var a = wirebox.getInstance( "Attachment@tickets" )
            .where( "id", arguments.attachmentId )
            .first();
        if ( isNull( a ) ) {
            throw(
                type    : "TicketsService.AttachmentNotFound",
                message : "No attachment with id [" & arguments.attachmentId & "]."
            );
        }
        if ( !canViewAttachment( a, arguments.viewer ) ) {
            throw(
                type    : "TicketsService.AttachmentAccessDenied",
                message : "Viewer cannot access this attachment."
            );
        }
        return a;
    }

    /**
     * Tags attached to a ticket, in insertion order. Bypasses tenant
     * scope; the caller (agent UI, AI triage) handles authorization.
     */
    public array function listTagsForTicket( required string ticketId ){
        var rows = queryExecute(
            "SELECT t.id, t.name, t.slug, t.color
             FROM   tags t
             JOIN   ticket_tags tt ON tt.tag_id = t.id
             WHERE  tt.ticket_id = :id
             ORDER  BY tt.created_at",
            { id : arguments.ticketId }
        );
        var out = [];
        for ( var i = 1; i <= rows.recordCount; i++ ) {
            out.append( {
                "id"    : rows.id[ i ],
                "name"  : rows.name[ i ],
                "slug"  : rows.slug[ i ],
                "color" : rows.color[ i ]
            } );
        }
        return out;
    }

    /**
     * Apply one or more tags to a ticket by display name. Idempotent:
     * unknown names are created (slugified, default colour), known
     * names are reused, and a (ticket, tag) pair already in the join
     * table is left alone. Returns the array of tag rows now on the
     * ticket.
     */
    public array function applyTagsByName(
        required string ticketId,
        required array  tagNames,
        string actorType = "",
        string actorId   = ""
    ){
        if ( !arguments.tagNames.len() ) return listTagsForTicket( arguments.ticketId );
        var t = getTicket( arguments.ticketId );
        if ( isNull( t ) ) {
            throw( type = "TicketsService.UnknownTicket", message = "No ticket with id [#arguments.ticketId#]." );
        }

        var addedNames = [];
        for ( var raw in arguments.tagNames ) {
            var name = trim( raw );
            if ( !len( name ) ) continue;
            var slug = slugifyTag( name );
            // Upsert the tag itself.
            var existing = queryExecute(
                "SELECT id FROM tags WHERE slug = :s",
                { s : slug }
            );
            var tagId = existing.recordCount ? existing.id[ 1 ] : "";
            if ( !len( tagId ) ) {
                tagId = newId();
                queryExecute(
                    "INSERT INTO tags ( id, name, slug, color, created_at )
                     VALUES ( :id, :name, :slug, 'secondary', NOW() )
                     ON CONFLICT ( slug ) DO NOTHING",
                    { id : tagId, name : name, slug : slug }
                );
                // Race: another caller created it between our SELECT
                // and INSERT; re-read to pick up their id.
                var verify = queryExecute( "SELECT id FROM tags WHERE slug = :s", { s : slug } );
                if ( verify.recordCount ) tagId = verify.id[ 1 ];
            }
            // Attach to the ticket.
            queryExecute(
                "INSERT INTO ticket_tags ( ticket_id, tag_id, created_at )
                 VALUES ( :tid, :tag, NOW() )
                 ON CONFLICT ( ticket_id, tag_id ) DO NOTHING",
                { tid : t.getId(), tag : tagId }
            );
            addedNames.append( name );
        }
        if ( addedNames.len() ) {
            recordTicketEvent(
                ticketId  : t.getId(),
                eventType : "ticket.tags_added",
                actorType : arguments.actorType,
                actorId   : arguments.actorId,
                metadata  : { "tags" : addedNames }
            );
            interceptorService.announce(
                "onTicketTagsAdded",
                eventPayloadBuilder.build(
                    event          : "onTicketTagsAdded",
                    organizationId : t.getOrganizationId() ?: "",
                    actorType      : arguments.actorType ?: "system",
                    actorId        : arguments.actorId ?: "system",
                    entity         : { type : "Ticket", id : t.getId() },
                    metadata       : { tags : addedNames }
                ),
                true
            );
        }
        return listTagsForTicket( t.getId() );
    }

    private string function slugifyTag( required string name ){
        var s = lCase( trim( arguments.name ) );
        s = reReplace( s, "[^a-z0-9]+", "-", "all" );
        s = reReplace( s, "^-+|-+$", "", "all" );
        return left( s, 80 );
    }

    /**
     * Persist (or overwrite) the AI thread summary on a ticket.
     * SummarizationService calls this after a successful generation
     * so the result survives navigation and shows a "generated at"
     * timestamp without having to re-run the model.
     */
    public void function saveAiSummary(
        required string ticketId,
        required struct summary
    ){
        var t = getTicket( arguments.ticketId );
        if ( isNull( t ) ) return;
        t.setAiSummary( jsonSerialize( {
            "summary"   : arguments.summary.summary   ?: "",
            "keyPoints" : arguments.summary.keyPoints ?: [],
            "nextStep"  : arguments.summary.nextStep  ?: ""
        } ) );
        t.setAiSummaryAt( now() );
        t.save();
    }

    /**
     * Read the persisted AI summary back into the struct shape the
     * agent UI renders. Returns null when no summary has been run.
     */
    public any function getAiSummary( required string ticketId ){
        var t = getTicket( arguments.ticketId );
        if ( isNull( t ) ) return javaCast( "null", "" );
        var raw = t.getAiSummary() ?: "";
        if ( !len( raw ) ) return javaCast( "null", "" );
        try {
            var data = jsonDeserialize( raw );
            return {
                "summary"     : data.summary   ?: "",
                "keyPoints"   : isArray( data.keyPoints ?: [] ) ? data.keyPoints : [],
                "nextStep"    : data.nextStep  ?: "",
                "generatedAt" : t.getAiSummaryAt()
            };
        } catch ( any e ) {
            return javaCast( "null", "" );
        }
    }

    /**
     * Public wrapper around recordTicketEvent for AI triage runs.
     * Keeps the private recorder private to non-tickets callers while
     * giving the AI triage service a one-call way to land a clean
     * ticket-timeline entry without touching ticket_events directly.
     */
    public void function recordTriageEvent(
        required string ticketId,
        struct metadata = {}
    ){
        recordTicketEvent(
            ticketId  : arguments.ticketId,
            eventType : "ticket.triaged",
            actorType : "ai",
            actorId   : "triage",
            metadata  : arguments.metadata
        );
    }

    // ---------- Writes ----------

    /**
     * Create a contact-backed ticket. Caller supplies a
     * requesterContactId (which determines the organization) plus
     * subject and source.
     */
    public any function createTicket( required struct data ){
        var contact = contactsService.getContactById( arguments.data.requesterContactId );
        if ( isNull( contact ) ) {
            throw( type="TicketsService.UnknownContact", message="No contact with id [#arguments.data.requesterContactId#]." );
        }

        var t = newTicket();
        t.setRequesterContactId( contact.getId() );
        t.setOrganizationId( contact.getOrganizationId() );
        t.setOriginatingEmail( arguments.data.originatingEmail ?: contact.getEmail() );
        applyCommonTicketFields( t, arguments.data );
        t.save();
        t = getTicket( t.getId() );
        applyInitialSla( t );

        recordTicketEvent(
            ticketId  : t.getId(),
            eventType : "ticket.created",
            actorType : arguments.data.actorType ?: "",
            actorId   : arguments.data.actorId ?: "",
            metadata  : { "source" : t.getSource(), "subject" : t.getSubject() }
        );
        recordAudit(
            eventType      : "ticket.created",
            entityId       : t.getId(),
            organizationId : t.getOrganizationId(),
            actorType      : arguments.data.actorType ?: "",
            actorId        : arguments.data.actorId ?: "",
            metadata       : { "requesterContactId" : t.getRequesterContactId(), "subject" : t.getSubject() }
        );

        // B3: emit the canonical envelope plus the legacy top-level
        // ticket/accountless keys so existing consumers keep working.
        var createdPayload = eventPayloadBuilder.build(
            event          : "onTicketCreated",
            organizationId : t.getOrganizationId() ?: "",
            actorType      : arguments.data.actorType ?: "system",
            actorId        : arguments.data.actorId   ?: "system",
            entity         : { type : "Ticket", id : t.getId() },
            after          : ticketDto.fromTicket( t ),
            metadata       : { "accountless" : false }
        );
        createdPayload.ticket      = t;
        createdPayload.accountless = false;
        interceptorService.announce( "onTicketCreated", createdPayload );

        return t;
    }

    /**
     * Create an accountless ticket from a raw sender email. No
     * organization, no contact; only provider agents can see it.
     * Phase 2's channel intake (inbound email) is the typical caller;
     * agents can also create one manually.
     */
    public any function createAccountlessTicket( required struct data ){
        if ( !len( arguments.data.originatingEmail ?: "" ) ) {
            throw( type="TicketsService.MissingEmail", message="Accountless tickets require an originatingEmail." );
        }
        var t = newTicket();
        t.setOriginatingEmail( arguments.data.originatingEmail );
        applyCommonTicketFields( t, arguments.data );
        t.save();
        t = getTicket( t.getId() );
        applyInitialSla( t );

        recordTicketEvent(
            ticketId  : t.getId(),
            eventType : "ticket.created_accountless",
            actorType : arguments.data.actorType ?: "",
            actorId   : arguments.data.actorId ?: "",
            metadata  : { "originatingEmail" : t.getOriginatingEmail(), "source" : t.getSource() }
        );
        recordAudit(
            eventType  : "ticket.created_accountless",
            entityId   : t.getId(),
            actorType  : arguments.data.actorType ?: "",
            actorId    : arguments.data.actorId ?: "",
            metadata   : { "originatingEmail" : t.getOriginatingEmail() }
        );

        var accountlessPayload = eventPayloadBuilder.build(
            event          : "onTicketCreated",
            organizationId : "",
            actorType      : arguments.data.actorType ?: "system",
            actorId        : arguments.data.actorId   ?: "system",
            entity         : { type : "Ticket", id : t.getId() },
            after          : ticketDto.fromTicket( t ),
            metadata       : { "accountless" : true }
        );
        accountlessPayload.ticket      = t;
        accountlessPayload.accountless = true;
        interceptorService.announce( "onTicketCreated", accountlessPayload );

        return t;
    }

    /**
     * Append a message to a ticket. Exactly one of authorAgentId or
     * authorContactId is expected for a normal message; an inbound
     * email that hasn't resolved to a contact passes neither, only
     * authorEmail.
     */
    public any function addMessage( required struct data ){
        var t = getTicket( arguments.data.ticketId );
        if ( isNull( t ) ) {
            throw( type="TicketsService.UnknownTicket", message="No ticket with id [#arguments.data.ticketId#]." );
        }

        var m = wirebox.getInstance( "TicketMessage@tickets" );
        m.setId( newId() );
        m.setTicketId( t.getId() );
        // Belt-and-braces null guard. The DB has a NOT NULL
        // constraint on body and a transient mail-jar getContent()
        // result (BoxLang can hand back a Java-null on a lazy
        // multipart fetch hiccup) used to slip past the ?: coalesce
        // and fail the INSERT, which then orphaned the parent
        // ticket and tripped the IMAP poll into a 60-second
        // duplicate-create loop. Coercing here ensures the INSERT
        // always has at least the empty string.
        var rawBody = arguments.data.body ?: "";
        if ( isNull( rawBody ) || !isSimpleValue( rawBody ) ) rawBody = "";
        m.setBody( toString( rawBody ) );
        m.setIsInternal( arguments.data.isInternal ?: false );
        m.setIsSystemMessage( arguments.data.isSystemMessage ?: false );
        if ( len( arguments.data.authorAgentId ?: "" ) ) m.setAuthorAgentId( arguments.data.authorAgentId );
        if ( len( arguments.data.authorContactId ?: "" ) ) m.setAuthorContactId( arguments.data.authorContactId );
        if ( len( arguments.data.authorEmail ?: "" ) ) m.setAuthorEmail( arguments.data.authorEmail );
        if ( len( arguments.data.messageId ?: "" ) ) m.setMessageId( arguments.data.messageId );
        m.save();

        recordFirstResponseIfPending( t, m );
        touchTicket( t );

        recordTicketEvent(
            ticketId  : t.getId(),
            eventType : m.getIsInternal() ? "ticket.internal_note_added" : "ticket.message_added",
            actorType : len( arguments.data.authorAgentId ?: "" ) ? "agent" : ( len( arguments.data.authorContactId ?: "" ) ? "contact" : "system" ),
            actorId   : arguments.data.authorAgentId ?: arguments.data.authorContactId ?: "",
            metadata  : { "messageId" : m.getId(), "isInternal" : m.getIsInternal() }
        );

        // Cross-module hook: channels listens for outbound dispatch.
        // Tickets does not depend on channels (cycle); the interceptor
        // service is the back-channel.
        var msgPayload = eventPayloadBuilder.build(
            event          : "onTicketMessageAdded",
            organizationId : t.getOrganizationId() ?: "",
            actorType      : len( arguments.data.authorAgentId ?: "" ) ? "agent" : ( len( arguments.data.authorContactId ?: "" ) ? "contact" : "system" ),
            actorId        : arguments.data.authorAgentId ?: arguments.data.authorContactId ?: "system",
            entity         : { type : "TicketMessage", id : m.getId() },
            after          : ticketDto.fromTicketMessage( m ),
            metadata       : { "ticketId" : t.getId(), "isInternal" : !!m.getIsInternal() }
        );
        msgPayload.message = m;
        msgPayload.ticket  = t;
        interceptorService.announce( "onTicketMessageAdded", msgPayload );

        return m;
    }

    /**
     * Move a ticket to a new status. Throws on an invalid transition
     * so callers can show a clear error rather than silently no-op.
     */
    public any function changeStatus( required struct data ){
        var t = getTicket( arguments.data.ticketId );
        if ( isNull( t ) ) {
            throw( type="TicketsService.UnknownTicket", message="No ticket with id [#arguments.data.ticketId#]." );
        }
        var from = t.getStatus();
        var to   = arguments.data.status;
        if ( from == to ) return t;
        if ( !isValidTransition( from, to ) ) {
            throw(
                type    = "TicketsService.InvalidTransition",
                message = "Cannot move ticket from [#from#] to [#to#]."
            );
        }

        t.setStatus( to );
        // Stamp resolved_at / closed_at from the destination
        // status's category, not a hardcoded key. Re-opening a
        // terminal ticket (any non-terminal target from a terminal
        // source) clears both stamps so historical rows do not
        // bleed into "currently resolved" reporting.
        var toCategory   = workflowCategoryFor( to );
        var fromCategory = workflowCategoryFor( from );
        if ( toCategory == "resolved" ) t.setResolvedAt( now() );
        if ( toCategory == "closed" )   t.setClosedAt( now() );
        var fromTerminal = ( fromCategory == "resolved" || fromCategory == "closed" );
        var toTerminal   = ( toCategory   == "resolved" || toCategory   == "closed" );
        if ( fromTerminal && !toTerminal ) {
            t.clearAttribute( name = "closedAt", setToNull = true );
            t.clearAttribute( name = "resolvedAt", setToNull = true );
        }
        applySlaStatusTransition( t, from, to );
        t.save();
        touchTicket( t );

        recordTicketEvent(
            ticketId  : t.getId(),
            eventType : "ticket.status_changed",
            actorType : arguments.data.actorType ?: "agent",
            actorId   : arguments.data.actorId ?: "",
            metadata  : { "from" : from, "to" : to }
        );
        recordAudit(
            eventType      : "ticket.status_changed",
            entityId       : t.getId(),
            organizationId : t.getOrganizationId() ?: "",
            actorType      : arguments.data.actorType ?: "agent",
            actorId        : arguments.data.actorId ?: "",
            metadata       : { "from" : from, "to" : to }
        );

        var statusPayload = eventPayloadBuilder.build(
            event          : "onTicketStatusChanged",
            organizationId : t.getOrganizationId() ?: "",
            actorType      : arguments.data.actorType ?: "agent",
            actorId        : arguments.data.actorId   ?: "system",
            entity         : { type : "Ticket", id : t.getId() },
            before         : { "status" : from },
            after          : ticketDto.fromTicket( t ),
            metadata       : { "from" : from, "to" : to }
        );
        statusPayload.ticket = t;
        statusPayload.from   = from;
        statusPayload.to     = to;
        interceptorService.announce( "onTicketStatusChanged", statusPayload );

        return t;
    }

    /**
     * Assign or reassign a ticket to an agent. Pass agentId="" to
     * unassign.
     */
    public any function assignToAgent( required struct data ){
        var t = getTicket( arguments.data.ticketId );
        if ( isNull( t ) ) {
            throw( type="TicketsService.UnknownTicket", message="No ticket with id [#arguments.data.ticketId#]." );
        }
        var previous = t.getAssignedToAgentId();
        var next     = arguments.data.agentId ?: "";
        if ( ( isNull( previous ) ? "" : previous ) == next ) return t;

        if ( len( next ) ) {
            t.setAssignedToAgentId( next );
            touchTicket( t );
        } else {
            // Quick's clearAttribute + save doesn't reliably emit a
            // SET column = NULL in the UPDATE; fall back to a direct
            // statement for the unset case.
            queryExecute(
                "UPDATE tickets SET assigned_to_agent_id = NULL, updated_at = NOW() WHERE id = :id",
                { id : t.getId() }
            );
            t = getTicket( t.getId() );
        }
        touchTicket( t );

        recordTicketEvent(
            ticketId  : t.getId(),
            eventType : "ticket.assigned",
            actorType : "agent",
            actorId   : arguments.data.actorId ?: "",
            metadata  : { "previousAgentId" : previous ?: "", "newAgentId" : next }
        );
        recordAudit(
            eventType      : "ticket.assigned",
            entityId       : t.getId(),
            organizationId : t.getOrganizationId() ?: "",
            actorType      : "agent",
            actorId        : arguments.data.actorId ?: "",
            metadata       : { "previousAgentId" : previous ?: "", "newAgentId" : next }
        );

        interceptorService.announce(
            "onTicketAssigned",
            eventPayloadBuilder.build(
                event          : "onTicketAssigned",
                organizationId : t.getOrganizationId() ?: "",
                actorType      : "agent",
                actorId        : arguments.data.actorId ?: "system",
                entity         : { type : "Ticket", id : t.getId() },
                before         : { assignedToAgentId : previous ?: "" },
                after          : { assignedToAgentId : next }
            ),
            true
        );
        return t;
    }

    /**
     * Promote the sender of an accountless ticket into a real Contact
     * and bring the ticket under tenancy. Caller supplies the new
     * Contact's organizationId (or creates the org first via
     * ContactsService.createOrganization).
     */
    public any function promoteSenderToContact( required struct data ){
        var t = getTicket( arguments.data.ticketId );
        if ( isNull( t ) ) {
            throw( type="TicketsService.UnknownTicket", message="No ticket with id [#arguments.data.ticketId#]." );
        }
        if ( !t.isAccountless() ) {
            throw( type="TicketsService.AlreadyHasContact", message="Ticket already has a requester contact." );
        }
        if ( !len( t.getOriginatingEmail() ?: "" ) ) {
            throw( type="TicketsService.NoOriginatingEmail", message="Ticket has no originating email to promote." );
        }

        var contact = contactsService.provisionContact( {
            organizationId : arguments.data.organizationId,
            email          : t.getOriginatingEmail(),
            password       : arguments.data.password ?: createUUID(),
            firstName      : arguments.data.firstName ?: "",
            lastName       : arguments.data.lastName ?: ""
        } );

        t.setRequesterContactId( contact.getId() );
        t.setOrganizationId( contact.getOrganizationId() );
        t.save();
        touchTicket( t );

        recordTicketEvent(
            ticketId  : t.getId(),
            eventType : "ticket.promoted_to_contact",
            actorType : "agent",
            actorId   : arguments.data.actorId ?: "",
            metadata  : {
                "contactId"      : contact.getId(),
                "organizationId" : contact.getOrganizationId(),
                "promotedEmail"  : t.getOriginatingEmail()
            }
        );
        recordAudit(
            eventType      : "ticket.promoted_to_contact",
            entityId       : t.getId(),
            organizationId : contact.getOrganizationId(),
            actorType      : "agent",
            actorId        : arguments.data.actorId ?: "",
            metadata       : { "contactId" : contact.getId(), "email" : t.getOriginatingEmail() }
        );

        interceptorService.announce(
            "onTicketPromotedToContact",
            eventPayloadBuilder.build(
                event          : "onTicketPromotedToContact",
                organizationId : contact.getOrganizationId(),
                actorType      : "agent",
                actorId        : arguments.data.actorId ?: "system",
                entity         : { type : "Ticket", id : t.getId() },
                metadata       : {
                    contactId       : contact.getId(),
                    promotedEmail   : t.getOriginatingEmail()
                }
            ),
            true
        );
        return { "ticket" : t, "contact" : contact };
    }

    // ---------- Attachments ----------

    /**
     * Persist an uploaded file against a ticket (and optionally a
     * specific message). Caller passes the temp path on disk + the
     * original filename + content type + size + uploader id.
     *
     * The service:
     *   - validates extension, size, and magic bytes
     *   - writes to the SECURE CBFS disk at
     *     org/<orgId>/tickets/<ticketId>/<uuid>.<ext>
     *     (or tickets/_no_org/<ticketId>/... when accountless)
     *   - records the Attachment row with organization_id +
     *     thumbnail_status
     *   - emits ticket.attachment_added through both the per-ticket
     *     timeline and the central audit log
     */
    public any function addAttachment( required struct data ){
        var t = getTicket( arguments.data.ticketId );
        if ( isNull( t ) ) {
            throw(
                type    : "TicketsService.UnknownTicket",
                message : "No ticket with id [" & arguments.data.ticketId & "]."
            );
        }
        var filename    = arguments.data.originalFilename;
        var size        = int( arguments.data.sizeBytes );
        var ctype       = arguments.data.contentType ?: "application/octet-stream";
        var sourcePath  = arguments.data.sourcePath;

        var validation = validateUpload(
            filename    : filename,
            sizeBytes   : size,
            sourcePath  : sourcePath,
            contentType : ctype
        );
        if ( !validation.ok ) {
            throw(
                type    : "TicketsService.UploadRejected",
                message : validation.error
            );
        }

        var orgId = t.getOrganizationId() ?: "";
        var orgSegment = len( orgId ) ? ( "org/" & orgId ) : "tickets/_no_org";
        var ext   = lCase( listLast( filename, "." ) );
        var path  = orgSegment & "/tickets/" & t.getId() & "/" & newId() & "." & ext;

        cbfs.defaultDisk().create(
            path      : path,
            contents  : fileReadBinary( sourcePath ),
            overwrite : true,
            mode      : "600"
        );

        var imageExts = [ "jpg", "jpeg", "png", "gif", "webp" ];
        var thumbStatus = arrayFindNoCase( imageExts, ext ) > 0 ? "pending" : "unsupported";

        var a = wirebox.getInstance( "Attachment@tickets" );
        a.setId( newId() );
        a.setTicketId( t.getId() );
        if ( len( orgId ) ) a.setOrganizationId( orgId );
        if ( len( arguments.data.messageId ?: "" ) ) a.setMessageId( arguments.data.messageId );
        if ( len( arguments.data.uploaderAgentId ?: "" ) ) a.setUploaderAgentId( arguments.data.uploaderAgentId );
        if ( len( arguments.data.uploaderContactId ?: "" ) ) a.setUploaderContactId( arguments.data.uploaderContactId );
        a.setOriginalFilename( filename );
        a.setContentType( ctype );
        a.setSizeBytes( size );
        a.setCbfsPath( path );
        a.setThumbnailStatus( thumbStatus );
        a.save();

        // Synchronous thumbnail generation for image extensions.
        // cbq is partially broken on Postgres per the project's
        // memory file; async deferred to a later phase. The avatar
        // pipeline (Phase 3) runs sync without complaints; image
        // attachments are similarly small.
        if ( thumbStatus == "pending" ) {
            try {
                var thumb = imageProcessing.generateThumbnail(
                    fileReadBinary( sourcePath ),
                    ctype
                );
                if ( thumb.ok ) {
                    cbfs.defaultDisk().create(
                        path      : path & ".thumb.jpg",
                        contents  : thumb.bytes,
                        overwrite : true,
                        mode      : "600"
                    );
                    markThumbnailReady( a.getId() );
                } else {
                    writeLog(
                        text : "Attachment thumbnail generation failed [" & a.getId() & "]: " & thumb.error,
                        log  : "tesserabx",
                        type : "warning"
                    );
                    markThumbnailFailed( a.getId() );
                }
            } catch ( any e ) {
                writeLog(
                    text : "Attachment thumbnail generation threw [" & a.getId() & "]: " & e.message,
                    log  : "tesserabx",
                    type : "warning"
                );
                markThumbnailFailed( a.getId() );
            }
        }

        touchTicket( t );

        var actorType = len( arguments.data.uploaderAgentId ?: "" ) ? "agent" : "contact";
        var actorId   = arguments.data.uploaderAgentId ?: arguments.data.uploaderContactId ?: "";
        var metadata  = {
            "attachmentId"   : a.getId(),
            "filename"       : filename,
            "sizeBytes"      : size,
            "contentType"    : ctype,
            "organizationId" : orgId
        };
        recordTicketEvent(
            ticketId  : t.getId(),
            eventType : "ticket.attachment_added",
            actorType : actorType,
            actorId   : actorId,
            metadata  : metadata
        );
        recordAudit(
            eventType      : "ticket.attachment_added",
            entityId       : t.getId(),
            organizationId : orgId,
            actorType      : actorType,
            actorId        : actorId,
            metadata       : metadata
        );

        interceptorService.announce(
            "onTicketAttachmentAdded",
            eventPayloadBuilder.build(
                event          : "onTicketAttachmentAdded",
                organizationId : orgId ?: "",
                actorType      : actorType,
                actorId        : actorId,
                entity         : { type : "Attachment", id : a.getId() },
                metadata       : metadata
            ),
            true
        );

        return a;
    }

    /**
     * Read raw bytes for an attachment through the access-check
     * chokepoint. Records ticket.attachment_downloaded on success.
     * Callers stream the returned bytes; the CBFS path never leaves
     * the service layer.
     */
    public any function readAttachmentBytes(
        required string attachmentId,
        required struct viewer
    ){
        var a = getAttachmentForViewer( arguments.attachmentId, arguments.viewer );

        // Soft-deleted: agents see metadata in the listing but get
        // a 403 on the bytes. canViewAttachment enforces; this is
        // defense-in-depth.
        if ( a.isDeleted() ) {
            throw(
                type    : "TicketsService.AttachmentAccessDenied",
                message : "Attachment has been deleted."
            );
        }

        var bytes = cbfs.defaultDisk().get( a.getCbfsPath() );

        recordAudit(
            eventType      : "ticket.attachment_downloaded",
            entityId       : a.getTicketId(),
            organizationId : a.getOrganizationId() ?: "",
            actorType      : arguments.viewer.type ?: "",
            actorId        : arguments.viewer.id ?: "",
            metadata       : {
                "attachmentId" : a.getId(),
                "ticketId"     : a.getTicketId(),
                "viewerType"   : arguments.viewer.type ?: "",
                "viewerId"     : arguments.viewer.id ?: ""
            }
        );

        return bytes;
    }

    /**
     * Soft delete: stamp the trail columns, record the audit event,
     * leave the CBFS bytes in place. Agents only; a non-empty reason
     * is required.
     */
    public any function softDeleteAttachment(
        required string attachmentId,
        required string agentId,
        required string reason
    ){
        if ( !len( trim( arguments.reason ) ) ) {
            throw(
                type    : "TicketsService.MissingDeletionReason",
                message : "Deletion reason is required."
            );
        }
        var a = wirebox.getInstance( "Attachment@tickets" )
            .where( "id", arguments.attachmentId )
            .first();
        if ( isNull( a ) ) {
            throw(
                type    : "TicketsService.AttachmentNotFound",
                message : "No attachment with id [" & arguments.attachmentId & "]."
            );
        }
        if ( a.isDeleted() ) {
            // Idempotent: re-deleting is a no-op.
            return a;
        }
        a.setDeletedAt( now() );
        a.setDeletedByAgentId( arguments.agentId );
        a.setDeletionReason( trim( arguments.reason ) );
        a.save();

        recordTicketEvent(
            ticketId  : a.getTicketId(),
            eventType : "ticket.attachment_deleted",
            actorType : "agent",
            actorId   : arguments.agentId,
            metadata  : {
                "attachmentId"   : a.getId(),
                "ticketId"       : a.getTicketId(),
                "deletionReason" : trim( arguments.reason )
            }
        );
        recordAudit(
            eventType      : "ticket.attachment_deleted",
            entityId       : a.getTicketId(),
            organizationId : a.getOrganizationId() ?: "",
            actorType      : "agent",
            actorId        : arguments.agentId,
            metadata       : {
                "attachmentId"   : a.getId(),
                "ticketId"       : a.getTicketId(),
                "deletionReason" : trim( arguments.reason )
            }
        );

        interceptorService.announce(
            "onTicketAttachmentDeleted",
            eventPayloadBuilder.build(
                event          : "onTicketAttachmentDeleted",
                organizationId : a.getOrganizationId() ?: "",
                actorType      : "agent",
                actorId        : arguments.agentId,
                entity         : { type : "Attachment", id : a.getId() },
                metadata       : {
                    ticketId       : a.getTicketId(),
                    deletionReason : trim( arguments.reason )
                }
            ),
            true
        );
        return a;
    }

    /**
     * Mark a queued thumbnail "ready" once the bytes are persisted
     * on the CBFS path <originalPath>.thumb.jpg. Called by Phase 8.3
     * thumbnail pipeline.
     */
    public void function markThumbnailReady( required string attachmentId ){
        var a = wirebox.getInstance( "Attachment@tickets" )
            .where( "id", arguments.attachmentId )
            .first();
        if ( isNull( a ) ) return;
        a.setThumbnailStatus( "ready" );
        a.setThumbnailGeneratedAt( now() );
        a.save();
        recordAudit(
            eventType      : "ticket.attachment_thumbnail_generated",
            entityId       : a.getTicketId(),
            organizationId : a.getOrganizationId() ?: "",
            metadata       : {
                "attachmentId" : a.getId(),
                "ticketId"     : a.getTicketId()
            }
        );
    }

    public void function markThumbnailFailed( required string attachmentId ){
        var a = wirebox.getInstance( "Attachment@tickets" )
            .where( "id", arguments.attachmentId )
            .first();
        if ( isNull( a ) ) return;
        a.setThumbnailStatus( "failed" );
        a.save();
    }

    /**
     * Validate an upload: extension whitelist, size cap, and
     * magic-byte sanity check against the declared content type.
     *
     * Returns { ok : boolean, error : string }. Does not throw.
     * The caller (handler or service entry) decides whether to
     * surface as a flash or to throw.
     */
    public struct function validateUpload(
        required string filename,
        required numeric sizeBytes,
        string sourcePath  = "",
        string contentType = ""
    ){
        var maxBytes = int( getSystemSetting( "UPLOAD_MAX_BYTES", "26214400" ) );
        if ( arguments.sizeBytes > maxBytes ) {
            return { ok : false, error : "Upload exceeds configured maximum (" & maxBytes & " bytes)." };
        }
        var allowed = listToArray(
            getSystemSetting( "UPLOAD_ALLOWED_EXTENSIONS", "jpg,jpeg,png,gif,pdf,txt,csv,xls,xlsx,doc,docx,zip" )
        );
        var ext = lCase( listLast( arguments.filename, "." ) );
        if ( !arrayFindNoCase( allowed, ext ) ) {
            return { ok : false, error : "File type [." & ext & "] is not allowed." };
        }
        // Magic-byte sniff. We can only verify what we have a
        // signature for; unknown-but-allowed extensions pass through
        // (text/csv/etc. have no reliable header). Mismatches between
        // declared content type / extension and actual bytes are the
        // common attack: rename evil.exe to evil.pdf.
        if ( len( arguments.sourcePath ) && fileExists( arguments.sourcePath ) ) {
            var sniffed = sniffMimeType( arguments.sourcePath );
            if ( len( sniffed ) && !mimeMatches( sniffed, ext, arguments.contentType ) ) {
                return {
                    ok    : false,
                    error : "File contents do not match declared type (." & ext & " / " & arguments.contentType & " vs detected " & sniffed & ")."
                };
            }
        }
        return { ok : true, error : "" };
    }

    /**
     * Read the first 16 bytes of a file and return the MIME family
     * we can identify. Empty string when unknown (caller treats that
     * as "no opinion" and passes validation).
     */
    private string function sniffMimeType( required string sourcePath ){
        try {
            var raf = createObject( "java", "java.io.RandomAccessFile" ).init( arguments.sourcePath, "r" );
            try {
                // Allocate the byte[] directly via Array.newInstance
                // because the newByteArray BIF isn't reliably present
                // in every BoxLang module set.
                var buf = createObject( "java", "java.lang.reflect.Array" )
                    .newInstance( createObject( "java", "java.lang.Byte" ).TYPE, 16 );
                var read = raf.read( buf );
                if ( read < 4 ) return "";
                var b0 = bitAnd( buf[ 1 ], 255 );
                var b1 = bitAnd( buf[ 2 ], 255 );
                var b2 = bitAnd( buf[ 3 ], 255 );
                var b3 = bitAnd( buf[ 4 ], 255 );
                // JPEG: FF D8 FF
                if ( b0 == 255 && b1 == 216 && b2 == 255 ) return "image/jpeg";
                // PNG: 89 50 4E 47
                if ( b0 == 137 && b1 == 80 && b2 == 78 && b3 == 71 ) return "image/png";
                // GIF: 47 49 46 38
                if ( b0 == 71 && b1 == 73 && b2 == 70 && b3 == 56 ) return "image/gif";
                // PDF: 25 50 44 46  ("%PDF")
                if ( b0 == 37 && b1 == 80 && b2 == 68 && b3 == 70 ) return "application/pdf";
                // ZIP / OOXML (docx/xlsx/pptx are zip containers):
                // 50 4B 03 04
                if ( b0 == 80 && b1 == 75 && b2 == 3 && b3 == 4 ) return "application/zip";
                // WebP: RIFF....WEBP — bytes 0-3 = "RIFF", 8-11 = "WEBP"
                if ( b0 == 82 && b1 == 73 && b2 == 70 && b3 == 70 && read >= 12 ) {
                    var b8  = bitAnd( buf[ 9  ], 255 );
                    var b9  = bitAnd( buf[ 10 ], 255 );
                    var b10 = bitAnd( buf[ 11 ], 255 );
                    var b11 = bitAnd( buf[ 12 ], 255 );
                    if ( b8 == 87 && b9 == 69 && b10 == 66 && b11 == 80 ) return "image/webp";
                }
                return "";
            } finally {
                raf.close();
            }
        } catch ( any e ) {
            return "";
        }
    }

    /**
     * True when the sniffed MIME is consistent with the declared
     * extension + content-type. Allows the common synonym pairs
     * (jpg/jpeg, zip/office-docs).
     */
    private boolean function mimeMatches(
        required string sniffed,
        required string ext,
        required string declaredContentType
    ){
        var s = lCase( arguments.sniffed );
        var e = lCase( arguments.ext );
        var d = lCase( arguments.declaredContentType );

        // Extension family expected for the sniffed type
        var expectedExts = {
            "image/jpeg"      : [ "jpg", "jpeg" ],
            "image/png"       : [ "png" ],
            "image/gif"       : [ "gif" ],
            "image/webp"      : [ "webp" ],
            "application/pdf" : [ "pdf" ],
            "application/zip" : [ "zip", "docx", "xlsx", "pptx" ]
        };
        if ( !structKeyExists( expectedExts, s ) ) return true;
        return arrayFindNoCase( expectedExts[ s ], e ) > 0;
    }

    /**
     * Access decision for a single attachment.
     *   - viewer.type=="agent": any signed-in agent allowed (the
     *     /agent firewall already covers role gating). Includes
     *     soft-deleted rows so the agent UI can show "deleted" badges.
     *   - viewer.type=="contact": parent ticket must belong to the
     *     contact's organization. Internal-note attachments are
     *     denied. Soft-deleted is denied.
     */
    private boolean function canViewAttachment(
        required any attachment,
        required struct viewer
    ){
        var vType = arguments.viewer.type ?: "";
        if ( vType == "agent" ) return true;

        if ( vType == "contact" ) {
            if ( arguments.attachment.isDeleted() ) return false;
            var ticket = getTicket( arguments.attachment.getTicketId() );
            if ( isNull( ticket ) ) return false;
            var ticketOrg  = ticket.getOrganizationId() ?: "";
            if ( !len( ticketOrg ) ) return false; // accountless never visible to contacts
            var contact = contactsService.getContactById( arguments.viewer.id ?: "" );
            if ( isNull( contact ) ) return false;
            if ( ( contact.getOrganizationId() ?: "" ) != ticketOrg ) return false;
            // Internal-note attachments hidden from contacts.
            var msgId = arguments.attachment.getMessageId() ?: "";
            if ( len( msgId ) ) {
                var msg = wirebox.getInstance( "TicketMessage@tickets" )
                    .where( "id", msgId ).first();
                if ( !isNull( msg ) && msg.getIsInternal() ) return false;
            }
            return true;
        }
        return false;
    }

    // ---------- helpers ----------

    private any function newTicket(){
        var t = wirebox.getInstance( "Ticket@tickets" );
        t.setId( newId() );
        return t;
    }

    private void function applyCommonTicketFields( required any ticket, required struct data ){
        arguments.ticket.setSubject( arguments.data.subject ?: "(no subject)" );
        arguments.ticket.setStatus( arguments.data.status ?: "new" );
        arguments.ticket.setPriority( arguments.data.priority ?: "normal" );
        arguments.ticket.setTicketType( arguments.data.ticketType ?: "request" );
        arguments.ticket.setSource( arguments.data.source ?: "agent" );
        if ( len( arguments.data.assignedToAgentId ?: "" ) ) {
            arguments.ticket.setAssignedToAgentId( arguments.data.assignedToAgentId );
        }
    }

    private void function touchTicket( required any ticket ){
        arguments.ticket.setUpdatedAt( now() );
        arguments.ticket.save();
    }

    private void function recordTicketEvent(
        required string ticketId,
        required string eventType,
        string actorType = "",
        string actorId   = "",
        struct metadata
    ){
        var e = wirebox.getInstance( "TicketEvent@tickets" );
        e.setId( newId() );
        e.setTicketId( arguments.ticketId );
        e.setEventType( arguments.eventType );
        if ( len( arguments.actorType ) ) e.setActorType( arguments.actorType );
        if ( len( arguments.actorId ) )   e.setActorId( arguments.actorId );
        if ( structKeyExists( arguments, "metadata" ) && !isNull( arguments.metadata ) ) {
            e.setMetadataJson( jsonSerialize( arguments.metadata ) );
        }
        e.save();
    }

    private void function recordAudit(
        required string eventType,
        string entityId,
        string organizationId,
        string actorType,
        string actorId,
        struct metadata
    ){
        var args = { "eventType" : arguments.eventType, "entityType" : "Ticket" };
        if ( structKeyExists( arguments, "entityId" ) && len( arguments.entityId ?: "" ) ) args.entityId = arguments.entityId;
        if ( structKeyExists( arguments, "organizationId" ) && len( arguments.organizationId ?: "" ) ) args.organizationId = arguments.organizationId;
        if ( structKeyExists( arguments, "actorType" ) && len( arguments.actorType ?: "" ) ) args.actorType = arguments.actorType;
        if ( structKeyExists( arguments, "actorId" ) && len( arguments.actorId ?: "" ) ) args.actorId = arguments.actorId;
        if ( structKeyExists( arguments, "metadata" ) && !isNull( arguments.metadata ) ) args.metadata = arguments.metadata;
        auditService.record( argumentCollection = args );
    }

    private string function newId(){
        return createObject( "java", "java.util.UUID" ).randomUUID().toString();
    }

    // ---------- SLA helpers ----------

    /**
     * Stamp the matched policy and the initial first-response /
     * resolution due_at instants on a freshly-saved ticket. A no-op
     * when no policy matches; the rest of the lifecycle then runs
     * unchanged and the ticket simply has no SLA.
     */
    private void function applyInitialSla( required any ticket ){
        var policy = slaService.matchPolicyForTicket( arguments.ticket );
        if ( isNull( policy ) ) return;

        var fr  = slaService.computeFirstResponseDeadline( arguments.ticket, policy );
        var res = slaService.computeResolutionDeadline(    arguments.ticket, policy );

        arguments.ticket.setSlaPolicyId( policy.getId() );
        arguments.ticket.setFirstResponseDueAt( slaService.formatInstantUtc( fr ) );
        arguments.ticket.setResolutionDueAt(    slaService.formatInstantUtc( res ) );
        arguments.ticket.save();
    }

    /**
     * Capture the first agent-authored, non-internal reply as the
     * first-response moment. Idempotent: once set, never overwritten.
     */
    private void function recordFirstResponseIfPending( required any ticket, required any message ){
        if ( !len( arguments.ticket.getSlaPolicyId() ?: "" ) ) return;
        if ( !isNull( arguments.ticket.getFirstResponseAt() ) && len( arguments.ticket.getFirstResponseAt() ?: "" ) ) return;
        if ( arguments.message.getIsInternal() ?: false ) return;
        if ( !len( arguments.message.getAuthorAgentId() ?: "" ) ) return;
        arguments.ticket.setFirstResponseAt( now() );
        // touchTicket() in the caller persists; we set the column here.
    }

    /**
     * Pause / resume math on status change.
     *   - Active -> paused: stamp sla_paused_at = now().
     *   - Paused -> active: shift both due_at columns forward by the
     *     business-minutes that elapsed during the pause, clear
     *     sla_paused_at.
     *   - Paused -> paused / Active -> active: no-op.
     */
    private void function applySlaStatusTransition( required any ticket, required string from, required string to ){
        if ( !len( arguments.ticket.getSlaPolicyId() ?: "" ) ) return;
        // SLA pause now flows from the destination status's
        // category (admin-editable). Old hardcoded "pending" /
        // "on-hold" remain in the seeded catalog as category=paused.
        var wasPaused = workflowService.pausesSla( arguments.from );
        var isPaused  = workflowService.pausesSla( arguments.to );

        if ( !wasPaused && isPaused ) {
            arguments.ticket.setSlaPausedAt( now() );
            return;
        }
        if ( wasPaused && !isPaused ) {
            var pausedAt = arguments.ticket.getSlaPausedAt();
            if ( isNull( pausedAt ) || !len( pausedAt ?: "" ) ) return;
            var policy   = slaService.getPolicyById( arguments.ticket.getSlaPolicyId() );
            if ( isNull( policy ) ) {
                arguments.ticket.clearAttribute( name = "sla_paused_at", setToNull = true );
                return;
            }
            var calendar = slaService.getDefaultCalendar();
            var policyCalId = policy.getBusinessHoursCalendarId() ?: "";
            if ( len( policyCalId ) ) {
                var maybe = slaService.getCalendarById( policyCalId );
                if ( !isNull( maybe ) ) calendar = maybe;
            }
            if ( isNull( calendar ) ) {
                arguments.ticket.clearAttribute( name = "sla_paused_at", setToNull = true );
                return;
            }

            var pausedMins = slaService.businessMinutesBetween( pausedAt, now(), calendar );
            if ( pausedMins > 0 ) {
                var frDue = arguments.ticket.getFirstResponseDueAt();
                if ( !isNull( frDue ) && len( frDue ?: "" ) ) {
                    var newFr = slaService.addBusinessMinutes( frDue, pausedMins, calendar );
                    arguments.ticket.setFirstResponseDueAt( slaService.formatInstantUtc( newFr ) );
                }
                var resDue = arguments.ticket.getResolutionDueAt();
                if ( !isNull( resDue ) && len( resDue ?: "" ) ) {
                    var newRes = slaService.addBusinessMinutes( resDue, pausedMins, calendar );
                    arguments.ticket.setResolutionDueAt( slaService.formatInstantUtc( newRes ) );
                }
            }
            arguments.ticket.clearAttribute( name = "sla_paused_at", setToNull = true );
        }
    }

    // ---------- SLA reads (scheduler / UI) ----------

    /**
     * Tickets whose first-response deadline has passed without a first
     * response, or whose resolution deadline has passed without the
     * ticket entering resolved/closed. Excludes paused tickets (their
     * deadlines are conceptually frozen).
     */
    public array function findBreachedTickets(){
        var q = wirebox.getInstance( "Ticket@tickets" )
            .withoutGlobalScope()
            .whereNotIn( "status", workflowService.keysByCategory( [ "resolved", "closed" ] ) )
            .whereNull( "sla_paused_at" )
            .where( function( w ){
                w.where( function( w2 ){
                    w2.whereNull( "first_response_at" )
                      .whereNotNull( "first_response_due_at" )
                      .whereRaw( "first_response_due_at < NOW()" );
                } ).orWhere( function( w2 ){
                    w2.whereNotNull( "resolution_due_at" )
                      .whereRaw( "resolution_due_at < NOW()" );
                } );
            } );
        return q.get();
    }

    /**
     * Tickets where the first-response or resolution deadline is
     * within `windowMinutes` from now but has not yet passed. Used by
     * the Phase 3e scheduler to emit warnings.
     */
    /**
     * Tickets the scheduler should evaluate for time-based escalation
     * rules: active (not resolved / closed) and not currently paused.
     * Bypasses the tenant scope; the scheduler runs as a provider-
     * side process across all organizations.
     */
    public array function findActiveTicketsForScan(){
        return wirebox.getInstance( "Ticket@tickets" )
            .withoutGlobalScope()
            .whereNotIn( "status", workflowService.keysByCategory( [ "resolved", "closed" ] ) )
            .whereNull( "sla_paused_at" )
            .orderBy( "created_at" )
            .get();
    }

    /**
     * Fire ticket.escalation on every active ticket so any time-based
     * AutomationRule has a chance to run. The scheduler task calls
     * this directly because BoxLang's arrow-function scope lookup
     * overflows on `for ( var x in svc.list() )` patterns inlined in
     * a scheduled task closure; keeping the loop inside the service
     * body sidesteps the recursion.
     */
    public struct function runEscalationScan(){
        var automation = wirebox.getInstance( "AutomationService@automation" );
        var scanned = 0;
        var failed  = 0;
        for ( var t in findActiveTicketsForScan() ) {
            try {
                automation.evaluateForTicket( "ticket.escalation", t );
                scanned++;
            } catch ( any e ) {
                failed++;
                writeLog(
                    text : "TicketsService.runEscalationScan [#t.getId()#] failed: " & e.message,
                    log  : "tesserabx-scheduler",
                    type : "error"
                );
            }
        }
        return { "scanned" : scanned, "failed" : failed };
    }

    public array function findApproachingBreachTickets( required numeric windowMinutes ){
        // Bake the interval into a local SQL fragment up front. qb's
        // nested closures don't inherit the outer `arguments` scope, so
        // we can't reach `arguments.windowMinutes` from inside the
        // where-builder.
        var interval = "INTERVAL '" & int( arguments.windowMinutes ) & " minutes'";
        var q = wirebox.getInstance( "Ticket@tickets" )
            .withoutGlobalScope()
            .whereNotIn( "status", workflowService.keysByCategory( [ "resolved", "closed" ] ) )
            .whereNull( "sla_paused_at" )
            .where( function( w ){
                w.where( function( w2 ){
                    w2.whereNull( "first_response_at" )
                      .whereNotNull( "first_response_due_at" )
                      .whereRaw( "first_response_due_at >  NOW()" )
                      .whereRaw( "first_response_due_at <= NOW() + " & interval );
                } ).orWhere( function( w2 ){
                    w2.whereNotNull( "resolution_due_at" )
                      .whereRaw( "resolution_due_at >  NOW()" )
                      .whereRaw( "resolution_due_at <= NOW() + " & interval );
                } );
            } );
        return q.get();
    }

    /**
     * Returns the category ("open" | "paused" | "resolved" |
     * "closed") for a status key, or "" when the key is unknown
     * (an admin may have removed it after the ticket was last
     * touched). Used by changeStatus to decide resolved_at /
     * closed_at stamping.
     */
    private string function workflowCategoryFor( required string statusKey ){
        if ( !len( arguments.statusKey ) ) return "";
        var s = workflowService.findStatus( arguments.statusKey );
        if ( isNull( s ) ) return "";
        return s.category ?: "";
    }

    // =====================================================================
    // Agent home dashboard reads.
    //
    // Each method resolves the current agent from cbauth itself so widget
    // partials and the /agent/home/poll endpoint can call them with no
    // arguments. When no agent is signed in the methods return zero/empty
    // shapes rather than throw, so a partial rendered in a non-agent
    // context (a misconfigured add-on, a test fixture) degrades gracefully.
    // =====================================================================

    /**
     * Count of "open" tickets currently assigned to the logged-in agent.
     * "Open" means category=open (new, open, ...) — paused/resolved/closed
     * are excluded. Returns 0 for an anonymous viewer.
     */
    public struct function countOpenAssignedToMe(){
        var id = currentAgentId();
        if ( !len( id ) ) return { "count" : 0 };
        var openKeys = workflowService.keysByCategory( [ "open" ] );
        if ( !arrayLen( openKeys ) ) return { "count" : 0 };
        return { "count" : countByAssigneeAndStatus( id, openKeys ) };
    }

    /**
     * Count of tickets the agent is assigned to that are sitting in a
     * paused-category status (pending, on-hold, etc.). The convention
     * across the project is that paused statuses mean "waiting on the
     * client to reply" so this is the agent's "awaiting reply" load.
     */
    public struct function countAwaitingReplyAssignedToMe(){
        var id = currentAgentId();
        if ( !len( id ) ) return { "count" : 0 };
        var pausedKeys = workflowService.keysByCategory( [ "paused" ] );
        if ( !arrayLen( pausedKeys ) ) return { "count" : 0 };
        return { "count" : countByAssigneeAndStatus( id, pausedKeys ) };
    }

    /**
     * Count of the agent's assigned tickets that are either past their
     * first-response or resolution SLA deadline, or within the
     * approaching window (default 30 minutes — same default
     * SlaService.slaSummaryForTicket uses).
     *
     * Excludes terminal statuses (resolved/closed) and paused statuses
     * — the SLA clock is not running on those.
     */
    public struct function countSlaAtRiskAssignedToMe( numeric approachingMinutes = 30 ){
        var id = currentAgentId();
        if ( !len( id ) ) return { "count" : 0 };
        var activeKeys = workflowService.keysByCategory( [ "open" ] );
        if ( !arrayLen( activeKeys ) ) return { "count" : 0 };
        var placeholders = [];
        var binds = {
            aid : id,
            mins: arguments.approachingMinutes
        };
        var i = 0;
        for ( var k in activeKeys ) {
            i++;
            placeholders.append( ":s" & i );
            binds[ "s" & i ] = k;
        }
        var sql = "
            SELECT COUNT(*) AS c
            FROM   tickets
            WHERE  assigned_to_agent_id = :aid
            AND    status IN ( " & placeholders.toList( "," ) & " )
            AND    (
                       (
                           first_response_at IS NULL
                           AND first_response_due_at IS NOT NULL
                           AND first_response_due_at <= NOW() + make_interval( mins => cast( :mins as integer ) )
                       )
                       OR (
                           resolution_due_at IS NOT NULL
                           AND resolution_due_at <= NOW() + make_interval( mins => cast( :mins as integer ) )
                       )
                   )
        ";
        var rows = queryExecute( sql, binds );
        return { "count" : ( rows.recordCount ? rows.c[ 1 ] : 0 ) };
    }

    /**
     * Count of tickets the agent was assigned to that have been
     * resolved since the start of the current UTC day. We don't track
     * who flipped the status, so this is "tickets on my plate that got
     * resolved today" — a close proxy for "my output today".
     */
    public struct function countResolvedTodayByMe(){
        var id = currentAgentId();
        if ( !len( id ) ) return { "count" : 0 };
        var resolvedKeys = workflowService.keysByCategory( [ "resolved" ] );
        if ( !arrayLen( resolvedKeys ) ) return { "count" : 0 };
        var placeholders = [];
        var binds = { aid : id };
        var i = 0;
        for ( var k in resolvedKeys ) {
            i++;
            placeholders.append( ":s" & i );
            binds[ "s" & i ] = k;
        }
        var sql = "
            SELECT COUNT(*) AS c
            FROM   tickets
            WHERE  assigned_to_agent_id = :aid
            AND    status IN ( " & placeholders.toList( "," ) & " )
            AND    resolved_at >= date_trunc( 'day', NOW() )
        ";
        var rows = queryExecute( sql, binds );
        return { "count" : ( rows.recordCount ? rows.c[ 1 ] : 0 ) };
    }

    /**
     * 14-day series of how many tickets currently assigned to the
     * agent were CREATED on each day. Useful as a quick "incoming
     * volume" sparkline. Zero-filled so the chart x-axis is
     * continuous even on quiet days. Mirrors the shape used by
     * ReportingService.ticketVolumePerDay.
     */
    public struct function workloadTrendForMe( numeric days = 14 ){
        var id = currentAgentId();
        if ( !len( id ) ) return { "series" : [] };
        var rows = queryExecute(
            "SELECT to_char( date_trunc( 'day', created_at ), 'YYYY-MM-DD' ) AS day,
                    COUNT(*) AS c
             FROM   tickets
             WHERE  assigned_to_agent_id = :aid
             AND    created_at >= date_trunc( 'day', NOW() ) - make_interval( days => cast( :d as integer ) - 1 )
             GROUP  BY date_trunc( 'day', created_at )
             ORDER  BY day ASC",
            { aid : id, d : arguments.days }
        );
        var counts = {};
        for ( var i = 1; i <= rows.recordCount; i++ ) counts[ rows.day[ i ] ] = rows.c[ i ];
        var out = [];
        var startOffset = arguments.days - 1;
        for ( var off = startOffset; off >= 0; off-- ) {
            var day = dateFormat( dateAdd( "d", -off, now() ), "yyyy-mm-dd" );
            out.append( { day : day, count : ( counts[ day ] ?: 0 ) } );
        }
        return { "series" : out };
    }

    /**
     * Queue health snapshot for the team-lead / admin role:
     *   - unassignedCount: how many open or paused tickets have no
     *     assignee
     *   - oldestUnassignedHours: how long the oldest unassigned ticket
     *     has been sitting (whole hours, rounded down)
     *   - openTotal: total active (open + paused) tickets across the
     *     deployment
     *
     * Cheap enough to call on every poll thanks to the existing index
     * on assigned_to_agent_id + status.
     */
    public struct function queueHealthSummary(){
        var activeKeys = workflowService.keysByCategory( [ "open", "paused" ] );
        if ( !arrayLen( activeKeys ) ) {
            return { "unassignedCount" : 0, "oldestUnassignedHours" : 0, "openTotal" : 0 };
        }
        var placeholders = [];
        var binds = {};
        var i = 0;
        for ( var k in activeKeys ) {
            i++;
            placeholders.append( ":s" & i );
            binds[ "s" & i ] = k;
        }
        var statusIn = "status IN ( " & placeholders.toList( "," ) & " )";
        var openRow = queryExecute(
            "SELECT COUNT(*) AS c FROM tickets WHERE " & statusIn,
            binds
        );
        var unRow = queryExecute(
            "SELECT COUNT(*) AS c,
                    EXTRACT( EPOCH FROM ( NOW() - MIN( created_at ) ) ) / 3600.0 AS hrs
             FROM   tickets
             WHERE  assigned_to_agent_id IS NULL
             AND    " & statusIn,
            binds
        );
        var hrsRaw = unRow.recordCount ? ( unRow.hrs[ 1 ] ?: "" ) : "";
        return {
            "unassignedCount"       : unRow.recordCount ? unRow.c[ 1 ] : 0,
            "oldestUnassignedHours" : isNumeric( hrsRaw ) ? int( hrsRaw ) : 0,
            "openTotal"             : openRow.recordCount ? openRow.c[ 1 ] : 0
        };
    }

    /**
     * Recent ticket activity on the agent's plate. Returns up to
     * `limit` rows of { id, ticketNumber, subject, status, priority,
     * updatedAt, url } for tickets currently assigned to the agent,
     * newest activity first.
     */
    public struct function recentForMe( numeric limit = 10 ){
        var id = currentAgentId();
        if ( !len( id ) ) return { "rows" : [] };
        var rows = queryExecute(
            "SELECT id, ticket_number, subject, status, priority, updated_at
             FROM   tickets
             WHERE  assigned_to_agent_id = :aid
             ORDER  BY updated_at DESC
             LIMIT  " & int( arguments.limit ),
            { aid : id }
        );
        var out = [];
        for ( var i = 1; i <= rows.recordCount; i++ ) {
            out.append( {
                "id"           : rows.id[ i ],
                "ticketNumber" : rows.ticket_number[ i ],
                "subject"      : rows.subject[ i ] ?: "",
                "status"       : rows.status[ i ] ?: "",
                "priority"     : rows.priority[ i ] ?: "",
                "updatedAt"    : dateTimeFormat( rows.updated_at[ i ], "yyyy-mm-dd HH:nn" ),
                "url"          : "/agent/tickets/" & rows.id[ i ]
            } );
        }
        return { "rows" : out };
    }

    /**
     * Recent messages on tickets the agent is currently assigned to.
     * Excludes the agent's own messages so the list answers
     * "what's been happening on my tickets while I wasn't looking?".
     * Internal notes from other agents are included; messages from
     * the client are included. The list is ordered newest-first and
     * capped at `limit`.
     */
    public struct function recentActivityOnMyTickets( numeric limit = 5 ){
        var id = currentAgentId();
        if ( !len( id ) ) return { "rows" : [] };
        var rows = queryExecute(
            "SELECT m.id              AS message_id,
                    m.ticket_id,
                    m.author_agent_id,
                    m.author_contact_id,
                    m.author_email,
                    m.is_internal,
                    m.created_at,
                    t.ticket_number,
                    t.subject
             FROM   ticket_messages m
             JOIN   tickets         t ON t.id = m.ticket_id
             WHERE  t.assigned_to_agent_id = :aid
             AND    ( m.author_agent_id IS NULL OR m.author_agent_id <> :aid )
             ORDER  BY m.created_at DESC
             LIMIT  " & int( arguments.limit ),
            { aid : id }
        );
        var out = [];
        for ( var i = 1; i <= rows.recordCount; i++ ) {
            out.append( {
                "messageId"    : rows.message_id[ i ],
                "ticketId"     : rows.ticket_id[ i ],
                "ticketNumber" : rows.ticket_number[ i ],
                "subject"      : rows.subject[ i ] ?: "",
                "isInternal"   : !!rows.is_internal[ i ],
                "fromAgent"    : len( rows.author_agent_id[ i ] ?: "" ) > 0,
                "createdAt"    : dateTimeFormat( rows.created_at[ i ], "yyyy-mm-dd HH:nn" ),
                "url"          : "/agent/tickets/" & rows.ticket_id[ i ]
            } );
        }
        return { "rows" : out };
    }

    // ---------- agent-home internals ----------

    private string function currentAgentId(){
        try {
            if ( !auth.isLoggedIn() ) return "";
            var u = auth.getUser();
            if ( isNull( u ) ) return "";
            return u.getId();
        } catch ( any e ) {
            return "";
        }
    }

    /**
     * Helper: COUNT(*) of tickets assigned to the agent with status in
     * the supplied keys. Returns 0 for an empty key list.
     */
    private numeric function countByAssigneeAndStatus( required string agentId, required array statusKeys ){
        if ( !arrayLen( arguments.statusKeys ) ) return 0;
        var placeholders = [];
        var binds = { aid : arguments.agentId };
        var i = 0;
        for ( var k in arguments.statusKeys ) {
            i++;
            placeholders.append( ":s" & i );
            binds[ "s" & i ] = k;
        }
        var rows = queryExecute(
            "SELECT COUNT(*) AS c
             FROM   tickets
             WHERE  assigned_to_agent_id = :aid
             AND    status IN ( " & placeholders.toList( "," ) & " )",
            binds
        );
        return rows.recordCount ? rows.c[ 1 ] : 0;
    }

}
