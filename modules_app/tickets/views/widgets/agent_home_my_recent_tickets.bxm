<bx:output>
<bx:set local.rows = ( prc.widgetData.rows ?: [] ) >
<div class="card flex-fill h-100">
    <div class="card-header d-flex align-items-center">
        <h3 class="card-title mb-0 flex-grow-1">
            <i class="bi bi-clock-history me-2"></i>My recent tickets
        </h3>
        <a href="/agent/tickets?assignee=me" class="small">All my tickets <i class="bi bi-arrow-right"></i></a>
    </div>
    <div class="card-body p-0">
        <bx:if !arrayLen( local.rows )>
            <p class="text-body-secondary mb-0 p-3">You have no tickets assigned right now.</p>
        <bx:else>
            <div class="table-responsive">
                <table class="table table-sm table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th scope="col" class="small">##</th>
                            <th scope="col" class="small">Subject</th>
                            <th scope="col" class="small">Status</th>
                            <th scope="col" class="small">Priority</th>
                            <th scope="col" class="small text-end">Updated</th>
                        </tr>
                    </thead>
                    <tbody data-recent-tickets>
                        <bx:loop array="#local.rows#" item="local.row">
                            <tr>
                                <td class="small text-body-secondary">###encodeForHTML( local.row.ticketNumber )#</td>
                                <td>
                                    <a href="#encodeForHTMLAttribute( local.row.url )#"
                                       class="link-body-emphasis text-decoration-none">
                                        #encodeForHTML( local.row.subject )#
                                    </a>
                                </td>
                                <td><span class="badge text-bg-light text-black">#encodeForHTML( local.row.status )#</span></td>
                                <td><span class="badge text-bg-light text-black">#encodeForHTML( local.row.priority )#</span></td>
                                <td class="text-end small text-body-secondary">#encodeForHTML( local.row.updatedAt )#</td>
                            </tr>
                        </bx:loop>
                    </tbody>
                </table>
            </div>
        </bx:if>
    </div>
</div>
<script>
(function(){
    window.tbxDashboard = window.tbxDashboard || { widgets : {} };
    window.tbxDashboard.widgets[ "agent-home.my-recent-tickets" ] = {
        update : function( payload, card ){
            // The polling refresh just blanks out the body and re-renders.
            // For the recent-tickets list a full server-side re-render of
            // the row markup is cheap, but to keep the client-side hook
            // self-contained we rebuild rows from the JSON payload.
            if ( !payload || !payload.rows ) return;
            var tbody = card.querySelector( "[data-recent-tickets]" );
            if ( !tbody ) return;
            var html = "";
            payload.rows.forEach( function( r ){
                html += "<tr>" +
                    "<td class=\"small text-body-secondary\">##" + escape( r.ticketNumber ) + "</td>" +
                    "<td><a href=\"" + escapeAttr( r.url ) + "\" class=\"link-body-emphasis text-decoration-none\">" + escape( r.subject ) + "</a></td>" +
                    "<td><span class=\"badge text-bg-light text-black\">" + escape( r.status ) + "</span></td>" +
                    "<td><span class=\"badge text-bg-light text-black\">" + escape( r.priority ) + "</span></td>" +
                    "<td class=\"text-end small text-body-secondary\">" + escape( r.updatedAt ) + "</td>" +
                "</tr>";
            } );
            tbody.innerHTML = html;
        }
    };
    function escape( s ){
        return String( s == null ? "" : s )
            .replace( /&/g, "&amp;" )
            .replace( /</g, "&lt;" )
            .replace( />/g, "&gt;" );
    }
    function escapeAttr( s ){
        return escape( s ).replace( /"/g, "&quot;" );
    }
})();
</script>
</bx:output>
