<bx:output>
<bx:set local.count = ( prc.widgetData.count ?: 0 ) >
#view( view = "_partials/small_box", module = "core", args = {
    color     : "danger",
    metric    : "<span data-metric>" & encodeForHTML( local.count ) & "</span>",
    label     : "SLA at risk",
    icon      : "bi bi-exclamation-triangle",
    link      : "/agent/tickets?sla=at-risk",
    linkLabel : "View at-risk"
} )#
<script>
(function(){
    window.tbxDashboard = window.tbxDashboard || { widgets : {} };
    window.tbxDashboard.widgets[ "agent-home.my-sla-at-risk" ] = {
        update : function( payload, card ){
            if ( !payload ) return;
            var el = card.querySelector( "[data-metric]" );
            if ( el && typeof payload.count !== "undefined" ) el.textContent = payload.count;
        }
    };
})();
</script>
</bx:output>
