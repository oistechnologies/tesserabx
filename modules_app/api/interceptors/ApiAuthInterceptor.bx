/**
 * ApiAuthInterceptor: blanket JWT enforcement on /api/v1/* (follow-up
 * A9).
 *
 * Every API request lands here in preProcess BEFORE handler dispatch.
 * The interceptor:
 *   - skips non-API requests entirely (no overhead),
 *   - lets the documented whitelist (login, refresh, swagger) through
 *     unauthenticated,
 *   - parses the bearer JWT through cbSecurity's JwtService and
 *     rejects with 401 if missing / invalid / expired,
 *   - asserts the token carries the "agent" scope and rejects with
 *     403 otherwise,
 *   - calls event.noExecution() on rejection so the handler never
 *     runs.
 *
 * Why this exists:
 *   ApiResourceRegistry is metadata-only; `requiresAuth : true` on an
 *   entry is descriptive (used by cbswagger and admin diagnostics).
 *   Without a centralized check an add-on that ships an API handler
 *   has to know about the per-action `ensureAgent()` convention or
 *   its endpoint is anonymously accessible. This interceptor closes
 *   that gap: an add-on can register a resource under /api/v1/<slug>
 *   and inherit JWT + agent-scope protection automatically.
 *
 * Backwards compatibility:
 *   Existing core handlers (Tickets, Auth, Swagger) keep their inline
 *   ensureAgent() guards as defense in depth. The double-check is
 *   cheap because the JWT is already parsed by the time the handler
 *   runs.
 *
 * Per-permission gating (B7):
 *   ApiResourceRegistry.requiredPermission is enforced when the
 *   incoming method + path matches a registered entry. The token's
 *   `permissions` custom claim (populated by Agent.getJwtCustomClaims
 *   from RoleRegistry.permissionsFor()) must contain the required
 *   permission, or the request fails 403.
 *
 *   Tokens minted before B7 do not carry the `permissions` claim;
 *   the interceptor treats a missing claim as "fall through to the
 *   scope-only check" so existing sessions keep working until they
 *   expire and re-mint. New tokens (and add-on resources) inherit
 *   the per-permission gate immediately.
 */
class accessors=true {

    property name="jwtService" inject="JwtService@cbsecurity";
    property name="wirebox"    inject="wirebox";
    // ApiResourceRegistry@api is mapped in this same module's onLoad,
    // which fires AFTER configure() where the interceptor is
    // constructed. Property injection at construction-time fails with
    // "Instance not found". We hold the resolved instance lazily and
    // look it up on first use.
    variables.apiResources = "";

    // Paths under /api that may be reached without a bearer token.
    // The leading "api/" prefix matches event.getCurrentRoutedURL()'s
    // shape (no leading slash, no trailing slash unless path is "/").
    variables.WHITELIST = [
        "api/v1/auth/login",
        "api/v1/auth/refresh",
        "api/swagger"
    ];

    function configure(){}

    /**
     * Fires before every event. We narrow to /api/v1/* requests inside
     * the function so non-API traffic pays no cost beyond the prefix
     * check.
     */
    function preProcess( event, interceptData, rc, prc ){
        // NOTE: `url` is a reserved BoxLang scope name (the query-string
        // struct). A local named `url` silently resolves to the scope
        // on later references, breaking string operations. Use
        // `routedPath` instead. See user CLAUDE.md gotcha log.
        var routedPath = lcase( arguments.event.getCurrentRoutedURL() );
        if ( !len( routedPath ) || left( routedPath, 7 ) != "api/v1/" ) {
            // Also let /api/swagger through without checking; everything
            // else under /api/* that isn't /api/v1/* is unmatched today
            // and reaches ColdBox's 404 naturally.
            return;
        }
        for ( var allowed in variables.WHITELIST ) {
            if ( routedPath == allowed ) return;
            if ( left( routedPath, len( allowed ) + 1 ) == allowed & "/" ) return;
        }

        var payload = "";
        try {
            payload = jwtService.getPayload();
        } catch ( any e ) {
            arguments.event.renderData(
                type       = "json",
                statusCode = 401,
                data       = { error : ( e.type ?: "TokenError" ) & ": " & ( e.message ?: "missing or invalid bearer token" ) }
            );
            arguments.event.noExecution();
            return;
        }

        if ( !len( payload.scope ?: "" ) || !listFindNoCase( payload.scope ?: "", "agent", " " ) ) {
            arguments.event.renderData(
                type       = "json",
                statusCode = 403,
                data       = { error : "Token does not carry the agent role." }
            );
            arguments.event.noExecution();
            return;
        }

        // B7: per-permission gate. Look up the resource entry by
        // method + path. If the entry declares a requiredPermission,
        // the token's `permissions` claim must contain it. Tokens
        // minted before B7 lack the claim entirely; treat that as a
        // grandfather pass through to the scope-only check above so
        // existing sessions keep working until they re-mint.
        var method  = arguments.event.getHTTPMethod();
        var entry   = lookupApiResources().findByRequest( method, "/" & routedPath );
        if ( !isNull( entry ) && len( entry.requiredPermission ?: "" ) ) {
            var requiredPerm = entry.requiredPermission;
            var permsClaim   = payload.permissions ?: "";
            if ( len( permsClaim ) && !listFindNoCase( permsClaim, requiredPerm, " " ) ) {
                arguments.event.renderData(
                    type       = "json",
                    statusCode = 403,
                    data       = { error : "Token does not carry the required permission [" & requiredPerm & "]." }
                );
                arguments.event.noExecution();
                return;
            }
            // permsClaim empty => grandfather; fall through.
        }

        // Token is valid and carries the agent role. The handler still
        // runs its own ensureAgent() guard for defense in depth.
    }

    /**
     * Lazy resolver for ApiResourceRegistry@api. The mapping does not
     * exist when configure() runs, but is guaranteed by the time
     * preProcess fires on a real request.
     */
    private any function lookupApiResources(){
        if ( !isObject( variables.apiResources ) ) {
            variables.apiResources = wirebox.getInstance( "ApiResourceRegistry@api" );
        }
        return variables.apiResources;
    }

}
