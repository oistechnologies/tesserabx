/**
 * WebhooksServiceSpec: subscription CRUD + dispatch match logic.
 *
 * The HTTP-out path (deliverOne) is exercised by hand-driven live
 * dispatch; the spec asserts the surface the rest of the code
 * relies on without making real network calls.
 */
class extends="coldbox.system.testing.BaseTestCase" appMapping="/" {

    function beforeAll(){
        super.beforeAll();
        super.setup();
        variables.svc = getController().getWireBox().getInstance( "WebhooksService@api" );
    }

    function run(){
        describe( "WebhooksService", function(){

            afterEach( function( currentSpec ){
                queryExecute( "DELETE FROM webhook_deliveries WHERE subscription_id IN ( SELECT id FROM webhook_subscriptions WHERE name LIKE 'spec-%%' )" );
                queryExecute( "DELETE FROM webhook_subscriptions WHERE name LIKE 'spec-%%'" );
            } );

            it( "eventCatalog includes ticket.created and friends", function(){
                var keys = [];
                for ( var e in variables.svc.eventCatalog() ) keys.append( e.key );
                expect( keys ).toInclude( "ticket.created" );
                expect( keys ).toInclude( "ticket.status_changed" );
                expect( keys ).toInclude( "ticket.message_added" );
            } );

            it( "createSubscription inserts and findSubscription reads back", function(){
                var id = variables.svc.createSubscription(
                    name      : "spec-" & createUUID(),
                    targetUrl : "https://example.test/hook",
                    eventKeys : "ticket.created"
                );
                var sub = variables.svc.findSubscription( id );
                expect( sub ).notToBeNull();
                expect( sub.targetUrl ).toBe( "https://example.test/hook" );
                expect( sub.secret ).toHaveLength( 64 );
            } );

            it( "rejects an invalid URL", function(){
                expect( function(){
                    variables.svc.createSubscription(
                        name      : "spec-" & createUUID(),
                        targetUrl : "ftp://example.test/hook",
                        eventKeys : "ticket.created"
                    );
                } ).toThrow();
            } );

            it( "rejects an unknown event key", function(){
                expect( function(){
                    variables.svc.createSubscription(
                        name      : "spec-" & createUUID(),
                        targetUrl : "https://example.test/hook",
                        eventKeys : "made.up.event"
                    );
                } ).toThrow();
            } );

            it( "accepts wildcard '*' as an event key", function(){
                var id = variables.svc.createSubscription(
                    name      : "spec-" & createUUID(),
                    targetUrl : "https://example.test/hook",
                    eventKeys : "*"
                );
                expect( variables.svc.findSubscription( id ).eventKeys ).toBe( "*" );
            } );

            it( "setActive flips the is_active flag", function(){
                var id = variables.svc.createSubscription(
                    name      : "spec-" & createUUID(),
                    targetUrl : "https://example.test/hook",
                    eventKeys : "ticket.created"
                );
                variables.svc.setActive( id, false );
                expect( variables.svc.findSubscription( id ).isActive ).toBeFalse();
            } );

            it( "dispatchForEvent records a delivery row for matching subscriptions", function(){
                // A target URL that fails fast (rejected by DNS / network)
                // is good enough — the dispatcher catches and records
                // the failure rather than crashing the caller.
                var id = variables.svc.createSubscription(
                    name      : "spec-" & createUUID(),
                    targetUrl : "http://127.0.0.1:1/nope",
                    eventKeys : "ticket.created"
                );
                var deliveryIds = variables.svc.dispatchForEvent(
                    eventKey : "ticket.created",
                    payload  : { "ticket" : { "id" : "fake" } }
                );
                expect( deliveryIds.len() ).toBe( 1 );
                var deliveries = variables.svc.listDeliveriesForSubscription( id );
                expect( deliveries.len() ).toBe( 1 );
                expect( deliveries[ 1 ].status ).toBeIn( [ "failed", "sent" ] );
                expect( deliveries[ 1 ].eventKey ).toBe( "ticket.created" );
            } );

            it( "dispatchForEvent skips subscriptions that do not match the event", function(){
                variables.svc.createSubscription(
                    name      : "spec-" & createUUID(),
                    targetUrl : "http://127.0.0.1:1/nope",
                    eventKeys : "ticket.status_changed"
                );
                var deliveryIds = variables.svc.dispatchForEvent(
                    eventKey : "ticket.created",
                    payload  : { "ticket" : { "id" : "x" } }
                );
                expect( deliveryIds.len() ).toBe( 0 );
            } );

            it( "wildcard subscriptions receive every event", function(){
                variables.svc.createSubscription(
                    name      : "spec-" & createUUID(),
                    targetUrl : "http://127.0.0.1:1/nope",
                    eventKeys : "*"
                );
                var ids = variables.svc.dispatchForEvent(
                    eventKey : "ticket.message_added",
                    payload  : { "message" : { "id" : "x" } }
                );
                expect( ids.len() ).toBe( 1 );
            } );

        } );
    }

}
