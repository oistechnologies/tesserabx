/**
 * automation module: trigger-condition-action rules engine.
 *
 * Owns AutomationRule plus escalation and assignment-strategy config.
 * Wires an interceptor that bridges the tickets module's announces
 * (onTicketCreated, onTicketStatusChanged) into the rules engine so
 * other modules never have to know automation exists.
 */
class {

    this.title              = "automation";
    this.author             = "TesseraBX";
    this.webURL             = "https://github.com/oistechnologies/tesserabx";
    this.description        = "Rules engine, escalation, assignment strategies, recurring tickets.";
    this.version            = "0.0.1";
    this.viewParentLookup   = true;
    this.layoutParentLookup = true;
    // Service-only module: no HTTP surface. The admin UI in Phase 5
    // surfaces rule management under /agent/admin.
    this.entryPoint         = "";
    this.modelNamespace     = "automation";
    this.cfmapping          = "tesserabx.modules.automation";
    this.autoMapModels      = false;
    this.dependencies       = [ "tickets", "contacts", "sla" ];

    function configure(){
        variables.settings = {
            tesserabx : {
                helpSections : [
                    { id : "automation", title : "Automation", audience : "agent", sortWeight : 500, icon : "bi bi-lightning" }
                ],
                helpPages : [
                    { id : "automation.rule-basics", section : "automation", title : "Automation rule basics", audience : "agent", sortWeight : 10, source : "resources/help/rule-basics.md", searchable : true, keywords : [ "automation", "rule", "trigger", "condition", "action" ] }
                ]
            }
        };
        variables.routes              = [];
        variables.interceptorSettings = { customInterceptionPoints : [] };
        variables.interceptors        = [
            {
                class      : "#moduleMapping#.interceptors.AutomationRuleInterceptor",
                name       : "AutomationRuleInterceptor",
                properties : {}
            }
        ];
    }

    function onLoad(){
        binder.map( "AutomationRule@automation" )
              .to( "#moduleMapping#.models.AutomationRule" );
        binder.map( "RecurringTicketTemplate@automation" )
              .to( "#moduleMapping#.models.RecurringTicketTemplate" );
        binder.map( "AutomationService@automation" )
              .to( "#moduleMapping#.models.AutomationService" )
              .asSingleton();
        binder.map( "AssignmentService@automation" )
              .to( "#moduleMapping#.models.AssignmentService" )
              .asSingleton();
        binder.map( "RecurringTicketService@automation" )
              .to( "#moduleMapping#.models.RecurringTicketService" )
              .asSingleton();

        // Phase 6 registries: trigger / operator / field / action.
        binder.map( "TriggerRegistry@automation" )
              .to( "#moduleMapping#.models.TriggerRegistry" )
              .asSingleton();
        binder.map( "OperatorRegistry@automation" )
              .to( "#moduleMapping#.models.OperatorRegistry" )
              .asSingleton();
        binder.map( "ConditionFieldRegistry@automation" )
              .to( "#moduleMapping#.models.ConditionFieldRegistry" )
              .asSingleton();
        binder.map( "ActionRegistry@automation" )
              .to( "#moduleMapping#.models.ActionRegistry" )
              .asSingleton();

        // Phase 6 action executors: one per built-in action. The
        // ActionRegistry's seed declares the executor mapping name;
        // these bindings make them resolvable.
        binder.map( "SetPriorityExecutor@automation" )
              .to( "#moduleMapping#.models.actions.SetPriorityExecutor" )
              .asSingleton();
        binder.map( "SetStatusExecutor@automation" )
              .to( "#moduleMapping#.models.actions.SetStatusExecutor" )
              .asSingleton();
        binder.map( "AssignToAgentExecutor@automation" )
              .to( "#moduleMapping#.models.actions.AssignToAgentExecutor" )
              .asSingleton();
        binder.map( "AssignByStrategyExecutor@automation" )
              .to( "#moduleMapping#.models.actions.AssignByStrategyExecutor" )
              .asSingleton();
        binder.map( "RequestApprovalExecutor@automation" )
              .to( "#moduleMapping#.models.actions.RequestApprovalExecutor" )
              .asSingleton();
    }

    function onUnload(){}

}
