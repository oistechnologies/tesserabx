class extends="coldbox.system.testing.BaseTestCase" appMapping="/" {

    function beforeAll(){
        super.beforeAll();
        super.setup();
    }

    function run(){
        describe( "automation module", function(){
            it( "is registered with ColdBox", function(){
                var modules = getController().getModuleService().getModuleRegistry();
                expect( modules ).toHaveKey( "automation" );
            } );

            it( "is service-only (no HTTP entry point)", function(){
                // automation is a service-only module. Phase 5 surfaces
                // rule management through /agent/admin, not a top-level
                // /automation route.
                var cache = getController().getModuleService().getModuleConfigCache();
                expect( cache ).toHaveKey( "automation" );
                expect( cache[ "automation" ].entryPoint ).toBe( "" );
            } );
        } );
    }

}
