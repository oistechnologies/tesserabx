/**
 * ActionParamsSpec: follow-up A3/A4.
 *
 * Verifies the action-storage migration from `{ type, value }` to
 * `{ type, params : {} }`:
 *
 *   1. normalizeAction wraps the legacy shape into the new shape and
 *      passes the new shape through untouched.
 *   2. Core executors (setPriority, setStatus, assignToAgent,
 *      assignByStrategy) read `params.value`, not `value`.
 *   3. A rule persisted in the new shape round-trips through the
 *      service and produces the same observable mutation as a rule
 *      persisted in the legacy shape (the in-flight shim makes both
 *      paths identical).
 *   4. The shape supports >1 parameter; the JSON survives a database
 *      round-trip even with multi-field params.
 */
class extends="coldbox.system.testing.BaseTestCase" appMapping="/" {

    function beforeAll(){
        super.beforeAll();
        super.setup();
        variables.automation = getController().getWireBox().getInstance( "AutomationService@automation" );
        variables.tickets    = getController().getWireBox().getInstance( "TicketsService@tickets" );
        variables.contacts   = getController().getWireBox().getInstance( "ContactsService@contacts" );
    }

    function run(){
        describe( "AutomationService.normalizeAction", function(){

            it( "wraps legacy { type, value } into { type, params : { value } }", function(){
                var out = variables.automation.normalizeAction( { type : "setPriority", value : "urgent" } );
                expect( out.type ).toBe( "setPriority" );
                expect( out ).toHaveKey( "params" );
                expect( out.params.value ).toBe( "urgent" );
            } );

            it( "passes through { type, params : { ... } } untouched", function(){
                var out = variables.automation.normalizeAction( {
                    type   : "setPriority",
                    params : { value : "low", note : "extra field" }
                } );
                expect( out.type ).toBe( "setPriority" );
                expect( out.params.value ).toBe( "low" );
                expect( out.params.note  ).toBe( "extra field" );
            } );

            it( "carries non-type legacy keys into params when params is absent", function(){
                var out = variables.automation.normalizeAction( {
                    type   : "custom.example",
                    foo    : "f",
                    bar    : "b"
                } );
                expect( out.params.foo ).toBe( "f" );
                expect( out.params.bar ).toBe( "b" );
            } );

        } );

        describe( "Action execution under both shapes", function(){
            beforeEach( function( currentSpec ){
                variables.fixture = makeFixture();
            } );
            afterEach( function( currentSpec ){
                cleanupFixture( variables.fixture );
            } );

            it( "executes a setPriority action persisted in the new params shape", function(){
                // Rule first, then ticket. The synchronous on-create
                // interceptor evaluates rules at the moment the ticket
                // is persisted, so the priority should already be
                // "urgent" on the first read-back.
                var rule = variables.automation.createRule( {
                    name       : "auto-spec-params-new-" & createUUID(),
                    trigger    : "ticket.created",
                    conditions : [ { field : "subject", op : "eq", value : "params-shape-new" } ],
                    actions    : [ { type : "setPriority", params : { value : "urgent" } } ]
                } );
                try {
                    var t = variables.tickets.createTicket( {
                        requesterContactId : variables.fixture.contact.getId(),
                        subject : "params-shape-new", priority : "normal"
                    } );
                    var after = variables.tickets.getTicket( t.getId() );
                    expect( after.getPriority() ).toBe( "urgent" );
                    cleanupTicket( t.getId() );
                } finally {
                    cleanupRule( rule.getId() );
                }
            } );

            it( "executes a setPriority action persisted in the legacy value shape (back-compat)", function(){
                var rule = variables.automation.createRule( {
                    name       : "auto-spec-params-legacy-" & createUUID(),
                    trigger    : "ticket.created",
                    conditions : [ { field : "subject", op : "eq", value : "params-shape-legacy" } ],
                    actions    : [ { type : "setPriority", value : "urgent" } ]
                } );
                try {
                    var t = variables.tickets.createTicket( {
                        requesterContactId : variables.fixture.contact.getId(),
                        subject : "params-shape-legacy", priority : "normal"
                    } );
                    var after = variables.tickets.getTicket( t.getId() );
                    expect( after.getPriority() ).toBe( "urgent" );
                    cleanupTicket( t.getId() );
                } finally {
                    cleanupRule( rule.getId() );
                }
            } );

            it( "multi-field params persist as JSON and round-trip into normalizeAction", function(){
                // Use setPriority as the carrier; the executor only
                // reads params.value, but the surrounding storage layer
                // happily preserves extra params. This proves a future
                // add-on action with multiple fields will round-trip.
                // A condition that no real ticket can match keeps the
                // rule inert against the rest of the suite.
                var rule = variables.automation.createRule( {
                    name       : "auto-spec-multi-field-" & createUUID(),
                    trigger    : "ticket.created",
                    conditions : [ { field : "subject", op : "eq", value : "__multi_field_canary__" } ],
                    actions    : [ {
                        type   : "setPriority",
                        params : { value : "high", note : "carried-through", count : 7 }
                    } ]
                } );
                try {
                    var reread = variables.automation.getRule( rule.getId() );
                    var raw    = jsonDeserialize( reread.getActions() );
                    expect( raw.len() ).toBe( 1 );
                    var normalized = variables.automation.normalizeAction( raw[ 1 ] );
                    expect( normalized.params.value ).toBe( "high" );
                    expect( normalized.params.note  ).toBe( "carried-through" );
                    expect( val( normalized.params.count ) ).toBe( 7 );
                } finally {
                    cleanupRule( rule.getId() );
                }
            } );

        } );
    }

    // ---------------- fixtures ----------------
    // Mirror the helpers in AutomationServiceSpec so this spec is
    // self-contained.

    private struct function makeFixture(){
        var org = variables.contacts.createOrganization( {
            name : "Params Spec Org " & createUUID(),
            slug : "params-spec-" & lCase( replace( createUUID(), "-", "", "all" ) )
        } );
        var contact = variables.contacts.provisionContact( {
            organizationId : org.getId(),
            email          : "params-spec-" & createUUID() & "@example.com",
            password       : "spec-password"
        } );
        return { org : org, contact : contact };
    }

    private void function cleanupTicket( required string id ){
        queryExecute( "DELETE FROM ticket_events   WHERE ticket_id = :id", { id : arguments.id } );
        queryExecute( "DELETE FROM ticket_messages WHERE ticket_id = :id", { id : arguments.id } );
        queryExecute( "DELETE FROM attachments     WHERE ticket_id = :id", { id : arguments.id } );
        queryExecute( "DELETE FROM audit_events    WHERE entity_id  = :id", { id : arguments.id } );
        queryExecute( "DELETE FROM tickets         WHERE id = :id", { id : arguments.id } );
    }

    private void function cleanupFixture( required struct fixture ){
        queryExecute( "DELETE FROM contact_roles WHERE contact_id = :id", { id : arguments.fixture.contact.getId() } );
        queryExecute( "DELETE FROM contacts WHERE id = :id", { id : arguments.fixture.contact.getId() } );
        queryExecute( "DELETE FROM audit_events WHERE organization_id = :id", { id : arguments.fixture.org.getId() } );
        queryExecute( "DELETE FROM organizations WHERE id = :id", { id : arguments.fixture.org.getId() } );
    }

    private void function cleanupRule( required string id ){
        queryExecute( "DELETE FROM automation_rule_fires WHERE rule_id = :id", { id : arguments.id } );
        queryExecute( "DELETE FROM automation_rules WHERE id = :id", { id : arguments.id } );
    }

}
