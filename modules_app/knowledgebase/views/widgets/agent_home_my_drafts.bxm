<bx:output>
<bx:set local.rows = ( prc.widgetData.rows ?: [] ) >
<div class="card flex-fill h-100">
    <div class="card-header d-flex align-items-center">
        <h3 class="card-title mb-0 flex-grow-1">
            <i class="bi bi-pencil-square me-2"></i>My drafts
        </h3>
        <a href="/agent/admin/kb" class="small">All drafts <i class="bi bi-arrow-right"></i></a>
    </div>
    <div class="card-body p-0">
        <bx:if !arrayLen( local.rows )>
            <p class="text-body-secondary mb-0 p-3">No drafts in progress.</p>
        <bx:else>
            <ul class="list-group list-group-flush" data-drafts-list>
                <bx:loop array="#local.rows#" item="local.row">
                    <li class="list-group-item d-flex align-items-center">
                        <a href="#encodeForHTMLAttribute( local.row.url )#"
                           class="link-body-emphasis text-decoration-none flex-grow-1 small">
                            #encodeForHTML( local.row.title )#
                        </a>
                        <span class="text-body-tertiary small ms-2">#encodeForHTML( local.row.updatedAt )#</span>
                    </li>
                </bx:loop>
            </ul>
        </bx:if>
    </div>
</div>
<script>
(function(){
    window.tbxDashboard = window.tbxDashboard || { widgets : {} };
    window.tbxDashboard.widgets[ "agent-home.my-kb-drafts" ] = {
        update : function( payload, card ){
            if ( !payload || !payload.rows ) return;
            var ul = card.querySelector( "[data-drafts-list]" );
            if ( !ul ) return;
            var html = "";
            payload.rows.forEach( function( r ){
                html += "<li class=\"list-group-item d-flex align-items-center\">" +
                    "<a href=\"" + escapeAttr( r.url ) + "\" class=\"link-body-emphasis text-decoration-none flex-grow-1 small\">" + escape( r.title ) + "</a>" +
                    "<span class=\"text-body-tertiary small ms-2\">" + escape( r.updatedAt ) + "</span>" +
                "</li>";
            } );
            ul.innerHTML = html;
        }
    };
    function escape( s ){
        return String( s == null ? "" : s )
            .replace( /&/g, "&amp;" )
            .replace( /</g, "&lt;" )
            .replace( />/g, "&gt;" );
    }
    function escapeAttr( s ){
        return escape( s ).replace( /"/g, "&quot;" );
    }
})();
</script>
</bx:output>
