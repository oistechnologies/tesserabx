class extends="coldbox.system.testing.BaseTestCase" appMapping="/" {

    function beforeAll(){
        super.beforeAll();
        super.setup();
    }

    function run(){
        describe( "portal module", function(){
            it( "is registered with ColdBox", function(){
                var modules = getController().getModuleService().getModuleRegistry();
                expect( modules ).toHaveKey( "portal" );
            } );

            it( "exposes its entry point", function(){
                var cache = getController().getModuleService().getModuleConfigCache();
                expect( cache ).toHaveKey( "portal" );
                // portal serves the root surface, so its entryPoint
                // is intentionally an empty string. The presence of
                // the key in the cache is the meaningful signal.
                expect( cache[ "portal" ] ).toHaveKey( "entryPoint" );
            } );
        } );
    }

}
