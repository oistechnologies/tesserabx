/**
 * ai module: bx-ai integration plus the AI middleware facade.
 *
 * This is the ONLY module that imports bx-ai. Every AI feature in
 * other modules calls the facade exposed here, never the provider
 * directly. Owns AiInteraction. Optional at runtime; when the
 * capability flag is off, no AI UI renders anywhere.
 *
 * Service-only module: no HTTP surface. Phase 5 mounts AI configuration
 * under /agent/admin.
 */
class {

    this.title              = "ai";
    this.author             = "TesseraBX";
    this.webURL             = "https://github.com/oistechnologies/tesserabx";
    this.description        = "AI middleware facade and bx-ai integration, optional at runtime.";
    this.version            = "0.0.1";
    this.viewParentLookup   = true;
    this.layoutParentLookup = true;
    this.entryPoint         = "";
    this.modelNamespace     = "ai";
    this.cfmapping          = "tesserabx.modules.ai";
    this.autoMapModels      = false;
    this.dependencies       = [ "contacts", "audit", "tickets", "knowledgebase" ];

    function configure(){
        variables.settings = {
            tesserabx : {
                // /agent home dashboard widget. requiresAi=true so the
                // registry auto-hides it when AI_ENABLED=false (the
                // hard constraint from CLAUDE.md: no AI UI surfaces
                // when AI is off). The data provider reads from
                // ai_interactions, which is empty in an AI-off
                // deployment anyway.
                dashboardWidgets : [
                    { id : "agent-home.ai-activity", title : "My AI activity (7d)", partial : "widgets/agent_home_ai_activity", module : "ai", zone : "agent-home", defaultGridSize : "col-12 d-flex", sortWeight : 1000, requiredPermission : "tickets.view", requiresAi : true, dataProvider : "AiMiddleware@ai", dataMethod : "activitySummaryForCurrentAgent" }
                ]
            }
        };
        variables.routes   = [];
        variables.interceptorSettings = { customInterceptionPoints : [] };
        variables.interceptors = [
            {
                class      : "#moduleMapping#.interceptors.TriageInterceptor",
                name       : "TriageInterceptor",
                properties : {}
            },
            {
                class      : "#moduleMapping#.interceptors.KbIndexingInterceptor",
                name       : "KbIndexingInterceptor",
                properties : {}
            },
            {
                class      : "#moduleMapping#.interceptors.EscalationRiskInterceptor",
                name       : "EscalationRiskInterceptor",
                properties : {}
            }
        ];
    }

    function onLoad(){
        binder.map( "AiInteraction@ai" )
              .to( "#moduleMapping#.models.AiInteraction" );
        binder.map( "AiSystemPrompt@ai" )
              .to( "#moduleMapping#.models.AiSystemPrompt" );
        binder.map( "AiCapability@ai" )
              .to( "#moduleMapping#.models.AiCapability" )
              .asSingleton();
        binder.map( "AiSystemPromptService@ai" )
              .to( "#moduleMapping#.models.AiSystemPromptService" )
              .asSingleton();
        binder.map( "AiMiddleware@ai" )
              .to( "#moduleMapping#.models.AiMiddleware" )
              .asSingleton();
        binder.map( "SuggestedReplyService@ai" )
              .to( "#moduleMapping#.models.SuggestedReplyService" )
              .asSingleton();
        binder.map( "TriageService@ai" )
              .to( "#moduleMapping#.models.TriageService" )
              .asSingleton();
        binder.map( "SummarizationService@ai" )
              .to( "#moduleMapping#.models.SummarizationService" )
              .asSingleton();
        binder.map( "KbIndexingService@ai" )
              .to( "#moduleMapping#.models.KbIndexingService" )
              .asSingleton();
        binder.map( "KbSuggestionService@ai" )
              .to( "#moduleMapping#.models.KbSuggestionService" )
              .asSingleton();
        binder.map( "KbDraftService@ai" )
              .to( "#moduleMapping#.models.KbDraftService" )
              .asSingleton();
        binder.map( "ReplyToneService@ai" )
              .to( "#moduleMapping#.models.ReplyToneService" )
              .asSingleton();
        binder.map( "EscalationRiskService@ai" )
              .to( "#moduleMapping#.models.EscalationRiskService" )
              .asSingleton();

        // Phase 7 registries.
        binder.map( "AiFeatureRegistry@ai" )
              .to( "#moduleMapping#.models.AiFeatureRegistry" )
              .asSingleton();
        binder.map( "AiProviderRegistry@ai" )
              .to( "#moduleMapping#.models.AiProviderRegistry" )
              .asSingleton();
        binder.map( "EmbeddingConsumerRegistry@ai" )
              .to( "#moduleMapping#.models.EmbeddingConsumerRegistry" )
              .asSingleton();
        // Follow-up A2: periodic re-embed sweep across every consumer
        // in the registry. Wired into config/Scheduler.bx; the sweep
        // is additive to KbIndexingService's existing onKbArticle
        // Published interceptor path.
        binder.map( "EmbeddingScheduler@ai" )
              .to( "#moduleMapping#.models.EmbeddingScheduler" )
              .asSingleton();

        // Phase 7 provider: BxAiProvider wraps the existing
        // aiChat / aiEmbed BIF calls; add-ons register additional
        // providers via the manifest's settings.tesserabx.aiProviders.
        binder.map( "BxAiProvider@ai" )
              .to( "#moduleMapping#.models.providers.BxAiProvider" )
              .asSingleton();
    }

    function onUnload(){}

}
