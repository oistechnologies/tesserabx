/**
 * SuggestedReplyServiceSpec: behaviour we can verify without a live
 * provider. The disabled-capability path is the contract every
 * feature exposes; the unknown-ticket path is the contract every
 * feature exposes; the actual provider call is tested in 4b's
 * smoke verification against the user's real API key.
 */
class extends="coldbox.system.testing.BaseTestCase" appMapping="/" {

    function beforeAll(){
        super.beforeAll();
        super.setup();
        variables.svc        = getController().getWireBox().getInstance( "SuggestedReplyService@ai" );
        variables.capability = getController().getWireBox().getInstance( "AiCapability@ai" );
        variables.aiOff      = !variables.capability.isEnabled();
    }

    function run(){
        describe( "SuggestedReplyService", function(){

            it( "returns available=false when the AI capability is off", function(){
                if ( !variables.aiOff ) return;
                var result = variables.svc.suggest( ticketId : "nonexistent" );
                expect( result.available ).toBeFalse();
                expect( result.outcome ).toBe( "disabled" );
            } );

        } );
    }

}
