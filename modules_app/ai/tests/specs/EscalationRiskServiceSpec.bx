/**
 * EscalationRiskServiceSpec: follow-up B9.
 *
 * Verifies:
 *   - When AI is off (the test app forces this), scoreFor returns
 *     available=false, outcome="disabled".
 *   - When the model returns a malformed/empty response, parseModelJson
 *     falls back to zero + empty rationale; apply() is a no-op so the
 *     ticket's existing score stays untouched.
 *   - apply() with outcome="ok" writes the three columns and clamps
 *     out-of-range scores (negative -> 0, >100 -> 100).
 *   - The CorePanelDogfoodSpec contract: the escalation-risk panel
 *     is registered with requiresAi=true.
 *   - AiFeatureRegistry exposes the new "escalation-risk" feature.
 *
 * The full prompt + provider round-trip is not exercised here because
 * the test app forces AI_ENABLED=false. The unit-level wiring is what
 * we cover; the live behavior is verified by hand against a real
 * provider once AI is configured.
 */
class extends="coldbox.system.testing.BaseTestCase" appMapping="/" {

    function beforeAll(){
        super.beforeAll();
        super.setup();
        var wb = getController().getWireBox();
        variables.svc       = wb.getInstance( "EscalationRiskService@ai" );
        variables.features  = wb.getInstance( "AiFeatureRegistry@ai" );
        variables.tickets   = wb.getInstance( "TicketsService@tickets" );
        variables.panels    = wb.getInstance( "TicketPanelRegistry@tickets" );
    }

    function run(){
        describe( "B9: EscalationRiskService + feature registration + panel", function(){

            it( "AiFeatureRegistry exposes the `escalation-risk` feature with requiresAi=true", function(){
                var ids = [];
                for ( var f in variables.features.listAll() ) ids.append( f.id );
                expect( ids ).toInclude( "escalation-risk" );
                // Each AiFeatureRegistry entry is requiresAi=true by
                // design (addEntry sets it unconditionally).
                for ( var f in variables.features.listAll() ) {
                    if ( f.id == "escalation-risk" ) expect( f.requiresAi ).toBeTrue();
                }
            } );

            it( "scoreFor returns available=false when AI is off (test mode)", function(){
                var result = variables.svc.scoreFor( "any-ticket-id-it-skips-before-touching-db" );
                expect( result.available ).toBeFalse();
                expect( result.outcome   ).toBe( "disabled" );
            } );

            it( "apply() persists the three columns to the ticket row", function(){
                var t = makeTicket();
                try {
                    variables.svc.apply( t.getId(), {
                        outcome   : "ok",
                        score     : 75,
                        rationale : "Customer is angry; SLA close to breach."
                    } );
                    // Re-read; the entity instance from createTicket
                    // is stale.
                    var fresh = variables.tickets.getTicket( t.getId() );
                    expect( fresh.getEscalationRiskScore() ).toBe( 75 );
                    expect( fresh.getEscalationRiskRationale() ).toBe( "Customer is angry; SLA close to breach." );
                    expect( fresh.getEscalationRiskAt() ).notToBeNull();
                } finally {
                    cleanupTicket( t.getId() );
                }
            } );

            it( "apply() clamps negative scores to 0 and >100 to 100", function(){
                var t = makeTicket();
                try {
                    variables.svc.apply( t.getId(), { outcome : "ok", score : -42, rationale : "x" } );
                    expect( variables.tickets.getTicket( t.getId() ).getEscalationRiskScore() ).toBe( 0 );
                    variables.svc.apply( t.getId(), { outcome : "ok", score : 999, rationale : "y" } );
                    expect( variables.tickets.getTicket( t.getId() ).getEscalationRiskScore() ).toBe( 100 );
                } finally {
                    cleanupTicket( t.getId() );
                }
            } );

            it( "apply() with outcome != ok is a no-op (preserves prior score)", function(){
                var t = makeTicket();
                try {
                    variables.svc.apply( t.getId(), { outcome : "ok", score : 60, rationale : "first" } );
                    variables.svc.apply( t.getId(), { outcome : "error", score : 99, rationale : "second" } );
                    expect( variables.tickets.getTicket( t.getId() ).getEscalationRiskScore() ).toBe( 60 );
                } finally {
                    cleanupTicket( t.getId() );
                }
            } );

            it( "the escalation-risk ticket panel is registered with requiresAi=true", function(){
                var matches = variables.panels.listAll().filter( ( p ) => p.id == "escalation-risk" );
                expect( arrayLen( matches ) ).toBe( 1 );
                expect( matches[ 1 ].requiresAi ).toBeTrue();
                expect( matches[ 1 ].requiredPermission ).toBe( "tickets.view" );
            } );

        } );
    }

    // ---------------- fixtures ----------------

    private any function makeTicket(){
        return variables.tickets.createAccountlessTicket( {
            subject          : "esc-risk-spec-" & createUUID(),
            originatingEmail : "esc-" & createUUID() & "@example.com",
            firstMessage     : "test",
            source           : "spec"
        } );
    }

    private void function cleanupTicket( required string id ){
        queryExecute( "DELETE FROM ticket_events   WHERE ticket_id = :id", { id : arguments.id } );
        queryExecute( "DELETE FROM ticket_messages WHERE ticket_id = :id", { id : arguments.id } );
        queryExecute( "DELETE FROM attachments     WHERE ticket_id = :id", { id : arguments.id } );
        queryExecute( "DELETE FROM audit_events    WHERE entity_id  = :id", { id : arguments.id } );
        queryExecute( "DELETE FROM tickets         WHERE id = :id", { id : arguments.id } );
    }

}
