/**
 * KbDraftServiceSpec: disabled-path coverage. Live generation is
 * exercised by the agent UI; CI runs with AI off so this spec asserts
 * the contract every caller can rely on (no provider calls, no DB
 * writes, a clean "disabled" outcome).
 */
class extends="coldbox.system.testing.BaseTestCase" appMapping="/" {

    function beforeAll(){
        super.beforeAll();
        super.setup();
        variables.svc = getController().getWireBox().getInstance( "KbDraftService@ai" );
    }

    function run(){
        describe( "KbDraftService", function(){
            it( "returns available=false when AI is off", function(){
                var r = variables.svc.draft( ticketId : "nonexistent" );
                expect( r.available ).toBeFalse();
                expect( r.outcome ).toBe( "disabled" );
            } );

            it( "draftAndCreate also short-circuits when AI is off", function(){
                var r = variables.svc.draftAndCreate( ticketId : "nonexistent" );
                expect( r.outcome ).toBe( "disabled" );
                expect( r.articleId ).toBe( "" );
            } );
        } );
    }

}
