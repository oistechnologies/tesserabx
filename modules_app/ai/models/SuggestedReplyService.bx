/**
 * SuggestedReplyService: drafts an agent reply for a ticket and
 * returns it split into two channels: the customer-visible `reply`
 * and the agent-only `notes`.
 *
 * The system prompt comes from ai_system_prompts (admin-editable
 * via the Phase 5 UI); the migration seeds a default for
 * `suggested-reply`. We force the model to respond with strict
 * JSON `{ "reply": "...", "notes": "..." }` so agent-facing notes
 * never leak into the customer reply (the failure mode we hit on
 * the first real test run).
 *
 * Lives in the `ai` module so the cross-module direction stays
 * one-way (AI imports tickets, never the other direction).
 */
class singleton=true {

    property name="wirebox"        inject="wirebox";
    property name="capability"     inject="AiCapability@ai";
    property name="middleware"     inject="AiMiddleware@ai";
    property name="promptService"  inject="AiSystemPromptService@ai";
    property name="ticketsService" inject="TicketsService@tickets";

    variables.FEATURE_KEY = "suggested-reply";
    variables.FALLBACK_SYSTEM_PROMPT = "You are an experienced customer support agent drafting a reply on behalf of {{agentName}}. Respond with strict JSON: {""reply"": ""..."", ""notes"": ""...""}. The reply is what the customer sees; notes are for the agent only.";

    /**
     * Suggest a reply for a ticket. Returns:
     *   {
     *     available : bool,
     *     reply     : string,   // customer-visible draft
     *     notes     : string,   // agent-only commentary; "" if none
     *     outcome   : string,
     *     error     : string
     *   }
     */
    public struct function suggest( required string ticketId, string actorAgentId = "" ){
        var off = { "available" : false, "reply" : "", "notes" : "", "outcome" : "disabled", "error" : "" };
        if ( !capability.isFeatureEnabled( variables.FEATURE_KEY ) ) return off;

        var ticket = ticketsService.getTicket( arguments.ticketId );
        if ( isNull( ticket ) ) {
            return { "available" : true, "reply" : "", "notes" : "", "outcome" : "error", "error" : "Ticket not found" };
        }

        var agentName    = lookupAgentName( arguments.actorAgentId );
        var template     = promptService.getForFeature( variables.FEATURE_KEY );
        if ( !len( template ) ) template = variables.FALLBACK_SYSTEM_PROMPT;
        var systemPrompt = promptService.renderTemplate(
            template,
            {
                "agentName"      : agentName,
                "ticketSubject"  : ticket.getSubject() ?: "",
                "ticketPriority" : ticket.getPriority() ?: "normal"
            }
        );

        var userPrompt = buildUserPrompt( ticket );
        var result = middleware.complete(
            feature : variables.FEATURE_KEY,
            prompt  : userPrompt,
            options : {
                systemPrompt   : systemPrompt,
                organizationId : ticket.getOrganizationId() ?: "",
                ticketId       : ticket.getId(),
                agentId        : arguments.actorAgentId,
                temperature    : 0.4,
                maxTokens      : 700
            }
        );

        if ( result.outcome != "ok" ) {
            return {
                "available" : true,
                "reply"     : "",
                "notes"     : "",
                "outcome"   : result.outcome,
                "error"     : result.error ?: ""
            };
        }

        var parsed = parseModelJson( result.text );
        return {
            "available" : true,
            "reply"     : parsed.reply,
            "notes"     : parsed.notes,
            "outcome"   : "ok",
            "error"     : ""
        };
    }

    /**
     * Parse the model's JSON output into {reply, notes}.
     *
     * Real model output sometimes prefixes the JSON with thinking
     * prose ("Let me think about this..."). The middleware's
     * extractor handles that; we just deserialize what it returns.
     * If nothing parseable came back, surface a clear note to the
     * agent and leave the reply blank rather than pasting raw
     * thinking text into a customer-facing textarea.
     */
    private struct function parseModelJson( required string raw ){
        var jsonStr = middleware.extractJsonObject( arguments.raw );
        if ( !len( jsonStr ) ) {
            return { "reply" : "", "notes" : "(AI did not return parseable JSON; the raw output is in the interaction log.)" };
        }
        try {
            var data = jsonDeserialize( jsonStr );
            if ( !isStruct( data ) ) return { "reply" : "", "notes" : "" };
            return {
                "reply" : toString( data.reply ?: "" ),
                "notes" : toString( data.notes ?: "" )
            };
        } catch ( any e ) {
            return { "reply" : "", "notes" : "(AI returned malformed JSON: " & e.message & ")" };
        }
    }

    private string function buildUserPrompt( required any ticket ){
        var messages = ticketsService.listMessagesForTicket( arguments.ticket.getId(), true );
        var lines = [
            "Ticket subject: " & arguments.ticket.getSubject(),
            "Ticket priority: " & ( arguments.ticket.getPriority() ?: "normal" ),
            ""
        ];
        if ( !messages.len() ) {
            lines.append( "No messages yet on this ticket. Draft an opening response acknowledging the request." );
            return lines.toList( char( 10 ) );
        }
        var slice = messages.len() <= 10 ? messages : messages.slice( messages.len() - 9, 10 );
        lines.append( "Conversation so far (oldest first):" );
        for ( var m in slice ) {
            if ( m.getIsInternal() ?: false ) continue;
            var who = len( m.getAuthorAgentId() ?: "" ) ? "Agent" : "Customer";
            lines.append( who & ": " & ( m.getBody() ?: "" ) );
        }
        lines.append( "" );
        lines.append( "Draft the agent's next reply." );
        return lines.toList( char( 10 ) );
    }

    private string function lookupAgentName( required string agentId ){
        if ( !len( arguments.agentId ) ) return "the support team";
        var agent = wirebox.getInstance( "Agent@agent" )
            .where( "id", arguments.agentId )
            .first();
        if ( isNull( agent ) ) return "the support team";
        var first = agent.getFirstName() ?: "";
        var last  = agent.getLastName() ?: "";
        var full  = trim( first & " " & last );
        return len( full ) ? full : ( agent.getEmail() ?: "the support team" );
    }

}
