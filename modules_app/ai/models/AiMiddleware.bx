/**
 * AiMiddleware: the single facade every AI feature talks to.
 *
 * Per CLAUDE.md this is the ONLY code that touches bx-ai. Feature
 * modules call complete( feature, prompt, options ) and never reach
 * past the facade to a provider directly.
 *
 * Phase 4a scope (no provider yet):
 *   - Short-circuit on disabled capability ("disabled" outcome).
 *   - PII redaction + prompt hashing (so the contract is stable
 *     before Phase 4b plugs in a real provider).
 *   - Log every call to ai_interactions through recordInteraction.
 *   - When enabled but no provider hookup exists, return an
 *     explicit "not implemented" outcome so callers learn early
 *     in dev that a provider config is missing.
 *
 * Phase 4b replaces the "not implemented" branch with the actual
 * bx-ai call.
 *
 * Returned struct shape:
 *   {
 *     outcome    : "ok" | "disabled" | "redacted_only" | "error" | "not_implemented",
 *     text       : "..."           // empty unless outcome is "ok"
 *     tokensIn   : 0,
 *     tokensOut  : 0,
 *     latencyMs  : 0,
 *     error      : ""              // populated on "error"
 *   }
 */
class singleton=true {

    property name="wirebox"     inject="wirebox";
    property name="capability"  inject="AiCapability@ai";

    /**
     * complete: the one-shot completion entry point.
     *
     * Required:
     *   feature  - short key for this call (e.g., "suggested-reply")
     *   prompt   - the user message (post-redaction, hashed for logging)
     * Optional in `options`:
     *   systemPrompt    - sent as a system message ahead of the user
     *                     message. Features feed the
     *                     AiSystemPromptService template through here.
     *   model           - override the configured model
     *   organizationId  - subject org for logging
     *   ticketId        - subject ticket for logging
     *   contactId       - subject contact for logging
     *   agentId         - acting agent for logging
     *   maxTokens       - provider hint
     *   temperature     - provider hint
     */
    public struct function complete(
        required string feature,
        required string prompt,
        struct options = {}
    ){
        var startMs = getTickCount();

        if ( !capability.isEnabled() ) {
            recordInteraction(
                feature : arguments.feature,
                outcome : "disabled",
                options : arguments.options,
                latency : 0
            );
            return baseResult( outcome = "disabled" );
        }

        var redacted = redactPrompt( arguments.prompt );
        if ( !len( trim( redacted ) ) ) {
            recordInteraction(
                feature : arguments.feature,
                outcome : "redacted_only",
                options : arguments.options,
                latency : getTickCount() - startMs
            );
            return baseResult( outcome = "redacted_only" );
        }

        // System prompt also runs through redaction. Both are folded
        // into the same SHA-256 hash so the logged digest reflects
        // exactly what hit the provider.
        var systemPrompt = arguments.options.systemPrompt ?: "";
        if ( len( systemPrompt ) ) systemPrompt = redactPrompt( systemPrompt );

        var hash       = hash( ( len( systemPrompt ) ? systemPrompt & char( 30 ) : "" ) & redacted, "SHA-256" );
        var modelToUse = arguments.options.model ?: capability.getModel();
        var providerToUse = capability.getProvider();

        try {
            var params = { "model" : modelToUse };
            if ( structKeyExists( arguments.options, "temperature" ) ) params[ "temperature" ] = arguments.options.temperature;
            if ( structKeyExists( arguments.options, "maxTokens" )   ) params[ "max_tokens"  ] = arguments.options.maxTokens;

            var providerOptions = {
                "provider"     : providerToUse,
                "apiKey"       : capability.getApiKey(),
                "timeout"      : capability.getTimeoutSeconds(),
                "returnFormat" : "raw"
            };
            if ( len( capability.getBaseUrl() ) ) providerOptions[ "baseUrl" ] = capability.getBaseUrl();

            // Build the messages payload. When a systemPrompt is
            // present we send a two-message conversation (system +
            // user); otherwise a single user message preserves the
            // earlier behavior for any caller that does not yet
            // supply a template.
            var messages = len( systemPrompt )
                ? [
                    { "role" : "system", "content" : systemPrompt },
                    { "role" : "user",   "content" : redacted }
                  ]
                : redacted;

            // bx-ai BIF: aiChat( messages, params, options ). The
            // facade is the only place that calls bx-ai directly,
            // per CLAUDE.md's "ai module is the only code that
            // imports bx-ai" rule.
            var raw = aiChat( messages, params, providerOptions );

            var result   = parseAiChatResponse( raw );
            var latency  = getTickCount() - startMs;
            recordInteraction(
                feature    : arguments.feature,
                outcome    : "ok",
                options    : arguments.options,
                latency    : latency,
                promptHash : hash,
                tokensIn   : result.tokensIn,
                tokensOut  : result.tokensOut
            );
            return {
                "outcome"   : "ok",
                "text"      : result.text,
                "tokensIn"  : result.tokensIn,
                "tokensOut" : result.tokensOut,
                "latencyMs" : latency,
                "error"     : ""
            };
        } catch ( any e ) {
            var latency = getTickCount() - startMs;
            recordInteraction(
                feature      : arguments.feature,
                outcome      : "error",
                options      : arguments.options,
                latency      : latency,
                promptHash   : hash,
                errorMessage : e.message
            );
            return {
                "outcome"   : "error",
                "text"      : "",
                "tokensIn"  : 0,
                "tokensOut" : 0,
                "latencyMs" : latency,
                "error"     : e.message
            };
        }
    }

    /**
     * Normalize bx-ai's raw response shape into our flat result.
     * The raw struct shape varies by provider; the keys we look at
     * (`choices[1].message.content`, `usage.prompt_tokens`,
     * `usage.completion_tokens`) match every OpenAI-compatible
     * provider, which is OpenRouter's protocol. Other providers fall
     * back to a best-effort scan.
     */
    private struct function parseAiChatResponse( required any raw ){
        var out = { "text" : "", "tokensIn" : 0, "tokensOut" : 0 };
        if ( isSimpleValue( arguments.raw ) ) {
            out.text = toString( arguments.raw );
            return out;
        }
        if ( isStruct( arguments.raw ) ) {
            // OpenAI-shaped: choices[1].message.content + usage.*
            if ( structKeyExists( arguments.raw, "choices" )
                 && isArray( arguments.raw.choices )
                 && arguments.raw.choices.len() ) {
                var choice = arguments.raw.choices[ 1 ];
                if ( structKeyExists( choice, "message" ) && structKeyExists( choice.message, "content" ) ) {
                    out.text = toString( choice.message.content );
                } else if ( structKeyExists( choice, "text" ) ) {
                    out.text = toString( choice.text );
                }
            } else if ( structKeyExists( arguments.raw, "content" ) ) {
                out.text = toString( arguments.raw.content );
            } else if ( structKeyExists( arguments.raw, "text" ) ) {
                out.text = toString( arguments.raw.text );
            }
            if ( structKeyExists( arguments.raw, "usage" ) ) {
                var usage = arguments.raw.usage;
                out.tokensIn  = int( usage.prompt_tokens     ?: usage.input_tokens  ?: 0 );
                out.tokensOut = int( usage.completion_tokens ?: usage.output_tokens ?: 0 );
            }
        }
        return out;
    }

    /**
     * Generate an embedding vector for `text`.
     *
     * Returns:
     *   {
     *     outcome   : "ok" | "disabled" | "redacted_only" | "error",
     *     vector    : array<float>      // empty unless ok
     *     dimension : numeric,
     *     latencyMs : numeric,
     *     error     : string
     *   }
     *
     * Goes through the same observability surface as complete():
     * one row in ai_interactions per call, PII redaction before the
     * payload leaves the process, and a "disabled" short-circuit
     * when the capability flag is off.
     */
    public struct function embed(
        required string feature,
        required string text,
        struct options = {}
    ){
        var startMs = getTickCount();
        var empty   = { "outcome" : "disabled", "vector" : [], "dimension" : 0, "latencyMs" : 0, "error" : "" };

        if ( !capability.isEnabled() ) {
            recordInteraction( feature : arguments.feature, outcome : "disabled", options : arguments.options, latency : 0 );
            return empty;
        }
        var redacted = redactPrompt( arguments.text );
        if ( !len( trim( redacted ) ) ) {
            recordInteraction( feature : arguments.feature, outcome : "redacted_only", options : arguments.options, latency : getTickCount() - startMs );
            empty.outcome = "redacted_only";
            return empty;
        }

        var hash = hash( redacted, "SHA-256" );
        var modelToUse = arguments.options.model ?: capability.getEmbeddingModel();
        var providerOptions = {
            "provider"     : capability.getProvider(),
            "apiKey"       : capability.getApiKey(),
            "timeout"      : capability.getTimeoutSeconds(),
            "returnFormat" : "embeddings"
        };
        if ( len( capability.getBaseUrl() ) ) providerOptions[ "baseUrl" ] = capability.getBaseUrl();

        try {
            var raw = aiEmbed( redacted, { "model" : modelToUse }, providerOptions );
            // returnFormat "embeddings" returns an array of vectors;
            // for a single-input call there is exactly one entry.
            var vector = ( isArray( raw ) && raw.len() ) ? raw[ 1 ] : raw;
            if ( !isArray( vector ) ) vector = [];

            var latency = getTickCount() - startMs;
            recordInteraction(
                feature    : arguments.feature,
                outcome    : "ok",
                options    : arguments.options,
                latency    : latency,
                promptHash : hash,
                tokensIn   : len( redacted )
            );
            return {
                "outcome"   : "ok",
                "vector"    : vector,
                "dimension" : vector.len(),
                "latencyMs" : latency,
                "error"     : ""
            };
        } catch ( any e ) {
            var latency = getTickCount() - startMs;
            recordInteraction(
                feature      : arguments.feature,
                outcome      : "error",
                options      : arguments.options,
                latency      : latency,
                promptHash   : hash,
                errorMessage : e.message
            );
            return {
                "outcome"   : "error",
                "vector"    : [],
                "dimension" : 0,
                "latencyMs" : latency,
                "error"     : e.message
            };
        }
    }

    /**
     * Pull the first valid JSON object out of a model response.
     *
     * Real-world model output, especially from "thinking" providers,
     * often wraps the JSON in prose: an apology, a chain-of-thought
     * preamble, or markdown fences. We scan for the first balanced
     * top-level object (tracking braces, respecting strings and
     * escapes) and return that substring; if no balanced object is
     * found, we fall back to whatever isJSON accepts on the trimmed
     * input, and finally to "".
     *
     * Public so every AI feature shares one extractor and the rules
     * stay consistent across triage / summary / reply / etc.
     */
    public string function extractJsonObject( required string raw ){
        var src = trim( arguments.raw );
        if ( !len( src ) ) return "";

        // Strip code fences if present so the substring scan does not
        // have to know about them.
        if ( left( src, 7 ) == "```json" ) src = listRest( src, char( 10 ) );
        else if ( left( src, 3 ) == "```" ) src = listRest( src, char( 10 ) );
        if ( right( src, 3 ) == "```" ) src = left( src, len( src ) - 3 );
        src = trim( src );
        if ( !len( src ) ) return "";

        // Fast path: the whole thing parses.
        if ( isJSON( src ) ) return src;

        // Scan for a balanced { ... } object. Tracks string literals
        // and escapes so a brace inside a string does not throw the
        // depth counter off. char(34) is " and char(92) is \, used
        // through char() to dodge BoxLang's string-literal escape
        // rules.
        var QUOTE     = char( 34 );
        var BACKSLASH = char( 92 );
        var depth     = 0;
        var start     = 0;
        var inStr     = false;
        var escaped   = false;
        for ( var i = 1; i <= len( src ); i++ ) {
            var c = mid( src, i, 1 );
            if ( escaped ) { escaped = false; continue; }
            if ( inStr ) {
                if ( c == BACKSLASH ) { escaped = true; continue; }
                if ( c == QUOTE )     { inStr   = false; continue; }
                continue;
            }
            if ( c == QUOTE ) { inStr = true; continue; }
            if ( c == "{" ) {
                if ( depth == 0 ) start = i;
                depth++;
            } else if ( c == "}" ) {
                depth--;
                if ( depth == 0 && start > 0 ) {
                    var candidate = mid( src, start, i - start + 1 );
                    if ( isJSON( candidate ) ) return candidate;
                    // Premature closing means we picked up an inner
                    // object as the outer; reset and keep looking.
                    start = 0;
                }
            }
        }
        return "";
    }

    /**
     * Redact PII before any payload leaves the system. Phase 4a
     * masks email addresses; phone numbers and digit runs are TODOs
     * tracked for the security review pass in Phase 6.
     *
     * Public so specs can exercise it without going through a full
     * complete() call.
     */
    public string function redactPrompt( required string raw ){
        if ( !capability.isPiiRedactionEnabled() ) return arguments.raw;
        // Email pattern: catches the common forms; deliberately
        // wider than RFC 5322 so we err on the side of redacting.
        var out = reReplaceNoCase(
            arguments.raw,
            "[A-Z0-9._%+-]+@[A-Z0-9.-]+\.[A-Z]{2,}",
            "[redacted-email]",
            "all"
        );
        return out;
    }

    /**
     * Log one interaction. Public so callers in 4b+ that bypass
     * complete() (streaming, batch) can still record consistently.
     */
    public void function recordInteraction(
        required string feature,
        required string outcome,
        struct options = {},
        numeric latency = 0,
        string promptHash = "",
        numeric tokensIn = 0,
        numeric tokensOut = 0,
        string errorMessage = ""
    ){
        var row = wirebox.getInstance( "AiInteraction@ai" );
        row.setId( createObject( "java", "java.util.UUID" ).randomUUID().toString() );
        row.setFeature( arguments.feature );
        // provider + model are NOT NULL columns; fall back to empty
        // string when nothing has been configured so the row still
        // logs (an unconfigured AI is itself a story to capture).
        row.setProvider( capability.getProvider() );
        var modelToLog = arguments.options.model ?: capability.getModel();
        row.setModel( len( modelToLog ) ? modelToLog : "" );
        if ( len( arguments.promptHash ) ) row.setPromptHash( arguments.promptHash );
        row.setTokensIn(  int( arguments.tokensIn ) );
        row.setTokensOut( int( arguments.tokensOut ) );
        row.setLatencyMs( int( arguments.latency ) );
        row.setOutcome( arguments.outcome );
        if ( len( arguments.errorMessage ) ) row.setErrorMessage( arguments.errorMessage );
        if ( len( arguments.options.organizationId ?: "" ) ) row.setOrganizationId( arguments.options.organizationId );
        if ( len( arguments.options.ticketId ?: "" ) )       row.setTicketId( arguments.options.ticketId );
        if ( len( arguments.options.contactId ?: "" ) )      row.setContactId( arguments.options.contactId );
        if ( len( arguments.options.agentId ?: "" ) )        row.setAgentId( arguments.options.agentId );
        row.save();
    }

    // ---------------- internals ----------------

    private struct function baseResult( required string outcome ){
        return {
            "outcome"   : arguments.outcome,
            "text"      : "",
            "tokensIn"  : 0,
            "tokensOut" : 0,
            "latencyMs" : 0,
            "error"     : ""
        };
    }

}
