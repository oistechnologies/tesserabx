<bx:output>
<bx:set local.brand = getInstance( "SettingsService@admin" ).getBranding() >
<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="surface" content="agent">
    <title>#encodeForHTML( local.brand.productName )# Agent</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/admin-lte@4.0.0-rc4/dist/css/adminlte.min.css">
    <!-- highlight.js: syntax highlighting for ``` code blocks rendered
         through bx-markdown. Active across every page on both surfaces
         (help pages, KB articles, anywhere a `<pre><code class="language-*">`
         appears). atom-one-dark theme + copy-on-click button. -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/highlightjs/cdn-release@11.10.0/build/styles/atom-one-dark.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/highlightjs-copy@1.0.6/dist/highlightjs-copy.min.css">
    <style>:root { --bs-primary: #encodeForCSS( local.brand.primaryColor )#; }</style>
    #tbxAssetCss( "agent" )#
</head>
<body class="layout-fixed sidebar-expand-lg bg-body">
    <div class="app-wrapper">

        <nav class="app-header navbar navbar-expand bg-body-tertiary border-bottom">
            <div class="container-fluid">
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" href="##" data-lte-toggle="sidebar"><i class="bi bi-list"></i></a>
                    </li>
                    <li class="nav-item d-none d-md-block">
                        <a href="/agent" class="nav-link">Dashboard</a>
                    </li>
                </ul>
                <ul class="navbar-nav ms-auto">
                    <bx:script>
                        // Cheap once-per-request lookup. Only renders
                        // the bell when an agent is signed in, so the
                        // login page does not 500 looking up "current
                        // agent" against an empty session.
                        local.bellAuth = getInstance( "AuthenticationService@cbauth" );
                        local.bellAgentId = "";
                        if ( local.bellAuth.isLoggedIn() ) {
                            local.u = local.bellAuth.getUser();
                            if ( !isNull( local.u ) ) local.bellAgentId = local.u.getId();
                        }
                        local.bellUnread = 0;
                        local.bellRecent = [];
                        if ( len( local.bellAgentId ) ) {
                            local.notifSvc = getInstance( "NotificationsService@notifications" );
                            local.bellUnread = local.notifSvc.unreadCount( "agent", local.bellAgentId );
                            local.bellRecent = local.notifSvc.listForRecipient( "agent", local.bellAgentId, false, 5 );
                        }
                    </bx:script>
                    <bx:if len( local.bellAgentId )>
                        <li class="nav-item dropdown" id="notif-bell">
                            <a class="nav-link position-relative" href="##" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-bell"></i>
                                <span id="notif-badge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill text-bg-danger"
                                      style="font-size:0.65rem; #( local.bellUnread gt 0 ? '' : 'display:none;' )#">
                                    #encodeForHTML( local.bellUnread )#
                                </span>
                            </a>
                            <div class="dropdown-menu dropdown-menu-end p-0" style="min-width:22rem">
                                <div class="d-flex justify-content-between align-items-center px-3 py-2 border-bottom">
                                    <strong class="small">Notifications</strong>
                                    <a href="/agent/notifications" class="small">View all</a>
                                </div>
                                <div id="notif-items">
                                    <bx:if !arrayLen( local.bellRecent )>
                                        <div class="px-3 py-3 small text-body-secondary">You're all caught up.</div>
                                    </bx:if>
                                    <bx:loop array="#local.bellRecent#" item="local.bn">
                                        <bx:set local.bnUnread = ( local.bn.getStatus() ?: "" ) eq "sent" >
                                        <form method="post" action="/agent/notifications/#encodeForHTMLAttribute( local.bn.getId() )#/read" class="m-0">
                                            <input type="hidden" name="link" value="#encodeForHTMLAttribute( local.bn.getLink() ?: '/agent/notifications' )#">
                                            <button type="submit" class="dropdown-item border-bottom py-2 #local.bnUnread ? 'fw-semibold' : 'text-body-secondary'#" style="white-space:normal">
                                                <div class="small">#encodeForHTML( local.bn.getTitle() )#</div>
                                                <div class="small text-body-secondary">#encodeForHTML( dateTimeFormat( local.bn.getCreatedAt(), "yyyy-mm-dd HH:nn" ) )#</div>
                                            </button>
                                        </form>
                                    </bx:loop>
                                </div>
                                <form method="post" action="/agent/notifications/mark-all-read" class="m-0" id="notif-mark-all"
                                      style="#( local.bellUnread gt 0 ? '' : 'display:none;' )#">
                                    <button type="submit" class="dropdown-item text-center small py-2">Mark all read</button>
                                </form>
                            </div>
                        </li>
                        <script>
                        (function(){
                            // Poll every 30 seconds so the bell stays
                            // fresh without a page reload. Skips polling
                            // while the tab is hidden; the visibility
                            // listener catches up when the tab regains
                            // focus.
                            var POLL_MS = 30000;
                            var badge   = document.getElementById( 'notif-badge' );
                            var items   = document.getElementById( 'notif-items' );
                            var markAll = document.getElementById( 'notif-mark-all' );
                            if ( !badge || !items ) return;

                            function esc( s ){
                                return String( s == null ? '' : s )
                                    .replace( /&/g, '&amp;' )
                                    .replace( /</g, '&lt;' )
                                    .replace( />/g, '&gt;' )
                                    .replace( /"/g, '&quot;' )
                                    .replace( /'/g, '&##39;' );
                            }

                            function renderItems( list ){
                                if ( !list || !list.length ){
                                    items.innerHTML = '<div class="px-3 py-3 small text-body-secondary">You&##39;re all caught up.</div>';
                                    return;
                                }
                                items.innerHTML = list.map( function( n ){
                                    var cls = n.unread ? 'fw-semibold' : 'text-body-secondary';
                                    return ''
                                        + '<form method="post" action="/agent/notifications/' + esc( n.id ) + '/read" class="m-0">'
                                        +     '<input type="hidden" name="link" value="' + esc( n.link || '/agent/notifications' ) + '">'
                                        +     '<button type="submit" class="dropdown-item border-bottom py-2 ' + cls + '" style="white-space:normal">'
                                        +         '<div class="small">' + esc( n.title ) + '</div>'
                                        +         '<div class="small text-body-secondary">' + esc( n.createdAt ) + '</div>'
                                        +     '</button>'
                                        + '</form>';
                                } ).join( '' );
                            }

                            function applyState( data ){
                                if ( !data || !data.loggedIn ) return;
                                var n = data.unreadCount || 0;
                                badge.textContent = n;
                                badge.style.display = n > 0 ? '' : 'none';
                                if ( markAll ) markAll.style.display = n > 0 ? '' : 'none';
                                renderItems( data.items || [] );
                            }

                            function pollOnce(){
                                if ( document.hidden ) return;
                                fetch( '/agent/notifications/poll', { credentials: 'same-origin', headers: { 'Accept': 'application/json' } } )
                                    .then( function( r ){ return r.ok ? r.json() : null; } )
                                    .then( function( d ){ if ( d ) applyState( d ); } )
                                    .catch( function(){ /* network blip; next tick will retry */ } );
                            }

                            setInterval( pollOnce, POLL_MS );
                            document.addEventListener( 'visibilitychange', function(){
                                if ( !document.hidden ) pollOnce();
                            } );
                        })();
                        </script>
                    </bx:if>
                    <bx:if len( local.bellAgentId )>
                        <bx:script>
                            local.meAgentMini = {
                                id        : local.u.getId(),
                                firstName : local.u.getFirstName() ?: "",
                                lastName  : local.u.getLastName()  ?: "",
                                email     : local.u.getEmail()     ?: "",
                                hasAvatar : len( local.u.getProfileImageOriginalPath() ?: "" ) > 0,
                                uploadedAt: local.u.getProfileImageUploadedAt()
                            };
                            local.meDisplayName = trim( local.meAgentMini.firstName & " " & local.meAgentMini.lastName );
                            if ( !len( local.meDisplayName ) ) local.meDisplayName = local.meAgentMini.email;
                        </bx:script>
                        <li class="nav-item dropdown">
                            <a class="nav-link p-1" href="##" role="button" data-bs-toggle="dropdown" aria-expanded="false" title="Account menu">
                                #view( view = "_partials/avatar", module = "core", args = { agent : local.meAgentMini, size : 32 } )#
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li class="dropdown-item-text">
                                    <div class="fw-semibold">#encodeForHTML( local.meDisplayName )#</div>
                                    <div class="small text-body-secondary">#encodeForHTML( local.meAgentMini.email )#</div>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <bx:loop array="#tbxNavigation( "agent", "account" )#" item="item">
                                    <li><a class="dropdown-item" href="#encodeForHTMLAttribute( item.route )#"><bx:if len( item.icon )><i class="#encodeForHTMLAttribute( item.icon )#"></i> </bx:if>#encodeForHTML( item.label )#</a></li>
                                </bx:loop>
                            </ul>
                        </li>
                    <bx:else>
                        <li class="nav-item">
                            <a href="/agent/logout" class="nav-link">Sign out</a>
                        </li>
                    </bx:if>
                </ul>
            </div>
        </nav>

        <aside class="app-sidebar bg-body-secondary shadow" data-bs-theme="dark">
            <div class="sidebar-brand">
                <a href="/agent" class="brand-link">
                    <bx:if len( local.brand.logoUrl )>
                        <img src="#encodeForHTMLAttribute( local.brand.logoUrl )#" alt="#encodeForHTMLAttribute( local.brand.productName )#" class="brand-image opacity-75 shadow">
                    </bx:if>
                    <span class="brand-text fw-light">#encodeForHTML( local.brand.productName )# Agent</span>
                </a>
            </div>
            <div class="sidebar-wrapper">
                <nav class="mt-2">
                    <ul class="nav sidebar-menu flex-column" role="menu">
                        <bx:loop array="#tbxNavigation( "agent", "main" )#" item="item">
                            <li class="nav-item">
                                <a href="#encodeForHTMLAttribute( item.route )#" class="nav-link">
                                    <bx:if len( item.icon )><i class="nav-icon #encodeForHTMLAttribute( item.icon )#"></i></bx:if>
                                    <p>#encodeForHTML( item.label )#</p>
                                </a>
                            </li>
                        </bx:loop>
                    </ul>
                </nav>
            </div>
        </aside>

        <main class="app-main">
            <div class="app-content-header">
                <div class="container-fluid">
                    <h1 class="mb-0 fs-3">#prc.pageTitle ?: "Dashboard"#</h1>
                </div>
            </div>
            <div class="app-content">
                <div class="container-fluid">
                    #getInstance( "messagebox@cbmessagebox" ).renderIt()#
                    #view()#
                </div>
            </div>
        </main>

        <footer class="app-footer">
            <div class="float-end d-none d-sm-inline">#encodeForHTML( local.brand.productName )# Agent</div>
            <strong>#encodeForHTML( local.brand.footerText )#</strong>
        </footer>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/admin-lte@4.0.0-rc4/dist/js/adminlte.min.js"></script>

    <!-- highlight.js: ships every language in the "common" bundle
         (HTML/JS/CSS/SQL/JSON/shell/Markdown/CFML/etc.) plus the copy
         button plugin. Auto-runs on DOMContentLoaded so any
         <pre><code class="language-*"> rendered into the page is
         highlighted with the atom-one-dark theme. Idempotent under
         CBWire re-render thanks to highlightAll's mark-already-done
         guard. -->
    <script src="https://cdn.jsdelivr.net/gh/highlightjs/cdn-release@11.10.0/build/highlight.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/highlightjs-copy@1.0.6/dist/highlightjs-copy.min.js"></script>
    <script>
        if ( typeof hljs !== "undefined" ) {
            if ( typeof CopyButtonPlugin !== "undefined" ) {
                hljs.addPlugin( new CopyButtonPlugin() );
            }
            // BoxLang / CFML aren't shipped languages in highlight.js
            // 11.x. The javascript grammar is the closest visual match
            // (struct literals, double-quoted strings, var, function,
            // line/block comments all line up), so we alias every name
            // bx-markdown might emit (```boxlang, ```bx, ```bxs,
            // ```cfscript, ```cfm, ```cfml) to javascript.
            hljs.registerAliases( [ "boxlang", "bx", "bxs", "cfscript", "cfm", "cfml" ], { languageName: "javascript" } );
            hljs.highlightAll();
        }
    </script>

    #view( view = "_partials/attachment_dropzone", module = "core" )#
    #tbxAssetJs( "agent" )#
</body>
</html>
</bx:output>
