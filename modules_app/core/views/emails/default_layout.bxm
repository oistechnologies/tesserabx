<bx:output>
<!---
    Default notification email layout.

    Wraps the pre-rendered HTML body in a branded shell with a
    colored header band, the configured product name / tagline /
    logo, the body content, and a footer with the configured
    footer text and an optional one-click unsubscribe link.

    Args (passed by MailComposerService.renderLayout):
      brand          struct : productName, tagline, logoUrl,
                              primaryColor, footerText
      body           string : pre-rendered inner HTML
      style          string : "notification" (this view) or
                              "reply" (uses default_layout_reply)
      preheader      string : inbox-preview text, hidden in body
      appBaseUrl     string : absolute URL prefix
      logoTarget     string : resolved absolute logo URL
      primaryColor   string : normalized hex CSS color
      eventKey       string : optional X-TesseraBX-Event value
      listUnsubscribeUrl
                     string : optional one-click unsubscribe URL
                              for the footer link
      tokens         struct : substitution data (unused here, but
                              available to bodyTemplate views)

    Constraint reminder (per the plan):
      - Inline CSS only. Most email clients strip <style> blocks.
      - Table-based 600px centered layout for compatibility.
      - No em dashes (CLAUDE.md deliverable rule).
--->
<bx:set local.brand        = args.brand        ?: { productName : "TesseraBX", tagline : "", logoUrl : "", primaryColor : "##0d6efd", footerText : "" }>
<bx:set local.bodyHtml     = args.body         ?: "">
<bx:set local.preheader    = args.preheader    ?: "">
<bx:set local.logoTarget   = args.logoTarget   ?: "">
<bx:set local.primaryColor = args.primaryColor ?: ( local.brand.primaryColor ?: "##0d6efd" )>
<bx:set local.appBaseUrl   = args.appBaseUrl   ?: "">
<bx:set local.unsubUrl     = args.listUnsubscribeUrl ?: "">
<bx:set local.productName  = local.brand.productName ?: "TesseraBX">
<bx:set local.tagline      = local.brand.tagline     ?: "">
<bx:set local.footerText   = local.brand.footerText  ?: "">
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>#encodeForHTML( local.productName )#</title>
</head>
<body style="margin:0;padding:0;background:##f5f6f7;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;color:##212529;">
<bx:if len( local.preheader )>
    <div style="display:none;max-height:0;overflow:hidden;color:transparent;line-height:0;font-size:0;">#encodeForHTML( local.preheader )#</div>
</bx:if>
<table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background:##f5f6f7;">
    <tr>
        <td align="center">
            <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="600" style="max-width:600px;background:##ffffff;margin:24px 0;">
                <tr>
                    <td style="padding:24px 32px;background:#local.primaryColor#;text-align:left;">
                        <bx:if len( local.logoTarget )>
                            <img src="#encodeForHTMLAttribute( local.logoTarget )#" alt="#encodeForHTMLAttribute( local.productName )#" width="180" style="display:inline-block;border:0;outline:none;text-decoration:none;height:auto;">
                        <bx:else>
                            <span style="color:##ffffff;font-size:24px;font-weight:600;">#encodeForHTML( local.productName )#</span>
                        </bx:if>
                        <bx:if len( local.tagline )>
                            <div style="margin-top:8px;color:##ffffff;opacity:0.85;font-size:14px;">#encodeForHTML( local.tagline )#</div>
                        </bx:if>
                    </td>
                </tr>
                <tr>
                    <td style="padding:32px;font-size:16px;line-height:1.5;color:##212529;">
                        #local.bodyHtml#
                    </td>
                </tr>
                <bx:if len( local.footerText ) or len( local.unsubUrl )>
                    <tr>
                        <td style="padding:24px 32px;font-size:12px;color:##666;border-top:1px solid ##eee;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;">
                            <bx:if len( local.footerText )>
                                #encodeForHTML( local.footerText )#
                            </bx:if>
                            <bx:if len( local.unsubUrl )>
                                <div style="margin-top:12px;">
                                    <a href="#encodeForHTMLAttribute( local.unsubUrl )#" style="color:##666;text-decoration:underline;">Unsubscribe from these notifications</a>
                                </div>
                            </bx:if>
                        </td>
                    </tr>
                </bx:if>
            </table>
        </td>
    </tr>
</table>
</body>
</html>
</bx:output>
