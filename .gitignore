.DS_Store
.env
.env.local
.env.*.local

# CommandBox
.engine/
.cfconfig/
.cfconfigignore
coldbox-be/
modules/coldbox/
.tmp/

# Module installs (resolved from box.json)
modules/cbq/
modules/cbfs/
modules/cbauth/
modules/cbsecurity/
modules/cbsswagger/
modules/cbswagger/
modules/cbvalidation/
modules/cbmailservices/
modules/cbmessagebox/
modules/cbstorages/
modules/cbjwt/
modules/cbwire/
modules/cfmigrations/
modules/mementifier/
modules/qb/
modules/quick/
modules/cbdebugger/
modules/testbox/
modules/mockbox/
modules/cbi18n/
modules/cbpaginator/
modules/cors/
modules/hyper/
modules/cbantisamy/
modules/cbcsrf/
modules/bcrypt/
modules/s3sdk/
modules/cbstreams/

# Local Claude Code agent state
.claude/

# Developer compose overrides. Used to bind-mount third-party
# add-ons (modules/<addon>/) from their own working trees into the
# host's app, worker, and scheduler containers during development.
# Local-only; never committed.
compose.override.yaml
compose.override.yml

# Operator add-on manifest. Lists the third-party add-ons this
# deployment installs (see tasks/InstallAddons.cfc and the committed
# box.addons.example.json template). Git-ignored so a core `git pull`
# never overwrites the operator's add-on list.
box.addons.json

# Build artifacts
build/
dist/

# Logs
logs/
*.log

# CBFS local storage and uploads (root-anchored; there is also
# an admin view folder named "storage" we do want to track).
/storage/

# CBFS public-disk local storage (dev). Track the dir itself
# (via the committed .gitkeep) but ignore everything underneath.
/public-files/*
!/public-files/.gitkeep

# Database backups
/backups/

# Staged add-on migrations (see tasks/Migrate.cfc). The canonical
# source lives in each add-on's own migrations/ folder; staged copies
# under the central dir are a runtime artifact, not version-controlled.
# The `_addon-` (hyphenated) sentinel after the timestamp is what
# distinguishes a staged file from a hand-written core migration like
# `2026_05_20_000010_create_addon_tables.cfc` (underscore, not hyphen).
resources/database/migrations/*_addon-*_*.cfc
resources/database/migrations/.staged.json

# IDE
.idea/
.vscode/
*.iml
.fleet/
.history/

# OS
Thumbs.db
